{"title":"MUE_IRA_Urgencia","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/MUE - Medicina de Urgencia/MUE_IRA_Urgencia.smmx","root":{"id":"0","parent":"-1","text":"IRA — INJURIA RENAL AGUDA EN URGENCIAS","guid":"Ukq7QmncScy7GDLhL6s40Q","children":[{"id":"1","parent":"0","text":"DEFINICIÓN KDIGO 2012","guid":"jN2MNYUHTJOgwlg3hlU8dg","children":[{"id":"2","parent":"1","text":"Criterio 1 → Creatinina aumenta ≥0.3 mg/dL en 48h","guid":"nFaUZOuFS8We6i2ogJqX6Q","children":[]},{"id":"3","parent":"1","text":"Criterio 2 → Creatinina aumenta ≥1.5x basal conocida o estimada en 7 días","guid":"B-De6CqJQWO-BkOtc2bg8Q","children":[]},{"id":"4","parent":"1","text":"Criterio 3 → Diuresis <0.5 mL/kg/h por ≥6h consecutivas","guid":"w4MxVBgMTZOxEvmZgCGb-g","children":[]},{"id":"5","parent":"1","text":"Cualquiera de los 3 criterios es suficiente","guid":"a_LQbthGR2i4W_ORBfhOlA","children":[]}]},{"id":"6","parent":"0","text":"ESTADIOS KDIGO","guid":"OYe5Es9GSq69qQsAU1Uhwg","children":[{"id":"7","parent":"6","text":"Estadio 1","guid":"7lUbaia2RTylFZ9b642O3g","children":[{"id":"8","parent":"7","text":"Cr 1.5-1.9x basal o aumento ≥0.3 mg/dL","guid":"EVlQqWzeTu6NQiLfYADA-Q","children":[]},{"id":"9","parent":"7","text":"Diuresis <0.5 mL/kg/h por 6-12h","guid":"wVXyaoauSkejW_MMSclcLw","children":[]}]},{"id":"10","parent":"6","text":"Estadio 2","guid":"nlqgUo07Sq-dryKQvj08qw","children":[{"id":"11","parent":"10","text":"Cr 2.0-2.9x basal","guid":"o8ldOytHT6at40CSgfPVxg","children":[]},{"id":"12","parent":"10","text":"Diuresis <0.5 mL/kg/h por ≥12h","guid":"2qy7rTocQUGq0WryusLD0w","children":[]}]},{"id":"13","parent":"6","text":"Estadio 3","guid":"XVh9t-eVQsGnIvIytnfN7A","children":[{"id":"14","parent":"13","text":"Cr ≥3.0x basal o Cr ≥4.0 mg/dL","guid":"yfv_K5eOT_GULJtRmZlVWw","children":[]},{"id":"15","parent":"13","text":"Inicio de TRR","guid":"d7r9s3nzTA6OUoIrJYvKHQ","children":[]},{"id":"16","parent":"13","text":"Diuresis <0.3 mL/kg/h por ≥24h o anuria ≥12h","guid":"0PHzhNBdR_eI7rXPGU6R1w","children":[]},{"id":"17","parent":"13","text":"En <18 años: caída eGFR a <35 mL/min/1.73m²","guid":"8i0EUKpNQoCUt2hEDzpzCQ","children":[]}]}]},{"id":"18","parent":"0","text":"EPIDEMIOLOGÍA Y GERIATRÍA","guid":"4ztrwl5rRkOfrX1aldFVQg","children":[{"id":"19","parent":"18","text":"Incidencia hospitalaria ~20% — hasta 50% en UCI","guid":"A3gH40WMQ2iCmw0YJe8wug","children":[]},{"id":"20","parent":"18","text":"AM >65 años → mayor riesgo por ↓reserva renal, sarcopenia","guid":"D7IBF2pzTe2vF9bES5xv_A","children":[]},{"id":"21","parent":"18","text":"Cr basal puede sobreestimar VFG en sarcopenia → usar CKD-EPI","guid":"jHR_b0FDTMuu9cWUdi4PCw","children":[]},{"id":"22","parent":"18","text":"Multifactorial en AM → medicamentos + deshidratación + sepsis","guid":"wXalb3RcQ7WWg6-UYB-G8A","children":[]},{"id":"23","parent":"18","text":"Mortalidad AM + IRA 3 = 50-70% intrahospitalaria","guid":"gx5umiVkTjiHUGPGUsxVOA","children":[]},{"id":"24","parent":"18","text":"Recuperación funcional frecuentemente incompleta","guid":"xmfGpfDQTz2mVD3S3pScHw","children":[]}]},{"id":"25","parent":"0","text":"ETIOLOGÍA POR CATEGORÍA","guid":"M2z_6C05R0-TnDvhHQdEHA","children":[{"id":"26","parent":"25","text":"PRE-RENAL (50-60% del total)","guid":"AXuUCagOQMinAEJhtyU8_Q","children":[{"id":"27","parent":"26","text":"Hipovolemia","guid":"Qve7Zo_wTmiXkBcD6uiaJg","children":[{"id":"28","parent":"27","text":"Pérdidas gastrointestinales (diarrea, vómitos)","guid":"VH52LhNlTP-rgEgpvlVp7w","children":[]},{"id":"29","parent":"27","text":"Hemorragia","guid":"DjFNC_vYRR2PSRZQkC5kRQ","children":[]},{"id":"30","parent":"27","text":"Diuréticos (sobre todo loop + tiazida)","guid":"5_UfQZD8QUK3suLxTe6eNg","children":[]},{"id":"31","parent":"27","text":"Tercer espacio (pancreatitis, obstrucción intestinal, sepsis)","guid":"FhvfyYOeQ-2E4jgiH0hX8w","children":[]},{"id":"32","parent":"27","text":"↓ingesta hídrica (AM, demencia, postrado)","guid":"ceOalJaJTRitdmPHIBmFPg","children":[]}]},{"id":"33","parent":"26","text":"Bajo gasto cardiaco","guid":"3Y_swVYcTzKxSyDyPL8oBg","children":[{"id":"34","parent":"33","text":"IC descompensada → síndrome cardiorenal tipo 1","guid":"ahd4l6WcTd-CpyBuFfrrnw","children":[]},{"id":"35","parent":"33","text":"IAM","guid":"rKpD1tHTStuKiNngEIdXaw","children":[]},{"id":"36","parent":"33","text":"Shock cardiogénico","guid":"xtITjaFjRPCsQVzqkDAifA","children":[]},{"id":"37","parent":"33","text":"Taponamiento cardiaco","guid":"Z6OGIwoyRMWQVeO8F06VPg","children":[]}]},{"id":"38","parent":"26","text":"Vasodilatación sistémica","guid":"t1W310yMQ2CKpM9tfSENNA","children":[{"id":"39","parent":"38","text":"Sepsis","guid":"iYDb-L-OSVy02Uhn9SeKuA","children":[]},{"id":"40","parent":"38","text":"Anafilaxia","guid":"URp79Y5eRBiXPzFCDRx3lg","children":[]},{"id":"41","parent":"38","text":"Cirrosis descompensada → síndrome hepatorenal","guid":"QaU7Vb9sTxi13rUugGL2UQ","children":[]}]},{"id":"42","parent":"26","text":"Vasoconstricción intraglomerular","guid":"7iuMJGlkRviAZdpLSdv_kQ","children":[{"id":"43","parent":"42","text":"AINEs → afecta vasodilatación aferente","guid":"mt3ZclzrTnGnVbmdg1vJpQ","children":[]},{"id":"44","parent":"42","text":"IECA/ARA2 → afecta vasoconstricción eferente","guid":"UDn5MKl3SWuNmiJ9DO-ITQ","children":[]},{"id":"45","parent":"42","text":"Contraste yodado","guid":"hfK6asK0RBKDHMmodD2KQg","children":[]},{"id":"46","parent":"42","text":"Ciclosporina, tacrolimus","guid":"ICAOeu78RFmLtf3ffcnIRg","children":[]}]},{"id":"47","parent":"26","text":"TRÍADA DE ALTO RIESGO EN AM → AINEs + IECA/ARA2 + diurético","guid":"4HfHkXosQGySgoenKHMYTA","children":[]}]},{"id":"48","parent":"25","text":"INTRÍNSECA / RENAL (30-40%)","guid":"blQrYIHsS1qu9d8NwMJqcg","children":[{"id":"49","parent":"48","text":"NECROSIS TUBULAR AGUDA (NTA) → causa más frecuente","guid":"zaLysxQ8RJihwSEz3IRO1Q","children":[{"id":"50","parent":"49","text":"Isquémica → continuación de pre-renal no tratada","guid":"C1aVNXIlR5emPIfvIZ1ejA","children":[]},{"id":"51"