. pylori.","guid":"","children":[]}]},{"id":"122","parent":"0","text":"Seguimiento y\\Npronóstico:","guid":"","children":[{"id":"123","parent":"122","text":"Monitorización con\\Nterapia prolongada:","guid":"","children":[{"id":"124","parent":"123","text":"Andrógenos: función hepática,\\Nperfil lipídico, hemograma","guid":"","children":[]},{"id":"125","parent":"123","text":"Antifibrinolíticos:\\NCPK, función renal","guid":"","children":[]}]},{"id":"126","parent":"122","text":"Severidad impredecible. Mortalidad de\\Nhasta 30% por edema laríngeo.","guid":"","children":[]}]},{"id":"127","parent":"0","text":"Prevención:","guid":"","children":[{"id":"128","parent":"127","text":"Evitar\\Ndesencadenantes\\Nconocidos.","guid":"","children":[]},{"id":"129","parent":"127","text":"Profilaxis a corto y largo plazo\\Nen casos seleccionados.","guid":"","children":[]}]},{"id":"130","parent":"0","text":"Tamizaje:","guid":"","children":[{"id":"131","parent":"130","text":"No hay recomendaciones\\Nen población general.","guid":"","children":[]},{"id":"132","parent":"130","text":"Estudio de familiares de primer\\Ngrado de pacientes con HAE.","guid":"","children":[]}]},{"id":"133","parent":"0","text":"Aspectos Geriátricos:","guid":"","children":[{"id":"134","parent":"133","text":"Deficiencia adquirida de C1-INH es más\\Nfrecuente en adultos mayores.","guid":"","children":[]},{"id":"135","parent":"133","text":"Mayor riesgo de complicaciones y\\Nmortalidad por edema laríngeo.","guid":"","children":[]},{"id":"136","parent":"133","text":"Precaución con dosis de\\Nandrógenos y antifibrinolíticos.\\NMonitorizar efectos adversos.","guid":"","children":[]}]}]},"node_count":287,"relations":[],"cross_references":[],"specialty":"General","folder":"Entidades clínicas/General","filename":"Deficiencia del inhibidor C1-2024-1","id":"map_717","resolved_references":[],"title_raw":"Deficiencia del inhibidor C1-2024-1"}