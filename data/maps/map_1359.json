{"title":"Hipertensión pulmonar","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Entidades clínicas/Neumología/Hipertensión pulmonar-2024.smmx","root":{"id":"0","parent":"-1","text":"Hipertensión\\Npulmonar","guid":"G0dSk0cq1ISywT8khX5B7g","children":[{"id":"1","parent":"0","text":"General","guid":"","children":[{"id":"2","parent":"1","text":"Definición","guid":"Xr1I0Ht2jXmmD1S50_C8Tw","children":[{"id":"3","parent":"2","text":"HP: mPAP > 20 mm Hg en reposo.","guid":"iRVnXfUdUPvsAx93ZRFyDg","children":[]}]},{"id":"4","parent":"1","text":"Clasificación de\\NHP (5 grupos)","guid":"ql3e9mGox9Z5xqlB4ED3zw","children":[{"id":"5","parent":"4","text":"HAP (Hipertensión Arterial Pulmonar) → ej: idiopática, hereditarias.","guid":"ag2BLe15Q9ySZyjzQB0qbg","children":[]},{"id":"6","parent":"4","text":"Enf. Cardiaca Izq. → disfunción sistólica/diastólica.","guid":"KZDdcjEsqYnek4eoB34hIA","children":[]},{"id":"7","parent":"4","text":"Enf. Pulmonar Crónica → EPOC, fibrosis.","guid":"VBaqghkDkcwt1gHYjGKjRA","children":[]},{"id":"8","parent":"4","text":"Obstrucción A. Pulmonar → Tromboembolia crónica.","guid":"YjmEc4t-SK2uF84OH01bnA","children":[]},{"id":"9","parent":"4","text":"Mecanismos Multifactoriales → causas diversas.","guid":"5UF4mW2Iqx4KMok04GXiPg","children":[]}]},{"id":"10","parent":"1","text":"Fisiopatología","guid":"Yqgg2isOPzdqTlhrnVW-3g","children":[{"id":"11","parent":"10","text":"↑ Presión en V. Der → HVD, dilatación o hipertrofia → Cor Pulmonale.","guid":"OmVvvzuQoj8rJ2ANII7bkQ","children":[]}]},{"id":"12","parent":"1","text":"Clínica","guid":"CX3CvTaIyJ2K7TOaOzKpVQ","children":[{"id":"13","parent":"12","text":"Inicialmente asintomática\\N→ síntomas tardíos:","guid":"03NxXhqq_eg1Ju2T55vobw","children":[{"id":"14","parent":"13","text":"Disnea de esfuerzo.","guid":"VWY6HBXCujS9EvFWRe0fBQ","children":[]},{"id":"15","parent":"13","text":"Fatiga.","guid":"4e7gr_OckTbORLdUsQyo0g","children":[]},{"id":"16","parent":"13","text":"Cianosis.","guid":"n3iJZAHTJn8p7Ll6Rrgmnw","children":[]},{"id":"17","parent":"13","text":"Síncope.","guid":"PjvDK-Lrfl8ZJIQcC86rRA","children":[]}]}]},{"id":"18","parent":"1","text":"Dx","guid":"UX349nluZSxISqZfHfJ99g","children":[{"id":"19","parent":"18","text":"Ecocardiograma → estimación no invasiva de presión arterial pulmonar, disfunción V. Der.","guid":"zwlAkafoCuWBb8tSjqExPw","children":[]},{"id":"20","parent":"18","text":"Cateterización Cardíaca Derecha → dx definitivo, mPAP.","guid":"TJd0Qrj3guDag8Nt8uveZw","children":[]}]},{"id":"21","parent":"1","text":"Tto","guid":"4qaoSMBFbfsiJU6bXa2jJg","children":[{"id":"22","parent":"21","text":"Manejo causa subyacente → evitar progresión.","guid":"BMoCCQR9X8cSGoGO2H21dw","children":[]},{"id":"23","parent":"21","text":"HAP (Grupo 1) → Bloq. canales Ca²⁺, vasodilatadores pulmonares.","guid":"UNOQusxkBh-lSCVq1wAUfw","children":[]},{"id":"24","parent":"21","text":"Otros grupos → beneficio incierto.","guid":"fgsjUYvljGTzGJcndNN7sA","children":[]},{"id":"25","parent":"21","text":"Referencia a especialistas → unidades especializadas.","guid":"9V_JtlwzoFeC12fkozXbFg","children":[]}]},{"id":"26","parent":"1","text":"Complicaciones","guid":"Gs7C62ZJf5rDUsEQVyUJOQ","children":[{"id":"27","parent":"26","text":"Descompensación Aguda HP:","guid":"lAyzGS6d3sofOjZ-_WB4OQ","children":[{"id":"28","parent":"27","text":"Alta mortalidad.","guid":"uatg8pZTqgCYXZPB1ZBniw","children":[]},{"id":"29","parent":"27","text":"UCI + ECMO/trasplante pulmonar.","guid":"_IXNKaFlhaf0z_ff_THX3g","children":[]}]},{"id":"30","parent":"26","text":"Cor Pulmonale\\N(Agudo o Crónico):","guid":"TTzeSEvZ-TPtVA5tTS8bxA","children":[{"id":"31","parent":"30","text":"Tto causa subyacente.","guid":"vBFwtsoHf5vIA9Smt2teZQ","children":[]},{"id":"32","parent":"30","text":"Estabilización aguda si es necesario.","guid":"LrigY0mLzpGlxuRhO0HgFw","children":[]}]}]}]},{"id":"33","parent":"0","text":"Definiciones de\\NHipertensión Pulmonar\\N(HP)","guid":"","children":[{"id":"34","parent":"33","text":"1. HP:","guid":"_A-Z-hgPmIjHl_a0Klm15g","children":[{"id":"35","parent":"34","text":"mPAP > 20 mm Hg en reposo (N:\\N10-14 mm Hg) (1)(4)(5)(6).","guid":"f0Hb9YTjGrh30Yh0YtO1pg","children":[]}]},{"id":"36","parent":"33","text":"2. Subtipos de HP:","guid":"2FzBT6Iuiiix89mN9xlHuw","children":[{"id":"37","parent":"36","text":"HP Precapilar:","guid":"Itpiy-t_NMERBmayHXrukA","children":[{"id":"38","parent":"37","text":"Remodelación vascular pulmonar → ↑ Resistencia Vascular Pulmonar (RVP).","guid":"erafcLH0HpDIuFSIXbub0A","children":[]},{"id":"39","parent":"37","text":"Causas: HAP, enf. pulmonar crónica, tromboembolismo crónico,\\Nmecanismos multifactoriales.","guid":"Ku9rqynkMqDvQI0sLmDE1g","children":[]},{"id":"40","parent":"37","text":"Cateterización Cardíaca Derecha (CCD): ↑ RVP (≥ 3 unidades Wood),\\N↓ Presión Capilar Wedge Pulmonar (PCWP).","guid":"H3F-W6R4TS6djLLy8vVIoA","children":[]}]},{"id":"41","parent":"36","text":"HP Postcapilar:","guid":"Mb_XsjqVxv5i2JR8w4Phxw","children":[{"id":"42","parent":"41","text":"↑ Presión venosa pulmonar (secundaria a enf. cardiaca izq. o mecanismos multifactoriales).","guid":"BhOefj9sHgAwHcDV_DGwfQ","children":[]},{"id":"43","parent":"41","text":"CCD: ↑ PCWP, RVP normal.","guid":"B599GTgpeixNFz59NHotSQ","children":[]}]}]},{"id":"44","parent":"33","text":"3. HAP (Hipertensión\\NArterial Pulmonar):","guid":"7twDUD-UJYV1yaO_aSNn5Q","children":[{"id":"45","parent":"44","text":"Tipo de HP precapilar → pérdida y remodelación obstructiva del lecho vascular pulmonar\\N→ ↑ Presión Arterial Pulmonar (PAP).","guid":"mVk5vb7MAMxwXP8c57QlBQ","children":[]}]},{"id":"46","parent":"33","text":"HAP es causa de HP, pero no toda HP es HAP.","guid":"U6bgHD7G0bhpAhxmCBQPgQ","children":[]}]},{"id":"47","parent":"0","text":"Epidemiología de HAP\\N(Hipertensión Arterial Pulmonar)","guid":"","children":[{"id":"48","parent":"47","text":"Prevalencia:","guid":"sl-iJY_8nkDR-Gr0mKpBMg","children":[{"id":"49","parent":"48","text":"HAP afecta más a mujeres que a hombres (proporción F\\\\* ≈ 3:1).\\\\*","guid":"G1YVAxJ68Gjkrfi6WFGvSg","children":[]}]}]},{"id":"50","parent":"0","text":"Etiología de Hipertensión Pulmonar\\N(Clasificación OMS)","guid":"mFc_tJNM9B6g_QRlIvu-zw","children":[{"id":"51","parent":"50","text":"1. HAP (Grupo 1 HP):","guid":"-1_7swcf7hYoMM4zL3KC_Q","children":[{"id":"52","parent":"51","text":"Idiopática","guid":"y1jhim1ReAgadCW0FcPURg","children":[]},{"id":"53","parent":"51","text":"Hereditarias (ej. mutación BMPR2) → ↓ inhibidores proliferación músculo liso vascular\\N→ mal pronóstico.","guid":"6ZwxymP8U3klOCKnBXdo0A","children":[]},{"id":"54","parent":"51","text":"Fármacos: Metanfetamina, anfetaminas, cocaína, supresores del apetito\\N(ej. diethylpropion, fenfluramina) (8).","guid":"6-QyM4xpBRjC0sNexPTPrA","children":[]},{"id":"55","parent":"51","text":"Asociadas:","guid":"SiLjkf5XjGe9jH17srYjXw","children":[{"id":"56","parent":"55","text":"Enf. Tejido Conectivo (ej. esclerosis sistémica).","guid":"oJJL_Zv7rgcaL_saBlfr7A","children":[]},{"id":"57","parent":"55","text":"Hipertensión portopulmonar.","guid":"rzmyZxdoHqjEGT1ZVPH18A","children":[]},{"id":"58","parent":"55","text":"Cardiopatías congénitas (ej. shunt izq-der, síndrome de Eisenmenger).","guid":"IWU2XVzn4Gt-Id3jO7hsww","children":[]},{"id":"59","parent":"55","text":"Infección VIH.","guid":"08k98o_PRDJ9j63gV9lXPw","children":[]},{"id":"60","parent":"55","text":"Esquistosomiasis.","guid":"i_FmS6h2Jyc7TNod7KZJFQ","children":[]},{"id":"61","parent":"55","text":"PPHN (Hipertensión pulmonar persistente del recién nacido).","guid":"SFiMGXvEbwt_rjxRbOzzOA","children":[]}]}]},{"id":"62","parent":"50","text":"2. Enf. Cardiaca Izquierda\\N(Grupo 2 HP):","guid":"pbjt9TbHfFd55bMjOOWS0A","children":[{"id":"63","parent":"62","text":"IC Congestiva.","guid":"adosoWhyv6YR7sgu6PB4BQ","children":[]},{"id":"64","parent":"62","text":"Enf. Valvulares (ej. estenosis válvula aórtica, estenosis válvula mitral).","guid":"RdnhRYYstYAh3o1enqM4Ug","children":[]},{"id":"65","parent":"62","text":"Otras cardiopatías adquiridas/congénitas → HP postcapilar.","guid":"59wGPPQagZAwgg3pBSAoLA","children":[]}]},{"id":"66","parent":"50","text":"3. Enf. Pulmonares Crónicas\\N(Grupo 3 HP):","guid":"eRUafp5sFI4_nPxL4sNAog","children":[{"id":"67","parent":"66","text":"Enf. Obstructivas:","guid":"oaTkz1MQWt0Op_QRpoXh4A","children":[{"id":"68","parent":"67","text":"EPOC, enfisema.","guid":"Dw2KaJtdLyCuHiMLtnuC6g","children":[]},{"id":"69","parent":"67","text":"Apnea obstructiva del sueño.","guid":"w81phM3ml66xkEfOipfMAw","children":[]}]},{"id":"70","parent":"66","text":"Enf. Restrictivas: ej. enf. pulmonar intersticial.","guid":"Zv1LHDA9jzOsSMaNvzHOGw","children":[]},{"id":"71","parent":"66","text":"Altitud elevada → HP por altitud elevada.","guid":"qbka2rhhcVD_chYwnwkgFw","children":[]}]},{"id":"72","parent":"50","text":"4. Obstrucción Arteria Pulmonar\\N(Grupo 4 HP):","guid":"rjQyfR0D8R0xKuoDxpQinw","children":[{"id":"73","parent":"72","text":"HP Tromboembólica\\NCrónica (CTEPH):","guid":"WyLY9hWdVGwedTSruoY_FA","children":[{"id":"74","parent":"73","text":"Oclusión tromboembólica crónica vasos pulmonares.","guid":"mBEyafDLfa4mJWevwzpGEg","children":[]},{"id":"75","parent":"73","text":"Microtrombos recurrentes → ↓ área seccional vasos pulmonares.","guid":"A4lwBeyhVKPSJWHNxfbbIQ","children":[]},{"id":"76","parent":"73","text":"↑ riesgo de embolia pulmonar.","guid":"cIh0N3fh4ujKLEQuOzSgNQ","children":[]}]},{"id":"77","parent":"72","text":"Otras causas: compresión extrínseca por tumores o masas mediastinales (10).","guid":"nUU0pJQAsiSzolQ8MkG2Jw","children":[]}]},{"id":"78","parent":"50","text":"5. Mecanismos Multifactoriales\\N(Grupo 5 HP):","guid":"Ahy8G3Ai2q6VfEIv--f62A","children":[{"id":"79","parent":"78","text":"Trastornos hematológicos (ej. drepanocitosis).","guid":"TSiSptMHLsIsaJeHFQpHBw","children":[]},{"id":"80","parent":"78","text":"Trastornos sistémicos (ej. sarcoidosis).","guid":"DvSlrHG3DxmdpmvzMjzjRA","children":[]},{"id":"81","parent":"78","text":"Trastornos metabólicos (ej. síndrome metabólico).","guid":"T_fWqj2XxXspDGIHxKjvrw","children":[]},{"id":"82","parent":"78","text":"Cardiopatías congénitas complejas (11).","guid":"kNMD8yjSUs6IT315L1yMWw","children":[]}]}]},{"id":"83","parent":"0","text":"Fisiopatología de la\\NHipertensión Pulmonar (HP)","guid":"","children":[{"id":"84","parent":"83","text":"1. ↑ Resistencia Vascular\\NPulmonar (RVP):","guid":"h28DuUUTJbxDz-pypknmww","children":[{"id":"85","parent":"84","text":"Vasculopatía oclusiva (ej. HAP idiopática, enf. tejido conectivo).","guid":"i1DaPG8rkyJ5RJ4mGmilmw","children":[]},{"id":"86","parent":"84","text":"Vasoconstricción pulmonar\\Nhipóxica crónica:","guid":"fLhF4uCJu148YokSQn0saw","children":[{"id":"87","parent":"86","text":"→ Hipertrofia músculo liso de vías aéreas (hipertrofia medial)\\N+ destrucción del lecho vascular pulmonar.","guid":"ETn1W1AB4RLr-X6uSQ0Zmw","children":[]},{"id":"88","parent":"86","text":"Ej: EPOC, apnea obstructiva del sueño.","guid":"EcJHjgoOqrmRE143Rf7E6g","children":[]}]},{"id":"89","parent":"84","text":"↑ Presión en vasos\\Npulmonares:","guid":"bFfEGRsmUQDUj_8FQkpAuQ","children":[{"id":"90","parent":"89","text":"→ Hipertrofia del corazón derecho → falla cardiaca derecha (Cor pulmonale) + arritmias → muerte.","guid":"hs2Me2ZGRhiQ5QfRHORlFA","children":[]}]},{"id":"91","parent":"84","text":"Inflamación (ej. EPOC):","guid":"uSgxBq5dxcGetw2Nyic2eQ","children":[{"id":"92","parent":"91","text":"→ Infiltración de células inflamatorias en íntima →\\Nengrosamiento de la pared endotelial → fibrosis intimal.","guid":"XJ8VcHwL0SEuR7Hc6NQILw","children":[]}]},{"id":"93","parent":"84","text":"HAP asociada a\\Ndisfunción endotelial:","guid":"mMCJq0PM7o85vl8slyWduQ","children":[{"id":"94","parent":"93","text":"↑ Endotelina, ↓ vasodilatadores (ej. NO, prostaciclinas) →\\Nvasoconstricción → arteriosclerosis, lesiones plexiformes (13).","guid":"RIyYD8LCLFLT6CmdK19nlA","children":[]}]}]},{"id":"95","parent":"83","text":"2. ↑ Presión Venosa\\NPulmonar:","guid":"ZZbXaKC4l_RbpWDdHcce4w","children":[{"id":"96","parent":"95","text":"Sobrecarga de volumen o presión por enf. cardiaca izq.\\N(ej. insuficiencia mitral).","guid":"7y0ozQ9HvlG307VypowiYw","children":[]}]},{"id":"97","parent":"83","text":"3. ↑ Flujo Sanguíneo\\NPulmonar:","guid":"90fF9xHyAF_Pu4Yjae1X8Q","children":[{"id":"98","parent":"97","text":"Shunt izq-der (ej. CIA, CIV, DAP).","guid":"4nuEAQUsD1I7-2hWQCus6g","children":[]},{"id":"99","parent":"97","text":"Hipertensión portopulmonar.","guid":"a-KT4A30qXuovQPxzweL4Q","children":[]},{"id":"100","parent":"97","text":"Anemia falciforme: ↑ GC por anemia.","guid":"javdiNEqgIKqc_6mLFWy6g","children":[]}]},{"id":"101","parent":"83","text":"4. Consecuencias:","guid":"MBsXvtts3eGos9H9rf4JXg","children":[{"id":"102","parent":"101","text":"↑ Presión en circuito pulmonar → ↑ postcarga ventricular derecha → dilatación/hipertrofia del corazón derecho\\N→ falla cardiaca derecha + arritmias → muerte.","guid":"TnrafLd61YlRQm1YZRctAA","children":[]}]}]},{"id":"103","parent":"0","text":"Características Clínicas de la\\NHipertensión Pulmonar (HP)","guid":"","children":[{"id":"104","parent":"103","text":"1. Inicialmente asintomática en etapas tempranas.","guid":"yYB4vEHgi_EiP54gAUS5eQ","children":[]},{"id":"105","parent":"103","text":"2. Síntomas\\Nclínicos comunes:","guid":"cwGmi6Q0k8tyZOlxZVxT4A","children":[{"id":"106","parent":"105","text":"Disnea y/o síncope al esfuerzo.","guid":"eTl2t10MFVqkMImRa_K0yQ","children":[]},{"id":"107","parent":"105","text":"Dolor torácico.","guid":"zJIHK6dVTmkwT4WxTxMpcg","children":[]},{"id":"108","parent":"105","text":"Fatiga.","guid":"w7JaQ1iSbUqMlq1np4AN-A","children":[]},{"id":"109","parent":"105","text":"Cianosis.","guid":"1mZNTqvZclAqwQ4kYRPEIQ","children":[]},{"id":"110","parent":"105","text":"Síntomas de la etiología subyacente\\N(ej. EPOC, apnea del sueño, TEP).","guid":"E_FUPdID1oZrojnhxaOv1Q","children":[]}]},{"id":"111","parent":"103","text":"3. Síntomas clínicos\\Nmenos comunes:","guid":"8YHGfhXjycMY3sLjQNKbHg","children":[{"id":"112","parent":"111","text":"Disfonía.","guid":"cl4ODn-HjOXgufmMilAdBQ","children":[]},{"id":"113","parent":"111","text":"Tos, hemoptisis.","guid":"5r1KUqS923TmX7sMbw4gnA","children":[]}]},{"id":"114","parent":"103","text":"4. Examen físico:","guid":"wLqiNtJ6736TT03PNKEtiA","children":[{"id":"115","parent":"114","text":"Segundo ruido cardiaco fuerte y palpable\\N(a menudo desdoblado).","guid":"hXQCJIpLt_BGkal6C8Nx9A","children":[]},{"id":"116","parent":"114","text":"Distensión yugular.","guid":"vVjsRtYoH6Bbp6SEKFmIuA","children":[]},{"id":"117","parent":"114","text":"Síntomas de falla\\Ncardiaca derecha:","guid":"rIdv3YqLA0nli8pJvxcfSA","children":[{"id":"118","parent":"117","text":"Palpitaciones.","guid":"GwkYzSIKeWjHZypxTIZrWw","children":[]},{"id":"119","parent":"117","text":"Edema periférico.","guid":"ZpIQiSA7ClosSF875fr8Fw","children":[]},{"id":"120","parent":"117","text":"Reflujo hepato-yugular.","guid":"2UB8teSvS3_gUdOWicjcFg","children":[]}]},{"id":"121","parent":"114","text":"Dedos en palillo de tambor.","guid":"RjxHCcMv4i5fI33LhFEGjA","children":[]},{"id":"122","parent":"114","text":"Latido paraesternal.","guid":"3XPqNxtNSgdZpq19XPZT-A","children":[]}]}]},{"id":"123","parent":"0","text":"Diagnóstico de Hipertensión Pulmonar\\N(HP)","guid":"lvcpAXrsGPNFYS7ep3ngWQ","children":[{"id":"124","parent":"123","text":"1. Enfoque:","guid":"onzY2ZCJSPIXiWluovId9Q","children":[{"id":"125","parent":"124","text":"Sospecha clínica alta → Ecocardiografía transtorácica (ETT) para\\Nidentificar marcadores de presión arterial pulmonar elevada.","guid":"llXbRw7061VsznjyaMZp3g","children":[]},{"id":"126","parent":"124","text":"Si ETT sugiere HP y no se\\Nconoce la etiología:","guid":"hYAs8ypt9Bxg0hYEjHHnuQ","children":[{"id":"127","parent":"126","text":"Evaluar causas más comunes (enf. cardiaca izq., enf. pulmonar crónica).","guid":"4o1WcGIOAe_gkAmK2BPbYg","children":[]},{"id":"128","parent":"126","text":"Si son inconclusas → Gammagrafía V/Q para tromboembolismo.","guid":"Ue4_Y9336hZ7POfGkPfB7A","children":[]}]},{"id":"129","parent":"124","text":"Si etiología no clara, ETT\\Nequívoca y/o HP severa:","guid":"Ia9t7Y0AOaiUGlu7rQeiuw","children":[{"id":"130","parent":"129","text":"Cateterización cardíaca derecha (CCD) confirmatoria.","guid":"Vr3CmX0S3Gdw8rqmnU9eFg","children":[]},{"id":"131","parent":"129","text":"Considerar estudios avanzados (ej. genéticos).","guid":"4VxPD1MU47cRf_kuE3Hw-A","children":[]}]}]},{"id":"132","parent":"123","text":"2. Ecocardiografía\\Ntranstorácica (ETT):","guid":"YBn0zQ4KqtZ9LUM6z7tUBg","children":[{"id":"133","parent":"132","text":"Indicación: estudio de primera línea en sospecha de HP.","guid":"PGNR9cfUywd3XXsDTJ9j8A","children":[]},{"id":"134","parent":"132","text":"Hallazgos:","guid":"R7Ws0eemZB0zAoTM95aogA","children":[{"id":"135","parent":"134","text":"↑ Velocidad de regurgitación tricuspídea (TRV).","guid":"Lozlm6mDBBPnazO4Ogiz_g","children":[]},{"id":"136","parent":"134","text":"Sobrecarga de presión en V. Der → aplanamiento del septo interventricular,\\Nhipertrofia de V. Der, dilatación del seno coronario.","guid":"xgwi7dw6xnu1CuJ5miQFMw","children":[]},{"id":"137","parent":"134","text":"Falla del V. Der → dilatación, hipocinesia, dilatación de la aurícula derecha.","guid":"gxBGz-RedA6dccM495oS9g","children":[]},{"id":"138","parent":"134","text":"Cámara cardíaca izquierda subllenada.","guid":"COUiMyNTodf_0wtqY0AaQA","children":[]},{"id":"139","parent":"134","text":"Evidencia de enf. cardiovascular subyacente.","guid":"cpP0jN-_ykuHK7_VVsI6IQ","children":[]}]}]},{"id":"140","parent":"123","text":"3. Cateterización\\NCardíaca Derecha (CCD):","guid":"0ELh3akPo4BbJ-gi1zFgLg","children":[{"id":"141","parent":"140","text":"Indicación: prueba confirmatoria para HP, evaluación detallada de enf. cardíacas.","guid":"D6-8szmAO-37z1IS8lVtQg","children":[]},{"id":"142","parent":"140","text":"Hallazgos:","guid":"vRryeR4FXAlVuGNXgrgyVQ","children":[{"id":"143","parent":"142","text":"HP: mPAP > 20 mm Hg en reposo.","guid":"y2WAgwscAy2zvNn1pj50HA","children":[]},{"id":"144","parent":"142","text":"HP precapilar (ej. HAP): RVP ≥ 3 unidades Wood, PCWP ≤ 15 mm Hg.","guid":"sUaQGfIfYz6LRFvF7a2nJQ","children":[]},{"id":"145","parent":"142","text":"HP postcapilar o mixta (ej. secundarias a enf. cardíaca izq.): PCWP > 15 mm Hg, RVP variable.","guid":"_cimOQgfGZVtIFIjueO4Uw","children":[]}]}]},{"id":"146","parent":"123","text":"4. ECG:","guid":"3PeREGznhLmkjL_LHU2Mfg","children":[{"id":"147","parent":"146","text":"Hipertrofia del V. Der.","guid":"8H6dymXArw_YuX0DRbbbSQ","children":[]},{"id":"148","parent":"146","text":"Desviación del eje derecho.","guid":"_mifQyVmUjmboxi2oR2z0Q","children":[]},{"id":"149","parent":"146","text":"P pulmonale.","guid":"xKv2PybEtcITCFMX-9Dy8w","children":[]},{"id":"150","parent":"146","text":"Bloqueo incompleto/completo de rama derecha.","guid":"XeHErukiZUPoHfGwi_LWHA","children":[]},{"id":"151","parent":"146","text":"Patrón S1Q3T3.","guid":"NQepRlseBiyMgbDqIvLwAw","children":[]},{"id":"152","parent":"146","text":"Signos de isquemia miocárdica.","guid":"4m5xyLZbdG-YEEIfVO_o1g","children":[]}]},{"id":"153","parent":"123","text":"5. Radiografía\\Nde tórax:","guid":"raZgGvCPK2hNM_6RjwfEfw","children":[{"id":"154","parent":"153","text":"Hipertrofia del corazón derecho → borde cardíaco derecho\\Nprominente, pérdida del espacio retroesternal (vista lateral).","guid":"wGI7HPoQl7AEXzFDFO1GUA","children":[]},{"id":"155","parent":"153","text":"Cambios vasculares: arterias pulmonares centrales agrandadas,\\N↓ número/tamaño de vasos periféricos (poda vascular).","guid":"IFuFWf6yO8HfYY1drmk7Vg","children":[]},{"id":"156","parent":"153","text":"Signos de causas subyacentes (ej. opacidades nodulares en enf. intersticial pulmonar,\\Nhiperinsuflación en EPOC, congestión venosa pulmonar en enf. cardíaca izq.).","guid":"wEMcs75HqcCqCC-bZ9vSnA","children":[]}]},{"id":"157","parent":"123","text":"6. Investigaciones de\\Ncausas subyacentes:","guid":"c57nAReFc59Eo82ZMltQNg","children":[{"id":"158","parent":"157","text":"Enf. cardíaca izq.: NT-proBNP.","guid":"UmhvkDahl_3HgipJgcte2Q","children":[]},{"id":"159","parent":"157","text":"Enf. pulmonar\\Ncrónica:","guid":"XFQsx59WQ43yG9hR-TsOEg","children":[{"id":"160","parent":"159","text":"Gasometría arterial.","guid":"FnJyMhvx8vfAmckfwaJSmA","children":[]},{"id":"161","parent":"159","text":"Pruebas de función pulmonar.","guid":"V9tHp66z83j4d9dAjr2JoQ","children":[]},{"id":"162","parent":"159","text":"Capacidad de difusión de CO.","guid":"DDRdIUiXZFf-wmKgiwC0cA","children":[]},{"id":"163","parent":"159","text":"TAC de tórax y estudios de sueño.","guid":"dp92DXG44JOBzymOuIREwg","children":[]}]},{"id":"164","parent":"157","text":"Tromboembolismo pulmonar crónico: Gammagrafía V/Q.","guid":"J24Qp7gSptf4XQIQk3nwmA","children":[]}]}]},{"id":"165","parent":"0","text":"Tratamiento de la Hipertensión Pulmonar\\N(HP)","guid":"lggvt-onKIVQZtLQoodJJg","children":[{"id":"166","parent":"165","text":"1. Enfoque:","guid":"d6EyiQOmzey6ZLFCxzxluA","children":[{"id":"167","parent":"166","text":"Tratar descompensación aguda de HP de manera urgente.","guid":"7991A0BWZvD9TQ08FecuTQ","children":[]},{"id":"168","parent":"166","text":"Determinar gravedad funcional y\\Nevaluar características de alto riesgo.","guid":"xFnk79D__KfxHuMB_CR6jg","children":[]},{"id":"169","parent":"166","text":"Adaptar tratamiento según el grupo de HP\\N(Clasificación OMS).","guid":"SqNteKpCrxQp64ut-YDPUQ","children":[]}]},{"id":"170","parent":"165","text":"2. Tratamiento de soporte:","guid":"5k6jmNS3g6OONDcbDyymcg","children":[{"id":"171","parent":"170","text":"Reducir síntomas y ralentizar progresión.","guid":"63-tSxvkwfrFKikj8C28sQ","children":[]}]},{"id":"172","parent":"165","text":"3. Tratamiento dirigido\\N(Grupo I HP - HAP):","guid":"oVdJ52MRcICTyJwZw8ZTTQ","children":[{"id":"173","parent":"172","text":"Considerar bloqueadores de canales de calcio\\N(BCC) y/o vasodilatadores pulmonares.","guid":"5U_lAJcyoTGZQ5y8AwBX1g","children":[]}]},{"id":"174","parent":"165","text":"4. Tratar la causa\\Nsubyacente:","guid":"5rm6Jhg3M_qN4dVihcX2Pw","children":[{"id":"175","parent":"174","text":"Apnea obstructiva del sueño (AOS): CPAP.","guid":"tm97E9L_h3rBWWPDZPke1A","children":[]},{"id":"176","parent":"174","text":"Insuficiencia cardíaca (IC): tratamiento específico.","guid":"cUms9YBQI4n9rI1YAc6oeg","children":[]},{"id":"177","parent":"174","text":"Embolia pulmonar (EP): anticoagulación.","guid":"okTk9SWw6CTatqgN_dGwuQ","children":[]}]}]},{"id":"178","parent":"0","text":"5. Notas importantes:","guid":"","children":[]},{"id":"179","parent":"0","text":"Iniciar tratamiento precozmente\\Nantes de cambios irreversibles en\\Nvasos pulmonares.","guid":"","children":[]},{"id":"180","parent":"0","text":"Vasodilatadores pulmonares\\Nno suelen ser beneficiosos\\Nen pacientes con:","guid":"","children":[]},{"id":"181","parent":"0","text":"HP Grupo 2 (enf.\\Ncardiaca izq.).","guid":"","children":[]},{"id":"182","parent":"0","text":"HP Grupo 3 (enf.\\Npulmonar crónica).","guid":"","children":[]},{"id":"183","parent":"0","text":"Hipertensión Pulmonar\\NDescompensada Aguda","guid":"","children":[]},{"id":"184","parent":"0","text":"1. Todos los pacientes:","guid":"","children":[]},{"id":"185","parent":"0","text":"Evaluar shock (ej. shock\\Ncardiogénico u obstructivo).","guid":"","children":[]},{"id":"186","parent":"0","text":"Identificar y tratar\\Nfactores precipitantes.","guid":"","children":[]},{"id":"187","parent":"0","text":"2. Soporte\\Nhemodinámico:","guid":"","children":[]},{"id":"188","parent":"0","text":"Objetivos generales:","guid":"","children":[]},{"id":"189","parent":"0","text":"Alcanzar euvolemia.","guid":"","children":[]},{"id":"190","parent":"0","text":"Reducir postcarga del V. Der: ej.\\Nvasodilatadores pulmonares.","guid":"","children":[]},{"id":"191","parent":"0","text":"Optimizar GC y\\Nperfusión periférica.","guid":"","children":[]},{"id":"192","parent":"0","text":"Falla del V. Der\\Nrefractaria:","guid":"","children":[]},{"id":"193","parent":"0","text":"Considerar soporte vital extracorpóreo\\N(ECMO) como puente para trasplante\\Npulmonar o cardiopulmonar urgente.","guid":"","children":[]},{"id":"194","parent":"0","text":"3. Consideraciones:","guid":"","children":[]},{"id":"195","parent":"0","text":"El manejo debe realizarse en\\Ncentros especializados\\Nsiempre que sea posible.","guid":"","children":[]},{"id":"196","parent":"0","text":"Manejo a largo plazo de la\\NHipertensión Pulmonar (HP)","guid":"","children":[]},{"id":"197","parent":"0","text":"1. Tratamiento individualizado según la\\Ncondición subyacente y características del\\Npaciente, bajo la guía de un especialista (ej.\\Ncardiólogo, neumólogo).","guid":"","children":[]},{"id":"198","parent":"0","text":"2. Tratamiento\\Nde soporte:","guid":"","children":[]},{"id":"199","parent":"0","text":"Oxigenoterapia en pacientes con\\NEPOC y PaO2 < 60 mm Hg.","guid":"","children":[]},{"id":"200","parent":"0","text":"Diuréticos para sobrecarga de volumen\\N(precaución con sobrediuresis → ↓ precarga\\Nventricular derecha → ↓ GC, falla prerrenal).","guid":"","children":[]},{"id":"201","parent":"0","text":"3. Grupo 1 HP (HAP):","guid":"","children":[]},{"id":"202","parent":"0","text":"Referir a centro especializado en HAP para\\Npruebas de vasorreactividad antes de iniciar\\Nvasodilatadores pulmonares.","guid":"","children":[]},{"id":"203","parent":"0","text":"Prueba de vasorreactividad (en CCD): mide\\NmPAP tras administrar un vasodilatador (ej.\\Nóxido nítrico inhalado).","guid":"","children":[]},{"id":"204","parent":"0","text":"Vasorreactivo:\\Ntratar con BCC.","guid":"","children":[]},{"id":"205","parent":"0","text":"No vasorreactivo: considerar otros\\Nvasodilatadores pulmonares.","guid":"","children":[]},{"id":"206","parent":"0","text":"BCC: primera línea en pacientes con HAP\\N+ prueba positiva, sin signos de falla V. Der\\Nni contraindicaciones.","guid":"","children":[]},{"id":"207","parent":"0","text":"Otros vasodilatadores\\Npulmonares: segunda línea,\\Nsegún severidad de los síntomas.","guid":"","children":[]},{"id":"208","parent":"0","text":"4. Agentes\\Nvasodilatadores\\Npulmonares:","guid":"","children":[]},{"id":"209","parent":"0","text":"Antagonistas del receptor de endotelina\\N(ej. bosentán, ambrisentán):","guid":"","children":[]},{"id":"210","parent":"0","text":"Mecanismo: inhiben competitivamente\\Nlos receptores de endotelina-1 → ↓\\Nvasoconstricción pulmonar.","guid":"","children":[]},{"id":"211","parent":"0","text":"EA: hepatotoxicidad\\N(control LFT).","guid":"","children":[]},{"id":"212","parent":"0","text":"CI: embarazo, uso concomitante de\\Nciclosporina o gliburida.","guid":"","children":[]},{"id":"213","parent":"0","text":"Inhibidores de PDE-5\\N(ej. sildenafil):","guid":"","children":[]},{"id":"214","parent":"0","text":"Mecanismo: inhiben PDE-5 → ↓\\Ndegradación de cGMP →\\Nvasodilatación pulmonar.","guid":"","children":[]},{"id":"215","parent":"0","text":"EA: cefalea, flushing, visión\\Nazulada (cianopsia).","guid":"","children":[]},{"id":"216","parent":"0","text":"CI: uso de bloqueadores alfa y\\Nnitratos (hipotensión grave).","guid":"","children":[]},{"id":"217","parent":"0","text":"Análogos de prostaciclina (ej.\\Niloprost, treprostinil):","guid":"","children":[]},{"id":"218","parent":"0","text":"Mecanismo: vasodilatación directa,\\Ninhiben agregación plaquetaria.","guid":"","children":[]},{"id":"219","parent":"0","text":"EA: dolor\\Nmandibular,\\Nflushing.","guid":"","children":[]},{"id":"220","parent":"0","text":"Prostaciclina sintética\\N(epoprostenol): indicado en falla\\Ncardiaca con FE reducida.","guid":"","children":[]},{"id":"221","parent":"0","text":"5. Grupo 2 HP (Enf.\\Ncardíaca izq.):","guid":"","children":[]},{"id":"222","parent":"0","text":"Tratar HTA y enf. cardíaca\\Nsegún corresponda.","guid":"","children":[]},{"id":"223","parent":"0","text":"Reparar/reemplazar válvulas\\Ndañadas si es necesario.","guid":"","children":[]},{"id":"224","parent":"0","text":"6. Grupo 3 HP (Enf.\\Npulmonar crónica):","guid":"","children":[]},{"id":"225","parent":"0","text":"Iniciar\\Noxigenoterapia a\\Nlargo plazo.","guid":"","children":[]},{"id":"226","parent":"0","text":"Optimizar tratamiento de EPOC o\\Nenf. intersticial pulmonar.","guid":"","children":[]},{"id":"227","parent":"0","text":"Considerar\\Ntrasplante\\Npulmonar.","guid":"","children":[]},{"id":"228","parent":"0","text":"7. Grupo 4 HP\\N(Obstrucción A.\\NPulmonar):","guid":"","children":[]},{"id":"229","parent":"0","text":"CTEPH:","guid":"","children":[]},{"id":"230","parent":"0","text":"Endarterectomía\\Npulmonar: primera línea.","guid":"","children":[]},{"id":"231","parent":"0","text":"Anticoagulación\\Nde por vida.","guid":"","children":[]},{"id":"232","parent":"0","text":"Tratar hipoxia asociada\\Ny falla cardíaca.","guid":"","children":[]},{"id":"233","parent":"0","text":"Compresión extrínseca:\\Ntratar según etiología.","guid":"","children":[]},{"id":"234","parent":"0","text":"8. Grupo 5 HP (Enf.\\Nmultifactoriales):","guid":"","children":[]},{"id":"235","parent":"0","text":"Tratar causa\\Nsubyacente.","guid":"","children":[]},{"id":"236","parent":"0","text":"Considerar vasodilatadores\\Npulmonares según caso.","guid":"","children":[]},{"id":"237","parent":"0","text":"Cor Pulmonale","guid":"","children":[]},{"id":"238","parent":"0","text":"Definición:","guid":"","children":[]},{"id":"239","parent":"0","text":"Alteración estructural (hipertrofia, dilatación) o\\Ndisfunción del ventrículo derecho (VD) causada\\Npor hipertensión pulmonar (HP) secundaria a un\\Ntrastorno primario del sistema respiratorio o\\Narterial pulmonar (41).","guid":"","children":[]},{"id":"240","parent":"0","text":"Conocido como enfermedad cardíaca pulmonar\\Nporque se origina por disfunción del VD debido a\\Nenfermedad pulmonar, no cardíaca (22).","guid":"","children":[]},{"id":"241","parent":"0","text":"1. Cor\\NPulmonale\\NAgudo:","guid":"","children":[]},{"id":"242","parent":"0","text":"Fisiopatología: Aumento súbito de la\\Npostcarga del VD → dilatación y\\Ndisfunción ventricular (22).","guid":"","children":[]},{"id":"243","parent":"0","text":"Etiología:","guid":"","children":[]},{"id":"244","parent":"0","text":"Embolia pulmonar masiva\\Naguda (más común).","guid":"","children":[]},{"id":"245","parent":"0","text":"SDRA (42).","guid":"","children":[]},{"id":"246","parent":"0","text":"Clínica: Inicio agudo con dolor torácico,\\Ndisnea, hipotensión, taquicardia,\\Nsíncope, síntomas de TVP.","guid":"","children":[]},{"id":"247","parent":"0","text":"2. Cor\\NPulmonale\\NCrónico:","guid":"","children":[]},{"id":"248","parent":"0","text":"Fisiopatología: Aumento progresivo de la\\Npostcarga del VD → hipertrofia progresiva\\Ndel VD → dilatación y disfunción ventricular\\Ncon el tiempo (22).","guid":"","children":[]},{"id":"249","parent":"0","text":"Etiología:","guid":"","children":[]},{"id":"250","parent":"0","text":"Parénquima pulmonar: EPOC,\\Nenfermedad pulmonar\\Nintersticial, bronquiectasias.","guid":"","children":[]},{"id":"251","parent":"0","text":"Vasculatura pulmonar: HAP, HP\\Ntromboembólica crónica.","guid":"","children":[]},{"id":"252","parent":"0","text":"Hipoxia crónica: Síndrome de hipoventilación por\\Nobesidad, apnea obstructiva del sueño,\\Ncifoescoliosis, trastornos neuromusculares.","guid":"","children":[]},{"id":"253","parent":"0","text":"Clínica: Síntomas similares a la HP,\\Ncon prominencia de los síntomas de\\Nfalla cardíaca derecha.","guid":"","children":[]},{"id":"254","parent":"0","text":"3. Diagnóstico:","guid":"","children":[]},{"id":"255","parent":"0","text":"Ecocardiograma: dilatación,\\Nhipertrofia o disfunción del VD (41).","guid":"","children":[]},{"id":"256","parent":"0","text":"Estudios adicionales según\\Nla causa subyacente (ver\\Ndiagnóstico de HP).","guid":"","children":[]},{"id":"257","parent":"0","text":"Si se sospecha cor\\Npulmonale agudo, realizar\\Nestudios urgentes para TEP.","guid":"","children":[]},{"id":"258","parent":"0","text":"4. Tratamiento:","guid":"","children":[]},{"id":"259","parent":"0","text":"Depende de la causa subyacente\\N(ver tratamiento de HP).","guid":"","children":[]},{"id":"260","parent":"0","text":"En cor pulmonale agudo, los\\Npacientes requieren:","guid":"","children":[]},{"id":"261","parent":"0","text":"Estabilización (ver manejo de HP\\Ndescompensada aguda).","guid":"","children":[]},{"id":"262","parent":"0","text":"Manejo intensivo de la causa\\Nsubyacente (ver tratamiento de\\NTEP masivo y SDRA).","guid":"","children":[]}]},"node_count":262,"relations":[],"cross_references":[],"specialty":"Neumología","folder":"Entidades clínicas/Neumología","filename":"Hipertensión pulmonar-2024","id":"map_1359","resolved_references":[],"title_raw":"Hipertensión pulmonar-2024"}