{"title":"MareoUrgencias iPad","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Entidades clínicas/Urgencias/MareoUrgencias iPad.smmx","root":{"id":"0","parent":"-1","text":"Mareo en\\NUrgencias","guid":"j1dgYJDiSCdf9ccdZbYdTQ","children":[{"id":"1","parent":"0","text":"Clasificación por\\NPerfil Temporal","guid":"MXeDiBLLWu4-OggrfK-E5A","children":[{"id":"2","parent":"1","text":"SÍNDROME VESTIBULAR\\NAGUDO (SVA)","guid":"g9jsjppNDUpsXu79-yao2A","children":[{"id":"3","parent":"2","text":"Definición → vértigo continuo >24h + nistagmo + inestabilidad","guid":"","children":[]},{"id":"4","parent":"2","text":"Diagnóstico diferencial\\NPRINCIPAL","guid":"g2HQ3Ev8V27LiB_KcTTQdw","children":[{"id":"5","parent":"4","text":"Neuronitis vestibular (periférico)","guid":"","children":[]},{"id":"6","parent":"4","text":"ACV de fosa posterior (central) → AICA, PICA, cerebeloso","guid":"","children":[]}]},{"id":"7","parent":"2","text":"Evaluación → protocolo HINTS","guid":"","children":[]}]},{"id":"8","parent":"1","text":"SÍNDROME\\NVESTIBULAR\\NEPISÓDICO","guid":"dgVB5iuEb2HIkKkF31MoUw","children":[{"id":"9","parent":"8","text":"Crisis Cortas\\N(segundos a\\Nminutos)","guid":"K-pm0V5EpEEhT-T0j7QLLQ","children":[{"id":"10","parent":"9","text":"VPPB → gatillado por movimientos cefálicos","guid":"","children":[]},{"id":"11","parent":"9","text":"Ortostatismo → frecuente en AM, sobremedicación antihipertensiva","guid":"","children":[]},{"id":"12","parent":"9","text":"Crisis de pánico → hiperventilación asociada","guid":"","children":[]},{"id":"13","parent":"9","text":"TIA de fosa posterior → raro, descartar con factores de riesgo vascular","guid":"","children":[]},{"id":"14","parent":"9","text":"Paroxismia vestibular → compresión nervio vestibular en APC por AICA/arteria laberíntica","guid":"","children":[]}]},{"id":"15","parent":"8","text":"Crisis Largas\\N(minutos a\\Nhoras)","guid":"8IS-INsf6bNQz9rKnHoQ7w","children":[{"id":"16","parent":"15","text":"Enfermedad de Meniere → vértigo + hipoacusia + tinnitus + plenitud ótica","guid":"","children":[]},{"id":"17","parent":"15","text":"Migraña vestibular → 50% asocia\\Ncefalea migrañosa, 20min-24h duración","guid":"2ru-DrpZpbZ5NaUSZ0x2oA","children":[{"id":"18","parent":"17","text":"GRAN IMITADORA → puede simular CUALQUIER síndrome vestibular","guid":"","children":[]},{"id":"19","parent":"17","text":"Criterios Bárány Society/IHS","guid":"","children":[]}]}]}]},{"id":"20","parent":"1","text":"SÍNDROME\\NVESTIBULAR\\NCRÓNICO","guid":"ME7qTlZDICGn_xfkphWmsg","children":[{"id":"21","parent":"20","text":"Vestibulopatía\\Nbilateral","guid":"l4R18eFAZo4S3umWMuqoBQ","children":[{"id":"22","parent":"21","text":"Presbivestibulopatía (asociada a edad)","guid":"","children":[]},{"id":"23","parent":"21","text":"Ototóxicos → ATB aminoglucósidos, diuréticos, QMT (cisplatino)","guid":"","children":[]},{"id":"24","parent":"21","text":"Idiopática","guid":"","children":[]}]},{"id":"25","parent":"20","text":"MPPP (Mareo Postural\\NPerceptual Persistente)","guid":"7G5Ee9P3-AYekZjkY0Y3zw","children":[{"id":"26","parent":"25","text":"Personalidad ansiosa + episodio vestibular previo mal compensado","guid":"","children":[]},{"id":"27","parent":"25","text":"Inestabilidad en bipedestación, NO en reposo","guid":"","children":[]},{"id":"28","parent":"25","text":"Requiere rehabilitación kinesiológica","guid":"","children":[]}]}]},{"id":"29","parent":"1","text":"SÍNDROME\\NVESTIBULAR\\NGATILLADO","guid":"WANfG-69cNUE4QZyXmd4Bw","children":[{"id":"30","parent":"29","text":"VPPB canal posterior → Dix-Hallpike","guid":"","children":[]},{"id":"31","parent":"29","text":"VPPB canal lateral → McClure/Roll Test","guid":"","children":[]},{"id":"32","parent":"29","text":"Síndrome de 3ra ventana →\\Ngatillado por ruido/Valsalva","guid":"0_6J97IRax3BCXhxmMA67A","children":[{"id":"33","parent":"32","text":"Dehiscencia canal semicircular superior (más frecuente hoy)","guid":"","children":[]},{"id":"34","parent":"32","text":"OMC colesteatomatosa","guid":"","children":[]},{"id":"35","parent":"32","text":"Sífilis terciaria (histórico)","guid":"","children":[]}]}]}]},{"id":"36","parent":"0","text":"Protocolo HINTS (Head Impulse,\\NNystagmus, Test of Skew)","guid":"yMN7VZLiuD3zMKL8UqN23g","children":[{"id":"37","parent":"36","text":"INDICACIÓN → solo en SVA con nistagmo espontáneo presente","guid":"","children":[]},{"id":"38","parent":"36","text":"Componente 1 →\\NHEAD IMPULSE TEST\\N(HIT)","guid":"Q4gymIpDlDRuLjXwsiD1HQ","children":[{"id":"39","parent":"38","text":"Normal (sin sacada correctiva) → CENTRAL hasta demostrar lo contrario","guid":"","children":[]},{"id":"40","parent":"38","text":"Anormal (sacada correctiva presente) → sugiere PERIFÉRICO","guid":"","children":[]},{"id":"41","parent":"38","text":"Sensibilidad aislada 76.8% (IC 95% 64.4-85.8%)","guid":"","children":[]},{"id":"42","parent":"38","text":"Especificidad aislada 89.1% (IC 95% 75.8-95.6%)","guid":"","children":[]}]},{"id":"43","parent":"36","text":"Componente 2 →\\NTIPO DE NISTAGMO","guid":"q2JJL3uZH-6bQ7ewLgQDGA","children":[{"id":"44","parent":"43","text":"Unidireccional horizontal → sugiere periférico","guid":"","children":[]},{"id":"45","parent":"43","text":"BIDIRECCIONAL → CENTRAL","guid":"","children":[]},{"id":"46","parent":"43","text":"VERTICAL puro (up-beat o down-beat) → CENTRAL","guid":"","children":[]},{"id":"47","parent":"43","text":"TORSIONAL PURO en posición primaria → CENTRAL","guid":"","children":[]},{"id":"48","parent":"43","text":"Desconjugado → CENTRAL","guid":"","children":[]},{"id":"49","parent":"43","text":"Sensibilidad nistagmo tipo central 50.7%, Especificidad 98.5%","guid":"","children":[]}]},{"id":"50","parent":"36","text":"Componente 3 →\\NTEST OF SKEW\\N(Skew Deviation)","guid":"urtKu4Q87_p2eL3ohEWMPw","children":[{"id":"51","parent":"50","text":"Desviación vertical al cover test alternante","guid":"","children":[]},{"id":"52","parent":"50","text":"ALTAMENTE ESPECÍFICO para patología central","guid":"","children":[]},{"id":"53","parent":"50","text":"Sensibilidad 23.7% (baja) / Especificidad 97.6% (alta)","guid":"","children":[]}]},{"id":"54","parent":"36","text":"HINTS combinado →\\Nrendimiento diagnóstico","guid":"xEmjs4ZhOmYXqYJ0j6BnjQ","children":[{"id":"55","parent":"54","text":"Sensibilidad 92.9% (IC 95% 79.1-97.9%) → ALTA certeza","guid":"","children":[]},{"id":"56","parent":"54","text":"Especificidad 83.4% (IC 95% 69.6-91.7%) → certeza MODERADA","guid":"","children":[]},{"id":"57","parent":"54","text":"SUPERA a RM-DWI precoz (<24-48h) para ACV fosa posterior","guid":"","children":[]}]},{"id":"58","parent":"36","text":"HINTS PLUS →\\Nagrega evaluación\\Nauditiva","guid":"GVkbJLIHW6BzUVrt8WfbuQ","children":[{"id":"59","parent":"58","text":"Frote de dedos bilateral → detectar hipoacusia aguda unilateral","guid":"","children":[]},{"id":"60","parent":"58","text":"Hipoacusia aguda nueva → sospecha infarto arteria laberíntica/AICA","guid":"","children":[]},{"id":"61","parent":"58","text":"Sensibilidad 99.0% / Especificidad 84.8%","guid":"","children":[]},{"id":"62","parent":"58","text":"VPP 100% para centralidad si HINTS central + hipoacusia","guid":"","children":[]}]},{"id":"63","parent":"36","text":"Evaluación\\Nauditiva adicional","guid":"jP452kwSxisBQzzOVM0LoQ","children":[{"id":"64","parent":"63","text":"Sin antecedente de asimetría previa → hipoacusia nueva = imagen","guid":"","children":[]},{"id":"65","parent":"63","text":"Irrigación → arteria laberíntica (rama de AICA) → zona emergencia VIII par","guid":"","children":[]}]},{"id":"66","parent":"36","text":"Evaluación de MARCHA\\N(propuesto en protocolo ampliado)","guid":"nJ1dzEpvLBoLBak0V1ZcHQ","children":[{"id":"67","parent":"66","text":"Inestabilidad grado 3 → imposibilidad de bipedestación sin ayuda o caídas francas","guid":"","children":[]},{"id":"68","parent":"66","text":"VPP 100% para causa CENTRAL","guid":"","children":[]},{"id":"69","parent":"66","text":"Ataxia truncal/marcha → S 69.7%, E 83.7% (grados crecientes mayor S)","guid":"","children":[]}]},{"id":"70","parent":"36","text":"LIMITACIÓN\\NCRÍTICA","guid":"JYOy9ydjBT6rtmnFU4nZjg","children":[{"id":"71","parent":"70","text":"HINTS requiere entrenamiento específico","guid":"","children":[]},{"id":"72","parent":"70","text":"Mayoría de urgenciólogos NO entrenados (GRACE-3, 2023)","guid":"","children":[]},{"id":"73","parent":"70","text":"Sin entrenamiento → HINTS es INEXACTO","guid":"","children":[]},{"id":"74","parent":"70","text":"NO es estándar de cuidado legal actual en urgencias","guid":"","children":[]}]},{"id":"75","parent":"36","text":"Protocolo STANDING\\N(alternativa)","guid":"YxwODIQBm_8cU-KuZkXmgQ","children":[{"id":"76","parent":"75","text":"SponTAneous Nystagmus, Direction, Gait","guid":"","children":[]},{"id":"77","parent":"75","text":"Combina nistagmo + inestabilidad de marcha + factores de riesgo vascular","guid":"","children":[]},{"id":"78","parent":"75","text":"Precisión diagnóstica comparable a HINTS+ cuando se entrena","guid":"","children":[]}]}]},{"id":"79","parent":"0","text":"Maniobras\\NDiagnósticas de\\NVPPB","guid":"h1kw3oycJSHuV5V2iUjDfg","children":[{"id":"80","parent":"79","text":"DIX-HALLPIKE\\N(canal posterior)","guid":"vL9jBJu3CDt4Yyl_vZU2uA","children":[{"id":"81","parent":"80","text":"Técnica → rotación cefálica 45° + decúbito supino rápido","guid":"","children":[]},{"id":"82","parent":"80","text":"Positivo → nistagmo TORSIONAL con batida hacia ARRIBA","guid":"","children":[]},{"id":"83","parent":"80","text":"LATENCIA antes del inicio del nistagmo (segundos)","guid":"","children":[]},{"id":"84","parent":"80","text":"INVERSIÓN del nistagmo al volver a posición sentada → CONFIRMA","guid":"","children":[]},{"id":"85","parent":"80","text":"Sin inversión → sospechar causa central","guid":"","children":[]}]},{"id":"86","parent":"79","text":"McCLURE / ROLL TEST\\N(canal lateral)","guid":"jMkgekfr9kOshPdTvwwVZw","children":[{"id":"87","parent":"86","text":"Técnica → cabeza 30° flexión + giro lateral","guid":"","children":[]},{"id":"88","parent":"86","text":"Nistagmo GEOTRÓPICO → bate hacia el suelo en ambos lados","guid":"","children":[]},{"id":"89","parent":"86","text":"Variantes apogetrópicas existen","guid":"","children":[]}]}]},{"id":"90","parent":"0","text":"Neuroimagen","guid":"","children":[{"id":"91","parent":"90","text":"TAC de cerebro →\\NDESACONSEJAR\\Nrutinariamente","guid":"aveg132SHfQSynhPrWRKOA","children":[{"id":"92","parent":"91","text":"Sensibilidad MUY BAJA para ACV fosa posterior","guid":"","children":[]},{"id":"93","parent":"91","text":"NO aporta en SVA ni en episódico ni en gatillado","guid":"","children":[]}]},{"id":"94","parent":"90","text":"RM de fosa posterior →\\NESTÁNDAR si sospecha\\Ncentral","guid":"Lutba1ACeb58b-9NFyjoJg","children":[{"id":"95","parent":"94","text":"Sensibilidad ~80% en agudo (<24-48h) → FALSOS NEGATIVOS posibles","guid":"","children":[]},{"id":"96","parent":"94","text":"Especificidad alta","guid":"","children":[]},{"id":"97","parent":"94","text":"Indicación → HINTS central o equívoco, sin examinador entrenado","guid":"","children":[]},{"id":"98","parent":"94","text":"GRACE-3 → si no hay examinador HINTS entrenado, RM como segunda opción","guid":"","children":[]}]},{"id":"99","parent":"90","text":"Angio-TAC/Angio-RM\\Ncabeza y cuello","guid":"9e_e3NYo8wYaTW9xQoI9Xg","children":[{"id":"100","parent":"99","text":"Indicación → sospecha TIA de fosa posterior","guid":"","children":[]},{"id":"101","parent":"99","text":"Síndrome episódico + factores de riesgo vascular","guid":"","children":[]}]}]},{"id":"102","parent":"0","text":"Tratamiento\\Nen Urgencias","guid":"1G8lteZ88EG_UtPL3xq5Og","children":[{"id":"103","parent":"102","text":"NEURONITIS VESTIBULAR\\N(SVA periférico confirmado)","guid":"PHU0kQUagadMxZhUmTu-pg","children":[{"id":"104","parent":"103","text":"Corticoides →\\Nmetilprednisolona/prednisona\\N1mg/kg/día (máx 60mg)","guid":"X9BLX81PH5DG2NH9EZwuKA","children":[{"id":"105","parent":"104","text":"Iniciar si síntomas <3 DÍAS de evolución","guid":"","children":[]},{"id":"106","parent":"104","text":"Beneficio en sintomatología aguda demostrado","guid":"","children":[]},{"id":"107","parent":"104","text":">3 días → sin beneficio en síntomas ni pronóstico a largo plazo","guid":"","children":[]}]},{"id":"108","parent":"103","text":"Sedantes vestibulares → difenidol (antihistamínico)","guid":"","children":[{"id":"109","parent":"108","text":"Uso CORTO plazo → no prolongar >48-72h (retrasa compensación)","guid":"","children":[]}]},{"id":"110","parent":"103","text":"REHABILITACIÓN VESTIBULAR\\N→ iniciar ANTES de 3 días","guid":"RcBpKniNnB_tRQ1UEYZ60w","children":[{"id":"111","parent":"110","text":"Terapia del reflejo vestíbulo-ocular","guid":"","children":[]},{"id":"112","parent":"110","text":"Derivación precoz a tecnología médica/kinesiología","guid":"","children":[]},{"id":"113","parent":"110","text":"MEJOR predictor de outcomes a largo plazo","guid":"","children":[]}]}]},{"id":"114","parent":"102","text":"ENFERMEDAD\\NDE MENIERE\\N(episódico)","guid":"fRMaIy57EeiHkxfDMnIFXA","children":[{"id":"115","parent":"114","text":"Sedantes vestibulares → difenidol","guid":"","children":[]},{"id":"116","parent":"114","text":"Benzodiazepinas → uso puntual en crisis","guid":"","children":[]},{"id":"117","parent":"114","text":"Corticoides orales → considerar","guid":"","children":[]},{"id":"118","parent":"114","text":"Corticoides transtimpánicos → evaluar en crisis agudas refractarias","guid":"","children":[]}]},{"id":"119","parent":"102","text":"VPPB","guid":"","children":[{"id":"120","parent":"119","text":"Maniobra de EPLEY (canal posterior) → tratamiento directo","guid":"","children":[]},{"id":"121","parent":"119","text":"NO requiere imágenes","guid":"","children":[]},{"id":"122","parent":"119","text":"Derivar a maniobras de reposición sin estudio previo","guid":"","children":[]}]},{"id":"123","parent":"102","text":"MIGRAÑA\\NVESTIBULAR","guid":"z1uFPiV4_aScNy4suxoE-A","children":[{"id":"124","parent":"123","text":"Puede simular los 3 tipos de síndromes vestibulares","guid":"","children":[]},{"id":"125","parent":"123","text":"Sospecha → características de centralidad SIN inestabilidad severa + historia de migraña","guid":"","children":[]},{"id":"126","parent":"123","text":"Ante duda → consultar a alguien más experimentado","guid":"","children":[]},{"id":"127","parent":"123","text":"Criterios de exclusión obligatorios antes de diagnosticar","guid":"","children":[]}]}]},{"id":"128","parent":"0","text":"Consideraciones\\NGeriátricas","guid":"BEY4ohwo6KtMmYKSpo1A6g","children":[{"id":"129","parent":"128","text":"AM → mayor prevalencia de ortostatismo por polifarmacia antihipertensiva","guid":"","children":[]},{"id":"130","parent":"128","text":"Presbivestibulopatía → evaluación funcional integrada","guid":"","children":[]},{"id":"131","parent":"128","text":"Fragilidad → condiciona pronóstico post-SVA","guid":"","children":[]},{"id":"132","parent":"128","text":"MPPP → sarcopenia + problemas articulares agravan la inestabilidad","guid":"","children":[]},{"id":"133","parent":"128","text":"Corticoides en AM → monitorizar glicemia, considerar duración limitada","guid":"","children":[]},{"id":"134","parent":"128","text":"Rehabilitación vestibular precoz → CRUCIAL para evitar deterioro funcional","guid":"","children":[]},{"id":"135","parent":"128","text":"Caídas → SVA/VPPB no tratado = factor precipitante de Fx cadera","guid":"","children":[]},{"id":"136","parent":"128","text":"Neuronitis mal compensada → riesgo de mareo crónico y aislamiento social","guid":"","children":[]}]},{"id":"137","parent":"0","text":"Futuro y\\NTecnología","guid":"LTRi0SiksgRYzdh4SCRP_w","children":[{"id":"138","parent":"137","text":"Tele-video-nistagmografía\\N(VNG remota)","guid":"ks84avbjf-2-uI8kSOujvQ","children":[{"id":"139","parent":"138","text":"Potencial para distinguir central vs periférico en urgencia","guid":"","children":[]},{"id":"140","parent":"138","text":"Reduciría interconsultas innecesarias a neurología (~20% de IC por vértigo)","guid":"","children":[]},{"id":"141","parent":"138","text":"IA aplicada a análisis de nistagmo → diagnóstico automatizado","guid":"","children":[]}]},{"id":"142","parent":"137","text":"Entrenamiento en HINTS para urgenciólogos → prioridad educativa","guid":"","children":[]}]},{"id":"143","parent":"0","text":"Perlas\\NClínicas","guid":"1k8nPvfHijDzvSEjbLHEaQ","children":[{"id":"144","parent":"143","text":"HINTS solo es válido en SVA CON nistagmo espontáneo → NO usar en episódicos","guid":"","children":[]},{"id":"145","parent":"143","text":"TAC de cerebro NO tiene rol en evaluación de vértigo agudo → preferir RM","guid":"","children":[]},{"id":"146","parent":"143","text":"HINTS+ SUPERA a RM-DWI precoz (<48h) en detección de ACV posterior","guid":"","children":[]},{"id":"147","parent":"143","text":"Nistagmo torsional puro en posición primaria = CENTRAL hasta demostrar lo contrario","guid":"","children":[]},{"id":"148","parent":"143","text":"Inestabilidad grado 3 (caídas francas) = VPP 100% para causa central","guid":"","children":[]},{"id":"149","parent":"143","text":"Migraña vestibular = gran imitadora → tenerla siempre en mente","guid":"","children":[]},{"id":"150","parent":"143","text":"Corticoides en neuronitis → solo útiles si <3 días de síntomas","guid":"","children":[]},{"id":"151","parent":"143","text":"Rehabilitación vestibular PRECOZ (<3 días) = mejor predictor de recuperación","guid":"","children":[]},{"id":"152","parent":"143","text":"Código Copleo Vestibular (13-01-022) → cubre posicional + reposición en CSM","guid":"","children":[]},{"id":"153","parent":"143","text":"En AM → descartar SIEMPRE ortostatismo por polifarmacia antes de asumir causa vestibular","guid":"","children":[]}]},{"id":"154","parent":"0","text":"VER TAMBIÉN","guid":"","children":[{"id":"155","parent":"154","text":"→ Vía Vestibulococlear (Neuroanatomía)","guid":"","children":[]},{"id":"156","parent":"154","text":"→ VPPB (Vértigo Posicional)","guid":"","children":[]},{"id":"157","parent":"154","text":"→ Enfermedad de Meniere (ORL)","guid":"","children":[]},{"id":"158","parent":"154","text":"→ Neuronitis Vestibular (ORL)","guid":"","children":[]},{"id":"159","parent":"154","text":"→ Schwannoma Vestibular (Neuro-otología)","guid":"","children":[]},{"id":"160","parent":"154","text":"→ Migraña Vestibular (Neurología/ORL)","guid":"","children":[]},{"id":"161","parent":"154","text":"→ Ortostatismo Hemodinámico (Geriatría)","guid":"","children":[]},{"id":"162","parent":"154","text":"→ Caídas en AM (Geriatría)","guid":"","children":[]},{"id":"163","parent":"154","text":"→ Fragilidad (Valoración Geriátrica)","guid":"","children":[]}]},{"id":"164","parent":"0","text":"Referencias","guid":"","children":[{"id":"165","parent":"164","text":"1. Edlow JA et al. GRACE-3: Acute dizziness and vertigo in the ED. Acad Emerg Med. 2023;30(5):442-486.","guid":"","children":[]},{"id":"166","parent":"164","text":"2. Gottlieb M et al. HINTS for diagnosing central causes of AVS. Cochrane Database Syst Rev. 2023;11:CD015089.","guid":"","children":[]},{"id":"167","parent":"164","text":"3. Shah VP et al. Diagnostic accuracy of physical exam in ED patients with acute vertigo: meta-analysis for GRACE-3. Acad Emerg Med. 2023;30(5):552-578.","guid":"","children":[]},{"id":"168","parent":"164","text":"4. Tarnutzer AA, Edlow JA. Bedside Testing in AVS - HINTS Plus and Beyond. Audiol Res. 2023;13(5):670-685.","guid":"","children":[]},{"id":"169","parent":"164","text":"5. Strupp M et al. AUVP/Vestibular neuritis: Diagnostic criteria. Bárány Society. J Vestib Res. 2022;32(6):389-406.","guid":"","children":[]},{"id":"170","parent":"164","text":"6. Lempert T et al. Vestibular migraine: Diagnostic criteria. J Vestib Res. 2012;22(4):167-172.","guid":"","children":[]},{"id":"171","parent":"164","text":"7. von Brevern M et al. BPPV: Diagnostic criteria. Bárány Society. J Vestib Res. 2015;25:105-117.","guid":"","children":[]},{"id":"172","parent":"164","text":"8. Lopez-Escamez JA et al. Diagnostic criteria for Meniere disease. Bárány Society. J Vestib Res. 2015;25(1):1-7.","guid":"","children":[]},{"id":"173","parent":"164","text":"9. Kim HA et al. Hemodynamic orthostatic dizziness/vertigo: Diagnostic criteria. Bárány Society. J Vestib Res. 2019;29:45-56.","guid":"","children":[]}]}]},"node_count":173,"relations":[],"cross_references":[],"specialty":"General","folder":"Entidades clínicas/Urgencias","filename":"MareoUrgencias iPad","id":"map_2370","resolved_references":[],"title_raw":"MareoUrgencias iPad"}