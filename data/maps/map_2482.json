{"title":"HYVET-2026","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Estudios Pivotales/HYVET-2026.smmx","root":{"id":"0","parent":"-1","text":"HYVET (2008)\\NHypertension in the Very Elderly Trial\\N\\N⭐ Estudio pivote HTA en ≥80 años","guid":"HYVET-ROOT","children":[{"id":"1","parent":"0","text":"📋 IDENTIFICACIÓN","guid":"HYVET-ID","children":[{"id":"2","parent":"1","text":"Acrónimo\\NHYpertension in the Very Elderly Trial","guid":"HYVET-ID1","children":[]},{"id":"3","parent":"1","text":"Publicación\\NNEJM 2008;358:1887-98\\NDOI: 10.1056/NEJMoa0801369","guid":"HYVET-ID2","children":[]},{"id":"4","parent":"1","text":"Financiamiento\\NBritish Heart Foundation","guid":"HYVET-ID3","children":[]}]},{"id":"5","parent":"0","text":"🔬 DISEÑO","guid":"HYVET-DESIGN","children":[{"id":"6","parent":"5","text":"Tipo\\NRCT doble ciego\\NPlacebo-controlado","guid":"HYVET-D1","children":[]},{"id":"7","parent":"5","text":"Países\\N195 centros, 13 países\\N(Europa, China, Australasia)","guid":"HYVET-D2","children":[]},{"id":"8","parent":"5","text":"Período\\N2001-2007\\NSeguimiento: 1.8 años\\NTerminado precozmente","guid":"HYVET-D3","children":[]}]},{"id":"9","parent":"0","text":"👥 POBLACIÓN","guid":"HYVET-POP","children":[{"id":"10","parent":"9","text":"n = 3845 aleatorizados\\N1933 indapamida\\N1912 placebo","guid":"HYVET-P1","children":[]},{"id":"11","parent":"9","text":"Criterios inclusión\\N• Edad ≥80 años\\N• PAS 160-199 mmHg\\N• PAD menor a 110 mmHg","guid":"HYVET-P2","children":[]},{"id":"12","parent":"9","text":"Exclusión\\N• HTA secundaria\\N• IC que requiere antiHTA\\N• Demencia\\N• Dependencia","guid":"HYVET-P3","children":[]},{"id":"13","parent":"9","text":"Edad media: 83.6 años\\N60.5% mujeres\\NPA: 173/90 mmHg","guid":"HYVET-P4","children":[]}]},{"id":"14","parent":"0","text":"💊 INTERVENCIÓN","guid":"HYVET-INT","children":[{"id":"15","parent":"14","text":"Grupo activo\\NIndapamida SR 1.5 mg/día\\N± Perindopril 2-4 mg","guid":"HYVET-I1","children":[]},{"id":"16","parent":"14","text":"Meta: PA menor a 150/80 mmHg","guid":"HYVET-I2","children":[]}]},{"id":"17","parent":"0","text":"📊 OUTCOMES","guid":"HYVET-OUT","children":[{"id":"18","parent":"17","text":"Outcome primario\\NACV fatal o no fatal\\NHR 0.70 (0.49-1.01) p=0.06\\N↓30% (no significativo)","guid":"HYVET-O1","children":[]},{"id":"19","parent":"17","text":"Outcomes secundarios ⭐\\N• Mortalidad total: ↓21% p=0.02\\N• IC: ↓64% p menor a 0.001\\N• ACV fatal: ↓39%","guid":"HYVET-O2","children":[]},{"id":"20","parent":"17","text":"NNT\\N• ACV: 40 a 2 años\\N• Mortalidad: 40 a 2 años","guid":"HYVET-O3","children":[]}]},{"id":"21","parent":"0","text":"⚠️ SESGOS","guid":"HYVET-SEG","children":[{"id":"22","parent":"21","text":"Limitaciones\\N• Terminado precozmente\\N• Run-in period\\N• Excluye dementes/frágiles\\N• Seguimiento corto","guid":"HYVET-S1","children":[]},{"id":"23","parent":"21","text":"Sesgo selección\\NNo aplica a población\\Ngeriátrica real (frágiles)","guid":"HYVET-S2","children":[]}]},{"id":"24","parent":"0","text":"🏥 GERIATRÍA","guid":"HYVET-GER","children":[{"id":"25","parent":"24","text":"Fortalezas\\N• Único RCT en ≥80 años\\N• Meta conservadora 150/80","guid":"HYVET-G1","children":[]},{"id":"26","parent":"24","text":"Precauciones\\N• No aplica a frágiles\\N• Vigilar hipotensión ortostática\\N• Evaluar expectativa vida","guid":"HYVET-G2","children":[]}]},{"id":"27","parent":"0","text":"💎 PERLAS CLÍNICAS","guid":"HYVET-PERLAS","children":[{"id":"28","parent":"27","text":"1. Primer RCT que demuestra\\Nbeneficio tratar HTA en ≥80","guid":"HYVET-PE1","children":[]},{"id":"29","parent":"27","text":"2. Meta 150/80 es razonable\\Nen muy ancianos","guid":"HYVET-PE2","children":[]},{"id":"30","parent":"27","text":"3. ↓IC 64% inesperado","guid":"HYVET-PE3","children":[]},{"id":"31","parent":"27","text":"4. NO aplica a frágiles/dementes","guid":"HYVET-PE4","children":[]}]},{"id":"32","parent":"0","text":"📚 Referencias","guid":"HYVET-REF","children":[{"id":"33","parent":"32","text":"1. Beckett NS, et al. NEJM 2008\\N2. Peters R, Lancet Neurol 2008","guid":"HYVET-R1","children":[]}]}]},"node_count":33,"relations":[],"cross_references":[],"specialty":"General","folder":"Estudios Pivotales","filename":"HYVET-2026","id":"map_2482","resolved_references":[]}