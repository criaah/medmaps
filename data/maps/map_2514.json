sxn2MFgIg","children":[]},{"id":"277","parent":"275","text":"EEG ambulatorio si no realizado","guid":"SMmaoD0xSAugII2AB3QaTQ","children":[]},{"id":"278","parent":"275","text":"Evaluacion cognitiva post-SE","guid":"gNdADeW4S0iC1L8uGnRX6A","children":[]}]},{"id":"279","parent":"267","text":"Prevencion de recurrencia","guid":"WQSI89cOSmSRCVfQCUr9fA","children":[{"id":"280","parent":"279","text":"Adherencia farmacologica","guid":"1fAXPfDnRJuRIE2ALDuWzQ","children":[]},{"id":"281","parent":"279","text":"Evitar desencadenantes (privacion sueno, alcohol, farmacos proconvulsivantes)","guid":"M74pyrVKTiKQRWzHcyWF_w","children":[]},{"id":"282","parent":"279","text":"Educacion paciente y cuidador","guid":"YjLojIwxTt6Ln04n6AKMcw","children":[]}]},{"id":"283","parent":"267","text":"Control neurologico en 2-4 semanas","guid":"ioqQswlsTnqDd6GEXRCXLQ","children":[]},{"id":"284","parent":"267","text":"Rehabilitacion si deterioro funcional","guid":"ZByrKpynQkSdMfa3BjpPJw","children":[]}]},{"id":"285","parent":"0","text":"ALGORITMO RESUMEN","guid":"kCO0R2QBTdqsTI5WTUz1kA","children":[{"id":"286","parent":"285","text":"0-5 min → RECONOCER SE + monitorizar + ABC","guid":"iQ2WL__cQGCIcmre1Zp4uw","children":[{"id":"287","parent":"286","text":"Glicemia capilar → si hipoglicemia: dextrosa + tiamina","guid":"p5u-Qg1aQ329rri1i1Q9ww","children":[]},{"id":"288","parent":"286","text":"BZD: lorazepam 0.1 mg/kg IV o midazolam 10 mg IM","guid":"dRnO_hg7SLqMmVM30NsM0A","children":[]}]},{"id":"289","parent":"285","text":"5-20 min → ESTABLECIDO","guid":"D8SJ3JRkSy2CwNn2LwVelA","children":[{"id":"290","parent":"289","text":"Repetir BZD si no cede","guid":"EtnX6unfRPGAkg4Ky6jgtw","children":[]},{"id":"291","parent":"289","text":"Iniciar 2da linea: levetiracetam o fenitoina o valproato IV","guid":"EqL2cPBhSXG-eiQ9wKG0NQ","children":[]}]},{"id":"292","parent":"285","text":"20-40 min → REFRACTARIO","guid":"_0SvMKhtSc6XhsxtrQRg1g","children":[{"id":"293","parent":"292","text":"UCI, intubacion","guid":"rmKLtfiXRm6Uv6_5tr9wRw","children":[]},{"id":"294","parent":"292","text":"Midazolam o propofol en infusion","guid":"xlGOoS5KRzmC4AKQF3WKNQ","children":[]},{"id":"295","parent":"292","text":"EEG continuo","guid":"hoVXl-YiR2qTIGOJ8fJ5tQ","children":[]}]},{"id":"296","parent":"285","text":">24h → SUPER-REFRACTARIO","guid":"RrvR7Hr3TdmA_e0HJiyEfw","children":[{"id":"297","parent":"296","text":"Ketamina, rotacion de anestesicos","guid":"5eTS096jRlSv0ZPlU0yHgA","children":[]},{"id":"298","parent":"296","text":"Considerar inmunoglobulina/corticoides si autoinmune","guid":"3CiRWglaSbyetBhSnKLmdg","children":[]}]}]},{"id":"299","parent":"0","text":"LR DIAGNOSTICOS","guid":"u095VjSiREC3WxMWXH5mKw","children":[{"id":"300","parent":"299","text":"HALLAZGOS CLINICOS (cabecera)","guid":"Jtr9HtGiQVyZy5Saoz-StA","children":[{"id":"301","parent":"300","text":"Mordedura LATERAL de lengua post-evento -> LR+ 16.5 -> LR- 0.42 -> PMID:7487258","guid":"7MaYq18eQvecO1GTSQQo9Q","children":[]},{"id":"302","parent":"300","text":"Mordedura de punta de lengua -> LR+ ~1-2 (inespecifica) -> PMID:7487258","guid":"AQ-vdbl_RcKGjLecGyHyBQ","children":[]},{"id":"303","parent":"300","text":"Giro cefalico lateralizado durante episodio -> LR+ 13.5 -> LR- NR -> PMID:18505986","guid":"tZUMDEm0Sfylsc6FY__Icw","children":[]},{"id":"304","parent":"300","text":"Confusion postictal -> LR+ 3.0 -> LR- 0.36 -> PMID:1660208","guid":"bQsxA7YkRMKKOsYOVTPx6A","children":[]},{"id":"305","parent":"300","text":"Hiporreactividad durante ataque -> LR+ 3.1 -> LR- 0.17 -> PMID:12103268","guid":"twcxOrnKSFybnY9T-AW75Q","children":[]},{"id":"306","parent":"300","text":"Incontinencia urinaria -> LR+ ~1 (no discriminativa vs sincope) -> PMID:1660208","guid":"xteIT1_jQ9yeu6wAr8sqNQ","children":[]},{"id":"307","parent":"300","text":"Aura prodromica -> LR+ 3.6 -> LR- NR -> PMID:12103268","guid":"cM3Xal8VTAagTlncLEKa3Q","children":[]},{"id":"308","parent":"300","text":"Deja vu o jamais vu -> LR+ 5.2 -> LR- NR -> PMID:12103268","guid":"c53aRZBKTJm5T6ofs370Bg","children":[]},{"id":"309","parent":"300","text":"Automatismos (smacking, chewing) -> soporta crisis focal","guid":"0KRg44WaSpeo45AGSI4sLg","children":[]}]},{"id":"310","parent":"299","text":"DEFINICION OPERATIVA (ILAE 2015)","guid":"uTqFHkaHT1Ck2EThO8a8uQ","children":[{"id":"311","parent":"310","text":"Estatus convulsivo -> crisis >=5 min o 2 crisis sin recuperacion conciencia intermedia","guid":"yZTrbSWYSdOpHZmgJyfzjw","children":[]},{"id":"312","parent":"310","text":"Estatus refractario -> falla 2 antiepilepticos","guid":"5MisvUTHTBKuZtbjkdesQw","children":[]},{"id":"313","parent":"310","text":"Estatus super-refractario -> persiste >24h pese a tratamiento con anestesia","guid":"pXn-911HT-W0r2GzFyqkUw","children":[]}]},{"id":"314","parent":"299","text":"HALLAZGOS EEG","guid":"jmfo0VSKTa62WrtcqlYArw","children":[{"id":"315","parent":"314","text":"Actividad epileptiforme interictal en EEG -> LR+ ~4 -> LR- ~0.4 -> PMID:18025394","guid":"mUHi4wjKQKyYALJ4RrURzA","children":[]},{"id":"316","parent":"314","text":"Estatus no convulsivo (NCSE) -> requiere EEG para dx","guid":"eQLCqyMrTpy8IsREyOuSEA","children":[]},{"id":"317","parent":"314","text":"Patron punta-onda continuo / punta-onda evolutiva -> diagnostico NCSE","guid":"Savhab5wTaG7xe-yXV-DHA","children":[]}]},{"id":"318","parent":"299","text":"HALLAZGOS LABORATORIO","guid":"SU29vQt5ROG3M7LES2UsaQ","children":[{"id":"319","parent":"318","text":"Prolactina serica elevada <20 min post-evento -> LR+ ~5 (GTC) -> PMID:16157908","guid":"QpDxb_RoS6mGQmv8o_p8PA","children":[]},{"id":"320","parent":"318","text":"Prolactina NO util en crisis focal ni NCSE","guid":"HBDfah59R0W7wVlrQ_jaSw","children":[]},{"id":"321","parent":"318","text":"Lactato elevado post-GTC -> marcador actividad muscular, no dx","guid":"yIamVYVvTJi_bcTwYQ5upg","children":[]}]},{"id":"322","parent":"299","text":"INTERPRETACION","guid":"KsDXuv1-Teu0NTs12K2JQA","children":[{"id":"323","parent":"322","text":"LR+ >10 o LR- <0.1 -> cambio GRANDE (mordedura lateral, giro cefalico)","guid":"RVFDvbtERAWZSz-5ohJS7A","children":[]},{"id":"324","parent":"322","text":"LR+ 5-10 -> cambio MODERADO (aura, deja vu)","guid":"ck7gahIzSBKk67ixoXnrIQ","children":[]}]},{"id":"325","parent":"299","text":"GERIATRIA","guid":"jBsoG7VGTG6LQ7iLJhsK8w","children":[{"id":"326","parent":"325","text":"Status no convulsivo (NCSE) subdiagnosticado en AM con alteracion conciencia","guid":"j4pefB59SlGkwV3pchXnJQ","children":[]},{"id":"327","parent":"325","text":"Bajo umbral para EEG continuo en AM con delirium prolongado","guid":"1CUwdlH5TjSkelEI7XQxAw","children":[]},{"id":"328","parent":"325","text":"30 porciento de crisis nuevas en >60a son sintomaticas agudas (ACV, tumor, toxico-metabolicas)","guid":"M-G7lDt1S_u3X-xo9Ms0xA","children":[]}]}]},{"id":"329","parent":"0","text":"REFERENCIAS","guid":"qxqqHD6NTB2W2iQPgfljLw","children":[{"id":"330","parent":"329","text":"Vossler 2020 → AES review tratamiento SER (PMID:32822230, DOI:10.1177/1535759720928269)","guid":"HaDSU92OSMqRT_hRIL3Dsw","children":[]},{"id":"331","parent":"329","text":"Strzelczyk 2017 → lacosamida en SE revision sistematica (PMID:28295226, DOI:10.1111/epi.13716)","guid":"ZzE2Eye9TJ-G5i9_P59tWA","children":[]},{"id":"332","parent":"329","text":"Pinto 2022 → revision diagnostico y manejo SE (PMID:35976303, DOI:10.1590/0004-282X-ANP-2022-S113)","guid":"KW8zKMfwSZm3-BX3vOdV2A","children":[]},{"id":"333","parent":"329","text":"Crawshaw 2019 → manejo medico SE urgencia a UCI (PMID:31722820, DOI:10.1016/j.seizure.2019.10.006)","guid":"OmwG3WODRTe9aZA6_-YDmA","children":[]},{"id":"334","parent":"329","text":"Mahmoud 2019 → manejo critico SE terciario (PMID:31554529, DOI:10.1017/cjn.2019.278)","guid":"zasSubCfQN2_aNROXwAgyw","children":[]},{"id":"335","parent":"329","text":"Kishima 2023 → SE convulsivo y no convulsivo (PMID:36682750, DOI:10.11477/mf.1436204716)","guid":"LWXzbh9VQs-SFk8UnFvwGQ","children":[]},{"id":"336","parent":"329","text":"ILAE 2015 → definicion y clasificacion SE","guid":"QP1WzDj0TauWovebmFTXwg","children":[]},{"id":"337","parent":"329","text":"AES 2016 → guia tratamiento SE","guid":"2idFstpNTU6Sya-u-tNlBg","children":[]},{"id":"338","parent":"329","text":"Kapur 2019 (ESETT) → levetiracetam vs fenitoina vs valproato en SE establecido","guid":"TeWbqk9qQA2Z7HCo2KC9EQ","children":[]}]}]},"node_count":338,"relations":[],"cross_references":[],"specialty":"General","folder":"MUE - Medicina de Urgencia","filename":"MUE_Status_Epileptico","id":"map_2514","resolved_references":[]}