, HTA, hiperglicemia","guid":"33hxJjRHTHmF-XN3dUA9aQ","children":[]},{"id":"70","parent":"68","text":"Acidosis lactica","guid":"XJbxQiG5S4irwZGqdINZ5w","children":[]},{"id":"71","parent":"68","text":"Rabdomiolisis","guid":"kqHTw79dTvCMfJpu7rmHxg","children":[]}]},{"id":"72","parent":"67","text":"FASE DESCOMPENSADA (>30 min)","guid":"0AyuH9e3Q82DzYM4DnonCA","children":[{"id":"73","parent":"72","text":"Hipotension, arritmias","guid":"xF9nMmozSmSUw5JKZP_CJg","children":[]},{"id":"74","parent":"72","text":"Hipoglicemia","guid":"K8-sLcmuRpCilRUuoonNEw","children":[]},{"id":"75","parent":"72","text":"Hipertermia","guid":"rTY06hoHRG2qm4mN9aszGw","children":[]},{"id":"76","parent":"72","text":"Edema cerebral","guid":"JYMAvnhrR4u4v8kqq0zk8g","children":[]},{"id":"77","parent":"72","text":"CID","guid":"EsU4QNtQRFyRQTEUY39GfQ","children":[]},{"id":"78","parent":"72","text":"Falla multiorganica","guid":"632Y5yKuTfKAoQcq1E3r8w","children":[]}]}]}]},{"id":"79","parent":"0","text":"PRESENTACION CLINICA EN ADULTO MAYOR","guid":"1JfuxTITQnGXqzHz8I9NIg","children":[{"id":"80","parent":"79","text":"SE CONVULSIVO","guid":"QVjQNjlwQwunifbRBScsjg","children":[{"id":"81","parent":"80","text":"Actividad tonico-clonica generalizada obvia","guid":"LUwZrai6RQuClbI6GAQwRw","children":[]},{"id":"82","parent":"80","text":"Puede ser sutil si prolongado → movimientos minimos","guid":"Ha6KmwmFT3-c3fKypQUJfQ","children":[]},{"id":"83","parent":"80","text":"PERLA → SE sutil = solo sacudidas faciales/oculares","guid":"LnDHp_HWRbehFId7iY1d0g","children":[]}]},{"id":"84","parent":"79","text":"SE NO CONVULSIVO → GRAN DESAFIO EN AM","guid":"lhrClZMqS-iKYCSCt35wCg","children":[{"id":"85","parent":"84","text":"Confusion o estupor sin causa clara","guid":"Xdak-H_WToyW3iSaHdba6A","children":[]},{"id":"86","parent":"84","text":"Cambio de conducta agudo","guid":"Fw1nycCLRkGcT4of17eArA","children":[]},{"id":"87","parent":"84","text":"Afasia/mutismo subito","guid":"IKR-rpCHTG2wWs30mnAyGA","children":[]},{"id":"88