":"","children":[]},{"id":"63","parent":"57","text":"Cambios en senal nativa: IAM / farmacos / alt. metabolicas / ectopicos","guid":"","children":[]},{"id":"64","parent":"57","text":"Problemas tecnicos:","guid":"","children":[{"id":"65","parent":"64","text":"Maduracion electrodo","guid":"","children":[]},{"id":"66","parent":"64","text":"Fallo electrodo (principalmente aislamiento)","guid":"","children":[]},{"id":"67","parent":"64","text":"Fallo generador de pulsos → requiere recambio","guid":"","children":[]}]}]}]},{"id":"68","parent":"0","text":"INTERFERENCIAS ELECTROMAGNETICAS (EMI)","guid":"","children":[{"id":"69","parent":"68","text":"Efectos posibles:","guid":"","children":[{"id":"70","parent":"69","text":"Marcapasos asincronico","guid":"","children":[]},{"id":"71","parent":"69","text":"INHIBICION estimulacion → riesgo en dependientes","guid":"","children":[]},{"id":"72","parent":"69","text":"Seguimiento ventricular rapido inapropiado","guid":"","children":[]}]},{"id":"73","parent":"68","text":"FUENTES EN AMBIENTE MEDICO","guid":"","children":[{"id":"74","parent":"73","text":"Electrocauterio → preferir bipolar / evitar campo cercano","guid":"","children":[]},{"id":"75","parent":"73","text":"Cardioversion/desfibrilacion","guid":"","children":[]},{"id":"76","parent":"73","text":"Resonancia magnetica (RM)","guid":"","children":[]},{"id":"77","parent":"73","text":"Tomografia computada (TC)","guid":"","children":[]},{"id":"78","parent":"73","text":"Radioterapia","guid":"","children":[]},{"id":"79","parent":"73","text":"Litotricia","guid":"","children":[]}]},{"id":"80","parent":"68","text":"RADIOTERAPIA","guid":"","children":[{"id":"81","parent":"80","text":"Efectos: reset electrico / reprogramacion erratica / dano permanente","guid":"","children":[]},{"id":"82","parent":"80","text":"No-salida subita o marcapasos desbocado","guid":"","children":[]},{"id":"83","parent":"80","text":"Manejo: evitar radiacion directa / evaluacion previa experto / registrar dosis dispersa","guid":"","children":[]}]},{"id":"84","parent":"68","text":"CARDIOVERSION / DESFIBRILACION","guid":"","children":[{"id":"85","parent":"84","text":"Mecanismo dano: pico voltaje → ↑ umbral captura/sensado / quemadura endocardica","guid":"","children":[]},{"id":"86","parent":"84","text":"Prevencion:","guid":"","children":[{"id":"87","parent":"86","text":"Palas lejos del generador (distancia minima 8 cm)","guid":"","children":[]},{"id":"88","parent":"86","text":"Corriente perpendicular al sistema","guid":"","children":[]},{"id":"89","parent":"86","text":"Posicion antero-posterior preferida","guid":"","children":[]}]}]},{"id":"90","parent":"68","text":"ELECTROCAUTERIO","guid":"","children":[{"id":"91","parent":"90","text":"Preferir bipolar siempre","guid":"","children":[]},{"id":"92","parent":"90","text":"Evitar campo cerca del sistema marcapasos","guid":"","children":[]},{"id":"93","parent":"90","text":"Efecto habitualmente temporal → retorno funcion post-procedimiento","guid":"","children":[]}]},{"id":"94","parent":"68","text":"RESONANCIA MAGNETICA","guid":"","children":[{"id":"95","parent":"94","text":"Riesgos: cambio programacion / estimulacion asincronica / calentamiento cables","guid":"","children":[]},{"id":"96","parent":"94","text":"Manejo: reprogramacion pre y post-procedimiento","guid":"","children":[]}]},{"id":"97","parent":"68","text":"LITOTRICIA","guid":"","children":[{"id":"98","parent":"97","text":"Evitar si cristal piezoelectrico","guid":"","children":[]},{"id":"99","parent":"97","text":"Modo VOO/DOO si paciente dependiente","guid":"","children":[]},{"id":"100","parent":"97","text":"DAI: desactivar terapias antitaquicardia previamente","guid":"","children":[]}]}]},{"id":"101","parent":"0","text":"AUSENCIA DE ESTIMULOS (no-salida)","guid":"","children":[{"id":"102","parent":"101","text":"DIAGNOSTICO DIFERENCIAL","guid":"","children":[{"id":"103","parent":"102","text":"Sobresensado de senales inapropidas","guid":"","children":[]},{"id":"104","parent":"102","text":"Circuito abierto","guid":"","children":[]},{"id":"105","parent":"102","text":"Fallo de componente del generador","guid":"","children":[]},{"id":"106","parent":"102","text":"Histeresis (programada → NO es fallo)","guid":"","children":[]},{"id":"107","parent":"102","text":"Algoritmos de evitacion de estimulacion","guid":"","children":[]}]},{"id":"108","parent":"101","text":"APLICACION IMAN (diagnostico)","guid":"","children":[{"id":"109","parent":"108","text":"Retorno estimulacion con iman → probable SOBRESENSADO","guid":"","children":[]},{"id":"110","parent":"108","text":"Persistencia pausas con iman → fallo componente / circuito abierto","guid":"","children":[]}]},{"id":"111","parent":"101","text":"SOBRESENSADO","guid":"","children":[{"id":"112","parent":"111","text":"Mas frecuente en configuracion UNIPOLAR","guid":"","children":[]},{"id":"113","parent":"111","text":"Bipolares → mejor ratio senal/ruido → mayor sensibilidad posible","guid":"","children":[]},{"id":"114","parent":"111","text":"Manejo: ↓ sensibilidad (riesgo: infrasensado si senal nativa pequeña)","guid":"","children":[]},{"id":"115","parent":"111","text":"Alternativa: modo estimulacion gatillada","guid":"","children":[]}]},{"id":"116","parent":"101","text":"PROBLEMAS DE CIRCUITO","guid":"","children":[{"id":"117","parent":"116","text":"Cortocircuito: rotura aislamiento → ruido → inhibicion salida (no visible en Rx)","guid":"","children":[]},{"id":"118","parent":"116","text":"Circuito abierto: fractura conductor / tornillo mal ajustado / clavija mal insertada","guid":"","children":[]}]},{"id":"119","parent":"101","text":"IMPEDANCIA CABLES","guid":"","children":[{"id":"120","parent":"119","text":"Circuito abierto: impedancia MUY ALTA","guid":"","children":[]},{"id":"121","parent":"119","text":"Defecto aislamiento: impedancia MUY BAJA","guid":"","children":[]}]},{"id":"122","parent":"101","text":"HISTERESIS","guid":"","children":[{"id":"123","parent":"122","text":"Intervalo escape > intervalo basico (no patologico)","guid":"","children":[]},{"id":"124","parent":"122","text":"Formato: ratio (ej 70/50)","guid":"","children":[]},{"id":"125","parent":"122","text":"Programable → no refleja disfuncion","guid":"","children":[]}]}]},{"id":"126","parent":"0","text":"ARTEFACTOS DE REGISTRO","guid":"","children":[{"id":"127","parent":"126","text":"Sistemas ECG digitales → digitalizacion puede perder pulso (duracion 0.4-0.6 ms)","guid":"","children":[]},{"id":"128","parent":"126","text":"Frecuencia muestreo insuficiente → perdida pulso / deflexion variable / polaridad opuesta","guid":"","children":[]},{"id":"129","parent":"126","text":"Dificultad diagnostica: unipolar vs bipolar no distinguible en digital","guid":"","children":[]}]},{"id":"130","parent":"0","text":"EXTRACCION DE ELECTRODOS","guid":"","children":[{"id":"131","parent":"130","text":"Indicaciones principales: INFECCION / fallo mecanico del electrodo","guid":"","children":[]},{"id":"132","parent":"130","text":"Requiere personal entrenado en tecnicas especializadas","guid":"","children":[]},{"id":"133","parent":"130","text":"Tecnicas: laser / electrocauterio de radiofrecuencia","guid":"","children":[]},{"id":"134","parent":"130","text":"Discusion obligatoria de complicaciones con paciente","guid":"","children":[]}]},{"id":"135","parent":"0","text":"Perlas Clinicas","guid":"","children":[{"id":"136","parent":"135","text":"EDAD BIOLOGICA priorizar sobre cronologica al indicar marcapasos → fragilidad modifica riesgo","guid":"","children":[]},{"id":"137","parent":"135","text":"Impedancia guia diagnostico: baja=aislamiento / alta=fractura → orienta antes de Rx","guid":"","children":[]},{"id":"138","parent":"135","text":"Iman al lecho → maniobra diagnostica rapida en bradicardia extrema con marcapasos","guid":"","children":[]},{"id":"139","parent":"135","text":"Cardio/desfibrilacion: distancia minima 8 cm del generador → prevencion dano","guid":"","children":[]},{"id":"140","parent":"135","text":"Electrocauterio: SIEMPRE bipolar en portador de marcapasos, efecto habitualmente reversible","guid":"","children":[]},{"id":"141","parent":"135","text":"Radioterapia requiere protocolo especifico → no es solo 'evitar campo'","guid":"","children":[]},{"id":"142","parent":"135","text":"Histeresis → NO confundir con fallo: intervalo escape largo es intencionado","guid":"","children":[]},{"id":"143","parent":"135","text":"Dependencia de marcapasos: evaluar ANTES de cualquier procedimiento con EMI","guid":"","children":[]},{"id":"144","parent":"135","text":"SOBRESENSADO diagnostico diferencial SIEMPRE ante pausas inesperadas → aplicar iman antes de quirofano","guid":"","children":[]},{"id":"145","parent":"135","text":"Agotamiento bateria: identificar RRT/ERI precozmente → cambio electivo 3 meses ANTES de agotamiento total","guid":"","children":[]}]},{"id":"146","parent":"0","text":"VER TAMBIEN","guid":"","children":[{"id":"147","parent":"146","text":"→ Fibrilacion Auricular en el Mayor (Patologias)","guid":"","children":[]},{"id":"148","parent":"146","text":"→ Toma de Decisiones en Cardiogeriatria (Etica)","guid":"","children":[]},{"id":"149","parent":"146","text":"→ Cardiopatia Isquemica y Coronaria (Patologias)","guid":"","children":[]}]},{"id":"150","parent":"0","text":"Referencias","guid":"","children":[{"id":"151","parent":"150","text":"1. Kusumoto FM et al. 2018 ACC/AHA/HRS Guideline on the Evaluation and Management of Patients With Bradycardia and Cardiac Conduction Delay. J Am Coll Cardiol. 2019;74(7):e51-e156.","guid":"","children":[]},{"id":"152","parent":"150","text":"2. UpToDate. Evaluation and management of pacemaker system problems. 2024. Wolters Kluwer.","guid":"","children":[]},{"id":"153","parent":"150","text":"3. Barold SS, Stroobandt RX, Sinnaeve AF. Cardiac Pacemakers and Resynchronization Step-by-Step. 2nd ed. Wiley-Blackwell; 2010.","guid":"","children":[]}]}]},"node_count":153,"relations":[],"cross_references":[],"specialty":"Cardiología","folder":"Entidades clínicas/Cardiología","filename":"Marcapasos ProblemasComunes iPad","id":"map_309","resolved_references":[],"title_raw":"Marcapasos ProblemasComunes iPad"}