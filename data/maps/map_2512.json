{"title":"MUE_SCA","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/MUE - Medicina de Urgencia/MUE_SCA.smmx","root":{"id":"0","parent":"-1","text":"SÍNDROME CORONARIO AGUDO EN URGENCIAS","guid":"BmZcPpKiRiq84sg_5breHA","children":[{"id":"1","parent":"0","text":"DEFINICIONES Y CLASIFICACIÓN","guid":"sb8hN2v_SqaiPmP9giO7jA","children":[{"id":"2","parent":"1","text":"SCA con elevación ST (SCACEST/STEMI)","guid":"gm90pGfaRguX8l6Sox0Ibw","children":[{"id":"3","parent":"2","text":"→ Oclusión coronaria total","guid":"XOSe42kkRSSKenWdDWtGUA","children":[]},{"id":"4","parent":"2","text":"→ Elevación ST ≥1 mm en 2 derivaciones contiguas","guid":"JsE--oqBS-Wh6o9UlLW29A","children":[]},{"id":"5","parent":"2","text":"→ O ≥2 mm en V1-V3","guid":"4XyChnKWTg6SlD-1VWlu7A","children":[]},{"id":"6","parent":"2","text":"→ O BCRI nuevo con clínica sugerente","guid":"po6vPMTLRd-HBhiG_EtLNg","children":[]},{"id":"7","parent":"2","text":"→ Equivalentes: infradesnivel recíproco, de Winter","guid":"xL3ZZ4HJTVm3WOhU4rKU9Q","children":[]}]},{"id":"8","parent":"1","text":"SCA sin elevación ST (SCASEST/NSTEMI)","guid":"tZUSPLeGR8mGwDTMgti5YA","children":[{"id":"9","parent":"8","text":"→ Troponina elevada + clínica isquémica","guid":"x6adW-OjTwivMXZDV_zxRA","children":[]},{"id":"10","parent":"8","text":"→ Sin elevación persistente del ST","guid":"Pjg2I7OZTCGpyOgivP665g","children":[]},{"id":"11","parent":"8","text":"→ Puede tener: infradesnivel ST, inversión T, ECG normal","guid":"kFK6NX5aTYez79bY4Hksbw","children":[]}]},{"id":"12","parent":"1","text":"Angina inestable","guid":"IRfq9uNiQdKCJD3UCwfncg","children":[{"id":"13","parent":"12","text":"→ Clínica isquémica SIN elevación troponina","guid":"u15xsfUPRKe5ba7QwzNAIg","children":[]},{"id":"14","parent":"12","text":"→ Con troponina ultrasensible → reclasificación frecuente a NSTEMI","guid":"I8MRnBkSRuSqqBoxzU5MAg","children":[]}]},{"id":"15","parent":"1","text":"PERLA: Con troponinas ultrasensibles, la angina inestable es cada vez menos frecuente","guid":"tuMbbYLkRly8SARrmrtKjQ","children":[]}]},{"id":"16","parent":"0","text":"EPIDEMIOLOGÍA","guid":"12hhaiwmSNKR7ZuU1nmyig","children":[{"id":"17","parent":"16","text":"1ª causa de muerte mundial","guid":"NIlGCy3eSk2lIijohN_-Gw","children":[]},{"id":"18","parent":"16","text":"Incidencia → ↑ con edad, especialmente >65 años","guid":"vnn2ITLWT769U9abi7Wn8A","children":[]},{"id":"19","parent":"16","text":"EN ADULTO MAYOR","guid":"9XpVLHQRRuK8gYL7ZlZTQg","children":[{"id":"20","parent":"19","text":"→ >50% de STEMI ocurre en >65 años","guid":"gisbbW0oT8KmlAf7pOKhug","children":[]},{"id":"21","parent":"19","text":"→ Mortalidad hospitalaria STEMI: 3-5% general vs 15-25% en >80 años","guid":"jhYzOEkrT-mIaWbvUFaSnA","children":[]},{"id":"22","parent":"19","text":"→ Presentación atípica en 40-60% de >75 años","guid":"qQqxfg2vT6ygRqhX4hCeDA","children":[]},{"id":"23","parent":"19","text":"→ Subdiagnóstico y subtratamiento frecuente","guid":"Z9sYC_JiTc2TN3X_ltE1KA","children":[]}]}]},{"id":"24","parent":"0","text":"PRESENTACIÓN CLÍNICA","guid":"VGc9sG9VT2qB2OK2gkcFJg","children":[{"id":"25","parent":"24","text":"Presentación típica","guid":"q1dGOPafT5mWx7Kv83jq_g","children":[{"id":"26","parent":"25","text":"→ Dolor torácico opresivo retroesternal","guid":"tl0sKHKYTVG-MdMAXARAXQ","children":[]},{"id":"27","parent":"25","text":"→ Irradiación a brazo izquierdo, mandíbula, epigastrio","guid":"PYDGHIYcTNO0_gWwQUyQ8g","children":[]},{"id":"28","parent":"25","text":"→ >20 minutos de duración","guid":"hZ-Vqz9oSt695gMQR4U8GQ","children":[]},{"id":"29","parent":"25","text":"→ Asociado: diaforesis, náuseas, disnea","guid":"tVkMzi60Rs6-Dlr1_czjjQ","children":[]},{"id":"30","parent":"25","text":"→ Sin alivio con reposo o NTG sublingual (en STEMI)","guid":"j6VK3nm5SRWc0tdwZEuCIA","children":[]}]},{"id":"31","parent":"24","text":"PRESENTACIÓN ATÍPICA EN ADULTO MAYOR (CRÍTICO)","guid":"U6Duya9UQ-eLOBvZ_3nmNQ","children":[{"id":"32","parent":"31","text":"→ Disnea como síntoma principal (50% en >80 años)","guid":"lO7n35XgQ1iFQ7eQk68jcQ","children":[]},{"id":"33","parent":"31","text":"→ Síncope o presíncope","guid":"KlC5cZXhSbqW8Fa22K-htw","children":[]},{"id":"34","parent":"31","text":"→ Delirium o confusión aguda","guid":"l8xR0ftTTiSe-PPLNH8hKQ","children":[]},{"id":"35","parent":"31","text":"→ Debilidad generalizada / deterioro funcional agudo","guid":"e8w2kpNgRQaXIlpUDTTsnA","children":[]},{"id":"36","parent":"31","text":"→ Dolor epigástrico aislado","guid":"IVAEIlUYQ_265CpLJp76MQ","children":[]},{"id":"37","parent":"31","text":"→ Ausencia de dolor torácico en 30-40% de >75 años","guid":"B4OYVPLIR2Oh5bu7eI7wDg","children":[]},{"id":"38","parent":"31","text":"→ EPA como debut de STEMI","guid":"F3BMC-PvSeCbl8e2DbHSQg","children":[]},{"id":"39","parent":"31","text":"→ PERLA: \"SCA silente\" es más frecuente en diabéticos y adultos mayores","guid":"pvST96rOSaeHSG4Jj8Iskw","children":[]}]},{"id":"40","parent":"24","text":"Diagnóstico diferencial","guid":"Hlge6WZXT6yrlS8wXC7Zpw","children":[{"id":"41","parent":"40","text":"→ TEP","guid":"NvPljJ72QxWSb4JX_aKaYQ","children":[]},{"id":"42","parent":"40","text":"→ Disección aórtica","guid":"ZWmWVS8tSfWUMSygq_jnyg","children":[]},{"id":"43","parent":"40","text":"→ Pericarditis/Taponamiento","guid":"-FFRei9xTae7pn_Wq3LgKA","children":[]},{"id":"44","parent":"40","text":"→ Neumotórax a tensión","guid":"7rgFpMwCTiSG_flKZC_9KA","children":[]},{"id":"45","parent":"40","text":"→ Espasmo esofágico","guid":"4KHNGDDtSZmL2e4w-VCLKA","children":[]},{"id":"46","parent":"40","text":"→ Síndrome Takotsubo (más frecuente en mujeres AM postmenopáusicas)","guid":"IoaXhk6ETU-daViUlMfThA","children":[]}]}]},{"id":"47","parent":"0","text":"EVALUACIÓN INICIAL EN URGENCIAS (<10 MIN)","guid":"soE9_c8iQ5O7yOer7QUSPQ","children":[{"id":"48","parent":"47","text":"ECG 12 derivaciones en <10 minutos (MANDATORIO)","guid":"QFhF4tyUR7m2NZZFfUuFvQ","children":[{"id":"49","parent":"48","text":"→ V3R-V4R si infarto inferior (descartar VD)","guid":"2ACYIW81RVqbiHFxENTosQ","children":[]},{"id":"50","parent":"48","text":"→ V7-V9 si sospecha posterior","guid":"FqJnYCSUR0CFOml_3YtyFA","children":[]},{"id":"51","parent":"48","text":"→ Repetir a los 15-30 min si primer ECG no concluyente","guid":"uqLLliymS52qlHi9oMid6A","children":[]}]},{"id":"52","parent":"47","text":"Troponina ultrasensible (hs-cTn)","guid":"5ibFoK_IRaazT4SU_xnWFA","children":[{"id":"53","parent":"52","text":"→ Algoritmo 0h/1h (ESC preferido) o 0h/3h","guid":"NQ176a2WTAiLzWa5V_q8Mw","children":[]},{"id":"54","parent":"52","text":"→ Valor T=0: rule-out si <5 ng/L (hs-cTnT) o <4 ng/L (hs-cTnI)","guid":"jE81twHSSzSBziimmOW96w","children":[]},{"id":"55","parent":"52","text":"→ Rule-in si >52 ng/L (hs-cTnT) o >64 ng/L (hs-cTnI) a T=0","guid":"zhJ4XGx4S8iKsQakM_PVOg","children":[]},{"id":"56","parent":"52","text":"→ Delta a 1h: >5 ng/L (hs-cTnT) = rule-in","guid":"Lr-XE04ORduC1QVDbvaqhQ","children":[]},{"id":"57","parent":"52","text":"EN ADULTO MAYOR","guid":"YvMCNHuSRk6qEWwbwjSxAg","children":[{"id":"58","parent":"57","text":"→ Troponina basal elevada frecuente (IC, ERC, FA)","guid":"ciG_jZMPRkGkfjdRWcF94A","children":[]},{"id":"59","parent":"57","text":"→ DELTA >20% sobre basal es más útil que valor absoluto","guid":"_O7ODoyqTtukQd_vSNqVQA","children":[]},{"id":"60","parent":"57","text":"→ Combinar con clínica + ECG para decisión","guid":"Ws_B-Oh2RQ2CcSYTS_dZoQ","children":[]}]}]},{"id":"61","parent":"47","text":"Laboratorio complementario","guid":"UMCD3CncQ26rmCjZzxNtFg","children":[{"id":"62","parent":"61","text":"→ Hemograma, función renal, electrolitos","guid":"GQIYllXhRvCWGXLI62KreQ","children":[]},{"id":"63","parent":"61","text":"→ Glicemia","guid":"kkSLGdD-RW6k7Hyx34ulZg","children":[]},{"id":"64","parent":"61","text":"→ Coagulación (INR, TTPa) — pre-anticoagulación","guid":"-9K6tv6HQ1W5-CIAKbBRgw","children":[]},{"id":"65","parent":"61","text":"→ BNP/NT-proBNP (pronóstico, sospecha IC)","guid":"7OFvXK0pRbqlno9GsrxFEA","children":[]}]},{"id":"66","parent":"47","text":"Rx tórax portátil","guid":"_UYfeldDQ0aetcaLAW42EA","children":[{"id":"67","parent":"66","text":"→ Descartar EPA, mediastino ensanchado (disección), neumotórax","guid":"4kiW6AeJTmyjhzw7ccU6CA","children":[]}]},{"id":"68","parent":"47","text":"Estratificación de riesgo","guid":"LRNIGZ8vTZiokXB0PUB6ww","children":[{"id":"69","parent":"68","text":"→ GRACE score (mortalidad intrahospitalaria y a 6 meses)","guid":"6HM6Tt-DTiulFn7bH-VDEw","children":[]},{"id":"70","parent":"68","text":"→ Variables: edad, FC, PAS, creatinina, Killip, troponina, ST, PCR","guid":"RdeQtvK1Rx6WLrXd4WvG7Q","children":[]},{"id":"71","parent":"68","text":"→ Alto riesgo: GRACE >140","guid":"BLLcOds-RwSuC7efVbz7kQ","children":[]},{"id":"72","parent":"68","text":"→ EN AM: GRACE sobreestima riesgo de sangrado → complementar con CRUSADE","guid":"6fjYWrZUTJyOrThOzR_xCA","children":[]}]}]},{"id":"73","parent":"0","text":"MANEJO INMEDIATO EN URGENCIAS","guid":"U67PPYQgRsCIbwaHNhTMuA","children":[{"id":"74","parent":"73","text":"SCACEST / STEMI — REPERFUSIÓN","guid":"H7icZ9dATzepmkbgc-8RdQ","children":[{"id":"75","parent":"74","text":"→ Meta: contacto médico → balón <90 min (ICP primaria)","guid":"HG1Fx87fQUuNWsd07Qd6Hg","children":[]},{"id":"76","parent":"74","text":"→ O <120 min si requiere traslado a centro con hemodinamia","guid":"dzyVtWpxQHi4WvmJLzSKxw","children":[]},{"id":"77","parent":"74","text":"→ Si ICP no disponible en <120 min → fibrinolisis (<12h desde inicio)","guid":"yXdxx0GkS--dNRhPf51TWA","children":[]},{"id":"78","parent":"74","text":"Fibrinolisis","guid":"-O3OseWsQqa0I6dEjp1www","children":[{"id":"79","parent":"78","text":"→ Tenecteplase (TNK) = más usado","guid":"HEWHFQjDQiul3qMpspFfeA","children":[]},{"id":"80","parent":"78","text":"→ EN ADULTO MAYOR >75 años: MEDIA DOSIS TNK","guid":"5cxij1JqR7aSHuEr7beOqw","children":[]},{"id":"81","parent":"78","text":"→ Contraindicaciones absolutas: ACV hemorrágico previo, neoplasia SNC, sangrado activo","guid":"XXaLK7ZpT5iVa3-AtI5aCA","children":[]},{"id":"82","parent":"78","text":"→ Relativas en AM: HTA severa no controlada, cirugía <3 semanas, anticoagulación","guid":"HN-FOp63Qtqr4ZvWmWujeg","children":[]}]},{"id":"83","parent":"74","text":"ICP primaria (preferida en AM)","guid":"20jy5ZjpTgiWAXLkQFvtSg","children":[{"id":"84","parent":"83","text":"→ Acceso radial preferido (menor sangrado)","guid":"s7Wn0qewTDKJ4kPgncKEhw","children":[]},{"id":"85","parent":"83","text":"→ Stent farmacológico (DES) si anatomía favorable","guid":"1xAdTSPUTbqt8Fi6Ix7Z7w","children":[]},{"id":"86","parent":"83","text":"→ Considerar: función renal (nefroprotección pre-contraste)","guid":"9jZqzHloR_KRPrwRICQeRg","children":[]},{"id":"87","parent":"83","text":"→ PERLA: Edad NO es contraindicación para ICP","guid":"LRG4vEFKSW2f8FFwwYbEyw","children":[]}]}]},{"id":"88","parent":"73","text":"SCASEST / NSTEMI — ESTRATEGIA INVASIVA","guid":"m1urAcwYQgu_Ix8QNcS4cQ","children":[{"id":"89","parent":"88","text":"→ Urgente (<2h): inestabilidad hemodinámica, arritmias, IC aguda","guid":"NVFbLsUxQ4OM_qgkfZJ8UQ","children":[]},{"id":"90","parent":"88","text":"→ Precoz (<24h): GRACE >140, cambios dinámicos ST/T, diabetes","guid":"MOyP7F2wRoyip6RP90Vgpg","children":[]},{"id":"91","parent":"88","text":"→ Electiva (<72h): GRACE 109-140, síntomas recurrentes","guid":"um5MTeapSL68YRIUWW0Dmw","children":[]},{"id":"92","parent":"88","text":"→ Conservadora: GRACE <109, troponina normal, sin cambios ECG","guid":"p2Jb7htIQYSIsDzGnS-vqg","children":[]},{"id":"93","parent":"88","text":"EN ADULTO MAYOR","guid":"xTtl213DSm6CRBoBctQd-Q","children":[{"id":"94","parent":"93","text":"→ Evaluar fragilidad (CFS) antes de decidir estrategia invasiva","guid":"n49xbQ76RaCeY8yOAiN5JA","children":[]},{"id":"95","parent":"93","text":"→ CFS ≥7 → estrategia conservadora probablemente preferible","guid":"TugPVeKsSvife4dTlKYPSQ","children":[]},{"id":"96","parent":"93","text":"→ Riesgo hemorrágico elevado → ajustar antitrombóticos","guid":"dRcP0O8nSISmrJRXL_BWTg","children":[]}]}]},{"id":"97","parent":"73","text":"Terapia farmacológica inicial","guid":"Trp9AMIqSMiXi1cnEEiPRA","children":[{"id":"98","parent":"97","text":"MONA modificado","guid":"EaGGEt3HT3aejjLh55_opA","children":[{"id":"99","parent":"98","text":"→ Morfina: 2-4 mg IV solo si dolor refractario (evitar en STEMI → hipotensión)","guid":"2Rx7PflURDGgAp3Uie0Nbw","children":[]},{"id":"100","parent":"98","text":"→ Oxígeno: SOLO si SpO2 <90% (no rutinario — DETO2X-AMI)","guid":"WHaPqDMaSSe009XmAJLl-w","children":[]},{"id":"101","parent":"98","text":"→ Nitroglicerina: SL 0.4 mg c/5 min x3, luego IV si persiste. CI: PAS <90, VD, PDE5i","guid":"iyg_OBX2To6qDSFxutPwWw","children":[]},{"id":"102","parent":"98","text":"→ AAS: 300 mg masticado STAT (162-325 mg)","guid":"JFILi4V7RxykUKio4-DjUQ","children":[]}]},{"id":"103","parent":"97","text":"Antiagregación dual","guid":"C3hQI328QU61L5VAj6UJ5g","children":[{"id":"104","parent":"103","text":"→ AAS + inhibidor P2Y12","guid":"EaZw9XYxT3yw6rb0AF4zqA","children":[]},{"id":"105","parent":"103","text":"→ Clopidogrel 300-600 mg carga (75 mg/día mantención)","guid":"so2yqm2aRmWyeSbGCv0XWw","children":[]},{"id":"106","parent":"103","text":"→ Ticagrelor 180 mg carga (90 mg c/12h) — preferido si no CI sangrado","guid":"Uqvub0AAR8-I_ZE3u7xPvA","children":[]},{"id":"107","parent":"103","text":"→ EN ADULTO MAYOR: Clopidogrel preferido sobre Ticagrelor (menor sangrado)","guid":"5eEGQ_FhSredaK9OzEDlYg","children":[]},{"id":"108","parent":"103","text":"→ PERLA: POPular-AGE trial → Clopidogrel = menos sangrado sin ↑ eventos en >70 años","guid":"9Ui3nAlHQcSRuKf0r_mlZw","children":[]}]},{"id":"109","parent":"97","text":"Anticoagulación","guid":"V-ueMS0BR2-Oc9qZhAmlkg","children":[{"id":"110","parent":"109","text":"→ Enoxaparina 1 mg/kg SC c/12h (0.75 mg/kg si >75 años)","guid":"qBboKJvpSOakU-BTUvQk7Q","children":[]},{"id":"111","parent":"109","text":"→ O HNF 60 UI/kg bolo + 12 UI/kg/h (máx 4000 UI bolo, 1000 UI/h)","guid":"ilXfUM5nQaO82HwMC6SE4w","children":[]},{"id":"112","parent":"109","text":"→ Fondaparinux 2.5 mg SC/día (SCASEST, menor sangrado)","guid":"nnTq-S_cRBC7pcw1gTypTw","children":[]},{"id":"113","parent":"109","text":"→ EN AM: AJUSTAR POR FUNCIÓN RENAL. Si ClCr <30 → HNF preferida","guid":"3mB6BBTfTPaH3f6loMLDmg","children":[]}]},{"id":"114","parent":"97","text":"Betabloqueadores","guid":"59ennGzFQ-iSpLoKgQ3aow","children":[{"id":"115","parent":"114","text":"→ Metoprolol 25-50 mg VO si FC >70, sin IC descompensada","guid":"5Qr0TUmGR1W1LkCgwJfsfw","children":[]},{"id":"116","parent":"114","text":"→ NO IV en primeras 24h (COMMIT trial)","guid":"uJ2OEEp3T6SCXMzA_cHAaA","children":[]},{"id":"117","parent":"114","text":"→ CI: Killip ≥3, bradicardia, BAV, asma severo","guid":"ynerTKiRSV6GKwdw-BCb0Q","children":[]}]},{"id":"118","parent":"97","text":"Estatinas","guid":"AfEGMj5rQeGBjb1JbR3g_Q","children":[{"id":"119","parent":"118","text":"→ Atorvastatina 80 mg desde ingreso (alta intensidad)","guid":"hQVaKOdNRFW6hlfcR__KjA","children":[]},{"id":"120","parent":"118","text":"→ EN AM: considerar 40 mg si riesgo miopatía","guid":"YMTMkGZ6SouPnNroWefDOA","children":[]}]}]}]},{"id":"121","parent":"0","text":"COMPLICACIONES AGUDAS","guid":"07kp0vSMQBKzezctiyipkw","children":[{"id":"122","parent":"121","text":"Arritmias","guid":"LfO2syNCRRmNoqc3vyaaIg","children":[{"id":"123","parent":"122","text":"→ FV/TV → desfibrilación, amiodarona","guid":"FPNXr7QCSSmPoNJ6d5tYWg","children":[]},{"id":"124","parent":"122","text":"→ BAV completo → marcapasos transitorio (especialmente si IAM inferior)","guid":"Uzm3vjLTTlmReKRC84pjeA","children":[]},{"id":"125","parent":"122","text":"→ FA de novo → frecuente en AM, betabloqueador o amiodarona","guid":"zQFqmBi3QVyx-Be01V56JQ","children":[]}]},{"id":"126","parent":"121","text":"Falla cardíaca aguda / Shock cardiogénico","guid":"ac-AWzutQ8GWTYbhA5T3qA","children":[{"id":"127","parent":"126","text":"→ Killip II-III → diuréticos, vasodilatadores","guid":"z5QtWdBhSyScr6cJ06kjHw","children":[]},{"id":"128","parent":"126","text":"→ Killip IV (shock) → vasopresores, balón intraaórtico, ICP urgente","guid":"XM2P1iloQNSNtnecPe0t7g","children":[]},{"id":"129","parent":"126","text":"→ EN AM: Killip ≥3 al ingreso → mortalidad >30%","guid":"x3rd5yn-TdWptnfbizyyKA","children":[]}]},{"id":"130","parent":"121","text":"Complicaciones mecánicas","guid":"ABNYhzIbT82tE-Nnk5D4HA","children":[{"id":"131","parent":"130","text":"→ Rotura pared libre → taponamiento → cirugía emergencia","guid":"nLo9hNRlSVS9FHRmpvzfXw","children":[]},{"id":"132","parent":"130","text":"→ CIV aguda → shunt I→D → cirugía","guid":"AYDQVEP3QOmc6U6akxJTmw","children":[]},{"id":"133","parent":"130","text":"→ Insuficiencia mitral aguda → rotura papilar → cirugía","guid":"BmqMIRrGRbO4GCDguDxcwQ","children":[]},{"id":"134","parent":"130","text":"→ Más frecuentes en AM, especialmente día 3-7 post-STEMI","guid":"e4qm6Ky9RROsh3vvaFX7Cg","children":[]}]}]},{"id":"135","parent":"0","text":"CONSIDERACIONES GERIÁTRICAS ESPECÍFICAS","guid":"D2WG7Vj7TAGPOkG_1PXHhQ","children":[{"id":"136","parent":"135","text":"Fragilidad y decisiones","guid":"_QZ4yGBnTyyERz3CWDLKbw","children":[{"id":"137","parent":"136","text":"→ CFS al ingreso → guía estrategia invasiva vs conservadora","guid":"5v5_bj31S9SVy6HYXcb4zA","children":[]},{"id":"138","parent":"136","text":"→ Fragilidad severa (CFS ≥7) → riesgo > beneficio de estrategia invasiva","guid":"1G_cBbHhSNG9F67m_vA-jg","children":[]},{"id":"139","parent":"136","text":"→ NO excluir por edad → evaluar biología, no cronología","guid":"NkybHB5gRPKbK_sG-UNH3Q","children":[]}]},{"id":"140","parent":"135","text":"Sangrado","guid":"v_u093tDRE-mX8kSyYbuDA","children":[{"id":"141","parent":"140","text":"→ Principal complicación de antitrombóticos en AM","guid":"d9ISahbPQxyVIvbLfALj5g","children":[]},{"id":"142","parent":"140","text":"→ Score CRUSADE para estratificar riesgo hemorrágico","guid":"0CvAVN-UQuOW_mMVId9pJQ","children":[]},{"id":"143","parent":"140","text":"→ Acceso radial siempre que sea posible","guid":"vfq70E42REKoKAqimaWxeQ","children":[]},{"id":"144","parent":"140","text":"→ Duración DAPT: 1-3 meses (vs 12 meses estándar) si alto riesgo sangrado","guid":"j6NGiwEKQK-zptsvQCgr_Q","children":[]},{"id":"145","parent":"140","text":"→ PERLA: SHORT-DAPT → DAPT abreviada segura en >75 años","guid":"RxJKGuTIQiue5XY6zSSoYQ","children":[]}]},{"id":"146","parent":"135","text":"Polifarmacia","guid":"zcXK1__mT-OPdpQxogtdPg","children":[{"id":"147","parent":"146","text":"→ Revisar interacciones: TACO + DAPT → triple terapia mínima","guid":"igSUtQ_nRjymiJoLqLF0ZA","children":[]},{"id":"148","parent":"146","text":"→ Si FA + SCA con stent: triple terapia 1 semana → doble (TACO + Clopidogrel)","guid":"Hvizu0kVQve0TWqFNAR7CQ","children":[]},{"id":"149","parent":"146","text":"→ IBP profiláctico con DAPT","guid":"NZbltEurRYeRKJD6GL2gIg","children":[]},{"id":"150","parent":"146","text":"→ Ajustar dosis por función renal y peso","guid":"1vu-QuPyTA6d7f0oZz0uiA","children":[]}]},{"id":"151","parent":"135","text":"Rehabilitación cardíaca","guid":"Pn5vFOfWTW25oiLH7DzUcw","children":[{"id":"152","parent":"151","text":"→ Iniciar precozmente post-SCA estabilizado","guid":"tCR9tXYuSsyariFP8kYTLg","children":[]},{"id":"153","parent":"151","text":"→ Ejercicio supervisado mejora outcomes en AM","guid":"BdIC0QzIQI6X51gqfEC45A","children":[]},{"id":"154","parent":"151","text":"→ Incluir evaluación funcional (Barthel, SPPB)","guid":"93iA-hoeS6mSlmkKedfcUw","children":[]}]}]},{"id":"155","parent":"0","text":"PERLAS CLÍNICAS MUE","guid":"h-51-6T5Q-aF9o4LWvndIA","children":[{"id":"156","parent":"155","text":"→ Dolor torácico AUSENTE en 30-40% de AM con SCA → mantener alto índice sospecha","guid":"48sudaimRLG47NYEVyqxuA","children":[]},{"id":"157","parent":"155","text":"→ ECG en <10 min es el estándar — NO esperar troponina para activar código STEMI","guid":"bCqG4OXwRquioY0mKXiKnw","children":[]},{"id":"158","parent":"155","text":"→ Disnea + EPA en AM = descartar SCA antes de asumir IC descompensada","guid":"OrPH_ZGYTLq1XOpBBFfShA","children":[]},{"id":"159","parent":"155","text":"→ Media dosis TNK en >75 años (STREAM-2 trial)","guid":"6beQfwR7Tpa9wIu9QNfL9Q","children":[]},{"id":"160","parent":"155","text":"→ Clopidogrel sobre Ticagrelor en >70 años por menor sangrado (POPular-AGE)","guid":"kieeXbUBSk-XZTY_gGNe3A","children":[]},{"id":"161","parent":"155","text":"→ Troponina basalmente elevada en AM → DELTA >20% sobre basal = más útil","guid":"NdGFbXavRYCv0EecgMXHzQ","children":[]},{"id":"162","parent":"155","text":"→ Acceso radial SIEMPRE en AM (MATRIX trial: ↓ sangrado, ↓ mortalidad)","guid":"1sWzx-lwS1WTPQtSSMhZjQ","children":[]},{"id":"163","parent":"155","text":"→ Edad NO es contraindicación para ICP — la fragilidad sí puede serlo","guid":"3JzMKv3ER7GT_tJzwEzUDg","children":[]},{"id":"164","parent":"155","text":"→ DAPT abreviada (1-3 meses) segura en AM con alto riesgo sangrado","guid":"BiS3aTMMQD2CwAFqcG0svg","children":[]},{"id":"165","parent":"155","text":"→ Takotsubo: diagnóstico diferencial obligatorio en mujer AM con estrés emocional","guid":"G_q3N6GETQ2rG_X_7_ltfg","children":[]}]},{"id":"166","parent":"0","text":"LR DIAGNOSTICOS","guid":"taNDonIZRruPDYgHtF3sFA","children":[{"id":"167","parent":"166","text":"HALLAZGOS CLINICOS (cabecera)","guid":"u1x4nF_1QDWoXgQbhmjHsg","children":[{"id":"168","parent":"167","text":"Dolor irradiado a AMBOS brazos -> LR+ 7.1 -> LR- 0.67 -> PMID:16304077","guid":"SHQvWsA7SqOpy5jlSz06aw","children":[]},{"id":"169","parent":"167","text":"Dolor irradiado a brazo derecho -> LR+ 4.7 -> LR- NR -> PMID:16304077","guid":"4MxtYXpqQx2zJbBtRbTf8Q","children":[]},{"id":"170","parent":"167","text":"Dolor irradiado a brazo izquierdo -> LR+ 2.3 -> LR- NR -> PMID:16304077","guid":"ajtzAefXQYaYCfFoY3TTnA","children":[]},{"id":"171","parent":"167","text":"Dolor similar a isquemia previa -> LR+ 2.2 -> LR- NR -> PMID:16304077","guid":"sIgNE7LURF2f_5q3PKb0Ew","children":[]},{"id":"172","parent":"167","text":"Dolor que cambia con esfuerzo -> LR+ 2.4 -> LR- NR -> PMID:16304077","guid":"k9jJD4yTS6y7xKNmbRYJsw","children":[]},{"id":"173","parent":"167","text":"Diaforesis asociada -> LR+ 2.0 -> LR- 0.64 -> PMID:16304077","guid":"At_DHHseQR2lQJQQ81PXsg","children":[]},{"id":"174","parent":"167","text":"Nauseas o vomitos -> LR+ 1.9 -> LR- 0.68 -> PMID:16304077","guid":"TpahPleOQc62NRJn38v1nw","children":[]},{"id":"175","parent":"167","text":"Dolor PLEURITICO (DESCARTA) -> LR+ 0.2 -> PMID:16304077","guid":"G6Yd0-jmRiuLVawalMJeVA","children":[]},{"id":"176","parent":"167","text":"Dolor REPRODUCIBLE con palpacion (DESCARTA) -> LR+ 0.2-0.3 -> PMID:16304077","guid":"ZIJfM6LBTjeCbLcFXRxDDw","children":[]},{"id":"177","parent":"167","text":"Dolor POSICIONAL (DESCARTA) -> LR+ 0.3 -> PMID:16304077","guid":"-Ky9zM7IS_yNd3o9LmlxBA","children":[]},{"id":"178","parent":"167","text":"Signo de Levine (puno sobre esternon) -> [LR no consolidado en literatura]","guid":"HZjko0hyQAGOreLQmuNpiA","children":[]}]},{"id":"179","parent":"166","text":"HALLAZGOS ECG","guid":"sZ9mJArpTSigf_sQOT7mNQ","children":[{"id":"180","parent":"179","text":"Nueva elevacion ST >=1 mm -> LR+ 22 -> LR- 0.5 -> PMID:9786377","guid":"3b4hQ-1ETUySF-Prri5ucA","children":[]},{"id":"181","parent":"179","text":"Nueva onda Q patologica -> LR+ 22 -> LR- NR -> PMID:9786377","guid":"ubIgwSyjQ62ltqPM12qqew","children":[]},{"id":"182","parent":"179","text":"Nuevo bloqueo de conduccion -> LR+ 6.3 -> LR- NR -> PMID:9786377","guid":"jsREMIYsSR28Afym2AK-GA","children":[]},{"id":"183","parent":"179","text":"Nueva inversion T -> LR+ 5.0 -> LR- NR -> PMID:9786377","guid":"qoUZGX16Q-qP9qxs2VXLEQ","children":[]}]},{"id":"184","parent":"166","text":"HALLAZGOS LABORATORIO","guid":"QE4_PhL0QwGZEgTRQ52m_Q","children":[{"id":"185","parent":"184","text":"hs-cTn elevada (cualquier corte) -> LR+ ~22 -> LR- ~0.01 -> PMID:19710484","guid":"3juCfrAkSZ2dUwxxHCRn9Q","children":[]},{"id":"186","parent":"184","text":"hs-cTn serie negativa 0/3h -> LR- ~0.03 -> PMID:19710484","guid":"GQZ7W7RxRs-TajD_CAVHdQ","children":[]}]},{"id":"187","parent":"166","text":"SCORE / REGLA CLINICA","guid":"SbZvmEHkQbW0BmapV63k4g","children":[{"id":"188","parent":"187","text":"HEART score >=7 (alto riesgo MACE) -> LR+ 13 -> LR- NR -> PMID:23465250","guid":"APJ8P8a7QvG85k8YqIZLAg","children":[]},{"id":"189","parent":"187","text":"HEART score <=3 (descarta MACE 30d) -> LR+ NR -> LR- 0.04 -> PMID:23465250","guid":"eM18ocOeR8KFm93fFQGLiw","children":[]},{"id":"190","parent":"187","text":"Marburg Heart Score >=3 (CAD cronica APS) -> LR+ 4.2 -> LR- 0.16 -> PMID:20603345","guid":"nmVZVE6gQ9GtNQ-sWtbqcw","children":[]},{"id":"191","parent":"187","text":"TIMI >=5 (alto riesgo) -> LR+ ~6 -> LR- NR -> PMID:10938172","guid":"REspQDYeTLicwYsg7P1Vgg","children":[]}]},{"id":"192","parent":"166","text":"INTERPRETACION","guid":"l816DEnCSzGg210QhpSpJg","children":[{"id":"193","parent":"192","text":"LR+ >10 o LR- <0.1 -> cambio GRANDE","guid":"o7YEaYoEQ8mrIK5q_isNbg","children":[]},{"id":"194","parent":"192","text":"LR+ 5-10 o LR- 0.1-0.2 -> cambio MODERADO","guid":"fb1ufX6qTVq52uz3tYgJRw","children":[]},{"id":"195","parent":"192","text":"LR+ 2-5 o LR- 0.2-0.5 -> cambio pequeno pero significativo","guid":"Rn-WrSsqRIKS3f29lWwGAA","children":[]}]},{"id":"196","parent":"166","text":"GERIATRIA","guid":"aQB5KsP1S2GYe4YkM60p9Q","children":[{"id":"197","parent":"196","text":">75 anos -> mas equivalentes anginosos (disnea, sincope, confusion, fatiga)","guid":"rodLNfz0SOSOeLxxznQ4DQ","children":[]},{"id":"198","parent":"196","text":"Ausencia de dolor toracico NO descarta SCA en AM","guid":"iwMCZBvmR5-t8p1aKCsS6Q","children":[]}]}]},{"id":"199","parent":"0","text":"REFERENCIAS","guid":"ejvZERFkRAiJ0Ys-UJCBNA","children":[{"id":"200","parent":"199","text":"→ Collet JP et al. ESC Guidelines NSTE-ACS 2020. Eur Heart J. 2021;42(14):1289-1367","guid":"AklfDTLlRgG_-_MYzxoJrA","children":[]},{"id":"201","parent":"199","text":"→ Ibanez B et al. ESC Guidelines STEMI 2017. Eur Heart J. 2018;39(2):119-177","guid":"-97LlxvnS4-uWcuPvQP3Sw","children":[]},{"id":"202","parent":"199","text":"→ Gili S et al. Frailty and NSTEMI outcomes. JACC. 2021;78(17):1723-1734","guid":"u8oJzY0zTmWWKqdExXdxdw","children":[]},{"id":"203","parent":"199","text":"→ Tegn N et al. After Eighty trial. Lancet. 2016;387:1057-1065","guid":"DU9v35xMS-GX8ePK7d1kwQ","children":[]},{"id":"204","parent":"199","text":"→ Savonitto S et al. POPular-AGE trial. NEJM. 2020;382:924-935","guid":"YCq-Xkl7TLK841iwzz6llg","children":[]},{"id":"205","parent":"199","text":"→ Amsterdam EA et al. AHA/ACC NSTE-ACS Guideline. JACC. 2014;64(24):e139-e228","guid":"h1RiFqF9QDKRe18iekGEag","children":[]},{"id":"206","parent":"199","text":"→ Szummer K et al. Elderly and STEMI management. Eur Heart J. 2020;41:3872-3883","guid":"Esk8O-2QQUCAwvgGxm6ZyA","children":[]},{"id":"207","parent":"199","text":"→ Roffi M et al. CRUSADE score and elderly. Am Heart J. 2015;170:939-947","guid":"k3KWTvHoToeA4458EUDk0g","children":[]}]}]},"node_count":207,"relations":[],"cross_references":[],"specialty":"Medicina de Urgencia","folder":"MUE - Medicina de Urgencia","filename":"MUE_SCA","id":"map_2512","resolved_references":[],"title_raw":"MUE_SCA"}