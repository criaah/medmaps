{"title":"ARDSNet","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Entidades clínicas/UCI-Medicina Crítica/ARDSNet-2026.smmx","root":{"id":"0","parent":"-1","text":"ARDSNet / ARMA (2000)\\N\\n⭐ Ventilación protectora SDRA\\N\\nVt 6 ml/kg peso predicho","guid":"ARDS-ROOT","children":[{"id":"1","parent":"0","text":"📋 IDENTIFICACIÓN","guid":"ARDS-ID","children":[{"id":"2","parent":"1","text":"NEJM 2000;342:1301-8\\nNHLBI ARDS Network","guid":"ARDS-ID1","children":[]},{"id":"3","parent":"1","text":"10 universidades EE.UU.\\nTerminado precozmente","guid":"ARDS-ID2","children":[]}]},{"id":"4","parent":"0","text":"👥 POBLACIÓN","guid":"ARDS-POB","children":[{"id":"5","parent":"4","text":"n = 861 pacientes\\nSDRA criterios AECC\\nPaO2/FiO2 ≤300","guid":"ARDS-P1","children":[]},{"id":"6","parent":"4","text":"Edad media: 51 años\\nEtiología: sepsis, aspiración, trauma","guid":"ARDS-P2","children":[]}]},{"id":"7","parent":"0","text":"💊 INTERVENCIÓN","guid":"ARDS-INT","children":[{"id":"8","parent":"7","text":"Vt BAJO (protector) ⭐\\nVt 6 mL/kg peso predicho\\nMeta Pplat ≤30 cmH2O\\nReducir hasta 4 ml/kg si necesario","guid":"ARDS-I1","children":[]},{"id":"9","parent":"7","text":"Vt TRADICIONAL\\nVt 12 mL/kg peso predicho\\nPplat hasta 50 cmH2O","guid":"ARDS-I2","children":[]},{"id":"10","parent":"7","text":"Peso predicho (IBW):\\nH: 50 + 0.91(alt cm - 152.4)\\nM: 45.5 + 0.91(alt cm - 152.4)","guid":"ARDS-I3","children":[]}]},{"id":"11","parent":"0","text":"📊 OUTCOMES","guid":"ARDS-OUT","children":[{"id":"12","parent":"11","text":"Mortalidad hospitalaria ⭐\\nVt bajo: 31.0%\\nVt trad: 39.8%\\np = 0.007","guid":"ARDS-O1","children":[]},{"id":"13","parent":"11","text":"Reducción absoluta: 8.8%\\nNNT = 11.4","guid":"ARDS-O2","children":[]},{"id":"14","parent":"11","text":"Días sin VM: 12 vs 10\\nMenos falla orgánica","guid":"ARDS-O3","children":[]}]},{"id":"15","parent":"0","text":"🏥 UCI GERIÁTRICA","guid":"ARDS-GER","children":[{"id":"16","parent":"15","text":"Mismo principio en ancianos\\n6 ml/kg IBW siempre\\nMayor riesgo VILI en ancianos","guid":"ARDS-G1","children":[]},{"id":"17","parent":"15","text":"Consideraciones:\\n• Cifosis afecta IBW\\n• Menor compliance torácica\\n• Riesgo delirium sedación","guid":"ARDS-G2","children":[]}]},{"id":"18","parent":"0","text":"💎 PERLAS CLÍNICAS","guid":"ARDS-PERLAS","children":[{"id":"19","parent":"18","text":"1. Usar PESO PREDICHO (IBW)\\nNO peso real - error frecuente","guid":"ARDS-PE1","children":[]},{"id":"20","parent":"18","text":"2. Meta Pplat ≤30 cmH2O\\nReducir Vt si necesario","guid":"ARDS-PE2","children":[]},{"id":"21","parent":"18","text":"3. Hipercapnia permisiva\\npH mayor 7.15 aceptable","guid":"ARDS-PE3","children":[]},{"id":"22","parent":"18","text":"4. ESTÁNDAR DE CUIDADO\\nNo hay indicación Vt alto","guid":"ARDS-PE4","children":[]}]}]},"node_count":22,"relations":[],"cross_references":[],"specialty":"UCI/Medicina Crítica","folder":"Entidades clínicas/UCI-Medicina Crítica","filename":"ARDSNet-2026","id":"map_2296","resolved_references":[],"title_raw":"ARDSNet-2026"}