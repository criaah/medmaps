":"36","parent":"34","text":"CALIBRA GANANCIA del RVO → ratio normal 1:1","guid":"","children":[]},{"id":"37","parent":"34","text":"Lesion →\\Nganancia\\Nanormal","guid":"uC0W0Ha1Ryfsfc7-8QOGEA","children":[{"id":"38","parent":"37","text":"Downbeat nystagmus → NUNCA periferico","guid":"","children":[]},{"id":"39","parent":"37","text":"Nistagmus de fijacion","guid":"","children":[]},{"id":"40","parent":"37","text":"Skew deviation","guid":"","children":[]}]}]}]},{"id":"41","parent":"0","text":"NISTAGMUS -\\NGENERACION Y\\NNOMENCLATURA","guid":"VAVyuh-baT2EfZlC0Mch_Q","children":[{"id":"42","parent":"41","text":"DEFINICION","guid":"","children":[{"id":"43","parent":"42","text":"Movimiento ocular ritmico e involuntario bicomponente","guid":"","children":[]},{"id":"44","parent":"42","text":"Fase lenta → movimiento compensatorio (generado por RVO)","guid":"","children":[]},{"id":"45","parent":"42","text":"Fase rapida (saccade) → reset correctivo → generado por FRPP","guid":"","children":[]},{"id":"46","parent":"42","text":"CONVENCION → direccion nombrada por FASE RAPIDA","guid":"","children":[]},{"id":"47","parent":"42","text":"Fisiopatologia esta en la FASE LENTA","guid":"","children":[]}]},{"id":"48","parent":"41","text":"CLASIFICACION\\NPOR DIRECCION","guid":"xHIfq96LLIL7GFJb7hsjBA","children":[{"id":"49","parent":"48","text":"Horizontal → periferico o central horizontal","guid":"","children":[]},{"id":"50","parent":"48","text":"Vertical ascendente → central (vermis posterior / medula oblonga)","guid":"","children":[]},{"id":"51","parent":"48","text":"Vertical descendente (downbeat) → central (floculo / union craneocervical)","guid":"","children":[]},{"id":"52","parent":"48","text":"Torsional → VPPB canal posterior o central","guid":"","children":[]},{"id":"53","parent":"48","text":"Mixto oblicuo → SIEMPRE central","guid":"","children":[]}]},{"id":"54","parent":"41","text":"DIFERENCIAL\\NPERIFERICO vs\\NCENTRAL","guid":"9RmLWXIquIuctfC4sL8bxQ","children":[{"id":"55","p