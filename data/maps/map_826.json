ular","guid":"GysKnIw72Ho1YVnPXOxsYA","children":[{"id":"150","parent":"149","text":"Post-viral / reactivacion herpetica probable","guid":"","children":[]},{"id":"151","parent":"149","text":"HIT + unilateral / sin hipoacusia / sin signos neurologicos","guid":"","children":[]},{"id":"152","parent":"149","text":"Manejo → corticoides (controversia) + rehabilitacion vestibular","guid":"","children":[]},{"id":"153","parent":"149","text":"PC >25% ipsilateral en VNG","guid":"","children":[]}]},{"id":"154","parent":"143","text":"Enfermedad de Meniere /\\NHidrops endolinfatico","guid":"nqn2C1abaiWF6MrnZEgYgQ","children":[{"id":"155","parent":"154","text":"Episodios recurrentes tríada → vertigo + hipoacusia fluctuante + tinnitus","guid":"","children":[]},{"id":"156","parent":"154","text":"Duracion 20 min - 12 horas","guid":"","children":[]},{"id":"157","parent":"154","text":"Manejo → dieta hiposodica + diureticos + betahistina","guid":"","children":[]}]},{"id":"158","parent":"143","text":"Migrania\\Nvestibular","guid":"3EFCm0j7Vq1yJf0soXfE5g","children":[{"id":"159","parent":"158","text":"Causa mas frecuente de vertigo episodico recurrente en adultos jovenes","guid":"","children":[]},{"id":"160","parent":"158","text":"Criterios Barany Society 2012","guid":"","children":[]},{"id":"161","parent":"158","text":"Antecedente de migrania + sintomas vestibulares recurrentes >5 min","guid":"","children":[]}]},{"id":"162","parent":"143","text":"Schwannoma\\Nvestibular","guid":"HETAflru4jq4DYqxpYq88Q","children":[{"id":"163","parent":"162","text":"Hipoacusia asimetrica unilateral progresiva","guid":"","children":[]},{"id":"164","parent":"162","text":"PC ipsilateral en calorico","guid":"","children":[]},{"id":"165","parent":"162","text":"RM con gadolinio → diagnostico definitivo","guid":"","children":[]}]},{"id":"166","parent":"143","text":"Vertigo central -\\NAVE posterior","guid":"HldmzvammAlxSwQJBtEYew","children":[{"id":"167","parent":"166","text":"HINTS benigno → ALTA sospecha","gui