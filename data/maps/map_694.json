t":"## Interpretación\\Nde resultados","guid":"","children":[]},{"id":"17","parent":"0","text":"### Validez de una\\Nprueba diagnóstica","guid":"","children":[{"id":"18","parent":"17","text":"- Tabla de\\Ncontingencia\\N(2x2)","guid":"","children":[{"id":"19","parent":"18","text":"- Verdadero Positivo (VP):\\NEstándar(+) y PD(+)","guid":"","children":[]},{"id":"20","parent":"18","text":"- Verdadero Negativo (VN):\\NEstándar(-) y PD(-)","guid":"","children":[]},{"id":"21","parent":"18","text":"- Falso Positivo (FP):\\NEstándar(-) y PD(+)","guid":"","children":[]},{"id":"22","parent":"18","text":"- Falso Negativo (FN):\\NEstándar(+) y PD(-)","guid":"","children":[]}]},{"id":"23","parent":"17","text":"- Sensibilidad (S)","guid":"","children":[{"id":"24","parent":"23","text":"- Proporción de sujetos\\Nenfermos con prueba positiva","guid":"","children":[]},{"id":"25","parent":"23","text":"- S =\\NVP/(VP+FN) =\\Na/(a+c)","guid":"","children":[]},{"id":"26","parent":"23","text":"- Capacidad para\\Ndetectar enfermedad","guid":"","children":[]},{"id":"27","parent":"23","text":"- Útil cuando no\\Ndiagnosticar puede ser\\Nfatal","guid":"","children":[]},{"id":"28","parent":"23","text":"- Pruebas de tamizaje deben\\Nser de alta sensibilidad","guid":"","children":[]}]},{"id":"29","parent":"17","text":"- Especificidad (E)","guid":"","children":[{"id":"30","parent":"29","text":"- Proporción de sujetos no\\Nenfermos con prueba negativa","guid":"","children":[]},{"id":"31","parent":"29","text":"- E =\\NVN/(FP+VN) =\\Nd/(b+d)","guid":"","children":[]},{"id":"32","parent":"29","text":"- Útil para confirmar diagnóstico\\N(evitar falsos positivos)","guid":"","children":[]},{"id":"33","parent":"29","text":"- Alta E necesaria en\\Nenfermedades graves sin\\Ntratamiento","guid":"","children":[]}]},{"id":"34","parent":"17","text":"- Valor Predictivo\\NPositivo (VPP)","guid":"","children":[{"id":"35","parent":"34","text":"- Probabilidad de padecer\\Nenfermedad si prueba positiva","guid":"","c