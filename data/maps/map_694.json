enta S vs (1-E) para\\Ndiferentes valores de corte","guid":"","children":[]},{"id":"56","parent":"53","text":"- Exactitud aumenta cuando curva se desplaza\\Nhacia vértice superior izquierdo","guid":"","children":[]},{"id":"57","parent":"53","text":"- Área bajo la curva ROC (ABC):\\Níndice de exactitud global","guid":"","children":[{"id":"58","parent":"57","text":"- ABC=1:\\Nexactitud\\Nmáxima","guid":"","children":[]},{"id":"59","parent":"57","text":"- ABC=0,5:\\Nexactitud mínima","guid":"","children":[]}]},{"id":"60","parent":"53","text":"- Determinar punto\\Nde corte óptimo","guid":"","children":[{"id":"61","parent":"60","text":"- Requiere conocer\\Nriesgos/beneficios de decisiones\\Nmédicas","guid":"","children":[]},{"id":"62","parent":"60","text":"- Coeficiente m = [Coste\\NFP/Coste FN] × [(1-P)/P]","guid":"","children":[]}]}]}]},{"id":"63","parent":"0","text":"##\\NAplicabilidad\\Nde la PD","guid":"","children":[{"id":"64","parent":"63","text":"- Consideraciones:","guid":"","children":[{"id":"65","parent":"64","text":"- Reproductibilidad\\Nde la prueba","guid":"","children":[]},{"id":"66","parent":"64","text":"- Similitud entre pacientes del\\Nestudio y nuestros pacientes","guid":"","children":[]},{"id":"67","parent":"64","text":"- Riesgos aceptables","guid":"","children":[]},{"id":"68","parent":"64","text":"- Consecuencias de no\\Ntratar la enfermedad","guid":"","children":[]},{"id":"69","parent":"64","text":"- Disponibilidad\\Nde tratamiento","guid":"","children":[]}]}]},{"id":"70","parent":"0","text":"## Reporte de\\Nresultados","guid":"","children":[{"id":"71","parent":"70","text":"- Iniciativas\\Nmetodológicas:","guid":"","children":[{"id":"72","parent":"71","text":"- STARD (Standards for Reporting\\Nof Diagnostic Accuracy)","guid":"","children":[{"id":"73","parent":"72","text":"- 25 ítems y\\Ndiagrama de flujo","guid":"","children":[]},{"id":"74","parent":"72","text":"- Mejora calidad\\Ndel reporte","guid":"","children":[]}]},{"id":"75","parent":"71","tex