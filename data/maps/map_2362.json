{"title":"VM_Paro_Cardiaco_Six-dial_iPad","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Entidades clínicas/UCI-Medicina Crítica/VM_Paro_Cardiaco_Six-dial_iPad.smmx","root":{"id":"0","parent":"-1","text":"VM en Paro Cardíaco\\N→ Estrategia Six-dial","guid":"Zz51zgL7otpTzQVKZpgFiA","children":[{"id":"1","parent":"0","text":"Contexto Clínico\\N→ Caso Tipo","guid":"fQkl3CeJwWhy-iReD8yRQg","children":[{"id":"2","parent":"1","text":"Politraumatismo + amputación traumática","guid":"","children":[]},{"id":"3","parent":"1","text":"Pérdida estimada 3.5 L sangre","guid":"","children":[]},{"id":"4","parent":"1","text":"Choque hipovolémico hemorrágico GRADO IV","guid":"","children":[]},{"id":"5","parent":"1","text":"FC 150 lpm, PA 70/50, Glasgow 4","guid":"","children":[]},{"id":"6","parent":"1","text":"AESP → primera causa = choque hemorrágico","guid":"","children":[]}]},{"id":"7","parent":"0","text":"ANTES de Intubar\\N→ Prioridades","guid":"AzBBPRjmpSkfJ8s5N4l6Qw","children":[{"id":"8","parent":"7","text":"PRIMERO → controlar hemorragia + reanimar","guid":"","children":[]},{"id":"9","parent":"7","text":"Torniquete + buscar hemorragia oculta (abdomen, tórax)","guid":"","children":[]},{"id":"10","parent":"7","text":"Hemoderivados o sangre total LO MÁS PRONTO posible","guid":"","children":[]},{"id":"11","parent":"7","text":"Ácido tranexámico","guid":"","children":[]},{"id":"12","parent":"7","text":"Inductores en choque severo\\N→ RIESGO DE PARO","guid":"B3oeCX_4I7BHRtPXUzScgg","children":[{"id":"13","parent":"12","text":"Propofol, midazolam → frenan corazón taquicárdico compensatorio","guid":"","children":[]},{"id":"14","parent":"12","text":"Presión positiva VM → reduce retorno venoso ya comprometido","guid":"","children":[]}]},{"id":"15","parent":"7","text":"NO ser héroe intubando → REANIMAR PRIMERO","guid":"","children":[]}]},{"id":"16","parent":"0","text":"Si Paciente en Paro\\N→ Secuencia Inicial","guid":"A634ixX6Aho-XoNWHGD_pg","children":[{"id":"17","parent":"16","text":"PEDIR AYUDA → código azul","guid":"","children":[]},{"id":"18","parent":"16","text":"Iniciar compresiones 100-120/min","guid":"","children":[]},{"id":"19","parent":"16","text":"Compresiones generan presión positiva intratorácica","guid":"","children":[]},{"id":"20","parent":"16","text":"Compresiones se visualizan en curvas del ventilador","guid":"","children":[]},{"id":"21","parent":"16","text":"VM como reanimador → libera personal para otras tareas","guid":"","children":[]}]},{"id":"22","parent":"0","text":"Modo\\NVentilatorio","guid":"Mmgbl01l6G5AQLFDbw4wFQ","children":[{"id":"23","parent":"22","text":"VCV (Controlado por Volumen) → MODO RECOMENDADO","guid":"","children":[]},{"id":"24","parent":"22","text":"Control preciso de Vt entregado","guid":"","children":[]},{"id":"25","parent":"22","text":"Algunos ventiladores tienen MODO RCP AUTOMÁTICO","guid":"","children":[{"id":"26","parent":"25","text":"Ajusta todos los parámetros en automático","guid":"","children":[]}]}]},{"id":"27","parent":"0","text":"Dial 1 → FiO2 = 100%","guid":"a3ivzn-skmV6AqB1UrclnA","children":[{"id":"28","parent":"27","text":"Poca sangre circulante (~20% del GC normal)","guid":"","children":[]},{"id":"29","parent":"27","text":"Maximizar transporte O2 en sangre disponible","guid":"","children":[]},{"id":"30","parent":"27","text":"PaO2 alto durante RCP → mayor tasa admisión hospitalaria","guid":"","children":[]}]},{"id":"31","parent":"0","text":"Dial 2 → Trigger OFF o máximo (-20 cmH2O)","guid":"Aqg1P03Ppb85TyskC6N3kg","children":[{"id":"32","parent":"31","text":"Compresiones activan trigger por presión y flujo","guid":"","children":[]},{"id":"33","parent":"31","text":"FR programada 16 → FR total 25-27 por auto-ciclado","guid":"","children":[]},{"id":"34","parent":"31","text":"Auto-ciclado → HIPERVENTILACIÓN INADVERTIDA → letal","guid":"","children":[]},{"id":"35","parent":"31","text":"Desactivar o subir al máximo → solo ciclos programados","guid":"","children":[]},{"id":"36","parent":"31","text":"Compresiones se ven pero NO disparan ventilaciones","guid":"","children":[]}]},{"id":"37","parent":"0","text":"Dial 3 → PEEP = 0 cmH2O","guid":"","children":[{"id":"38","parent":"37","text":"Toda presión positiva impide retorno venoso","guid":"","children":[]},{"id":"39","parent":"37","text":"Paciente en paro necesita MÁXIMO retorno venoso","guid":"","children":[]},{"id":"40","parent":"37","text":"CONTROVERSIA → 1 estudio (n=298) PEEP 5 → mayor ROSC (48% vs 22%)","guid":"","children":[{"id":"41","parent":"40","text":"Sin análisis multivariado → cautela","guid":"","children":[]}]},{"id":"42","parent":"37","text":"Recomendación actual → PEEP 0","guid":"","children":[]}]},{"id":"43","parent":"0","text":"Dial 4 → FR = 10 rpm","guid":"","children":[{"id":"44","parent":"43","text":"1 ventilación cada 6 segundos (AHA 2020)","guid":"","children":[]},{"id":"45","parent":"43","text":"EVITAR FR >10 → hiperventilación","guid":"","children":[]},{"id":"46","parent":"43","text":"Hiperventilación → aumento\\Npresión intratorácica","guid":"NK6zYFWEZ10BFwSzN970nQ","children":[{"id":"47","parent":"46","text":"Reduce retorno venoso y gasto cardíaco","guid":"","children":[]},{"id":"48","parent":"46","text":"Cae presión de perfusión coronaria","guid":"","children":[]}]}]},{"id":"49","parent":"0","text":"Dial 5 → Relación I:E = 1:5","guid":"","children":[{"id":"50","parent":"49","text":"Maximizar tiempo de EXHALACIÓN","guid":"","children":[]},{"id":"51","parent":"49","text":"Inspiración → tórax inflado → impide retorno venoso","guid":"","children":[]},{"id":"52","parent":"49","text":"Exhalación → expansión torácica → sangre llega al corazón","guid":"","children":[]},{"id":"53","parent":"49","text":"Flujo ajustado para lograr 1:5","guid":"","children":[]}]},{"id":"54","parent":"0","text":"Dial 6 → Vt 400-500 mL (adulto)","guid":"","children":[{"id":"55","parent":"54","text":"NO medir al paciente durante paro","guid":"","children":[]},{"id":"56","parent":"54","text":"Vt aproximado aceptable → 400-500 mL","guid":"","children":[]},{"id":"57","parent":"54","text":"Paciente grave → no perfeccionismo","guid":"","children":[]}]},{"id":"58","parent":"0","text":"Alarma Pmax = 60 cmH2O","guid":"","children":[{"id":"59","parent":"58","text":"Compresiones generan picos de presión","guid":"","children":[]},{"id":"60","parent":"58","text":"Alarma estándar (~40) interrumpe entrega de Vt","guid":"","children":[]},{"id":"61","parent":"58","text":"Elevar a 60 → permite completar ventilación","guid":"","children":[]},{"id":"62","parent":"58","text":"Riesgo barotrauma aceptable en paro","guid":"","children":[]}]},{"id":"63","parent":"0","text":"Transición POST-ROSC →\\NCAMBIO INMEDIATO","guid":"bmsMhiA-z-1vaG7ga3QyYw","children":[{"id":"64","parent":"63","text":"Paciente ahora NEUROCRÍTICO potencial","guid":"","children":[]},{"id":"65","parent":"63","text":"Isquemia previa (paro + choque hemorrágico)","guid":"","children":[]},{"id":"66","parent":"63","text":"1) FiO2 → BAJAR PRIMERO y RÁPIDO","guid":"","children":[{"id":"67","parent":"66","text":"De 100% a mínimo posible","guid":"","children":[]},{"id":"68","parent":"66","text":"Objetivo SpO2 94-97% (NO >98%)","guid":"","children":[]},{"id":"69","parent":"66","text":"O2 alto + reperfusión → radicales libres → daño cerebral","guid":"","children":[]},{"id":"70","parent":"66","text":"Caso → FiO2 21% → SpO2 95%","guid":"","children":[]}]},{"id":"71","parent":"63","text":"2) PEEP → NO urgente post-ROSC inmediato","guid":"","children":[{"id":"72","parent":"71","text":"Recién reanimado → riesgo hipotensión","guid":"","children":[]},{"id":"73","parent":"71","text":"Titular después, cuando estable","guid":"","children":[]}]},{"id":"74","parent":"63","text":"3) Vt → Ahora SÍ medir al paciente","guid":"","children":[{"id":"75","parent":"74","text":"8 mL/kg peso ideal","guid":"","children":[]},{"id":"76","parent":"74","text":"Rango 6-10 mL/kg aceptable agudo","guid":"","children":[]}]},{"id":"77","parent":"63","text":"4) FR → Ajustar según PaCO2","guid":"","children":[{"id":"78","parent":"77","text":"OBJETIVO → normocapnia ~40 mmHg","guid":"","children":[]},{"id":"79","parent":"77","text":"CO2 alto → vasodilatación cerebral → EDEMA","guid":"","children":[]},{"id":"80","parent":"77","text":"FÓRMULA → (CO2 actual x FR actual) / CO2 objetivo","guid":"","children":[]},{"id":"81","parent":"77","text":"Caso → (46 x 10) / 40 = 11.5 → poner 12 rpm","guid":"","children":[]}]},{"id":"82","parent":"63","text":"5) I:E → Volver a 1:2 (convencional)","guid":"","children":[]},{"id":"83","parent":"63","text":"6) Trigger → REACTIVAR a -2 cmH2O","guid":"","children":[{"id":"84","parent":"83","text":"Permite ventilaciones espontáneas al despertar","guid":"","children":[]}]},{"id":"85","parent":"63","text":"7) Sedación → NO SEDAR post-paro","guid":"","children":[{"id":"86","parent":"85","text":"Impide evaluación neurológica","guid":"","children":[]},{"id":"87","parent":"85","text":"Solo ANALGESIA adecuada","guid":"","children":[]},{"id":"88","parent":"85","text":"Vigilar deterioro neurológico","guid":"","children":[{"id":"89","parent":"88","text":"Herniación, DTC, vaina nervio óptico","guid":"","children":[]},{"id":"90","parent":"88","text":"TAC → edema, borramiento cisuras, desviación línea media","guid":"","children":[]}]},{"id":"91","parent":"85","text":"Si sedo → regalo días de VM innecesarios","guid":"","children":[]}]}]},{"id":"92","parent":"0","text":"Vigilancia\\NContinua\\NPost-ROSC","guid":"R8iRVWJikz97QMOlT0KvXg","children":[{"id":"93","parent":"92","text":"Calcio (hemorragia masiva + transfusión)","guid":"","children":[]},{"id":"94","parent":"92","text":"Tiempos de coagulación","guid":"","children":[]},{"id":"95","parent":"92","text":"Hemoglobina y plaquetas","guid":"","children":[]},{"id":"96","parent":"92","text":"Temperatura","guid":"","children":[]},{"id":"97","parent":"92","text":"Prevenir nuevo paro","guid":"","children":[]}]},{"id":"98","parent":"0","text":"Perlas\\NClínicas","guid":"Ylq270KHl3wid0vhZgiveg","children":[{"id":"99","parent":"98","text":"REANIMAR ANTES de intubar en choque hemorrágico severo","guid":"","children":[]},{"id":"100","parent":"98","text":"Inductores + VM en choque severo = PARO","guid":"","children":[]},{"id":"101","parent":"98","text":"Paciente YA en VM → NO desconectar, AJUSTAR 6 diales","guid":"","children":[]},{"id":"102","parent":"98","text":"Checklist mental → dominar en <10 segundos","guid":"","children":[]},{"id":"103","parent":"98","text":"Trigger sensible + compresiones = auto-ciclado = muerte","guid":"","children":[]},{"id":"104","parent":"98","text":"PEEP 0 en RCP ≠ PEEP post-ROSC → cambiar inmediatamente","guid":"","children":[]},{"id":"105","parent":"98","text":"FR >10 en RCP → tan dañina como no ventilar","guid":"","children":[]},{"id":"106","parent":"98","text":"Post-ROSC → bajar FiO2 PRIMERO (radicales libres)","guid":"","children":[]},{"id":"107","parent":"98","text":"Fórmula FR post-ROSC → (CO2 x FR) / CO2 objetivo","guid":"","children":[]},{"id":"108","parent":"98","text":"NO SEDAR post-paro → evaluación neurológica continua","guid":"","children":[]},{"id":"109","parent":"98","text":"AESP → primera causa = choque hemorrágico","guid":"","children":[]},{"id":"110","parent":"98","text":"EtCO2 → guía calidad RCP y predictor ROSC","guid":"","children":[]}]},{"id":"111","parent":"0","text":"Referencias","guid":"","children":[{"id":"112","parent":"111","text":"1. Sahu AK et al. Six-dial Strategy—VM during CPR. Indian J Crit Care Med. 2020;24(6):487-489.","guid":"","children":[]},{"id":"113","parent":"111","text":"2. AHA. 2020 Guidelines for CPR and ECC. Circulation. 2020;142(16 Suppl 2):S366-S468.","guid":"","children":[]},{"id":"114","parent":"111","text":"3. Cordioli RL et al. New insights in ventilation during CPR. Curr Opin Crit Care. 2019;25(1):37-44.","guid":"","children":[]},{"id":"115","parent":"111","text":"4. Pérez Nieto OR et al. Material AVENTHO: VM y caso clínico VM en paro. 2020.","guid":"","children":[]},{"id":"116","parent":"111","text":"5. Kill C et al. Mechanical ventilation during CPR. Resuscitation. 2014;85(S1):S101.","guid":"","children":[]},{"id":"117","parent":"111","text":"6. Nolan JP et al. ERC-ESICM Guidelines 2021: Post-resuscitation care. Resuscitation. 2021;161:220-269.","guid":"","children":[]}]}]},"node_count":117,"relations":[],"cross_references":[],"specialty":"UCI/Medicina Crítica","folder":"Entidades clínicas/UCI-Medicina Crítica","filename":"VM_Paro_Cardiaco_Six-dial_iPad","id":"map_2362","resolved_references":[],"title_raw":"VM_Paro_Cardiaco_Six-dial_iPad"}