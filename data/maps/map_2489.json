G6BoA","children":[]}]}]},{"id":"34","parent":"0","text":"Comorbilidades","guid":"dI7J3jpsT52cYNqoXeCCcA","children":[{"id":"35","parent":"34","text":"70-80% tiene AL MENOS una condición mental comórbida en la vida","guid":"eG1pvz3aQ5KT9O75Mk1VVA","children":[]},{"id":"36","parent":"34","text":"Psiquiátricas\\Nen infancia","guid":"IszwiFSeQQuTce3ti_itLw","children":[{"id":"37","parent":"36","text":"Trastorno de conducta OR 10.7 (IC 7.7-14.8)","guid":"KKWGR0_PQNuyPp1RiARK0Q","children":[]},{"id":"38","parent":"36","text":"TDM OR 5.5 (IC 3.5-8.4)","guid":"swjSR0wnQRysRD-e9LoZSQ","children":[]},{"id":"39","parent":"36","text":"Ansiedad OR 3.0 (IC 2.1-4.3)","guid":"8utI-8DySYeRjovmjOm2rw","children":[]},{"id":"40","parent":"36","text":"Trastorno oposicionista desafiante → común","guid":"B1bdqyHDSde7nobYpTQaJw","children":[]}]},{"id":"41","parent":"34","text":"Psiquiátricas\\Nen adultez","guid":"1Cwhh6xiTMan-hPFwcjm2Q","children":[{"id":"42","parent":"41","text":"Trastorno bipolar OR 8.7 (IC 5.5-13.9)","guid":"rtKHba8SSL2zfcQ-iMwF6w","children":[]},{"id":"43","parent":"41","text":"Ansiedad OR 5.0 (IC 3.3-7.5)","guid":"IwYWNaisQnCWFGG_5B0feg","children":[]},{"id":"44","parent":"41","text":"Trastorno por uso sustancias OR 4.6 (IC 2.7-7.8)","guid":"wDVrxrh1TEuImtIEcxqzWg","children":[]},{"id":"45","parent":"41","text":"TDM OR 4.5 (IC 2.4-8.3)","guid":"daadM7zySf2sun758a805A","children":[]}]},{"id":"46","parent":"34","text":"Somáticas\\Nniños","guid":"bRbdfC0UT7WiIzfvBpuwJA","children":[{"id":"47","parent":"46","text":"Dermatitis OR 1.4 (IC 1.3-1.5)","guid":"_xICdcUERoePiTbO13LAHw","children":[]},{"id":"48","parent":"46","text":"Obesidad OR 1.3 (IC 1.2-1.5)","guid":"lEkiNmZtQ1yfl70xgr3JWQ","children":[]},{"id":"49","parent":"46","text":"Asma OR 1.6 (IC 1.2-2.1)","guid":"qefwhqDGShCFx4XmVJMwlQ","children":[]},{"id":"50","parent":"46","text":"Rinitis OR 1.6 (IC 1.3-1.9)","guid":"ntXnbk1RRaGvO_P66w96wg","children":[]}]},{"id":"51","parent":"34","text":"Somáticas\\Nadultos","guid":"KilsfxlYQtOf6VDzW_jxqA","children":[{"id":"52","parent":"51","text":"DM2 OR 2.3 (IC 1.5-3.6)","guid":"rCAPl-OyQKOXXS484HB1Hg","children":[]},{"id":"53","parent":"51","text":"Enfermedad CV HR 2.05 (IC 1.98-2.13)","guid":"66cEOofyQPmEs__XllVUYQ","children":[]},{"id":"54","parent":"51","text":"Problemas visuales (sin alteración estructural)","guid":"4n2yTPOrRsGCH1_4N1TX2w","children":[]}]},{"id":"55","parent":"34","text":"Sueño","guid":"UY1BrCYUSlemmcQNpBSHkA","children":[{"id":"56","parent":"55","text":"ALTA prevalencia → resistencia acostarse, despertares, SAHOS, somnolencia diurna","guid":"JSdtSD_kSve4T-Ttyeu_Ow","children":[]}]},{"id":"57","parent":"34","text":"IMPACTO → mayor severidad + peores outcomes + muerte prematura","guid":"Q79Tl1aRTcC6zWGI0jhQ0w","children":[]}]},{"id":"58","parent":"0","text":"Fisiopatología","guid":"a2TsMIqpRPGWlg7At6V0tA","children":[{"id":"59","parent":"58","text":"Genética","guid":"P-rHE_EQR0WdfFpthNNoNw","children":[{"id":"60","parent":"59","text":"HEREDABILIDAD ~80% (gemelos y estudios familiares)","guid":"6ECKME9TRRaVrkmcJd2bdw","children":[]},{"id":"61","parent":"59","text":"Similar en ambos sexos y a lo largo del ciclo vital","guid":"YNaX8nwWTfS5Z7qsXf01mA","children":[]},{"id":"62","parent":"59","text":"SNPs comunes → 14-20% heredabilidad","guid":"uWDYEEx3TgGY25A8GHgsNw","children":[]},{"id":"63","parent":"59","text":"GWAS 2023 (Demontis) → 27 loci, 76 genes","guid":"1A42UgfJS7mR_O55JytL6A","children":[]},{"id":"64","parent":"59","text":"Genes upregulated en desarrollo cerebral temprano","guid":"iymoZXPBQF237_DiF1GEPg","children":[]},{"id":"65","parent":"59","text":"Genes\\Nclave","guid":"XMmXY2xUTnqSXa0p87Sigg","children":[{"id":"66","parent":"65","text":"PTPRF → sinaptogénesis, densidad sináptica","guid":"BWNuxIwoQge2jkSJtuPqog","children":[]},{"id":"67","parent":"65","text":"FOXP1 FOXP2 → regulación sinapsis, habla, cognición","guid":"2IK0qVAfRmqf340G3qvvkA","children":[]},{"id":"68","parent":"65","text":"MEF2C → proliferación neuronal, balance E/I","guid":"aLfpYE9WTLaY225XDf0pdg","children":[]},{"id":"69","parent":"65","text":"SORCS3 → plasticidad sináptica","guid":"lw9eSUsBRc2CD97QGVwSwA","children":[]},{"id":"70","parent":"65","text":"DUSP6 → homeostasis dopaminérgica","guid":"yzzFHXgMQNWmU0_vjYtPeQ","children":[]}]},{"id":"71","parent":"59","text":"Variantes\\Nraras","guid":"9GpBu09_QZW9EVHMHcQExw","children":[{"id":"72","parent":"71","text":"CNVs replicados → 1q21.1 6q26 15q11-13 16p11.2 17q12 22q11.21","guid":"rQ9NTHA4TgqdxqgqM6THIw","children":[]},{"id":"73","parent":"71","text":"Superposición con TEA y esquizofrenia","guid":"QXWDkN_DTuep0c21wPN6jg","children":[]}]},{"id":"74","parent":"59","text":"PRS actual NO sirve para diagnóstico clínico","guid":"gYtYJVFTTZS6QlqhnIJ5Sg","children":[]},{"id":"75","parent":"59","text":"PRS NO predice elección de medicación","guid":"DgD-d17dR52J_hCmRqBOQg","children":[]}]},{"id":"76","parent":"58","text":"Correlatos\\Nambientales","guid":"PdW0rUPASYie80p7g4w69w","children":[{"id":"77","parent":"76","text":"Rara vez causales","guid":"WZASlJtsSDudEZdLdl635w","children":[]},{"id":"78","parent":"76","text":"TEC moderado-severo → asociación robusta","guid":"haHNqIHaSlO5v_rJnYFWeQ","children":[]},{"id":"79","parent":"76","text":"Privación extrema temprana → causal","guid":"HRD9HQ4aRcmEIF_nMSkCPw","children":[]},{"id":"80","parent":"76","text":"Eventos perinatales → bajo peso, hipoxia, edad paterna avanzada (riesgo bajo)","guid":"1cyJRYFLTPGchurmWLSraw","children":[]},{"id":"81","parent":"76","text":"Tabaquismo materno\\N→ NO es causa directa","guid":"qL0uhGvSThqfKKIow-S_aQ","children":[{"id":"82","parent":"81","text":"Se explica por riesgo poligénico compartido madre-hijo","guid":"rqNj0a93Sy2OVE2r5A9DHQ","children":[]},{"id":"83","parent":"81","text":"Meta-análisis sibling-control sin asociación","guid":"ILP1zIvnSo-S0w9546J4rg","children":[]},{"id":"84","parent":"81","text":"Estudios de ovocito donado → sin asociación","guid":"MuGqZGVkSqeEqX5q88qq2A","children":[]}]},{"id":"85","parent":"76","text":"Bajo NSE → doble riesgo vs alto NSE","guid":"gbdeX95TSwi1wRTSYg30WA","children":[{"id":"86","parent":"85","text":"Transmisión mixta → genética + ambiental","guid":"Xm0YcIzCTa6VqBgmOp8cCQ","children":[]}]},{"id":"87","parent":"76","text":"Scaffolding social e intelectual → retrasa inicio de síntomas","guid":"FachRBe7QbKJYlR_jLdtqw","children":[]}]},{"id":"88","parent":"58","text":"Neuroimagen\\Nestructural","guid":"PaDAH2QCQx-YSipcwQ6pMw","children":[{"id":"89","parent":"88","text":"Superficie cortical reducida → frontal cingulado parietal temporal","guid":"8zM2TBEJRP2PtxDWjkpK8g","children":[]},{"id":"90","parent":"88","text":"Menor grosor cortical → fusiforme polo temporal (emoción)","guid":"2WeQv0b4QluXyK2p29Dz6A","children":[]},{"id":"91","parent":"88","text":"Volumen intracraneal menor","guid":"FQQtl73NT-y23hiqkX_70Q","children":[]},{"id":"92","parent":"88","text":"Ganglios basales y sistema límbico reducidos","guid":"aueuiXv_Sh-YwpbTFbXgkQ","children":[]},{"id":"93","parent":"88","text":"Hallazgos presentes en hermanos NO afectos → vulnerabilidad genética","guid":"Ye-P18WzR6OCSOEuUBMKDg","children":[]}]},{"id":"94","parent":"58","text":"Materia\\Nblanca","guid":"8ruIo_-mQ_2eH-Im9-NzqQ","children":[{"id":"95","parent":"94","text":"Menor anisotropía fraccional","guid":"v_aWfRDgRlySHY6RRuTrAQ","children":[]},{"id":"96","parent":"94","text":"Cuerpo calloso posterior + fascículo uncinado izq","guid":"LFMugcRbTXaYqMtqWDiGWA","children":[]},{"id":"97","parent":"94","text":"Fascículo longitudinal inferior (atención visual)","guid":"ssNS2RXMQnikfpQrZr__LQ","children":[]}]},{"id":"98","parent":"58","text":"fMRI\\Nfuncional","guid":"afd0wGxqT-K9f8OabRokyA","children":[{"id":"99","parent":"98","text":"HIPOACTIVACION córtex frontal inferior + ínsula (control cognitivo)","guid":"jITab-TvR5-cvzl8z83Amg","children":[]},{"id":"100","parent":"98","text":"HIPOACTIVACION DLPFC (atención, memoria trabajo)","guid":"P5T1pXgBSLCFufTWT1vUxg","children":[]},{"id":"101","parent":"98","text":"DMN → interferencia anormal con redes de atención","guid":"UjGczHDDRpm4uavHbdhyDg","children":[]},{"id":"102","parent":"98","text":"Reducida anti-correlación DMN ↔ redes atencionales","guid":"yS1inWw7QK6n-pvVRa7NKg","children":[]}]},{"id":"103","parent":"58","text":"Maduración\\Ncerebral","guid":"VheYOThZRfaaKAHxvucaVw","children":[{"id":"104","parent":"103","text":"RETRASO madurativo estructural y funcional","guid":"EeO4qx8AQXy6hY1Fpwna3g","children":[]},{"id":"105","parent":"103","text":"Delay en grosor y superficie cortical frontotemporal","guid":"VZz0OSFJQNCamBVxM559vA","children":[]},{"id":"106","parent":"103","text":"Delay en sustancia blanca cerebelar","guid":"krsh2mhUQI6QA7Du2B5Zog","children":[]},{"id":"107","parent":"103","text":"Conectividad prefrontal inferior ← peor inatención","guid":"s0_0FJ3ORq6xG6ghJSyS_Q","children":[]}]},{"id":"108","parent":"58","text":"Neurotransmisores","guid":"LhFtyZlDRYK4QwZeIlFrgw","children":[{"id":"109","parent":"108","text":"Dopamina → movimiento, recompensa, atención, aprendizaje","guid":"PzHRAg2IQ9OrjEncV_TZ1Q","children":[]},{"id":"110","parent":"108","text":"Noradrenalina → atención, arousal, señal-ruido","guid":"wbQhktGcS3y5_4PlSIN74Q","children":[]},{"id":"111","parent":"108","text":"Ambos son DIANA farmacológica principal","guid":"v21kB_dVSBu8D9fSf-ogmg","children":[]}]},{"id":"112","parent":"58","text":"EEG","guid":"mfvE63xyQhOREDusSwRP0w","children":[{"id":"113","parent":"112","text":"Mayor razón theta/beta → solo en síntomas combinados","guid":"mvwXSS7yQdSEAC96PWVLJQ","children":[]},{"id":"114","parent":"112","text":"ERPs alterados en procesamiento cognitivo superior","guid":"82cKTfF1TqWlDUr_CYFHDw","children":[]},{"id":"115","parent":"112","text":"Mayor efecto en no medicados y jóvenes","guid":"sBXScBZHRz-Jfw9F3fz5hg","children":[]}]}]},{"id":"116","parent":"0","text":"Diagnóstico","guid":"Dbp2GNl1RsW95_JgyHX4IA","children":[{"id":"117","parent":"116","