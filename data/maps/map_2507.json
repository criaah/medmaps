{"title":"MUE_Hemorragia_Digestiva","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/MUE - Medicina de Urgencia/MUE_Hemorragia_Digestiva.smmx","root":{"id":"0","parent":"-1","text":"HEMORRAGIA DIGESTIVA EN URGENCIAS","guid":"CuPt1Q1PRQGF3FtjljCB-g","children":[{"id":"1","parent":"0","text":"DEFINICIÓN Y CLASIFICACIÓN","guid":"FrjsQTwoRGW5v5XTnwzbHg","children":[{"id":"2","parent":"1","text":"HEMORRAGIA DIGESTIVA ALTA (HDA)","guid":"UzRHlWieT7uRKDk4pMLqjQ","children":[{"id":"3","parent":"2","text":"Origen proximal al ángulo de Treitz","guid":"RgepPsdvShiJzwI_dznxkQ","children":[]},{"id":"4","parent":"2","text":"80% de las hemorragias digestivas","guid":"5-J5m1wxTgq5RJtKqUVTgg","children":[]},{"id":"5","parent":"2","text":"Mortalidad 2-15% (↑ en AM)","guid":"fNatm-eMTmyV041d1sk5mg","children":[]}]},{"id":"6","parent":"1","text":"HEMORRAGIA DIGESTIVA BAJA (HDB)","guid":"dSn3ZHk_RY-sSxlC5e7YFg","children":[{"id":"7","parent":"6","text":"Origen distal al ángulo de Treitz","guid":"i5gKp0q8QhyIyoWayL5l4w","children":[]},{"id":"8","parent":"6","text":"20% de las hemorragias digestivas","guid":"fFHg6SHbTJmorxA61KaIOw","children":[]},{"id":"9","parent":"6","text":"Mortalidad 2-4%","guid":"ztXXOa07RmGYYT2OpS8O5Q","children":[]}]},{"id":"10","parent":"1","text":"HEMORRAGIA DIGESTIVA OSCURA","guid":"k4-SDW4vQWWUUDXq8_ZVjg","children":[{"id":"11","parent":"10","text":"Sin origen identificado tras EDA + colonoscopía","guid":"tJbY-mglQdyFIu95UEatFQ","children":[]},{"id":"12","parent":"10","text":"Sospechar intestino delgado (angiodisplasia)","guid":"5c9YN8rcTnmaZrfnq_UByg","children":[]}]},{"id":"13","parent":"1","text":"HEMORRAGIA DIGESTIVA OCULTA","guid":"mess2WHOTu6eezCkXSxfXQ","children":[{"id":"14","parent":"13","text":"Sin evidencia clínica → anemia ferropénica crónica","guid":"2I1sa-DuRt2mj6UhQs1IQQ","children":[]},{"id":"15","parent":"13","text":"Frecuente en AM → screening neoplasia","guid":"WIBlShdCRw-kqvOXl0-Hug","children":[]}]}]},{"id":"16","parent"