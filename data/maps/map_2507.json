eyde)","guid":"ir-3w9BLTyWvdn4QkJ5Zsg","children":[]},{"id":"52","parent":"49","text":"Puede ser HDA o HDB","guid":"U0-6JH2bSsiwuGwr6Ee5zg","children":[]}]},{"id":"53","parent":"27","text":"NEOPLASIA GÁSTRICA/ESOFÁGICA","guid":"Z0TXLVH2RpyQlrwi3I_f0Q","children":[{"id":"54","parent":"53","text":"Sospechar en AM + anemia + pérdida peso","guid":"gXzQmx1PRN2iyU8cF-nRkw","children":[]}]},{"id":"55","parent":"27","text":"LESIÓN DE DIEULAFOY","guid":"i4tArIuLTxqRqfzPebH0gQ","children":[{"id":"56","parent":"55","text":"Arteria submucosa aberrante","guid":"aAWStwhZQ_in9EWvLxeacw","children":[]},{"id":"57","parent":"55","text":"Sangrado masivo intermitente","guid":"H0X3HZo8TC-oIWJxFaeNtQ","children":[]}]}]},{"id":"58","parent":"26","text":"HDB → CAUSAS PRINCIPALES","guid":"FTrsx7WESeSzDgzyiOHgnA","children":[{"id":"59","parent":"58","text":"ENFERMEDAD DIVERTICULAR (30-40%)","guid":"ME63pLEtTZud2kS8FDnfFw","children":[{"id":"60","parent":"59","text":"Causa más frecuente de HDB en AM","guid":"amQMhHsLQLG5OxVx3a-RCg","children":[]},{"id":"61","parent":"59","text":"Sangrado arterial, indoloro, autolimitado en 80%","guid":"6wEIfV43QTWEKmhtneo65g","children":[]},{"id":"62","parent":"59","text":"Recurrencia 25-30%","guid":"WRzI6zj5Qv-u9XDwUYULJQ","children":[]}]},{"id":"63","parent":"58","text":"ANGIODISPLASIA (20-30%)","guid":"aAb6oUY3Tca5adOYrNBm9A","children":[{"id":"64","parent":"63","text":"Colon derecho predominante","guid":"_q1ycUzmSdyMW3cSPifPnw","children":[]},{"id":"65","parent":"63","text":"Sangrado crónico/intermitente","guid":"hh83ZDFERcqY5_gZqduVpQ","children":[]}]},{"id":"66","parent":"58","text":"NEOPLASIA COLORRECTAL (10-15%)","guid":"z1Tp8g00SeGeZ3eD9FhtNA","children":[{"id":"67","parent":"66","text":"Sospechar: cambio hábito intestinal + hematoquecia + anemia","guid":"ogsguGeXTM-gcEZPshKn_g","children":[]}]},{"id":"68","parent":"58","text":"COLITIS ISQUÉMICA (5-10%)","guid":"PwsfxOTMT82V9W_ZyExn5Q","children":[{"id":"69","parent":"68","text":"AM con aterosclerosi