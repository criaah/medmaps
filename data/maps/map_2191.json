{"title":"Fibromialgia-2023","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Entidades clínicas/Reumatología/Fibromialgia-2023.smmx","root":{"id":"0","parent":"-1","text":"Fibromialgia\\NCompletar","guid":"v_nSaoV26HM9P3e8awytNQ","children":[{"id":"1","parent":"0","text":"Definición","guid":"Eeghw91xbShhJWVoNn-6lQ","children":[{"id":"2","parent":"1","text":"Trastorno de dolor crónico, no inflamatorio y\\Ndifuso con una causa desconocida.","guid":"vM_1xbJ1NE1UMd5XhYuAKQ","children":[]},{"id":"3","parent":"1","text":"Síndrome de dolor crónico\\NGeneralizado y poco específico","guid":"er9BXv_pwnB4l598iFXtpw","children":[{"id":"4","parent":"3","text":"Músculos","guid":"mzSERzHoBtPqE0R94NHudg","children":[]},{"id":"5","parent":"3","text":"Articulaciones","guid":"","children":[]}]},{"id":"6","parent":"1","text":">3 meses","guid":"F2_X2Ced0UQjhR4vd6GBeQ","children":[]},{"id":"7","parent":"1","text":"Sin otra causa médica que lo explique","guid":"ivHJvz6YiflAHMGlwrCjWQ","children":[]},{"id":"8","parent":"1","text":"Destacan","guid":"2G_T8amWgQ2Zf1YlvjueAA","children":[{"id":"9","parent":"8","text":"Hipersensibilidad","guid":"1TFW2kYFnAAW9hp0pcIgVg","children":[]},{"id":"10","parent":"8","text":"Alodinea","guid":"1qaifl03MmuSp4ceVu1ZZw","children":[]},{"id":"11","parent":"8","text":"Puntos sensibles","guid":"","children":[]},{"id":"12","parent":"8","text":"Fatigabilidad","guid":"v4w73Xvqk0zkKZ-tO2_muw","children":[]},{"id":"13","parent":"8","text":"Sueño no reparador","guid":"L-0uZ20UdbrxliPrvkhFLA","children":[]},{"id":"14","parent":"8","text":"Síntomas cognitivos","guid":"IiNoKmkgqpjaPvYbZw43ug","children":[]},{"id":"15","parent":"8","text":"...","guid":"","children":[]}]}]},{"id":"16","parent":"0","text":"Epidemiologia","guid":"EzrId11nPIxqkzKfItzJZw","children":[{"id":"17","parent":"16","text":"Prevalencia 1-2%","guid":"3LGEY6tkneChNykz4lw7tw","children":[]},{"id":"18","parent":"16","text":"Mujeres x 9\\NDg 35-55ā","guid":"FPkEkAZ9_VY6vwZNt4O_xA","c