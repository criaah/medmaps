:"22","parent":"13","text":"Cadena osicular","guid":"9M40J_7qPoEuIh-Ao2xLqw","children":[{"id":"23","parent":"22","text":"Martillo → incus en inglés","guid":"","children":[]},{"id":"24","parent":"22","text":"Yunque (Incus)","guid":"","children":[]},{"id":"25","parent":"22","text":"Estribo → se apoya en ventana oval","guid":"","children":[]},{"id":"26","parent":"22","text":"Función → amplificación mecánica del sonido ~20x","guid":"","children":[]}]},{"id":"27","parent":"13","text":"Músculos","guid":"","children":[{"id":"28","parent":"27","text":"Músculo tensor del tímpano → amortiguación","guid":"","children":[]},{"id":"29","parent":"27","text":"Músculo del estribo (estapedio) → reflejo estapedial","guid":"","children":[]}]},{"id":"30","parent":"13","text":"Estructuras\\Nclave","guid":"xPXGwPiHKoH3tFdBF_sx-Q","children":[{"id":"31","parent":"30","text":"Conducto de Eustaquio → equilibrio de presiones, drenaje","guid":"","children":[]},{"id":"32","parent":"30","text":"Cuerda del tímpano → rama del VII, cruza oído medio","guid":"","children":[]},{"id":"33","parent":"30","text":"Umbo → punto más profundo de la membrana timpánica","guid":"","children":[]}]}]},{"id":"34","parent":"0","text":"OÍDO INTERNO","guid":"","children":[{"id":"35","parent":"34","text":"CÓCLEA (Audición)","guid":"mEAL7zVxrudXcHi20Dc9RQ","children":[{"id":"36","parent":"35","text":"Caracol de 2.5 vueltas","guid":"","children":[]},{"id":"37","parent":"35","text":"Tres compartimentos","guid":"","children":[{"id":"38","parent":"37","text":"Scala vestibuli → perilinfa","guid":"","children":[]},{"id":"39","parent":"37","text":"Scala media (conducto coclear) → endolinfa","guid":"","children":[]},{"id":"40","parent":"37","text":"Scala tympani → perilinfa","guid":"","children":[]}]},{"id":"41","parent":"35","text":"Membrana basilar → tonotopía","guid":"","children":[{"id":"42","parent":"41","text":"Base → ALTA FRECUENCIA (fibras cortas)","guid":"","children":[]},{"id":"43","parent":"41","text":"Ápex → BAJA FRECUENCIA (fibras largas)","guid":"","children":[]},{"id":"44","parent":"41","text":"MEDIANA FRECUENCIA → zona media","guid":"","children":[]}]},{"id":"45","parent":"35","text":"Membrana de Reissner → separa escala vestibular de conducto coclear","guid":"","children":[]},{"id":"46","parent":"35","text":"Estría vascular → produce endolinfa (+80mV potencial endococlear)","guid":"","children":[]},{"id":"47","parent":"35","text":"Ligamento espiral","guid":"","children":[]},{"id":"48","parent":"35","text":"Cúpula de la cóclea → ápex","guid":"","children":[]},{"id":"49","parent":"35","text":"Ventana oval → entrada del estribo","guid":"","children":[]},{"id":"50","parent":"35","text":"Ventana redonda → alivio de presiones","guid":"","children":[]}]},{"id":"51","parent":"34","text":"LABERINTO MEMBRANOSO","guid":"d0wvIxIhRLRw5tGthS8piw","children":[{"id":"52","parent":"51","text":"1. Canales semicirculares (x3)","guid":"","children":[{"id":"53","parent":"52","text":"A. Anterior (superior)","guid":"","children":[]},{"id":"54","parent":"52","text":"B. Posterior","guid":"","children":[]},{"id":"55","parent":"52","text":"C. Lateral (horizontal)","guid":"","children":[]},{"id":"56","parent":"52","text":"Función → detección de ACELERACIÓN ANGULAR","guid":"","children":[]}]},{"id":"57","parent":"51","text":"2. Ampolla → contiene crista ampullaris","guid":"","children":[]},{"id":"58","parent":"51","text":"3. Utrículo → macula utricular, aceleración lineal horizontal","guid":"","children":[]},{"id":"59","parent":"51","text":"4. Sáculo → macula sacular, aceleración lineal vertical","guid":"","children":[]},{"id":"60","parent":"51","text":"5. Ventana oval","guid":"","children":[]},{"id":"61","parent":"51","text":"6. Ventana redonda","guid":"","children":[]},{"id":"62","parent":"51","text":"7. Conducto coclear","guid":"","children":[]},{"id":"63","parent":"51","text":"8. Cúpula de la cóclea","guid":"","children":[]},{"id":"64","parent":"51","text":"9. Cóclea","guid":"","children":[]},{"id":"65","parent":"51","text":"10. Nervio coclear","guid":"","children":[]},{"id":"66","parent":"51","text":"11. Nervio vestibular","guid":"","children":[]},{"id":"67","parent":"51","text":"12. Nervio facial (VII)","guid":"","children":[]},{"id":"68","parent":"51","text":"13. Ampolla membranosa","guid":"","children":[]}]}]},{"id":"69","parent":"0","text":"ÓRGANO DE CORTI (Audición)","guid":"zzvt2IJS2fyn2y0lucY1dQ","children":[{"id":"70","parent":"69","text":"Membrana tectorial → sobre células ciliadas","guid":"","children":[]},{"id":"71","parent":"69","text":"Células de Hensen → soporte externo","guid":"","children":[]},{"id":"72","parent":"69","text":"Células de Claudius → soporte basal","guid":"","children":[]},{"id":"73","parent":"69","text":"Células de Deiters → soporte de células ciliadas externas","guid":"","children":[]},{"id":"74","parent":"69","text":"Células ciliadas externas (~12.000) → amplificación activa (electromotilidad)","guid":"","children":[]},{"id":"75","parent":"69","text":"Células ciliadas internas (~3.500) → TRANSDUCCIÓN principal del sonido","guid":"","children":[]},{"id":"76","parent":"69","text":"Espacio de Nuel","guid":"","children":[]},{"id":"77","parent":"69","text":"Túnel de Corti → separa células ciliadas internas de externas","guid":"","children":[]},{"id":"78","parent":"69","text":"Membrana basilar → vibra según frecuencia","guid":"","children":[]},{"id":"79","parent":"69","text":"Mecanismo → ondas de vibración → deflexión estereocilios → apertura canales K+ → despolarización → neurotransmisor → nervio coclear","guid":"","children":[]}]},{"id":"80","parent":"0","text":"AMPOLLA MEMBRANOSA (Control del Equilibrio)","guid":"cgEKuMdgnCKHWlcsndB5hQ","children":[{"id":"81","parent":"80","text":"Endolinfa → fluido intralaberníntico","guid":"","children":[]},{"id":"82","parent":"80","text":"Crista ampullaris → detector de aceleración angular","guid":"","children":[]},{"id":"83","parent":"80","text":"Cúpula → gelatinosa, cierra la ampolla","guid":"","children":[]},{"id":"84","parent":"80","text":"Mecanismo","guid":"","children":[{"id":"85","parent":"84","text":"Rotación cefálica → movimiento endolinfa → deflexión cúpula → activación células ciliadas","guid":"","children":[]},{"id":"86","parent":"84","text":"Movimiento hacia utrículo (utriculópeto) → excitación","guid":"","children":[]},{"id":"87","parent":"84","text":"Movimiento alejándose (utriculófugo) → inhibición","guid":"","children":[]}]}]},{"id":"88","parent":"0","text":"MÁCULA DEL SÁCULO (Control del Equilibrio)","guid":"MfDgh22bb28COlN0fFwKMA","children":[{"id":"89","parent":"88","text":"Capa gelatinosa","guid":"","children":[]},{"id":"90","parent":"88","text":"Otolitos → cristales de carbonato de calcio","guid":"","children":[]},{"id":"91","parent":"88","text":"Macula → epitelio sensorial con células ciliadas","guid":"","children":[]},{"id":"92","parent":"88","text":"Nervio vestibular","guid":"","children":[]},{"id":"93","parent":"88","text":"Cabeza erguida → posición basal","guid":"","children":[]},{"id":"94","parent":"88","text":"Cabeza inclinada hacia adelante → deflexión otolitos → señal","guid":"","children":[]},{"id":"95","parent":"88","text":"Función → aceleración lineal y gravedad","guid":"","children":[]}]},{"id":"96","parent":"0","text":"FISIOLOGÍA DE LA AUDICIÓN","guid":"vgardHXPsz18NQ-Ky1hiEw","children":[{"id":"97","parent":"96","text":"Tonotopía coclear","guid":"","children":[{"id":"98","parent":"97","text":"Fibras cortas → ALTA FRECUENCIA","guid":"","children":[]},{"id":"99","parent":"97","text":"Fibras medias → MEDIANA FRECUENCIA","guid":"","children":[]},{"id":"100","parent":"97","text":"Fibras largas → BAJA FRECUENCIA","guid":"","children":[]}]},{"id":"101","parent":"96","text":"Transducción auditiva","guid":"","children":[{"id":"102","parent":"101","text":"Sonido → MAE → tímpano → cadena osicular → ventana oval → ondas perilinfa → membrana basilar → células ciliadas → nervio coclear","guid":"","children":[]}]},{"id":"103","parent":"96","text":"Amplificación → células ciliadas externas (prestin, proteína motora)","guid":"","children":[]},{"id":"104","parent":"96","text":"Vía auditiva central","guid":"","children":[{"id":"105","parent":"104","text":"Nervio coclear (VIII) → núcleos cocleares → complejo olivar superior → colículo inferior → cuerpo geniculado medial → corteza auditiva (giro de Heschl)","guid":"","children":[]}]}]},{"id":"106","parent":"0","text":"EN EL CEREBRO","guid":"5QKrFGu9kJ6TV1OHeZTm1Q","children":[{"id":"107","parent":"106","text":"Corteza cerebral → área de percepción del sonido","guid":"","children":[]},{"id":"108","parent":"106","text":"Lóbulo temporal → procesamiento auditivo primario","guid":"","children":[]},{"id":"109","parent":"106","text":"Lóbulo parietal → integración espacial","guid":"","children":[]},{"id":"110","parent":"106","text":"Lóbulo frontal → atención auditiva","guid":"","children":[]},{"id":"111","parent":"106","text":"Lóbulo occipital → integración audiovisual","guid":"","children":[]},{"id":"112","parent":"106","text":"Médula espinal → vías reflejas","guid":"","children":[]},{"id":"113","parent":"106","text":"Cerebelo → coordinación vestíbulo-motora","guid":"","children":[]},{"id":"114","parent":"106","text":"Áreas temporales laterales","guid":"dJqacu9pKeDbb74RqIR8lw","children":[{"id":"115","parent":"114","text":"Área medial → reconocimiento ALTA FRECUENCIA","guid":"","children":[]},{"id":"116","parent":"114","text":"Área lateral → reconocimiento BAJA FRECUENCIA","guid":"","children":[]}]},{"id":"117","parent":"106","text":"Vía vestibular central","guid":"","children":[{"id":"118","parent":"117","text":"Nervio vestibular → núcleos vestibulares → cerebelo, médula espinal, núcleos oculomotores, tálamo → corteza parieto-insular","guid":"","children":[]}]}]},{"id":"119","parent":"0","text":"Perlas Clínicas","guid":"","children":[{"id":"120","parent":"119","text":"Otoscopia normal → cono de luz en horario 5 (OD) y 7 (OI)","guid":"","children":[]},{"id":"121","parent":"119","text":"Pars flácida → zona más vulnerable a colesteatoma","guid":"","children":[]},{"id":"122","parent":"119","text":"Pérdida auditiva conductiva → problema oído externo/medio (Weber lateraliza al ENFERMO)","guid":"","children":[]},{"id":"123","parent":"119","text":"Pérdida auditiva neurosensorial → problema cóclea/nervio (Weber lateraliza al SANO)","guid":"","children":[]},{"id":"124","parent":"119","text":"BPPV → otolitos desplazados al canal semicircular (posterior el más frecuente)","guid":"","children":[]},{"id":"125","parent":"119","text":"Test de Dix-Hallpike → diagnóstico BPPV, nistagmo geotrópico","guid":"","children":[]},{"id":"126","parent":"119","text":"Maniobra de Epley → reposicionamiento otolitos, 80% efectividad","guid":"","children":[]},{"id":"127","parent":"119","text":"Daño ototóxico (aminoglucósidos, cisplatino) → primero células ciliadas externas","guid":"","children":[]},{"id":"128","parent":"119","text":"Presbiacusia → pérdida BILATERAL simétrica alta frecuencia en >65a","guid":"","children":[]},{"id":"129","parent":"119","text":"Reflejo estapedial ausente → lesión nervio facial o cadena osicular","guid":"","children":[]},{"id":"130","parent":"119","text":"Endolinfa ↑ → hidrops endolinfático (Enfermedad de Menière)","guid":"","children":[]},{"id":"131","parent":"119","text":"Desequilibrio postural en AM → evaluar SIEMPRE canal semicircular + función macular","guid":"","children":[]}]},{"id":"132","parent":"0","text":"VER TAMBIÉN","guid":"","children":[{"id":"133","parent":"132","text":"→ Vía Vestibulocochlear (Neuroanatomía)","guid":"","children":[]},{"id":"134","parent":"132","text":"→ Síndrome de Ramsay Hunt (Neuropatología)","guid":"","children":[]},{"id":"135","parent":"132","text":"→ Schwannoma Vestibular (ORL-Oncología)","guid":"","children":[]}]},{"id":"136","parent":"0","text":"Referencias","guid":"","children":[{"id":"137","parent":"136","text":"1. Standring S. Gray's Anatomy. 41st ed. Elsevier; 2021. Chapter 36: Ear.","guid":"","children":[]},{"id":"138","parent":"136","text":"2. Dhillon RS, East CA. Ear, Nose and Throat. 5th ed. Churchill Livingstone; 2013.","guid":"","children":[]},{"id":"139","parent":"136","text":"3. Bhattacharyya N. Clinical practice guideline: benign paroxysmal positional vertigo. Otolaryngol Head Neck Surg. 2017;156(3_suppl):S1-S47.","guid":"","children":[]},{"id":"140","parent":"136","text":"4. Gates GA, Mills JH. Presbycusis. Lancet. 2005;366(9491):1111-20.","guid":"","children":[]}]}]},"node_count":140,"relations":[],"cross_references":[],"specialty":"ORL","folder":"Entidades clínicas/Otorrinolaringología","filename":"Audicion Equilibrio iPad","id":"map_1557","resolved_references":[]}