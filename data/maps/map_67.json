ext":"Mareos y prurito\\N20 a 30%","guid":"RIJbtlgprLeET-tZ38VLMQ","children":[{"id":"122","parent":"121","text":"Prevención","guid":"Gqlm7AOyJT_XuwfwHtmqfQ","children":[{"id":"123","parent":"122","text":"Líquidos abundantes","guid":"swT93fwNxMlQkLvQD1lbGw","children":[]},{"id":"124","parent":"122","text":"Higiene corporal y ropa de algodón","guid":"GeYVkF5RgVW35gpLOiiKFQ","children":[]},{"id":"125","parent":"122","text":"Acompañar a la persona enferma","guid":"NVyCGlJjQWhOlHuYlyqyvQ","children":[]}]},{"id":"126","parent":"121","text":"Manejo","guid":"03ZPMPBHIi9bZMcJR1aauQ","children":[{"id":"127","parent":"126","text":"Clorfenamina maleato ½ a 1 CMP al\\Ndesayuno y antes de dormir. C/12 hrs.","guid":"SaeiKyuOd_aGDAr6qEVXkQ","children":[]}]}]},{"id":"128","parent":"96","text":"Depresión respiratoria\\N<10%","guid":"Rhd8mhouaFafI41yGsEO-g","children":[{"id":"129","parent":"128","text":"Prevención ","guid":"PnfS9aanDD_1sm9YpZ6J5A","children":[{"id":"130","parent":"129","text":"Monitoreo continuo","guid":"cNCAoO4xo0xYjdfpkCNkfg","children":[]},{"id":"131","parent":"129","text":"Ajustar dosis opioides","guid":"OxYa6AznNSsSvN38hAUcng","children":[]}]},{"id":"132","parent":"128","text":"Manejo","guid":"ogqXhLOQpoUtm8A-ULszFw","children":[{"id":"133","parent":"132","text":"Naloxona 0.04 mg, debe estar presente\\Nen el stock de la UPAD y CP.","guid":"","children":[]}]}]}]},{"id":"134","parent":"18","text":"Paso de morfina EV","guid":"e5RAjXWpl2R6ArXY84JIcA","children":[{"id":"135","parent":"134","text":"Oral","guid":"OO3Gvd6FhJgS1eKdK4eb6A","children":[]},{"id":"136","parent":"134","text":"Transdermica","guid":"ujYO03IOHGE0VpIdXNkLjA","children":[]}]}]},{"id":"137","parent":"0","text":"Disnea","guid":"-uwXsqHCgq0fQvHxnyAI3A","children":[{"id":"138","parent":"137","text":"Definición ","guid":"Lm7BPGMhVz-dItRlrEB_Qw","children":[{"id":"139","parent":"138","text":"Sensación subjetiva de discomfort respiratorio","guid":"IJrLr6iiRo7-645QZ0NoNw","children":[]},{"id":"140","parent":"138","text":"Experimentada por casi todos los pacientes con condiciones terminales","guid":"k5xxgNK53JC1BOnWy36UrA","children":[]},{"id":"141","parent":"138","text":"Múltiples causas","guid":"AaHNRkSmSl7Ce0mF-fN0SQ","children":[]}]},{"id":"142","parent":"137","text":"Opciones de\\Nmanejo","guid":"Ffu7CIfSSIdcah8xHgJH4w","children":[{"id":"143","parent":"142","text":"Tratar a primera instancia la causa específica","guid":"G-YM_wtc1SxaUcdC7aIBDQ","children":[]},{"id":"144","parent":"142","text":"Opioides ","guid":"7v0MObXn9dLkWZOB5BrNXg","children":[{"id":"145","parent":"144","text":"Opioid naive","guid":"zd2HAAGnRTVr6P7j1_cGeg","children":[{"id":"146","parent":"145","text":"5 mg PO morphine equivalent as single dose; if tolerated, can administer every\\N4 h around the clock, hold for sedation; an additional dose every hour in\\Nbetween scheduled doses can be made available PRN for severe dyspnea","guid":"GGrJ2Uc2G203ARXZcXwcIQ","children":[]}]},{"id":"147","parent":"144","text":"Older adults, CO2 retainers, or\\Npatients with renal impairment","guid":"LYRnEsyLRGcr6Qul_NNRqw","children":[{"id":"148","parent":"147","text":"Consider reducing starting dose by half; avoid\\Nuse of morphine in renal disease","guid":"oKZJDPCMBqV9Xt_d5g2LYQ","children":[]}]},{"id":"149","parent":"144","text":"If current opioid\\Ndosage is inadequate","guid":"XAbOZf8wvzQgBj0WsABUiw","children":[{"id":"150","parent":"149","text":"Titrate by increments of\\N25% to 50% to effect","guid":"","children":[]}]},{"id":"151","parent":"144","text":"Dyspnea with exertion\\Nor movement","guid":"2hwYP-34BLNu5dGI0kh0BQ","children":[{"id":"152","parent":"151","text":"Give 30 min before activity","guid":"QVaMYTw6xLCqBJC6_zeoSQ","children":[]}]},{"id":"153","parent":"144","text":"If acutely dyspneic or\\Nactively dying","guid":"8HekXKK0ZCVxQxj8S8TDaA","children":[{"id":"154","parent":"153","text":"Use IV morphine bolus (2-5 mg or 10% of daily dosage) every 5-10 min PRN, titrate to\\Neffect (decline of self-reported dyspnea on 10-point scale); consider starting a\\Ncontinuous infusion based on the dosage needed to improve the patient's symptoms","guid":"v4ri2uKihorIMey0cGod-g","children":[]},{"id":"155","parent":"153","text":"For patients who cannot self-report, an improvement of nonverbal signs of distress or a decline in\\Nelevated respiratory rate toward the normal range may be used as surrogate markers of dyspnea","guid":"pRQAFELWxpaGUWPxve_d8A","children":[]}]},{"id":"156","parent":"144","text":"If on stable opioid dosage","guid":"1Kdpdgg54D_EIbtoGB5nXg","children":[{"id":"157","parent":"156","text":"Consider a trial of scheduled short-acting opioid or long-acting opioid\\Nas baseline, with immediate-release opioid PRN in between","guid":"hsxvO0KTFBCcLoTzAARTJA","children":[]}]}]},{"id":"158","parent":"142","text":"Benzodiazepinas","guid":"ttI1cGs56kh3urma_gpY6A","children":[]},{"id":"159","parent":"142","text":"Manejo de secreciones ","guid":"XFcf5JPpLpFmsNTZMPu2PA","children":[]},{"id":"160","parent":"142","text":"Broncodilatadores","guid":"O05waQMlCmvvqd_TxIi4Zg","children":[]},{"id":"161","parent":"142","text":"Oxígeno ","guid":"K1YEULMxWa9_lRDBu1R0ew","children":[]}]}]},{"id":"162","parent":"0","text":"Náusea y Vómitos","guid":"ajSVFNmgQ5-svX-uZk1xfA","children":[{"id":"163","parent":"162","text":"Por QT","guid":"gk9Xlei582sqhTs3xiloQg","children":[{"id":"164","parent":"163","text":"Antagonistas 5HT3\\NDomperidona","guid":"-1kaNvdImipSPxD5lohkmg","children":[]},{"id":"165","parent":"163","text":"Dexametasona","guid":"EPz7qQ-ZgBGYO3hgJ7g-FQ","children":[]}]},{"id":"166","parent":"162","text":"Por RT","guid":"MoaN7XGCXKLxY77BhYRZwQ","children":[{"id":"167","parent":"166","text":"Antagonistas 5HT3\\NDomperidona","guid":"w3POYxLCcp0VNc_yMjW8kw","children":[]}]},{"id":"168","parent":"162","text":"Por opioides o\\Nalteraciones GI","guid":"TTaiP3mR-8bHvg0yZVMnWg","children":[{"id":"169","parent":"168","text":"Antagonistas D2\\NMetoclopramida o Haloperidol","guid":"