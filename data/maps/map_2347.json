:"203","text":"Charlson >=1","guid":"","children":[]},{"id":"214","parent":"203","text":"Edad >=65 años","guid":"","children":[]},{"id":"215","parent":"203","text":"Taquicardia al ingreso","guid":"","children":[]},{"id":"216","parent":"203","text":"Lesión renal aguda","guid":"","children":[]}]},{"id":"217","parent":"197","text":"Modelos pronósticos","guid":"","children":[{"id":"218","parent":"217","text":"PESI → 11 variables + edad → Clases I-V","guid":"","children":[{"id":"219","parent":"218","text":"Limitación → complejo para uso clínico rápido","guid":"","children":[]}]},{"id":"220","parent":"217","text":"sPESI → versión\\Nsimplificada","guid":"Tu2fNTc83XUSXu21dJCxWA","children":[{"id":"221","parent":"220","text":"0 → bajo riesgo","guid":"","children":[]},{"id":"222","parent":"220","text":">=1 → alto riesgo","guid":"","children":[]},{"id":"223","parent":"220","text":"Precisión similar a PESI","guid":"","children":[]}]},{"id":"224","parent":"217","text":"BOVA score, Protect score → requieren más validación","guid":"","children":[]}]}]},{"id":"225","parent":"0","text":"Seguimiento","guid":"","children":[{"id":"226","parent":"225","text":"1 semana post-alta","guid":"","children":[]},{"id":"227","parent":"225","text":"3 meses → decisión duración anticoagulación","guid":"","children":[]},{"id":"228","parent":"225","text":"1 año → evaluación HTPC","guid":"","children":[]},{"id":"229","parent":"225","text":"Restricción viajes largos → 4 semanas (riesgo intermedio-alto)","guid":"","children":[]},{"id":"230","parent":"225","text":"Monitorización","guid":"","children":[{"id":"231","parent":"230","text":"Niveles terapéuticos ACO","guid":"","children":[]},{"id":"232","parent":"230","text":"Complicaciones TEP (recurrencia, HTPC)","guid":"","children":[]},{"id":"233","parent":"230","text":"Complicaciones terapia (sangrado, osteoporosis, trombocitopenia)","guid":"","children":[]},{"id":"234","parent":"230","text":"Necesidad anticoagulación indefinida","guid":"","children":[]},{"id":"235","parent":"230","text":"Retiro filtro IVC cuando sea posible","guid":"","children":[]},{"id":"236","parent":"230","text":"Factores predisponentes (neoplasia, trombofilia)","guid":"","children":[]}]},{"id":"237","parent":"225","text":"Disnea persistente → test marcha 6 min a 6 meses","guid":"","children":[]},{"id":"238","parent":"225","text":"Sospecha HTPC → reimaginar sin esperar","guid":"","children":[]}]},{"id":"239","parent":"0","text":"Manejo\\NRecurrencia en\\NTerapia","guid":"oQUm-jw1yIGuylsbRzOXaw","children":[{"id":"240","parent":"239","text":"Causa más común →\\NANTICOAGULACIÓN\\NSUBTERAPÉUTICA","guid":"qytmJD3ouM8L1WYZFZBafA","children":[{"id":"241","parent":"240","text":"Malabsorción (ej: rivaroxabán sin alimentos)","guid":"","children":[]},{"id":"242","parent":"240","text":"Suspensión por procedimientos","guid":"","children":[]},{"id":"243","parent":"240","text":"Mala adherencia","guid":"","children":[]},{"id":"244","parent":"240","text":"Cambio farmacocinético (warfarina → vitamina K dietaria)","guid":"","children":[]},{"id":"245","parent":"240","text":"Interacciones medicamentosas con ACOD","guid":"","children":[]},{"id":"246","parent":"240","text":"Dosis incorrecta","guid":"","children":[]}]},{"id":"247","parent":"239","text":"Si HNF subterapéutica → aumentar dosis rápidamente","guid":"","children":[]},{"id":"248","parent":"239","text":"Si HBPM/ACOD sospecha subterapéutico → cambiar a HNF monitorizable","guid":"","children":[]},{"id":"249","parent":"239","text":"Terapia subóptima → filtro IVC o embolectomía sin ACO posterior","guid":"","children":[]},{"id":"250","parent":"239","text":"Estímulos protrombóticos persistentes","guid":"","children":[{"id":"251","parent":"250","text":"Neoplasia, síndrome May-Thurner, trombofilias, SAF","guid":"","children":[]}]},{"id":"252","parent":"239","text":"Diagnóstico erróneo → embolia tumoral o grasa","guid":"","children":[]}]},{"id":"253","parent":"0","text":"Consideraciones\\NGeriátricas","guid":"KZg3NMwkmboB2Vp95P-5nQ","children":[{"id":"254","parent":"253","text":"PESI sobreestima riesgo en AM (edad pesa mucho en score)","guid":"","children":[]},{"id":"255","parent":"253","text":"Respuesta FC puede estar atenuada (betabloqueadores, cardiopatía basal)","guid":"","children":[]},{"id":"256","parent":"253","text":"FRAGILIDAD → considerar CFS en decisiones terapéuticas","guid":"","children":[]},{"id":"257","parent":"253","text":"Función renal → ajuste HBPM, precaución con ACOD","guid":"","children":[]},{"id":"258","parent":"253","text":"Polifarmacia → interacciones con anticoagulantes","guid":"","children":[]},{"id":"259","parent":"253","text":"Riesgo sangrado aumentado → balancear con riesgo recurrencia","guid":"","children":[]},{"id":"260","parent":"253","text":"Deprescripción de antiagregantes si se inicia ACO","guid":"","children":[]},{"id":"261","parent":"253","text":"Delirium post-TEP → buscar activamente (CAM-ICU)","guid":"","children":[]},{"id":"262","parent":"253","text":"Caídas → no son contraindicación absoluta de ACO","guid":"","children":[]},{"id":"263","parent":"253","text":"Proporcionalidad terapéutica → considerar pronóstico global","guid":"","children":[]}]},{"id":"264","parent":"0","text":"Perlas Clínicas","guid":"","children":[{"id":"265","parent":"264","text":"Muerte por TEP alto riesgo ocurre en primeras 2h → ACTUAR RÁPIDO","guid":"","children":[]},{"id":"266","parent":"264","text":"Resucitación agresiva con volumen EMPEORA falla VD → bolos pequeños","guid":"","children":[]},{"id":"267","parent":"264","text":"Norepinefrina primera línea en shock por TEP (no dopamina)","guid":"","children":[]},{"id":"268","parent":"264","text":"sPESI = 0 NO descarta disfunción VD → evaluar con eco si duda","guid":"","children":[]},{"id":"269","parent":"264","text":"Taquicardia >120 + caída SaO2 = precursores de colapso → escalar","guid":"","children":[]},{"id":"270","parent":"264","text":"PESI sobreestima mortalidad en AM por peso de edad en score","guid":"","children":[]},{"id":"271","parent":"264","text":"Hemoptisis por infarto pulmonar NO es contraindicación de ACO","guid":"","children":[]},{"id":"272","parent":"264","text":"CDI en TEP riesgo intermedio-alto → menor sangrado que trombolisis sistémica","guid":"","children":[]},{"id":"273","parent":"264","text":"Filtro IVC + ACO no superior a ACO sola (PREPIC2)","guid":"","children":[]},{"id":"274","parent":"264","text":"HTPC → disnea progresiva primeros 2 años → screening activo","guid":"","children":[]},{"id":"275","parent":"264","text":"AM frágil con TEP → proporcionalidad terapéutica antes de escalar","guid":"","children":[]},{"id":"276","parent":"264","text":"ECMO V-A → puente, no tratamiento definitivo","guid":"","children":[]},{"id":"277","parent":"264","text":"Caídas frecuentes en AM NO son contraindicación absoluta de ACO","guid":"","children":[]}]},{"id":"278","parent":"0","text":"Referencias","guid":"","children":[{"id":"279","parent":"278","text":"1. Weinberg AS, Rali P. Overview of treatment of acute PE. UpToDate. Updated Mar 2026.","guid":"","children":[]},{"id":"280","parent":"278","text":"2. Konstantinides SV et al. 2019 ESC Guidelines for diagnosis and management of acute PE. Eur Heart J. 2020;41(4):543-603.","guid":"","children":[]},{"id":"281","parent":"278","text":"3. Stevens SM et al. AHA/ACC/ACCP/CHEST guideline for management of PE. Circulation. 2026.","guid":"","children":[]},{"id":"282","parent":"278","text":"4. Anan H et al. Catheter-directed interventions vs surgical embolectomy in massive PE. J Vasc Surg Venous Lymphat Disord. 2025;14(2):102379.","guid":"","children":[]},{"id":"283","parent":"278","text":"5. Senosy TM et al. EKOS catheter-directed thrombolysis vs systemic alteplase in acute PE. Front Pharmacol. 2026;16:1709708.","guid":"","children":[]},{"id":"284","parent":"278","text":"6. Pot L et al. Catheter-directed vs standard therapy in intermediate-high-risk PE. Arch Cardiovasc Dis. 2025.","guid":"","children":[]},{"id":"285","parent":"278","text":"7. Kearon C et al. Antithrombotic therapy for VTE disease: CHEST Guideline. Chest. 2016;149(2):315-352.","guid":"","children":[]},{"id":"286","parent":"278","text":"8. Mismetti P et al. Effect of a retrievable IVC filter plus ACO vs ACO alone (PREPIC2). JAMA. 2015;313(16):1627-35.","guid":"","children":[]}]}]},"node_count":286,"relations":[],"cross_references":[],"specialty":"UCI/Medicina Crítica","folder":"Entidades clínicas/UCI-Medicina Crítica","filename":"TEP Agudo Tratamiento iPad","id":"map_2347","resolved_references":[],"title_raw":"TEP Agudo Tratamiento iPad"}