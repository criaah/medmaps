{"title":"Omc","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Entidades clínicas/General/omc iPad.smmx","root":{"id":"0","parent":"-1","text":"Otitis Media\\NCrónica","guid":"zmZBnuqxJbntr05H110bYQ","children":[{"id":"1","parent":"0","text":"Definición y\\NClasificación","guid":"YYsvyxYuPeoa1gU46hQTlA","children":[{"id":"2","parent":"1","text":"OMC = inflamación crónica del oído medio > 3 meses","guid":"","children":[]},{"id":"3","parent":"1","text":"CLASIFICACIÓN\\NPRINCIPAL","guid":"KK3lteeExNFrW2tYHZRNjw","children":[{"id":"4","parent":"3","text":"OMC sin colesteatoma\\N(tubotimpánica)","guid":"w5w5IFvBY2qe80e1RvRzxA","children":[{"id":"5","parent":"4","text":"Perforación central → microorganismos externos","guid":"","children":[]},{"id":"6","parent":"4","text":"Otorrea mucopurulenta intermitente","guid":"","children":[]},{"id":"7","parent":"4","text":"Hipoacusia conductiva variable","guid":"","children":[]},{"id":"8","parent":"4","text":"PRONÓSTICO: generalmente favorable","guid":"","children":[]}]},{"id":"9","parent":"3","text":"OMC con colesteatoma\\N(aticoantral)","guid":"UPlI9oDXU9fPCEUN6H4YMQ","children":[{"id":"10","parent":"9","text":"Perforación marginal o ática → epitelio escamoso","guid":"","children":[]},{"id":"11","parent":"9","text":"Colesteatoma = queratina acumulada → erosión ósea","guid":"","children":[]},{"id":"12","parent":"9","text":"DESTRUCTIVA → complicaciones graves","guid":"","children":[]},{"id":"13","parent":"9","text":"Requiere cirugía ineludible","guid":"","children":[]}]}]},{"id":"14","parent":"1","text":"OMC supurativa crónica\\N(OMSC)","guid":"p4n9-btXA4f6y3dX6YCOtw","children":[{"id":"15","parent":"14","text":"Definición: perforación + otorrea crónica/recurrente","guid":"","children":[]},{"id":"16","parent":"14","text":"Alta carga sanitaria → promedio 9.5 visitas, 1.7 cirugías/paciente","guid":"","children":[]},{"id":"17","parent":"14","text":"41% desarrolla hipoacusia neurosensorial moderada-severa","guid":"","children":[]}]},{"id":"18","parent":"1","text":"Disfunción\\Ntubaria crónica","guid":"7lZxNODsVokdfVyGs5EraA","children":[{"id":"19","parent":"18","text":"Retracción timpánica → martillo mediatizado","guid":"","children":[]},{"id":"20","parent":"18","text":"Sin perforación pero con fisiopatología obstructiva crónica","guid":"","children":[]},{"id":"21","parent":"18","text":"HALLAZGO DEL CASO: OD martillo mediatizado = compatible con OMC","guid":"","children":[]}]}]},{"id":"22","parent":"0","text":"Epidemiología y\\NFactores de Riesgo","guid":"ZlWWH7g_GVZkZHCU_Jv7OA","children":[{"id":"23","parent":"22","text":"Prevalencia global OMC ~1-5% de la población","guid":"","children":[]},{"id":"24","parent":"22","text":"Mayor prevalencia en países en desarrollo","guid":"","children":[]},{"id":"25","parent":"22","text":"Factores\\Nde riesgo","guid":"7Wc2KaBbWheqEah6pNkGYQ","children":[{"id":"26","parent":"25","text":"Otitis medias agudas a repetición","guid":"","children":[]},{"id":"27","parent":"25","text":"Disfunción tubaria crónica","guid":"","children":[]},{"id":"28","parent":"25","text":"Inmunodeficiencia, diabetes","guid":"","children":[]},{"id":"29","parent":"25","text":"Condiciones socioeconómicas adversas","guid":"","children":[]},{"id":"30","parent":"25","text":"Exposición a tabaco","guid":"","children":[]}]},{"id":"31","parent":"22","text":"En adulto\\Nmayor","guid":"H1QqDc8-2EWaYsn4NE72Xg","children":[{"id":"32","parent":"31","text":"OMC de larga data → mayor carga de comorbilidades","guid":"","children":[]},{"id":"33","parent":"31","text":"Hipoacusia mixta → conductiva + neurosensorial acumulada","guid":"","children":[]},{"id":"34","parent":"31","text":"Mayor riesgo de otorrea refractaria","guid":"","children":[]}]}]},{"id":"35","parent":"0","text":"Fisiopatología","guid":"","children":[{"id":"36","parent":"35","text":"VÍA\\NTUBOTIMPÁNICA","guid":"zQNFHTT606v-7cWN3GqziQ","children":[{"id":"37","parent":"36","text":"Disfunción tuba auditiva → presión negativa oído medio","guid":"","children":[]},{"id":"38","parent":"36","text":"Retracción timpánica progresiva","guid":"","children":[]},{"id":"39","parent":"36","text":"Derrame → inflamación crónica → perforación","guid":"","children":[]}]},{"id":"40","parent":"35","text":"VÍA\\NATICOANTRAL","guid":"x_lXB55rTOlCA6j0G5tLKQ","children":[{"id":"41","parent":"40","text":"Bolsa de retracción → migración de epitelio escamoso","guid":"","children":[]},{"id":"42","parent":"40","text":"Colesteatoma: enzimas proteolíticas → erosión osicular y pared","guid":"","children":[]},{"id":"43","parent":"40","text":"Exposición a Pseudomonas y Staphylococcus aureus","guid":"","children":[]}]},{"id":"44","parent":"35","text":"DAÑO\\NAUDITIVO","guid":"dEvscvdmtEz0u59MLlz5QA","children":[{"id":"45","parent":"44","text":"Hipoacusia conductiva → interrupción cadena osicular","guid":"","children":[]},{"id":"46","parent":"44","text":"Hipoacusia neurosensorial → toxinas, fístula laberíntica, inflamación coclear","guid":"","children":[]},{"id":"47","parent":"44","text":"Hipoacusia mixta → patrón más común en OMC de larga evolución","guid":"","children":[]}]},{"id":"48","parent":"35","text":"COMPLICACIONES POTENCIALES\\N(señales de alarma)","guid":"BRdvUtDo1GFMtBbvjgUmFw","children":[{"id":"49","parent":"48","text":"Vértigo → fístula canal semicircular lateral (más frecuente)","guid":"","children":[]},{"id":"50","parent":"48","text":"Parálisis facial → erosión canal de Falopio","guid":"","children":[]},{"id":"51","parent":"48","text":"Cefalea + fiebre → meningitis, absceso cerebral","guid":"","children":[]},{"id":"52","parent":"48","text":"Otorrea refractaria → OME necrotizante","guid":"","children":[]}]}]},{"id":"53","parent":"0","text":"Diagnóstico","guid":"","children":[{"id":"54","parent":"53","text":"OTOSCOPIA →\\Nexamen central","guid":"KtkW9hVc102vrv4CypM2jQ","children":[{"id":"55","parent":"54","text":"Perforación central → tubotimpánica","guid":"","children":[]},{"id":"56","parent":"54","text":"Perforación marginal/ática → colesteatoma","guid":"","children":[]},{"id":"57","parent":"54","text":"Retracción timpánica → grados I-IV (Sade)","guid":"","children":[]},{"id":"58","parent":"54","text":"Martillo mediatizado → tímpano retraído sobre mango → sugiere disfunción tubaria crónica","guid":"","children":[]},{"id":"59","parent":"54","text":"Colesteatoma: escama blancogrisácea, ática","guid":"","children":[]},{"id":"60","parent":"54","text":"Tejido de granulación → sospechar OMNE si diabético/inmunocomprometido","guid":"","children":[]}]},{"id":"61","parent":"53","text":"AUDIOMETRÍA","guid":"","children":[{"id":"62","parent":"61","text":"Hipoacusia conductiva → gap aéreo-óseo","guid":"","children":[]},{"id":"63","parent":"61","text":"Hipoacusia neurosensorial → por extensión coclear","guid":"","children":[]},{"id":"64","parent":"61","text":"Hipoacusia mixta → PATRÓN DEL CASO (usuaria de audífonos bilateral)","guid":"","children":[]},{"id":"65","parent":"61","text":"Audiometría de palabras → discriminación (relevante para pronóstico de audífonos)","guid":"","children":[]}]},{"id":"66","parent":"53","text":"IMPEDANCIOMETRÍA","guid":"","children":[{"id":"67","parent":"66","text":"Timpanograma tipo B → efusión","guid":"","children":[]},{"id":"68","parent":"66","text":"Tipo C → presión negativa, retracción","guid":"C8T_fE5zaEmwJWtk8uEj3g","children":[]},{"id":"69","parent":"66","text":"Reflejo estapedial → ausente en hipoacusia conductiva","guid":"","children":[]}]},{"id":"70","parent":"53","text":"IMÁGENES","guid":"","children":[{"id":"71","parent":"70","text":"TC de hueso temporal → gold standard para evaluar extensión","guid":"","children":[]},{"id":"72","parent":"70","text":"Indicaciones: sospecha de colesteatoma, complicaciones, preoperatorio","guid":"","children":[]},{"id":"73","parent":"70","text":"RM con difusión (DWI) → detecta colesteatoma residual/recurrente (evita segunda cirugía)","guid":"","children":[]}]},{"id":"74","parent":"53","text":"Microbiología\\N(otorrea activa)","guid":"IQ_xvLrowriJdLZyheQQbA","children":[{"id":"75","parent":"74","text":"Pseudomonas aeruginosa → más frecuente","guid":"","children":[]},{"id":"76","parent":"74","text":"Staphylococcus aureus (incluyendo MRSA)","guid":"","children":[]},{"id":"77","parent":"74","text":"Proteus mirabilis, anaerobios","guid":"","children":[]}]}]},{"id":"78","parent":"0","text":"Manejo\\NMédico","guid":"L1UBSi8-JeVIKTOZu7hzFw","children":[{"id":"79","parent":"78","text":"MANEJO LOCAL →\\Nprimera línea en fase activa","guid":"pGQj9FbiO2bH8c6BrcAkew","children":[{"id":"80","parent":"79","text":"Aseo ótico cuidadoso → microaspiración bajo otomicroscopio","guid":"","children":[]},{"id":"81","parent":"79","text":"Quinolonas tópicas →\\Nciprofloxacino 0.3% gotas →\\Nprimera línea","guid":"cWi_ixmebia4UorvFunjxQ","children":[{"id":"82","parent":"81","text":"Superioridad sobre aminoglucósidos tópicos + sin ototoxicidad","guid":"","children":[]},{"id":"83","parent":"81","text":"Solución ácido acético (Oticum) → alternativa antiséptica","guid":"","children":[]}]},{"id":"84","parent":"79","text":"EVITAR aminoglucósidos tópicos en perforación timpánica","guid":"","children":[]}]},{"id":"85","parent":"78","text":"MANEJO\\NSISTÉMICO","guid":"t9iI-CCigRp_PBK9zrWnpA","children":[{"id":"86","parent":"85","text":"Indicaciones: signos de complicación, afección mastoidea, falla a tópico","guid":"","children":[]},{"id":"87","parent":"85","text":"Ciprofloxacino oral 500-750mg c/12h x 2 semanas","guid":"","children":[]},{"id":"88","parent":"85","text":"Amoxicilina-clavulánico si no hay respuesta a quinolona","guid":"","children":[]}]},{"id":"89","parent":"78","text":"CONTROL DE FACTORES\\NPREDISPONENTES","guid":"kCxZF6A_nWmbUtwv_17DQA","children":[{"id":"90","parent":"89","text":"Tratar rinitis y disfunción tubaria asociada","guid":"","children":[]},{"id":"91","parent":"89","text":"Control de comorbilidades (DM → glucemia)","guid":"","children":[]},{"id":"92","parent":"89","text":"No introducir agua al oído → tapón de silicona para baño","guid":"","children":[]}]}]},{"id":"93","parent":"0","text":"Manejo\\NQuirúrgico","guid":"VbVdl6Zo8kt_MET1mNqV7A","children":[{"id":"94","parent":"93","text":"TIMPANOPLASTIA","guid":"","children":[{"id":"95","parent":"94","text":"Objetivo: cierre de perforación + rehabilitación auditiva","guid":"","children":[]},{"id":"96","parent":"94","text":"Injerto: fascia de temporal, pericondrio, cartílago","guid":"","children":[]},{"id":"97","parent":"94","text":"Tipos I-V (clasificación de Wullstein)","guid":"","children":[]},{"id":"98","parent":"94","text":"CASO: timpanoplastia OD previa → evaluar éxito anatómico y funcional","guid":"","children":[]},{"id":"99","parent":"94","text":"Tasa éxito anatómico ~80-90% en primera cirugía","guid":"","children":[]}]},{"id":"100","parent":"93","text":"TIMPANOSIMPANOSTOMÍA MASTOIDEA\\N(miringoplastia + mastoidectomía)","guid":"EFMaJ48PF4Ftcn7TKAO8_g","children":[{"id":"101","parent":"100","text":"Indicada en colesteatoma, OMC con compromiso mastoideo","guid":"","children":[]},{"id":"102","parent":"100","text":"Canal wall up (CWU) → preserva pared canal → segunda cirugía a 12 meses para revisión","guid":"","children":[]},{"id":"103","parent":"100","text":"Canal wall down (CWD) → cavidad radical → mayor control, más morbilidad","guid":"","children":[]},{"id":"104","parent":"100","text":"Obliteración de cavidad mastoidea → ↑ capacidad de usar audífono convencional (3% → 57%)","guid":"","children":[]}]},{"id":"105","parent":"93","text":"CIRUGÍA DE\\NCOLESTEATOMA","guid":"nTN6T8lpoQis2OAkyG3NlQ","children":[{"id":"106","parent":"105","text":"Mastoidectomía canal wall down → gold standard en colesteatoma extenso","guid":"VP4eZtgFOnCREOKd9qLwGA","children":[]},{"id":"107","parent":"105","text":"Cierre de fístula → fascia temporal + polvo óseo → preserva umbrales óseos","guid":"","children":[]},{"id":"108","parent":"105","text":"Seguimiento: NF + RM DWI a los 12-18 meses (recurrencia hasta 30%)","guid":"","children":[]},{"id":"109","parent":"105","text":"Factores pronósticos para cirugía de revisión: aireación cavidad timpánica (OR 13.3), ausencia ocupación ventana oval (OR 13.4)","guid":"","children":[]}]},{"id":"110","parent":"93","text":"REHABILITACIÓN AUDITIVA\\NPOST-QUIRÚRGICA","guid":"7fYBQuWPPSu0o41vRrZsLA","children":[{"id":"111","parent":"110","text":"Audífono convencional → si gap residual o HNSN post-cirugía","guid":"","children":[]},{"id":"112","parent":"110","text":"BAHA (Bone-Anchored Hearing Aid) → en cavidades radicales sin posibilidad de audífono aéreo","guid":"","children":[]},{"id":"113","parent":"110","text":"Implante osteointegrado → indicación cuando audífono convencional no tolerable","guid":"fIRUdNlOduQ7nzpLAzRhjQ","children":[]}]}]},{"id":"114","parent":"0","text":"Rehabilitación Auditiva\\N(Foco del Caso)","guid":"whI4ldWNbmtpCkhBqOubeA","children":[{"id":"115","parent":"114","text":"PACIENTE USUARIA DE\\NAUDÍFONOS BILATERAL","guid":"i_BHg6KHUkMk1i3GlqxjQA","children":[{"id":"116","parent":"115","text":"Indicación de audífonos aun con OMC en fase seca → mejorar función auditiva","guid":"","children":[]},{"id":"117","parent":"115","text":"Condición: oído seco, sin perforación activa, sin otorrea","guid":"vKgFqIJlgyMmXg_THA1wMg","children":[]},{"id":"118","parent":"115","text":"Evaluar tipo de audífono según anatomía del CAE y presencia de cavidad","guid":"","children":[]}]},{"id":"119","parent":"114","text":"AUDÍFONO CONVENCIONAL\\N(vía aérea)","guid":"df2QYAzsDdUYNZg3DDAB0Q","children":[{"id":"120","parent":"119","text":"Primer escalón si umbral conversacional > 35 dB y discriminación adecuada","guid":"","children":[]},{"id":"121","parent":"119","text":"Precaución en cavidades radicales → irritación, otorrea","guid":"","children":[]},{"id":"122","parent":"119","text":"Preferir molde cerrado en hipoacusia conductiva","guid":"","children":[]}]},{"id":"123","parent":"114","text":"DISPOSITIVOS DE\\NCONDUCCIÓN ÓSEA","guid":"L4SEGxZbUrronfpKWlEQTw","children":[{"id":"124","parent":"123","text":"BAHA o Osia → indicados cuando audífono convencional no viable","guid":"","children":[]},{"id":"125","parent":"123","text":"Oído seco obligatorio para BAHA externo","guid":"","children":[]}]},{"id":"126","parent":"114","text":"EN ADULTO MAYOR\\NUSUARIO DE AUDÍFONOS","guid":"m2ENz--0Z598-NgC_K81og","children":[{"id":"127","parent":"126","text":"Hipoacusia bilateral en OMC → componente mixto → ajuste específico","guid":"","children":[]},{"id":"128","parent":"126","text":"Verificar anatomía del CAE para molde (cavidad radical = molde personalizado)","guid":"","children":[]},{"id":"129","parent":"126","text":"Audífonos mejoran estabilidad postural → reduce riesgo de caídas","guid":"","children":[]}]}]},{"id":"130","parent":"0","text":"Consideraciones\\NGeriátricas","guid":"iVx47Tm6MgijMAIvNfTqjA","children":[{"id":"131","parent":"130","text":"OMC en adulto mayor →\\Nenfermedad de larga data","guid":"4DilS094oAn_UOputkSf1g","children":[{"id":"132","parent":"131","text":"Múltiples cirugías previas frecuentes","guid":"","children":[]},{"id":"133","parent":"131","text":"Hipoacusia mixta progresiva con impacto funcional mayor","guid":"","children":[]},{"id":"134","parent":"131","text":"Mayor riesgo de deterioro cognitivo asociado a hipoacusia","guid":"","children":[]}]},{"id":"135","parent":"130","text":"AUDÍFONOS EN OMC\\N→ prioridad funcional","guid":"QJ2ap_zCbj4TzjdW5yp3nQ","children":[{"id":"136","parent":"135","text":"No esperar cirugía para prescribir audífonos si oído seco","guid":"","children":[]},{"id":"137","parent":"135","text":"Evaluar habilidad manual para manejo del audífono","guid":"","children":[]},{"id":"138","parent":"135","text":"Considerar audífonos con control de feedback (cavidades son inestables acústicamente)","guid":"","children":[]}]},{"id":"139","parent":"130","text":"EVALUACIÓN\\NPRE-QUIRÚRGICA","guid":"zs90_ltrCbLwnTLiphRsmg","children":[{"id":"140","parent":"139","text":"VGI preoperatoria si cirugía planificada","guid":"","children":[]},{"id":"141","parent":"139","text":"Fragilidad → predice complicaciones perioperatorias","guid":"","children":[]},{"id":"142","parent":"139","text":"Anestesia local con sedación consciente → opción viable en AM frágil","guid":"","children":[]}]},{"id":"143","parent":"130","text":"POLIFARMACIA\\NY OMC","guid":"ktWB27Y90Y86BJ971GNy-g","children":[{"id":"144","parent":"143","text":"Evitar gotas con aminoglucósidos (gentamicina, neomicina) en perforación → ototoxicidad","guid":"","children":[]},{"id":"145","parent":"143","text":"AINEs → pueden enmascarar dolor en complicaciones","guid":"","children":[]},{"id":"146","parent":"143","text":"Corticoides sistémicos → precaución en diabético (hiperglicemia)","guid":"","children":[]}]},{"id":"147","parent":"130","text":"IMPACTO\\NFUNCIONAL","guid":"a6lXPwYY_9pz5BxXMQX4fg","children":[{"id":"148","parent":"147","text":"Hipoacusia → aislamiento → depresión → deterioro cognitivo","guid":"","children":[]},{"id":"149","parent":"147","text":"Infecciones crónicas → descompensación de comorbilidades","guid":"","children":[]},{"id":"150","parent":"147","text":"Cirugías repetidas → ansiedad, dependencia","guid":"","children":[]}]}]},{"id":"151","parent":"0","text":"Perlas\\NClínicas","guid":"nUAF2oYKeRxfLqNAWyx3Kw","children":[{"id":"152","parent":"151","text":"Martillo mediatizado = tímpano retraído sobre mango → OMC sin perforación pero con fisiopatología activa","guid":"","children":[]},{"id":"153","parent":"151","text":"Todo AM con OMC activa → primero secar el oído, LUEGO ajustar audífono","guid":"","children":[]},{"id":"154","parent":"151","text":"NUNCA usar aminoglucósidos tópicos si hay perforación → ototoxicidad coclear irreversible","guid":"","children":[]},{"id":"155","parent":"151","text":"Colesteatoma no huele, huele la infección que lo acompaña → otorrea fétida SIEMPRE sospecha colesteatoma","guid":"","children":[]},{"id":"156","parent":"151","text":"OMC en diabético con otorrea refractaria + tejido de granulación → descartar OMNE (otitis externa necrotizante)","guid":"","children":[]},{"id":"157","parent":"151","text":"Audífono convencional tolerable en OMC seca con cavidad si molde personalizado bien ajustado","guid":"","children":[]},{"id":"158","parent":"151","text":"Hipoacusia mixta en AM con OMC previa → audífono primero, cirugía si hay colesteatoma activo","guid":"","children":[]},{"id":"159","parent":"151","text":"Timpanoplastia previa fallida → no contraindica nuevo intento → evaluar con TC antes de reintervenir","guid":"","children":[]},{"id":"160","parent":"151","text":"RM DWI secuencia no eco planar → detecta colesteatoma residual > 3mm sin segunda cirugía exploratoria","guid":"","children":[]}]},{"id":"161","parent":"0","text":"VER\\NTAMBIÉN","guid":"9yR84vko7Fow-DY57C3xJQ","children":[{"id":"162","parent":"161","text":"→ Presbiacusia - Módulo 2 (Oído)","guid":"","children":[]},{"id":"163","parent":"161","text":"→ Presbistasis - Módulo 2 (Oído)","guid":"","children":[]},{"id":"164","parent":"161","text":"→ Otitis Externa Necrotizante - Módulo 2 (Oído Externo)","guid":"","children":[]},{"id":"165","parent":"161","text":"→ Rehabilitación Auditiva y Audífonos (Módulo 2)","guid":"","children":[]},{"id":"166","parent":"161","text":"→ VGI preoperatoria - Módulo 7 (Integración)","guid":"","children":[]}]},{"id":"167","parent":"0","text":"Referencias","guid":"","children":[{"id":"168","parent":"167","text":"1. Thai A, Aaron KA, Kaufman AC, Santa Maria PL. Long-Term Health Utilization and Outcomes in Chronic Suppurative Otitis Media. Otolaryngol Head Neck Surg. 2022;167(2):341-349. PMID: 34637356. DOI: 10.1177/01945998211050626","guid":"","children":[]},{"id":"169","parent":"167","text":"2. Geerse S, Bost TJM, et al. Hearing and hearing rehabilitation after obliteration of troublesome mastoid cavities. Eur Arch Otorhinolaryngol. 2021;277(12):3307-3313. PMID: 32444965. DOI: 10.1007/s00405-020-06041-4","guid":"","children":[]},{"id":"170","parent":"167","text":"3. Motegi M, Yamamoto Y, et al. Radiological and audiological prediction for hearing outcome in cholesteatoma recidivism surgery. Eur Arch Otorhinolaryngol. 2023;280(6):2715-2724. PMID: 36436081. DOI: 10.1007/s00405-022-07760-6","guid":"","children":[]},{"id":"171","parent":"167","text":"4. Savaş Ö, et al. Chronic otitis media with cholesteatoma: management of lateral semicircular canal fistulas. Medicine (Baltimore). 2025;104(48):e46190. PMID: 41327670. DOI: 10.1097/MD.0000000000046190","guid":"","children":[]},{"id":"172","parent":"167","text":"5. Bareiss A, Nieman CL, Emmett SD. Otolaryngology in Older Adults. En: Brocklehurst Textbook of Geriatric Medicine. Cap. 12.","guid":"","children":[]}]}]},"node_count":172,"relations":[],"cross_references":[],"specialty":"General","folder":"Entidades clínicas/General","filename":"omc iPad","id":"map_897","resolved_references":[],"title_raw":"omc iPad"}