{"title":"DAPA-HF","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Entidades clínicas/Cardiología/DAPA-HF.smmx","root":{"id":"0","parent":"-1","text":"DAPA-HF (2019)\\N\\n⭐ iSGLT2 en IC\\nindependiente de diabetes\\N\\nDapagliflozina en ICFEr","guid":"DAPA-ROOT","children":[{"id":"1","parent":"0","text":"📋 IDENTIFICACIÓN","guid":"DAPA-ID","children":[{"id":"2","parent":"1","text":"NEJM 2019;381:1995-2008\\n20 países, 410 centros","guid":"DAPA-ID1","children":[]},{"id":"3","parent":"1","text":"Financiado por AstraZeneca\\nSeguimiento: 18.2 meses","guid":"DAPA-ID2","children":[]}]},{"id":"4","parent":"0","text":"👥 POBLACIÓN","guid":"DAPA-POB","children":[{"id":"5","parent":"4","text":"n = 4744\\nICFEr NYHA II-IV\\nFEVI ≤40%","guid":"DAPA-P1","children":[]},{"id":"6","parent":"4","text":"42% SIN diabetes ⭐\\nEdad media: 66 años\\n77% hombres","guid":"DAPA-P2","children":[]}]},{"id":"7","parent":"0","text":"💊 INTERVENCIÓN","guid":"DAPA-INT","children":[{"id":"8","parent":"7","text":"Dapagliflozina 10 mg/día\\nvs Placebo","guid":"DAPA-I1","children":[]},{"id":"9","parent":"7","text":"Sobre terapia óptima:\\n96% IECA/ARA2/ARNI\\n96% BB, 71% ARM","guid":"DAPA-I2","children":[]}]},{"id":"10","parent":"0","text":"📊 OUTCOMES","guid":"DAPA-OUT","children":[{"id":"11","parent":"10","text":"Outcome primario ⭐\\nMuerte CV + Hosp IC\\nHR 0.74 (0.65-0.85) p menor 0.001\\nNNT = 21","guid":"DAPA-O1","children":[]},{"id":"12","parent":"10","text":"Subgrupo sin DM ⭐\\nBeneficio IGUAL que con DM\\nHR 0.73 (0.60-0.88)","guid":"DAPA-O2","children":[]},{"id":"13","parent":"10","text":"Muerte CV: HR 0.82\\nMuerte total: HR 0.83","guid":"DAPA-O3","children":[]}]},{"id":"14","parent":"0","text":"⚠️ SEGURIDAD","guid":"DAPA-SEG","children":[{"id":"15","parent":"14","text":"Depleción volumen: 7.5% vs 6.8%\\nInfecciones genitales: 0.9% vs 0.4%\\nCetoacidosis: muy rara","guid":"DAPA-S1","children":[]},{"id":"16","parent":"14","text":"MENOS insuficiencia renal\\nque placebo (6.5% vs 7.2%)","guid":"DAPA-S2","children":[]}]},{"id":"17","parent":"0","text":"🏥 GERIATRÍA","guid":"DAPA-GER","children":[{"id":"18","parent":"17","text":"Subgrupo ≥65 años\\nBeneficio consistente\\nHR 0.73 (0.63-0.86)","guid":"DAPA-G1","children":[]},{"id":"19","parent":"17","text":"Ventajas ancianos:\\n• Una vez al día\\n• Sin hipotensión significativa\\n• Protección renal","guid":"DAPA-G2","children":[]}]},{"id":"20","parent":"0","text":"💎 PERLAS CLÍNICAS","guid":"DAPA-PERLAS","children":[{"id":"21","parent":"20","text":"1. Funciona SIN diabetes\\nMecanismo cardíaco directo","guid":"DAPA-PE1","children":[]},{"id":"22","parent":"20","text":"2. Beneficio rápido (semanas)\\nNo esperar meses","guid":"DAPA-PE2","children":[]},{"id":"23","parent":"20","text":"3. Cuarto pilar ICFEr\\nARNI + BB + ARM + iSGLT2","guid":"DAPA-PE3","children":[]}]}]},"node_count":23,"relations":[],"cross_references":[],"specialty":"Cardiología","folder":"Entidades clínicas/Cardiología","filename":"DAPA-HF","id":"map_274","resolved_references":[]}