SbGWt9niWbnoKQ","children":[]}]},{"id":"104","parent":"101","text":"Triptasa serica","guid":"UTzf1goJRauroenKneEwpQ","children":[{"id":"105","parent":"104","text":"GOLD STANDARD bioquimico","guid":"IXK9E2pVQyeDeCT0d_0P4g","children":[]},{"id":"106","parent":"104","text":"Medir dentro de 1-2 h del inicio (pico 1-2h)","guid":"ePaRUaLOSOiy639I612cTg","children":[]},{"id":"107","parent":"104","text":"Segundo nivel basal a las 24h","guid":"QWa3XmZlRpintjBLCK4Lqg","children":[]},{"id":"108","parent":"104","text":"Formula: triptasa aguda >1.2x basal + 2 ng/mL","guid":"iNU8EOSTRpunO9pLfdbruA","children":[]},{"id":"109","parent":"104","text":"Util para confirmar diagnostico retrospectivo","guid":"Vi2BBfnfSM2qqCeiatbtEQ","children":[]},{"id":"110","parent":"104","text":"LIMITACION → puede ser normal en anafilaxia alimentaria","guid":"n39aMYcVRBKqEWVblndrPA","children":[]}]},{"id":"111","parent":"101","text":"Histamina plasmatica","guid":"sWGtmHElQOOR_AO9QhbV7A","children":[{"id":"112","parent":"111","text":"Pico a los 5-10 min, desaparece en 30-60 min","guid":"Qb6qGLEkRNCTB_s1T-lcqA","children":[]},{"id":"113","parent":"111","text":"Poco util en practica clinica (ventana muy corta)","guid":"1EjJIp18SJe8neDicqnmCA","children":[]}]},{"id":"114","parent":"101","text":"Diagnostico diferencial","guid":"I_aoQbowSYGdYZ5E_X8Xqg","children":[{"id":"115","parent":"114","text":"Sindrome vasovagal → bradicardia (vs taquicardia en anafilaxia)","guid":"9RmZb4ztTbir0_2U3gsJLQ","children":[]},{"id":"116","parent":"114","text":"Crisis de panico/ansiedad","guid":"TgmcF0M3SDWusXUuRuDQzg","children":[]},{"id":"117","parent":"114","text":"Angioedema hereditario (sin urticaria, sin respuesta a adrenalina)","guid":"fe0soqUkS6aL6gL6OELXcQ","children":[]},{"id":"118","parent":"114","text":"Sindrome carcinoide","guid":"A4dUu0-bTQmhbbejSPAImQ","children":[]},{"id":"119","parent":"114","text":"Mastocitosis sistemica","guid":"F9p9JHhESEiZJp9qUdk4jw","children":[]},{"id":"120","parent":"114","text":"Shock