{"title":"ShockCardiogenico iPad","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Entidades clínicas/General/ShockCardiogenico iPad.smmx","root":{"id":"0","parent":"-1","text":"SHOCK CARDIOGENICO\\N(Thiele, NEJM 2026)","guid":"2Z_Bvab1mR7QYdE9bXDdbQ","children":[{"id":"1","parent":"0","text":"Definicion y\\NDiagnostico","guid":"vQvA7eP-xh7OWasKahZd7w","children":[{"id":"2","parent":"1","text":"Definicion SHARC (Shock\\NAcademic Research Consortium)","guid":"MFekdoA6PlmicfTfn_B_cA","children":[{"id":"3","parent":"2","text":"Trastorno cardiaco → hipoperfusion tisular sostenida","guid":"","children":[]},{"id":"4","parent":"2","text":"Evidencia clinica Y bioquimica requeridas","guid":"","children":[]}]},{"id":"5","parent":"1","text":"Criterios\\Nclinicos","guid":"wb_-wv8a9A1qQl2Ris0qsA","children":[{"id":"6","parent":"5","text":"PAS <90 mmHg por >30 min","guid":"","children":[]},{"id":"7","parent":"5","text":"O necesidad de inotropicos/vasopresores/MCS para PAS >=90","guid":"","children":[]},{"id":"8","parent":"5","text":"Hipoperfusion sistemica → extremidades frias, oliguria, AMS","guid":"","children":[]},{"id":"9","parent":"5","text":"Lactato arterial elevado → marcador bioquimico CLAVE","guid":"","children":[]},{"id":"10","parent":"5","text":"Ecocardiograma con disfuncion cardiaca","guid":"","children":[]}]},{"id":"11","parent":"1","text":"Criterios hemodinamicos\\N(cateterismo derecho)","guid":"awAVqRkqwZWfVgDSykg3cg","children":[{"id":"12","parent":"11","text":"Indice cardiaco <=2.2 L/min/m2","guid":"","children":[]},{"id":"13","parent":"11","text":"RVS >2200 dinas*s/cm5","guid":"","children":[]},{"id":"14","parent":"11","text":"Utiles para diagnostico diferencial con otros tipos de shock","guid":"","children":[]}]},{"id":"15","parent":"1","text":"Subtipos\\Nespeciales","guid":"lU1-8f9MLIK_CopTth9o1w","children":[{"id":"16","parent":"15","text":"Shock cardiogenico NORMOTENSO → PAS >90 con hipoperfusion","guid":"","children":[]},{"id":"17","parent":"15","text":"Shock MIXTO → cardiogenico + otra causa simultanea (ej sepsis)","guid":"","children":[]}]}]},{"id":"18","parent":"0","text":"Estadificacion\\NSCAI","guid":"Fgak8DiqydtJuLC5mLtFZQ","children":[{"id":"19","parent":"18","text":"Stage A → EN RIESGO","guid":"","children":[{"id":"20","parent":"19","text":"Sin signos actuales de shock","guid":"","children":[]},{"id":"21","parent":"19","text":"Lactato <=2 mmol/L","guid":"","children":[]},{"id":"22","parent":"19","text":"Monitorizar","guid":"","children":[]}]},{"id":"23","parent":"18","text":"Stage B → INICIO\\N(Preshock)","guid":"ygItJDD-xqMPSAKpRx7EKg","children":[{"id":"24","parent":"23","text":"Hipotension relativa o taquicardia SIN hipoperfusion","guid":"","children":[]},{"id":"25","parent":"23","text":"Lactato <=2 mmol/L","guid":"","children":[]}]},{"id":"26","parent":"18","text":"Stage C → CLASICO","guid":"","children":[{"id":"27","parent":"26","text":"LACTATO >2 mmol/L","guid":"","children":[]},{"id":"28","parent":"26","text":"IC <2.2 L/min/m2","guid":"","children":[]},{"id":"29","parent":"26","text":"PCP >15 mmHg","guid":"","children":[]},{"id":"30","parent":"26","text":"Hipoperfusion evidente","guid":"","children":[]}]},{"id":"31","parent":"18","text":"Stage D → DETERIORO","guid":"","children":[{"id":"32","parent":"31","text":"Lactato en aumento o persistente >2 mmol/L","guid":"","children":[]},{"id":"33","parent":"31","text":"Escalada de vasopresores o adicion de MCS","guid":"","children":[]},{"id":"34","parent":"31","text":"No responde a terapia inicial","guid":"","children":[]}]},{"id":"35","parent":"18","text":"Stage E → EXTREMIS","guid":"","children":[{"id":"36","parent":"35","text":"LACTATO >8 mmol/L","guid":"","children":[]},{"id":"37","parent":"35","text":"Hipotension severa pese a soporte maximo","guid":"","children":[]},{"id":"38","parent":"35","text":"Colapso circulatorio profundo","guid":"","children":[]}]},{"id":"39","parent":"18","text":"Limitaciones del sistema","guid":"","children":[{"id":"40","parent":"39","text":"Subjetividad en asignacion","guid":"","children":[]},{"id":"41","parent":"39","text":"Requiere reevaluaciones multiples (naturaleza dinamica)","guid":"","children":[]}]}]},{"id":"42","parent":"0","text":"Fisiopatologia","guid":"","children":[{"id":"43","parent":"42","text":"Espiral descendente\\Ndeleterea","guid":"J7B9T1J2c9t_wgWTvLKliw","children":[{"id":"44","parent":"43","text":"Disminucion funcion cardiaca e IC","guid":"","children":[]},{"id":"45","parent":"43","text":"Hipotension → isquemia coronaria","guid":"","children":[]},{"id":"46","parent":"43","text":"Menor contractilidad → mayor reduccion IC","guid":"","children":[]}]},{"id":"47","parent":"42","text":"Respuesta\\Nvascular bifasica","guid":"U6b91ox8PWik5-5JuoMg6w","children":[{"id":"48","parent":"47","text":"Fase inicial → vasoconstriccion compensatoria","guid":"","children":[]},{"id":"49","parent":"47","text":"Fase tardia → VASODILATACION PATOLOGICA por SIRS","guid":"","children":[]}]},{"id":"50","parent":"42","text":"Dano\\Nmultiorganico","guid":"hkBByq4keeEC_nXdj4gEKQ","children":[{"id":"51","parent":"50","text":"Cerebral → hipoperfusion, confusion","guid":"","children":[]},{"id":"52","parent":"50","text":"Cardiaco → isquemia, deterioro bomba (BNP y troponina elevados)","guid":"","children":[]},{"id":"53","parent":"50","text":"Pulmonar → congestion, lesion ventilatoria, neumonia","guid":"","children":[]},{"id":"54","parent":"50","text":"Hepatico → hepatitis hipoxica, falla hepatica (AST/ALT/bilirrubina)","guid":"","children":[]},{"id":"55","parent":"50","text":"Renal → oliguria, necrosis tubular (creatinina, cistatina C)","guid":"","children":[]},{"id":"56","parent":"50","text":"Intestinal → perdida integridad, translocacion bacteriana","guid":"","children":[]},{"id":"57","parent":"50","text":"Muscular → catabolismo, proteolisis","guid":"","children":[]},{"id":"58","parent":"50","text":"Microvascular → edema endotelial, microtrombos, estasis","guid":"","children":[]},{"id":"59","parent":"50","text":"Coagulacion → CID, sangrado","guid":"","children":[]}]},{"id":"60","parent":"42","text":"Biomarcadores\\Ninflamatorios","guid":"W9yOfJXROpzc6PApVX62Lg","children":[{"id":"61","parent":"60","text":"PCR, IL-6, IL-1, IL-8","guid":"","children":[]},{"id":"62","parent":"60","text":"DPP-3 (dipeptidil peptidasa 3)","guid":"","children":[]},{"id":"63","parent":"60","text":"IFN-gamma, TNF-alfa","guid":"","children":[]}]}]},{"id":"64","parent":"0","text":"Etiologia y\\NFenotipos","guid":"2Y57qKEaMZC_RbnrlK2izA","children":[{"id":"65","parent":"64","text":"IAM (~50% y declinando\\Nproporcionalmente)","guid":"mjq_TROLnovQ7kXXKs2D4w","children":[{"id":"66","parent":"65","text":"STEMI (~66% de los IAM-shock)","guid":"","children":[]},{"id":"67","parent":"65","text":"Non-STEMI (~30%)","guid":"","children":[]},{"id":"68","parent":"65","text":"Complicaciones\\Nmecanicas (~3%)","guid":"etQ8YQn_c_jfxpFudF3flw","children":[{"id":"69","parent":"68","text":"Ruptura pared libre","guid":"","children":[]},{"id":"70","parent":"68","text":"Ruptura septo ventricular","guid":"","children":[]},{"id":"71","parent":"68","text":"Ruptura musculo papilar → IM aguda","guid":"","children":[]}]}]},{"id":"72","parent":"64","text":"Insuficiencia cardiaca\\N(>50% y en aumento)","guid":"lPyGUWw0OVyqr7i37yVuLQ","children":[{"id":"73","parent":"72","text":"IC aguda sobre cronica (~75% de los IC-shock)","guid":"","children":[]},{"id":"74","parent":"72","text":"IC de novo (~25%)","guid":"","children":[]},{"id":"75","parent":"72","text":"Miocarditis aguda","guid":"","children":[]},{"id":"76","parent":"72","text":"Sindrome Takotsubo","guid":"","children":[]},{"id":"77","parent":"72","text":"Miocardiopatia periparto","guid":"","children":[]}]},{"id":"78","parent":"64","text":"Causas secundarias\\Nno miocardicas","guid":"FToi812uw6_I6anwllKomA","children":[{"id":"79","parent":"78","text":"Enfermedad valvular","guid":"","children":[]},{"id":"80","parent":"78","text":"Enfermedad pericardica","guid":"","children":[]},{"id":"81","parent":"78","text":"Arritmias","guid":"","children":[]}]},{"id":"82","parent":"64","text":"Shock postcardiotomia","guid":"","children":[]},{"id":"83","parent":"64","text":"Fenotipos por tipo\\Nde fallo ventricular","guid":"TQtBfoQG0o_6OyNVoCWeKQ","children":[{"id":"84","parent":"83","text":"Fallo VI → DOMINANTE y mas frecuente","guid":"","children":[]},{"id":"85","parent":"83","text":"Fallo biventricular → comun","guid":"","children":[]},{"id":"86","parent":"83","text":"Fallo VD → presente en 44% de IAM-shock","guid":"","children":[]},{"id":"87","parent":"83","text":"Complicaciones mecanicas → requieren manejo especifico","guid":"","children":[]}]},{"id":"88","parent":"64","text":"Fenotipo post-paro\\Ncardiaco","guid":"uJzd7f5SX3D3vzcOC9wMOQ","children":[{"id":"89","parent":"88","text":"Disfuncion cardiaca por stunning","guid":"","children":[]},{"id":"90","parent":"88","text":"Lactato NO correlaciona bien con IC inicial","guid":"","children":[]},{"id":"91","parent":"88","text":"20-30% mueren por lesion cerebral (no circulatoria)","guid":"","children":[]}]}]},{"id":"92","parent":"0","text":"Epidemiologia\\Ny Pronostico","guid":"JQLSNxUMY9emvqvSI6BZOQ","children":[{"id":"93","parent":"92","text":"Mortalidad global 40-50% a 30 dias","guid":"","children":[]},{"id":"94","parent":"92","text":"Mortalidad intrahospitalaria\\Npor causa (n=8974)","guid":"_lAqSSAxQHVktAQkuq2puA","children":[{"id":"95","parent":"94","text":"Shock mixto → 48%","guid":"","children":[]},{"id":"96","parent":"94","text":"IAM-shock → 41%","guid":"","children":[]},{"id":"97","parent":"94","text":"IC de novo → 31%","guid":"","children":[]},{"id":"98","parent":"94","text":"Causas secundarias → 31%","guid":"","children":[]},{"id":"99","parent":"94","text":"IC aguda sobre cronica → 25%","guid":"","children":[]}]},{"id":"100","parent":"92","text":"Causa de muerte principal → shock persistente","guid":"","children":[{"id":"101","parent":"100","text":"Seguida de arritmia, dano cerebral anoxico, falla respiratoria","guid":"","children":[]}]},{"id":"102","parent":"92","text":"Tendencia temporal →\\Nmortalidad en AUMENTO","guid":"NIsyD5FiAG7_m2rFkrKA3A","children":[{"id":"103","parent":"102","text":"Poblacion envejecida","guid":"","children":[]},{"id":"104","parent":"102","text":"Mayor comorbilidad","guid":"","children":[]},{"id":"105","parent":"102","text":"Perfiles de riesgo desfavorables","guid":"","children":[]}]},{"id":"106","parent":"92","text":"FRAGILIDAD en IAM-shock → 71% tienen fragilidad","guid":"","children":[]},{"id":"107","parent":"92","text":"Scores pronosticos → SCAI stages como sistema recomendado","guid":"","children":[]}]},{"id":"108","parent":"0","text":"CONSIDERACIONES\\NGERIATRICAS (PubMed)","guid":"my-H-dVQRqaydcRFoALecw","children":[{"id":"109","parent":"108","text":"Fragilidad como predictor\\Nindependiente","guid":"U3-HfwkxLv_qYc26cmgFJQ","children":[{"id":"110","parent":"109","text":"OR 2.15 (IC 95% 2.03-2.27) mortalidad intrahospitalaria (alto vs bajo riesgo)","guid":"","children":[]},{"id":"111","parent":"109","text":"Menor uso de MCS en fragiles","guid":"","children":[]},{"id":"112","parent":"109","text":"Sangrado mayor OR 6.18 en alto riesgo de fragilidad","guid":"","children":[]}]},{"id":"113","parent":"108","text":"Diferencias por\\Nsexo y edad","guid":"x89CGIVO74zTiLoHWC-p3Q","children":[{"id":"114","parent":"113","text":"Mujeres con MAYOR mortalidad en fragilidad baja/intermedia","guid":"","children":[]},{"id":"115","parent":"113","text":"Mujeres reciben MENOS CAP, IABP y Impella","guid":"","children":[]},{"id":"116","parent":"113","text":"Disparidades de genero en cuidado del shock","guid":"","children":[]}]},{"id":"117","parent":"108","text":"Impella en ADULTOS MAYORES\\N→ DanGer Shock subestudio\\N(Klein 2025)","guid":"8AuFGPWVfeckmaAwfiDFNA","children":[{"id":"118","parent":"117","text":"Mortalidad por cuartiles edad → 31%, 47%, 61%, 73%","guid":"","children":[]},{"id":"119","parent":"117","text":"Beneficio Impella en <77 anios → OR 0.45 (IC 95% 0.28-0.73, p=0.001)","guid":"","children":[]},{"id":"120","parent":"117","text":"SIN beneficio en >=77 anios → OR 1.52 (IC 95% 0.57-4.08, p=0.40)","guid":"","children":[]},{"id":"121","parent":"117","text":"P interaccion = 0.028","guid":"","children":[]},{"id":"122","parent":"117","text":"EDAD como factor de seleccion para MCS","guid":"","children":[]}]},{"id":"123","parent":"108","text":"Fragilidad en STEMI\\Ncon ICP primaria","guid":"fjN60schtXml7MngrOj8xA","children":[{"id":"124","parent":"123","text":"14.4% de STEMI >=65a son fragiles","guid":"","children":[]},{"id":"125","parent":"123","text":"Fragilidad asociada a mortalidad intrahospitalaria (OR 1.88, IC 95% 1.50-2.35)","guid":"","children":[]},{"id":"126","parent":"123","text":"Mortalidad a 1 anio OR 1.48 (IC 95% 1.10-2.00)","guid":"","children":[]}]},{"id":"127","parent":"108","text":"Solo 5% de todos los shocks cardiogenicos cumplen criterios DanGer","guid":"","children":[{"id":"128","parent":"127","text":"32% de los IAM-CEST con shock elegibles","guid":"","children":[]}]},{"id":"129","parent":"108","text":"Implicancias\\Npara AM en UCI","guid":"N4s88xWvn4Eq931Su6A4mQ","children":[{"id":"130","parent":"129","text":"Evaluar CFS antes de decidir MCS","guid":"","children":[]},{"id":"131","parent":"129","text":"Considerar proporcionalidad terapeutica","guid":"","children":[]},{"id":"132","parent":"129","text":"Mayor riesgo de complicaciones vasculares","guid":"","children":[]},{"id":"133","parent":"129","text":"Mayor necesidad de TRR en fragiles","guid":"","children":[]}]}]},{"id":"134","parent":"0","text":"Tratamiento →\\NSistemas de Cuidado","guid":"q_67qEo4AY8HfoixnzR3WQ","children":[{"id":"135","parent":"134","text":"Centros terciarios especializados OBLIGATORIO","guid":"","children":[{"id":"136","parent":"135","text":"Capacidad MCS, cirugia cardiaca, UCI cardiologica","guid":"","children":[]}]},{"id":"137","parent":"134","text":"Volumen institucional importa","guid":"","children":[{"id":"138","parent":"137","text":"Mayor volumen (>=107 casos/anio) → menor mortalidad","guid":"","children":[]}]},{"id":"139","parent":"134","text":"SHOCK TEAMS\\Nmultidisciplinarios","guid":"5EgCD4eIBUbIgJQcWHt3Qw","children":[{"id":"140","parent":"139","text":"Intensivistas + intervencionistas + perfusionistas + cirujanos cardiacos","guid":"","children":[]},{"id":"141","parent":"139","text":"Factor independiente de mejores outcomes","guid":"","children":[]}]}]},{"id":"142","parent":"0","text":"Tratamiento →\\NCuidados UCI","guid":"sNmmr8OcynX6vwuLfe5vFw","children":[{"id":"143","parent":"142","text":"Lactato cada hora hasta estabilizacion","guid":"","children":[]},{"id":"144","parent":"142","text":"Control glicemico","guid":"","children":[]},{"id":"145","parent":"142","text":"Oxigenacion adecuada","guid":"","children":[]},{"id":"146","parent":"142","text":"Tromboprofilaxis","guid":"","children":[]},{"id":"147","parent":"142","text":"Profilaxis ulcera de estres","guid":"","children":[]},{"id":"148","parent":"142","text":"Alimentacion enteral precoz post-estabilizacion","guid":"","children":[]},{"id":"149","parent":"142","text":"Medicacion vasoactiva SIEMPRE IV","guid":"","children":[]},{"id":"150","parent":"142","text":"Ventilacion\\Nmecanica","guid":"5tHqfWsWZL-A0x2aBKJPKA","children":[{"id":"151","parent":"150","text":"Proteccion pulmonar → Vt 6-8 ml/kg peso predicho","guid":"","children":[]},{"id":"152","parent":"150","text":"CPAP puede evitar intubacion en situaciones limites","guid":"","children":[]},{"id":"153","parent":"150","text":"Precaucion con CPAP si predomina fallo VD","guid":"","children":[]}]},{"id":"154","parent":"142","text":"Terapia\\Nreemplazo renal","guid":"9NWCMJIjTiQPBJmV1SRnuA","children":[{"id":"155","parent":"154","text":"Indicada en → uremia, sobrecarga intratable, acidosis, hiperK refractaria","guid":"","children":[]},{"id":"156","parent":"154","text":"Inicio temprano SIN indicacion convencional → SIN beneficio","guid":"","children":[]},{"id":"157","parent":"154","text":"Uso en trials: IABP-SHOCK II 18%, CULPRIT-SHOCK 14%, ECLS-SHOCK 11%","guid":"","children":[]}]}]},{"id":"158","parent":"0","text":"Tratamiento →\\NMonitorizacion\\NHemodinamica","guid":"mC9lWbaa0b0YpsKyvXPd0g","children":[{"id":"159","parent":"158","text":"Ecocardiografia/POCUS → PRIMERA LINEA","guid":"","children":[{"id":"160","parent":"159","text":"Identificar causa y fenotipificar el shock","guid":"","children":[]}]},{"id":"161","parent":"158","text":"Cateter arteria\\Npulmonar (CAP)","guid":"SRK8Oh1aE_0IuGQNmNp2Rw","children":[{"id":"162","parent":"161","text":"Sugerido en no respondedores o incertidumbre diagnostica","guid":"","children":[]},{"id":"163","parent":"161","text":"Util en shock mixto","guid":"","children":[]},{"id":"164","parent":"161","text":"SIN datos de RCTs que confirmen beneficio en mortalidad","guid":"","children":[]},{"id":"165","parent":"161","text":"Ensayo PACCS en curso (n=400, IC-shock)","guid":"","children":[]}]}]},{"id":"166","parent":"0","text":"Tratamiento →\\NManejo\\NFarmacologico","guid":"hts45XFZfcGzrOWGPeosHg","children":[{"id":"167","parent":"166","text":"Fluidos","guid":"","children":[{"id":"168","parent":"167","text":"SOLO si hipovolemia central sin congestion","guid":"","children":[]},{"id":"169","parent":"167","text":"Test de elevacion pasiva de piernas para predecir respuesta","guid":"","children":[]},{"id":"170","parent":"167","text":"Diureticos de asa IV si sobrecarga de volumen","guid":"","children":[]},{"id":"171","parent":"167","text":"EVITAR hipovolemia → crucial","guid":"","children":[]},{"id":"172","parent":"167","text":"Manejo diferenciado segun fallo VD vs VI","guid":"","children":[]}]},{"id":"173","parent":"166","text":"Inotropicos e\\Ninodilatadores","guid":"z0ScK9VBk4N9S-Er3KJzBQ","children":[{"id":"174","parent":"173","text":"DOBUTAMINA → primera linea clasica en fallo VI","guid":"","children":[]},{"id":"175","parent":"173","text":"MILRINONA → alternativa (iPDE3)","guid":"","children":[{"id":"176","parent":"175","text":"Sin diferencia vs dobutamina en RCT","guid":"","children":[]}]},{"id":"177","parent":"173","text":"LEVOSIMENDAN →\\Nsensibilizador de calcio","guid":"z_lrkwRr8B07pZvAraMJEg","children":[{"id":"178","parent":"177","text":"Aumenta inotropia + reduce postcarga","guid":"","children":[]},{"id":"179","parent":"177","text":"NO facilito destete de VA-ECMO (LEVOECMO trial)","guid":"","children":[]}]},{"id":"180","parent":"173","text":"Cochrane → evidencia INSUFICIENTE para superioridad de cualquier inotropico","guid":"","children":[]}]},{"id":"181","parent":"166","text":"Vasopresores","guid":"","children":[{"id":"182","parent":"181","text":"NOREPINEFRINA → vasoconstrictor de ELECCION","guid":"","children":[]},{"id":"183","parent":"181","text":"Dopamina vs NE → dopamina = MAS arritmias, sin diferencia mortalidad (n=1679)","guid":"","children":[]},{"id":"184","parent":"181","text":"Epinefrina vs NE → epinefrina = efectos desfavorables (FC, acidosis lactica)","guid":"","children":[]},{"id":"185","parent":"181","text":"Vasopresina → sin estudios especificos en shock cardiogenico","guid":"","children":[]},{"id":"186","parent":"181","text":"Objetivo PAM → generalmente >65 mmHg","guid":"","children":[]},{"id":"187","parent":"181","text":"Ensayo NorShock en curso → 55 vs 65 mmHg (n=776)","guid":"","children":[]}]}]},{"id":"188","parent":"0","text":"Tratamiento →\\NSoporte Mecanico\\NCirculatorio (MCS)","guid":"833hF34N1pppBgGwHXh5Xg","children":[{"id":"189","parent":"188","text":"Conceptos\\Nde bridge","guid":"mm5AObU--nZ0fAvIIUDsdg","children":[{"id":"190","parent":"189","text":"Bridge to decision","guid":"","children":[]},{"id":"191","parent":"189","text":"Bridge to recovery","guid":"","children":[]},{"id":"192","parent":"189","text":"Bridge to durable LVAD","guid":"","children":[]},{"id":"193","parent":"189","text":"Bridge to transplante","guid":"","children":[]}]},{"id":"194","parent":"188","text":"IABP (Balon de\\NContrapulsacion)","guid":"STQDdgls8CBkBBGIO91uEQ","children":[{"id":"195","parent":"194","text":"Facil insercion, bajo costo, buen perfil EA","guid":"","children":[]},{"id":"196","parent":"194","text":"Mejora perfusion coronaria en diastole, reduce postcarga","guid":"","children":[]},{"id":"197","parent":"194","text":"IABP-SHOCK II → SIN beneficio supervivencia vs terapia medica","guid":"","children":[]},{"id":"198","parent":"194","text":"Altshock-2 (IC-shock) → SIN beneficio supervivencia","guid":"","children":[]},{"id":"199","parent":"194","text":"NO recomendado rutinariamente en IAM-shock","guid":"","children":[]},{"id":"200","parent":"194","text":"Indicado en complicaciones mecanicas (guias europeas, no US)","guid":"","children":[]}]},{"id":"201","parent":"188","text":"VA-ECMO\\N(ECMO\\NVenoarterial)","guid":"hWZPhYEGMk9EMrXPFuhZOw","children":[{"id":"202","parent":"201","text":"Soporte hasta 6 L/min, soporte biventricular + oxigenacion","guid":"","children":[]},{"id":"203","parent":"201","text":"Cannulacion venosa (AD) → bomba + oxigenador → retorno aorta descendente","guid":"","children":[]},{"id":"204","parent":"201","text":"ECLS-SHOCK →\\Nmortalidad 47.8%\\Nvs 49.0% control","guid":"tKXRz5YBGjyHQWYAuhYwiA","children":[{"id":"205","parent":"204","text":"RR 0.98 (IC 95% 0.80-1.19, p=0.81)","guid":"","children":[]},{"id":"206","parent":"204","text":"Resultados similares a 1 anio","guid":"","children":[]}]},{"id":"207","parent":"201","text":"Metanalisis IPD (4 RCTs) → SIN beneficio mortalidad, MAS complicaciones","guid":"","children":[]},{"id":"208","parent":"201","text":"PUEDE DANAR corazon → aumento postcarga por flujo retrogrado","guid":"","children":[]},{"id":"209","parent":"201","text":"Descarga VI con Impella/IABP → observacional sugiere menor mortalidad","guid":"","children":[]},{"id":"210","parent":"201","text":"EARLY-UNLOAD RCT → descarga transeptal LA vs ECMO solo → SIN efecto","guid":"","children":[]},{"id":"211","parent":"201","text":"NO recomendado rutinariamente (guias US)","guid":"","children":[]}]},{"id":"212","parent":"188","text":"Bombas de flujo\\Nmicroaxial\\N(IMPELLA)","guid":"LXHpUXNOzrNJFseOVBur-g","children":[{"id":"213","parent":"212","text":"Flujo pico ~4.3 L/min, via percutanea","guid":"","children":[]},{"id":"214","parent":"212","text":"Para shock con fallo VI predominante","guid":"","children":[]},{"id":"215","parent":"212","text":"DanGer Shock\\N(n=360, STEMI\\Nsin dano cerebral)","guid":"hxH4uLMAUwfh1UZgzHZvHw","children":[{"id":"216","parent":"215","text":"HR 0.74 (IC 95% 0.55-0.99, p=0.04) a 180 dias","guid":"","children":[]},{"id":"217","parent":"215","text":"Beneficio sostenido hasta 10 anios","guid":"","children":[]},{"id":"218","parent":"215","text":"MAYOR sangrado, isquemia extremidades, TRR","guid":"","children":[]}]},{"id":"219","parent":"212","text":"PERO → estudios propensity-matched (>100.000 pts) → SIN beneficio + MAS complicaciones","guid":"","children":[]},{"id":"220","parent":"212","text":"Guias US → indicacion IIa en pacientes SELECCIONADOS","guid":"","children":[]},{"id":"221","parent":"212","text":"RECOVER IV suspendido por seguridad","guid":"","children":[]}]},{"id":"222","parent":"188","text":"TandemHeart","guid":"","children":[{"id":"223","parent":"222","text":"Flujo LA → arteria femoral, hasta 4 L/min","guid":"","children":[]},{"id":"224","parent":"222","text":"Descarga VI directamente","guid":"","children":[]},{"id":"225","parent":"222","text":"Dos trials pequenos → sin evidencia concluyente","guid":"","children":[]},{"id":"226","parent":"222","text":"Uso raro comparado con ECMO e Impella","guid":"","children":[]}]},{"id":"227","parent":"188","text":"Reflexiones\\Nsobre MCS","guid":"TiErdE3PzjtstuaG_7d82g","children":[{"id":"228","parent":"227","text":"50-60% sobreviven IAM-shock SIN MCS","guid":"","children":[]},{"id":"229","parent":"227","text":"Solo 5% de todos los shocks son candidatos segun criterios DanGer","guid":"","children":[]},{"id":"230","parent":"227","text":"SELECCION DE PACIENTES ES CLAVE","guid":"","children":[]},{"id":"231","parent":"227","text":"Beneficio de MCS solo en → fallo VI dominante + bajo riesgo dano cerebral","guid":"","children":[{"id":"232","parent":"231","text":"Metanalisis IPD (1059 pts, 9 trials) → HR 0.77 (IC 95% 0.61-0.97, p=0.024)","guid":"","children":[]}]},{"id":"233","parent":"227","text":"Complicaciones SIEMPRE mayores con MCS independiente del dispositivo","guid":"","children":[]},{"id":"234","parent":"227","text":"En IC-shock → MCS solo si chance de recuperacion o elegible para LVAD/Tx","guid":"","children":[]}]}]},{"id":"235","parent":"0","text":"Tratamiento →\\NRevascularizacion","guid":"27CTj8GT99g15ZexekUcgA","children":[{"id":"236","parent":"235","text":"Revascularizacion\\Ntemprana en\\NIAM-shock","guid":"nCxiOSo1na8_T_oG3WcXlg","children":[{"id":"237","parent":"236","text":"SHOCK trial → sin reduccion mortalidad 30 dias","guid":"","children":[]},{"id":"238","parent":"236","text":"PERO reduccion mortalidad a largo plazo (6 anios)","guid":"","children":[]},{"id":"239","parent":"236","text":"ALTAMENTE RECOMENDADA en guias","guid":"","children":[]},{"id":"240","parent":"236","text":"Retraso → peores outcomes → reducir tiempo puerta-balon","guid":"","children":[]}]},{"id":"241","parent":"235","text":"Estrategia\\Nfarmacoinvasiva","guid":"pLaD4eptd6z2KQE9MVEIQQ","children":[{"id":"242","parent":"241","text":"Fibrinolisis si tiempos de traslado prolongados","guid":"","children":[]},{"id":"243","parent":"241","text":"Sin aumento sangrado mayor","guid":"","children":[]}]},{"id":"244","parent":"235","text":"Enfermedad multivaso\\N(70-80% de IAM-shock)","guid":"cG8vxxemIwewfm4yFNXnQQ","children":[{"id":"245","parent":"244","text":"CULPRIT-SHOCK → ICP lesion culpable\\NSUPERIOR a multivaso inmediata","guid":"jkoKAGSZd4zZt9tLxy5XGg","children":[{"id":"246","parent":"245","text":"Muerte o TRR → 45.9% vs 55.4%","guid":"","children":[]},{"id":"247","parent":"245","text":"RR 0.83 (IC 95% 0.71-0.96, p=0.01)","guid":"","children":[]},{"id":"248","parent":"245","text":"Impulsado por reduccion significativa mortalidad","guid":"","children":[]}]},{"id":"249","parent":"244","text":"Revascularizacion completa POSTERIOR por etapas","guid":"","children":[]},{"id":"250","parent":"244","text":"CIRUGIA si anatomia no permite ICP","guid":"","children":[]}]}]},{"id":"251","parent":"0","text":"Tratamiento →\\NComplicaciones Mecanicas","guid":"NMiFphIg3wWDF_QRN_K65A","children":[{"id":"252","parent":"251","text":"Ruptura papilar → cirugia o intervencion percutanea","guid":"","children":[]},{"id":"253","parent":"251","text":"Ruptura septo ventricular → cirugia urgente","guid":"","children":[]},{"id":"254","parent":"251","text":"Ruptura pared libre → reparacion emergente","guid":"","children":[]},{"id":"255","parent":"251","text":"Incidencia en descenso pero pronostico sombrio","guid":"","children":[]}]},{"id":"256","parent":"0","text":"Ensayos Clinicos en Curso\\N(Tabla 2)","guid":"rsRm9k7LTUP4q3cQyhq69g","children":[{"id":"257","parent":"256","text":"MCS","guid":"","children":[{"id":"258","parent":"257","text":"ECMO-RRT → VA-ECMO + TRR vs ECMO solo (n=362)","guid":"","children":[]},{"id":"259","parent":"257","text":"ANCHOR → VA-ECMO + IABP vs terapia medica (n=400)","guid":"","children":[]},{"id":"260","parent":"257","text":"UNLOAD-ECMO → VA-ECMO + Impella vs ECMO (n=198, lactato >5)","guid":"","children":[]},{"id":"261","parent":"257","text":"ULYSS → Impella vs terapia medica (n=204)","guid":"","children":[]},{"id":"262","parent":"257","text":"RECOVER IV → Impella vs terapia medica (n=558, SUSPENDIDO)","guid":"","children":[]},{"id":"263","parent":"257","text":"REMAP ECMO → VA-ECMO + IABP vs ECMO (n=430, Bayesiano)","guid":"","children":[]}]},{"id":"264","parent":"256","text":"Intervencion\\Ntranscateter","guid":"NUqQ6exfswsFS8ha8T1lZQ","children":[{"id":"265","parent":"264","text":"MINOS → M-TEER vs terapia medica (n=144, IM 3-4+)","guid":"","children":[]