{"title":"NecrosisTabiqueNasal iPad","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Entidades clínicas/General/NecrosisTabiqueNasal iPad.smmx","root":{"id":"0","parent":"-1","text":"Necrosis de Tabique Nasal\\Nen Persona Mayor","guid":"Kos7NiHj6r0eKHhzj03n1g","children":[{"id":"1","parent":"0","text":"Anatomia y\\NVascularizacion","guid":"U3MAAAKZ56Uw9NR1YdY3-Q","children":[{"id":"2","parent":"1","text":"Tabique nasal = lamina perpendicular etmoides + vomer + cartilago cuadrangular","guid":"","children":[]},{"id":"3","parent":"1","text":"Irrigacion → AREA\\NDE KIESSELBACH\\N(Little)","guid":"K4qSMWcXOcR-xyOrvV9AJQ","children":[{"id":"4","parent":"3","text":"Arteria esfenopalatina (maxilar interna)","guid":"","children":[]},{"id":"5","parent":"3","text":"Arteria etmoidal anterior y posterior (oftalmica)","guid":"","children":[]},{"id":"6","parent":"3","text":"Arteria labial superior (facial)","guid":"","children":[]},{"id":"7","parent":"3","text":"Arteria palatina mayor (maxilar interna)","guid":"","children":[]}]},{"id":"8","parent":"1","text":"Plexo de Woodruff → posterior, epistaxis posterior en AM","guid":"","children":[]},{"id":"9","parent":"1","text":"MUCOSA SEPTAL = mucoperiosteio y mucopericondrio → nutricion del cartilago por DIFUSION","guid":"","children":[]},{"id":"10","parent":"1","text":"Cartilago avascular → vulnerable a isquemia","guid":"","children":[]},{"id":"11","parent":"1","text":"ENVEJECIMIENTO → atrofia mucosa + reduccion glandulas seromucosas + xerosis nasal","guid":"","children":[]}]},{"id":"12","parent":"0","text":"Fisiopatologia de\\Nla Necrosis Septal","guid":"Xj_8CuSm9IwLrvUUKsZXqA","children":[{"id":"13","parent":"12","text":"Mecanismo central =\\NISQUEMIA del\\Ncartilago septal","guid":"fQJrQef_g4r7w67vc1mapA","children":[{"id":"14","parent":"13","text":"Compresion vascular (hematoma, absceso)","guid":"","children":[]},{"id":"15","parent":"13","text":"Vasoconstriccion sostenida (cocaina, vasoconstrictores topicos)","guid":"","children":[]},{"id":"16","parent":"13","text":"Vasculitis de pequeno vaso (GPA, GEPA)","guid":"","children":[]},{"id":"17","parent":"13","text":"Infiltracion tumoral o granulomatosa","guid":"","children":[]}]},{"id":"18","parent":"12","text":"Secuencia → isquemia → condrolisis → necrosis → perforacion","guid":"","children":[]},{"id":"19","parent":"12","text":"En AM → mucosa ya adelgazada + hipoperfusion basal → MAYOR vulnerabilidad","guid":"","children":[]},{"id":"20","parent":"12","text":"Factores agravantes\\Nen geriatria","guid":"etIIhICEJVtEXSnu4UPRZQ","children":[{"id":"21","parent":"20","text":"Polifarmacia (anticoagulantes → hematoma septal)","guid":"","children":[]},{"id":"22","parent":"20","text":"Oxigenoterapia prolongada sin humidificacion","guid":"","children":[]},{"id":"23","parent":"20","text":"CPAP/BiPAP mal ajustado","guid":"","children":[]},{"id":"24","parent":"20","text":"Diabetes → microangiopatia → isquemia","guid":"","children":[]},{"id":"25","parent":"20","text":"Xerosis nasal por farmacos anticolinergicos","guid":"","children":[]}]}]},{"id":"26","parent":"0","text":"Etiologia","guid":"","children":[{"id":"27","parent":"26","text":"TRAUMATICA\\N(causa mas\\Nfrecuente global)","guid":"iGQ5BFCy3v7kPH0WqCwFIQ","children":[{"id":"28","parent":"27","text":"Cirugía nasal previa (septoplastia, rinoplastia) → IATROGÉNICA","guid":"","children":[]},{"id":"29","parent":"27","text":"Hematoma septal no drenado → absceso → necrosis","guid":"","children":[]},{"id":"30","parent":"27","text":"Manipulacion digital cronica (rinodactilia)","guid":"","children":[]},{"id":"31","parent":"27","text":"Cauterizacion bilateral simultanea → CONTRAINDICADA","guid":"","children":[]},{"id":"32","parent":"27","text":"Sonda nasogastrica prolongada","guid":"","children":[]},{"id":"33","parent":"27","text":"Taponamiento nasal prolongado","guid":"","children":[]},{"id":"34","parent":"27","text":"Cuerpo extrano nasal","guid":"","children":[]}]},{"id":"35","parent":"26","text":"INFLAMATORIA/\\NAUTOINMUNE","guid":"0xQqZQ9QULzzpUGUdP8m6w","children":[{"id":"36","parent":"35","text":"GRANULOMATOSIS CON POLIANGEITIS\\N(GPA, ex-Wegener) → causa N1 autoinmune","guid":"3PLsnp8Urxtg-XtXlVK7gQ","children":[{"id":"37","parent":"36","text":"Afecta via aerea superior en 70-100% casos","guid":"","children":[]},{"id":"38","parent":"36","text":"Necrosis granulomatosa + vasculitis necrotizante","guid":"","children":[]},{"id":"39","parent":"36","text":"ANCA c-ANCA/PR3 positivo (~90% forma generalizada)","guid":"","children":[]},{"id":"40","parent":"36","text":"Nasal → costras, epistaxis, deformidad en silla de montar","guid":"","children":[]},{"id":"41","parent":"36","text":"Buscar compromiso renal (GN necrotizante) y pulmonar (nodulos, hemorragia)","guid":"","children":[]}]},{"id":"42","parent":"35","text":"Granulomatosis eosinofilica con\\Npoliangeitis (GEPA, ex-Churg-Strauss)","guid":"ERVGe5QYMCPBGLNNaWtSsw","children":[{"id":"43","parent":"42","text":"Asma + eosinofilia + vasculitis","guid":"","children":[]},{"id":"44","parent":"42","text":"p-ANCA/MPO positivo (~40%)","guid":"","children":[]},{"id":"45","parent":"42","text":"Menos frecuente como causa de necrosis septal","guid":"","children":[]}]},{"id":"46","parent":"35","text":"Lupus eritematoso\\Nsistemico (LES)","guid":"-ClUF3GxiT-wCvWVrMcC_w","children":[{"id":"47","parent":"46","text":"Ulceras nasales en 5-10% de pacientes","guid":"","children":[]},{"id":"48","parent":"46","text":"Buscar criterios ACR/EULAR","guid":"","children":[]}]},{"id":"49","parent":"35","text":"Policondritis\\Nrecidivante","guid":"GZ3FmD8rxajXov0YXo0SdQ","children":[{"id":"50","parent":"49","text":"Destruccion cartilago nasal, auricular, traqueal","guid":"","children":[]},{"id":"51","parent":"49","text":"Nariz en silla de montar","guid":"","children":[]},{"id":"52","parent":"49","text":"Anti-colágeno tipo II","guid":"","children":[]}]},{"id":"53","parent":"35","text":"Sarcoidosis","guid":"","children":[{"id":"54","parent":"53","text":"Granulomas no caseificantes","guid":"","children":[]},{"id":"55","parent":"53","text":"Raro compromiso nasal aislado","guid":"","children":[]}]}]},{"id":"56","parent":"26","text":"INFECCIOSA","guid":"","children":[{"id":"57","parent":"56","text":"Tuberculosis → ulcera granulomatosa, BAAR+, PPD/IGRA","guid":"","children":[]},{"id":"58","parent":"56","text":"Lepra (M. leprae) → infiltracion, anestesia nasal, rinitis costrosa","guid":"","children":[]},{"id":"59","parent":"56","text":"Sifilis terciaria → goma sifilítico, VDRL/FTA-Abs","guid":"","children":[]},{"id":"60","parent":"56","text":"Leishmaniasis mucocutanea → forma espundia, endémica en Latam","guid":"","children":[]},{"id":"61","parent":"56","text":"Rinoescleroma (Klebsiella rhinoscleromatis)","guid":"","children":[]},{"id":"62","parent":"56","text":"Mucormicosis → EMERGENCIA,\\Ninmunodeprimidos/DM descompensada","guid":"yK0RTfPoKMA_jniywTdS4A","children":[{"id":"63","parent":"62","text":"Necrosis negra de cornetes y septum","guid":"","children":[]},{"id":"64","parent":"62","text":"Mortalidad >50% sin tratamiento","guid":"","children":[]}]},{"id":"65","parent":"56","text":"Aspergilosis invasiva → neutropénicos","guid":"","children":[]}]},{"id":"66","parent":"26","text":"TOXICA/\\NFARMACOLOGICA","guid":"c26JSCp0NVzLwDgB5Ik37A","children":[{"id":"67","parent":"66","text":"COCAINA → vasoconstriccion +\\Nisquemia directa + contaminacion\\Ncon levamisol","guid":"RUZ8uxdyuesvQW4D8Us73w","children":[{"id":"68","parent":"67","text":"Levamisol → vasculitis ANCA+ (MPO y PR3 positivos)","guid":"","children":[]},{"id":"69","parent":"67","text":"Lesion destructiva de linea media inducida por cocaina (CIMDL)","guid":"","children":[]},{"id":"70","parent":"67","text":"Mimetiza GPA → diagnostico diferencial CRITICO","guid":"","children":[]}]},{"id":"71","parent":"66","text":"Vasoconstrictores topicos cronicos\\N(oximetazolina, nafazolina)","guid":"hdi08JgSzF-Vl4I5CkHmMQ","children":[{"id":"72","parent":"71","text":"Rinitis medicamentosa → atrofia mucosa → necrosis","guid":"","children":[]},{"id":"73","parent":"71","text":"Uso >7-10 dias = RIESGO","guid":"","children":[]}]},{"id":"74","parent":"66","text":"Bifosfonatos (raro, osteonecrosis maxilar mas frecuente)","guid":"","children":[]},{"id":"75","parent":"66","text":"Bevacizumab/anti-VEGF (raro)","guid":"","children":[]}]},{"id":"76","parent":"26","text":"NEOPLASICA","guid":"","children":[{"id":"77","parent":"76","text":"Linfoma NK/T nasal\\N(ex-granuloma letal\\Nde linea media)","guid":"v_6IJSIdHNjY4ZhtqvE1cw","children":[{"id":"78","parent":"77","text":"Asociado a VEB","guid":"","children":[]},{"id":"79","parent":"77","text":"Necrosis mediofacial destructiva","guid":"","children":[]},{"id":"80","parent":"77","text":"Fenotipo CD56+, CD3epsilon+","guid":"","children":[]},{"id":"81","parent":"77","text":"CRITICO en diagnostico diferencial","guid":"","children":[]}]},{"id":"82","parent":"76","text":"Carcinoma epidermoide nasosinusal","guid":"","children":[]},{"id":"83","parent":"76","text":"Adenocarcinoma (asociado a exposicion a polvo de madera)","guid":"","children":[]},{"id":"84","parent":"76","text":"Melanoma mucoso nasal (raro, agresivo)","guid":"","children":[]},{"id":"85","parent":"76","text":"Metastasis (infrecuente)","guid":"","children":[]}]},{"id":"86","parent":"26","text":"OTRAS","guid":"","children":[{"id":"87","parent":"86","text":"Idiopatica (hasta 20% de perforaciones septales)","guid":"","children":[]},{"id":"88","parent":"86","text":"Exposicion ocupacional (cromo, niquel, arsenico, acido sulfurico)","guid":"","children":[]},{"id":"89","parent":"86","text":"Radioterapia (necrosis post-RT)","guid":"","children":[]}]}]},{"id":"90","parent":"0","text":"Clinica","guid":"","children":[{"id":"91","parent":"90","text":"Sintomas","guid":"","children":[{"id":"92","parent":"91","text":"Epistaxis recurrente → SINTOMA MAS FRECUENTE","guid":"","children":[]},{"id":"93","parent":"91","text":"Costras nasales persistentes","guid":"","children":[]},{"id":"94","parent":"91","text":"Obstruccion nasal","guid":"","children":[]},{"id":"95","parent":"91","text":"Rinorrea → puede ser purulenta si infeccion","guid":"","children":[]},{"id":"96","parent":"91","text":"Silbido nasal (perforacion pequena)","guid":"","children":[]},{"id":"97","parent":"91","text":"Dolor nasal/facial","guid":"","children":[]},{"id":"98","parent":"91","text":"Cacosmia (mal olor)","guid":"","children":[]},{"id":"99","parent":"91","text":"Deformidad nasal progresiva (silla de montar)","guid":"","children":[]}]},{"id":"100","parent":"90","text":"Signos","guid":"","children":[{"id":"101","parent":"100","text":"Perforacion septal visible en rinoscopia anterior","guid":"","children":[]},{"id":"102","parent":"100","text":"Costras hemato-purulentas en bordes","guid":"","children":[]},{"id":"103","parent":"100","text":"Tejido granulatorio periperforacion","guid":"","children":[]},{"id":"104","parent":"100","text":"Necrosis negra/grisacea (mucormicosis, cocaina)","guid":"","children":[]},{"id":"105","parent":"100","text":"Deformidad en silla de montar → sugiere destruccion cartilaginosa extensa","guid":"","children":[]}]},{"id":"106","parent":"90","text":"RED FLAGS en\\Npersona mayor","guid":"KouJED5JyaabWZY8y06V1A","children":[{"id":"107","parent":"106","text":"Perdida de peso + necrosis → NEOPLASIA hasta demostrar lo contrario","guid":"","children":[]},{"id":"108","parent":"106","text":"Fiebre + necrosis → infeccion invasiva o vasculitis activa","guid":"","children":[]},{"id":"109","parent":"106","text":"Hematuria + necrosis nasal → GPA con compromiso renal","guid":"","children":[]},{"id":"110","parent":"106","text":"Necrosis negra + DM descompensada → MUCORMICOSIS = EMERGENCIA","guid":"","children":[]},{"id":"111","parent":"106","text":"Necrosis rapidamente progresiva → linfoma NK/T o mucormicosis","guid":"","children":[]}]}]},{"id":"112","parent":"0","text":"Diagnostico","guid":"","children":[{"id":"113","parent":"