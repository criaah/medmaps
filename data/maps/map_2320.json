cuencia\\NCardiaca","guid":"","children":[]},{"id":"86","parent":"0","text":"- SatO2:\\NSaturación de\\NOxígeno","guid":"","children":[]},{"id":"87","parent":"0","text":"- Hb: Hemoglobina","guid":"","children":[]},{"id":"88","parent":"0","text":"- TRC: Tiempo de\\NRelleno Capilar","guid":"","children":[]},{"id":"89","parent":"0","text":"- ∆pCO2(v-a): Diferencia\\Nveno-arterial de CO2","guid":"","children":[]},{"id":"90","parent":"0","text":"- VI: Ventrículo\\NIzquierdo","guid":"","children":[]},{"id":"91","parent":"0","text":"- VD:\\NVentrículo\\NDerecho","guid":"","children":[]},{"id":"92","parent":"0","text":"- SDRA: Síndrome de Distrés\\NRespiratorio Agudo","guid":"","children":[]},{"id":"93","parent":"0","text":"- SvcO2: Saturación Venosa\\NCentral de Oxígeno","guid":"","children":[]},{"id":"94","parent":"0","text":"- NE: Norepinefrina","guid":"","children":[]},{"id":"95","parent":"0","text":"- SOFA: Sequential Organ\\NFailure Assessment","guid":"","children":[]},{"id":"96","parent":"0","text":"- AKI: Acute\\NKidney Injury","guid":"","children":[]},{"id":"97","parent":"0","text":"- KDIGO: Kidney Disease\\NImproving Global Outcomes","guid":"","children":[]},{"id":"98","parent":"0","text":"- PEEP: Presión Positiva al\\NFinal de la Espiración","guid":"","children":[]},{"id":"99","parent":"0","text":"- Pplat: Presión Plateau","guid":"","children":[]},{"id":"100","parent":"0","text":"- VM:\\NVentilación\\NMecánica","guid":"","children":[]}]},"node_count":100,"relations":[],"cross_references":[],"specialty":"UCI/Medicina Crítica","folder":"Entidades clínicas/UCI-Medicina Crítica","filename":"Ecografía en el Shock Indiferenciado-2024","id":"map_2320","resolved_references":[],"title_raw":"Ecografía en el Shock Indiferenciado-2024"}