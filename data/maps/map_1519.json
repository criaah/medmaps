:[{"id":"135","parent":"134","text":"VGI ABREVIADA en urgencia","guid":"","children":[]},{"id":"136","parent":"134","text":"CFS → estratificar fragilidad","guid":"","children":[]},{"id":"137","parent":"134","text":"Estado funcional basal (Barthel, Lawton-Brody)","guid":"","children":[]},{"id":"138","parent":"134","text":"Valoracion cognitiva basal → riesgo delirium","guid":"","children":[]},{"id":"139","parent":"134","text":"Revision farmacologica →\\NANTICOAGULANTES y\\NANTIAGREGANTES","guid":"QlLrgPKV40qAhBDFlyOu7g","children":[{"id":"140","parent":"139","text":"TACO/NACO → riesgo hemorragico aumentado","guid":"","children":[]},{"id":"141","parent":"139","text":"Revertir si sangrado activo o cirugia urgente","guid":"","children":[]},{"id":"142","parent":"139","text":"Hemoseno en anticoagulado → vigilancia estrecha","guid":"","children":[]}]},{"id":"143","parent":"134","text":"Comorbilidades cardiovasculares → riesgo anestesico","guid":"","children":[]}]},{"id":"144","parent":"133","text":"Manejo\\Nfarmacologico","guid":"VDt6fzZC3AhRMjp7Q1lcqg","children":[{"id":"145","parent":"144","text":"Analgesia multimodal →\\Nevitar opioides potentes","guid":"38IXKdcMRJbKIpZ_eIcaqg","children":[{"id":"146","parent":"145","text":"Paracetamol 1g c/8h (base)","guid":"","children":[]},{"id":"147","parent":"145","text":"Metamizol si no contraindicado","guid":"","children":[]},{"id":"148","parent":"145","text":"EVITAR AINEs prolongados → riesgo renal, GI, CV","guid":"","children":[]}]},{"id":"149","parent":"144","text":"Profilaxis antitrombotica → iniciar precoz","guid":"","children":[]},{"id":"150","parent":"144","text":"ATB si Fx expuesta o contaminada","guid":"","children":[]},{"id":"151","parent":"144","text":"EVITAR benzodiazepinas → riesgo delirium","guid":"","children":[]}]},{"id":"152","parent":"133","text":"Prevencion\\Nde delirium","guid":"8SiNDz9Ljz5MN1WpY-gaMA","children":[{"id":"153","parent":"152","text":"Protocolo no farmacologico → PRIMERA LINEA","guid":"","children":[]},{"id":"154","parent":"152","text":"Reorientacion, ciclo sueno-vigilia, movilizacion precoz","guid":"","children":[]},{"id":"155","parent":"152","text":"CAM en urgencia si AM con trauma","guid":"","children":[]}]},{"id":"156","parent":"133","text":"Rehabilitacion","guid":"","children":[{"id":"157","parent":"156","text":"Movilizacion precoz obligatoria","guid":"","children":[]},{"id":"158","parent":"156","text":"Evaluacion deglutoria si Fx mandibular/maxilar","guid":"","children":[]},{"id":"159","parent":"156","text":"Nutricion → riesgo desnutricion por dificultad masticatoria","guid":"","children":[]},{"id":"160","parent":"156","text":"Kinesioterapia respiratoria si Fx costales asociadas","guid":"","children":[]}]},{"id":"161","parent":"133","text":"Prevencion\\Nsecundaria\\Nde caidas","guid":"HhR8Omap7I5Bba6tQUtgvw","children":[{"id":"162","parent":"161","text":"Evaluacion MULTIFACTORIAL de caidas obligatoria","guid":"","children":[{"id":"163","parent":"162","text":"Vision, audicion, equilibrio, medicamentos, entorno","guid":"","children":[]}]},{"id":"164","parent":"161","text":"Correccion deficit visual","guid":"","children":[]},{"id":"165","parent":"161","text":"Revision farmacos que aumentan riesgo caidas","guid":"","children":[{"id":"166","parent":"165","text":"BZD, antihipertensivos, hipoglicemiantes, psicofarmacos","guid":"","children":[]}]},{"id":"167","parent":"161","text":"Adaptacion del hogar → barras apoyo, rampas, iluminacion","guid":"","children":[]},{"id":"168","parent":"161","text":"Programa ejercicio → equilibrio y fuerza (Otago, Tai Chi)","guid":"","children":[]},{"id":"169","parent":"161","text":"Evaluacion osteoporosis → DXA si no realizada","guid":"","children":[]}]}]},{"id":"170","parent":"0","text":"Estudio\\NDiagnostico","guid":"k6CqXwrOdeDDyoTNOGpPHA","children":[{"id":"171","parent":"170","text":"Examen\\Nfisico","guid":"TULgVm24FM7tBGgb_77DWA","children":[{"id":"172","parent":"171","text":"Inspeccion → asimetria, edema, equimosis, laceraciones","guid":"","children":[]},{"id":"173","parent":"171","text":"Palpacion → escalones oseos, crepitacion, enfisema SC","guid":"","children":[]},{"id":"174","parent":"171","text":"Evaluacion oclusion dental","guid":"","children":[]},{"id":"175","parent":"171","text":"Examen ocular COMPLETO → agudeza visual, motilidad, pupilas","guid":"","children":[]},{"id":"176","parent":"171","text":"Pares craneales → V (sensibilidad facial), VII (motor)","guid":"","children":[]},{"id":"177","parent":"171","text":"Rinoscopia → hematoma septal, rinolicuorrea","guid":"","children":[]},{"id":"178","parent":"171","text":"Test de beta-2 transferrina si sospecha fistula LCR","guid":"","children":[]}]},{"id":"179","parent":"170","text":"Imagenologia","guid":"","children":[{"id":"180","parent":"179","text":"TC MACIZO FACIAL\\NSIN CONTRASTE →\\NGOLD STANDARD","guid":"lWYskgiP78YL_RlMXvBy3A","children":[{"id":"181","parent":"180","text":"Cortes axiales y coronales (1-2mm)","guid":"","children":[]},{"id":"182","parent":"180","text":"Ventana osea + partes blandas","guid":"","children":[]},{"id":"183","parent":"180","text":"Reconstruccion 3D si Fx compleja","guid":"","children":[]}]},{"id":"184","parent":"179","text":"Rx simple → baja sensibilidad,\\NNO recomendada como unica","guid":"iypdsDW7hXPzx16NgvXFHg","children":[{"id":"185","parent":"184","text":"Waters → seno maxilar","guid":"","children":[]},{"id":"186","parent":"184","text":"Caldwell → seno frontal","guid":"","children":[]},{"id":"187","parent":"184","text":"Towne → mandibula","guid":"","children":[]}]},{"id":"188","parent":"179","text":"RM → solo si sospecha lesion intracraneal asociada","guid":"","children":[]}]},{"id":"189","parent":"170","text":"Evaluacion\\Ncomplementaria\\Nen AM","guid":"EQkggffJc_O4G4IDBW5GqQ","children":[{"id":"190","parent":"189","text":"TC cerebro → si deterioro consciencia o anticoagulado","guid":"","children":[]},{"id":"191","parent":"189","text":"Rx columna cervical o TC → SIEMPRE en caida de nivel","guid":"","children":[]},{"id":"192","parent":"189","text":"Laboratorio → hemograma, coagulacion, funcion renal, glicemia","guid":"","children":[]},{"id":"193","parent":"189","text":"ECG → descartar causa cardiaca de caida (sincope)","guid":"","children":[]}]}]},{"id":"194","parent":"0","text":"Manejo Segun\\NTipo de Fractura","guid":"BAbvPnFgxLcpNCwmNs8C-w","children":[{"id":"195","parent":"194","text":"Fractura\\Nnasal","guid":"2PZ1HnL4JFh1IUmpdQqfZQ","children":[{"id":"196","parent":"195","text":"Reduccion cerrada dentro de 7-14 dias","guid":"","children":[]},{"id":"197","parent":"195","text":"Ferula nasal externa 1 semana","guid":"","children":[]},{"id":"198","parent":"195","text":"En AM → considerar manejo conservador si morbilidad quirurgica alta","guid":"","children":[]}]},{"id":"199","parent":"194","text":"Fractura piso\\Norbitario","guid":"J9iDY-Z6tE5g5paEPUtVDw","children":[{"id":"200","parent":"199","text":"Indicaciones\\Nquirurgicas","guid":"B6BS40DujThX2Eg4AqHs8A","children":[{"id":"201","parent":"200","text":"Diplopia persistente >7-10 dias","guid":"","children":[]},{"id":"202","parent":"200","text":"Enoftalmos >2mm","guid":"","children":[]},{"id":"203","parent":"200","text":"Defecto piso >50% o gran fragmento atrapado","guid":"","children":[]}]},{"id":"204","parent":"199","text":"ORIF con malla titanio o polietileno poroso","guid":"ltWf6UevkH668286nXlRFg","children":[]},{"id":"205","parent":"199","text":"Enoftalmos tardio → complicacion frecuente en AM","guid":"","children":[]}]},{"id":"206","parent":"194","text":"Fractura cigomatica\\N(ZMC)","guid":"N9C0YPvOALSPO08A3SrgMQ","children":[{"id":"207","parent":"206","text":"Desplazada → ORIF con miniplacas","guid":"","children":[]},{"id":"208","parent":"206","text":"No desplazada → observacion","guid":"","children":[]},{"id":"209","parent":"206","text":"En AM → balance riesgo-beneficio quirurgico","guid":"","children":[]}]},{"id":"210","parent":"194","text":"Fractura maxilar\\N(Le Fort)","guid":"gS6Oc4tMrfLmsG81CA-f5g","children":[{"id":"211","parent":"210","text":"Reduccion abierta + fijacion rigida","guid":"","children":[]},{"id":"212","parent":"210","text":"MMF (fijacion maxilomandibular) → evitar si posible en AM","guid":"","children":[{"id":"213","parent":"212","text":"Riesgo aspiracion, desnutricion, delirium","guid":"","children":[]}]},{"id":"214","parent":"210","text":"Considerar fijacion rigida sin MMF","guid":"","children":[]}]},{"id":"215","parent":"194","text":"Fractura\\Nmandibular","guid":"wMSCcaMgEellBatIkDG3oQ","children":[{"id":"216","parent":"215","text":"Mandibula atrofica → DESAFIO quirurgico","guid":"","children":[]},{"id":"217","parent":"215","text":"Menor stock oseo → fijacion con placas de reconstruccion","guid":"","children":[]},{"id":"218","parent":"215","text":"Evaluacion dental previa","guid":"","children":[]}]},{"id":"219","parent":"194","text":"Fractura\\Nseno frontal","guid":"YmZVtwepIgBLqcNTCwQ1Zg","children":[{"id":"220","parent":"219","text":"Tabla anterior no desplazada → observacion","guid":"","children":[]},{"id":"221","parent":"219","text":"Tabla anterior desplazada → ORIF","guid":"","children":[]},{"id":"222","parent":"219","text":"Compromiso tabla posterior → obliteracion o cranializacion","guid":"","children":[]},{"id":"223","parent":"219","text":"Fistula LCR → ATB + observacion 5-7 dias → cirugia si persiste","guid":"","children":[]}]}]},{"id":"224","parent":"0","text":"Perlas\\NClinicas","guid":"9Wi0J5pykUybx8Ob7VFcow","children":[{"id":"225","parent":"224","text":"Caida en AM + trauma facial → SIEMPRE descartar Fx cervical y lesion intracraneal","guid":"","children":[]},{"id":"226","parent":"224","text":"Hemoseno en TC = MARCADOR de fractura sinusal → buscar activamente la linea de Fx","guid":"","children":[]},{"id":"227","parent":"224","text":"Hemoseno maxilar unilateral + hipoestesia V2 = Fx piso orbitario hasta demostrar lo contrario","guid":"","children":[]},{"id":"228","parent":"224","text":"En anticoagulado con hemoseno → vigilancia estrecha, TC control 24-48h","guid":"","children":[]},{"id":"229","parent":"224","text":"Hematoma septal → URGENCIA → drenaje en <72h o riesgo necrosis cartilaginosa","guid":"","children":[]},{"id":"230","parent":"224","text":"Evaluar CAUSA DE LA CAIDA → no solo tratar la fractura","guid":"","children":[]},{"id":"231","parent":"224","text":"Fx facial en AM = oportunidad de evaluar riesgo caidas, osteoporosis y fragilidad","guid":"","children":[]},{"id":"232","parent":"224","text":"Menor tasa quirurgica en AM NO significa menor complejidad → comorbilidades prolongan estancia","guid":"","children":[]},{"id":"233","parent":"224","text":"MMF en AM → evitar si posible → riesgo aspiracion, desnutricion, delirium","guid":"","children":[]},{"id":"234","parent":"224","text":"Siempre examen ocular completo antes de reducir cualquier Fx mediofacial","guid":"","children":[]}]},{"id":"235","parent":"0","text":"VER\\NTAMBIEN","guid":"yYHtN12XypcypMLf2YqMrQ","children":[{"id":"236","parent":"235","text":"→ Sindrome Vestibular (ORL)","guid":"","children":[]},{"id":"237","parent":"235","text":"→ Infecciones Profundas de Cuello (ORL)","guid":"","children":[]},{"id":"238","parent":"235","text":"→ Delirium en UCI (Geriatria Critica)","guid":"","children":[]},{"id":"239","parent":"235","text":"→ Caidas y Fractura Cadera (Ortogeriatria)","guid":"","children":[]},{"id":"240","parent":"235","text":"→ Osteoporosis (Metabolismo Oseo)","guid":"","children":[]},{"id":"241","parent":"235","text":"→ Anticoagulacion Perioperatoria (Farmacologia)","guid":"","children":[]}]},{"id":"242","parent":"0","text":"Referencias","guid":"","children":[{"id":"243","parent":"242","text":"1. Rahimpour A, et al. Age-Related Patterns of Traumatic Facial Fractures. Cureus. 2024;16(6):e62090.","guid":"","children":[]},{"id":"244","parent":"242","text":"2. Lee K, et al. Facial Fractures as a Result of Falls in the Elderly. J Craniofac Surg. 2019;30(1):135-139.","guid":"","children":[]},{"id":"245","parent":"242","text":"3. Allareddy V, et al. Facial Fractures In the Aging Population. Ann Plast Surg. 2016;76(Suppl 3):S204-8.","guid":"","children":[]},{"id":"246","parent":"242","text":"4. Boscia J, et al. Age Effects in Facial Fracture Trauma. Cureus. 2023;15(11):e48091.","guid":"","children":[]},{"id":"247","parent":"242","text":"5. Arroyo Bote S, et al. Surgical Management of Facial Fractures in Geriatric Patients. Diagnostics. 2023;13(19):3021.","guid":"","children":[]},{"id":"248","parent":"242","text":"6. Torabi SJ, et al. Incidence and Reimbursement Trends for Facial Fracture Repair in the Elderly. Laryngoscope. 2024;134(2):659-665.","guid":"","children":[]},{"id":"249","parent":"242","text":"7. Amar AP, et al. Epidemiology of facial fractures in the elderly. Eur J Trauma Emerg Surg. 2020;46(4):765-770.","guid":"","children":[]},{"id":"250","parent":"242","text":"8. Lenkeit C, et al. Maxillary Sinus Fracture. StatPearls. 2023.","guid":"","children":[]},{"id":"251","parent":"242","text":"9. Manolidis S. Frontal Sinus Fractures: Management and Complications. Craniomaxillofac Trauma Reconstr. 2019;12(3):241-249.","guid":"","children":[]},{"id":"252","parent":"242","text":"10. Irgebay Z, et al. Characteristics of facial fractures in the elderly population. J Craniofac Surg. 2022;33:1294-1298.","guid":"","children":[]}]}]},"node_count":252,"relations":[],"cross_references":[],"specialty":"Geriatría","folder":"Entidades clínicas/Ortogeriatría","filename":"FracturaFacial PersonaMayor iPad","id":"map_1519","resolved_references":[],"title_raw":"FracturaFacial PersonaMayor iPad"}