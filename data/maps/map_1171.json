{"title":"Mononucleosis infecciosa","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Entidades clínicas/Infectología/Paper. Mononucleosis infecciosa-2025.smmx","root":{"id":"0","parent":"-1","text":"Mononucleosis\\Ninfecciosa","guid":"jae8TZt5oTvYfuJ8iZpcBw","children":[{"id":"1","parent":"0","text":"##\\NCARACTERÍSTICAS\\NGENERALES","guid":"","children":[{"id":"2","parent":"1","text":"- Caracterizada por fiebre de inicio reciente, odinofagia, adenopatías cervicales y linfocitosis atípica","guid":"MSnL6T4PW_rpJv4VFb41Kg","children":[]},{"id":"3","parent":"1","text":"- Principal causa: Virus Epstein-Barr (VEB) - 80-90% de los casos","guid":"EtZ4ec-8WB9C_rh2na2lqA","children":[]},{"id":"4","parent":"1","text":"- Transmisión: secreciones orofaríngeas","guid":"YFRiKXeKMZRBMIWNSnE9Mg","children":[]},{"id":"5","parent":"1","text":"- Período de incubación: 30-50 días","guid":"YTHSlZzrO9XDJYSJMTo3KQ","children":[]},{"id":"6","parent":"1","text":"- Mayor expresión clínica en adolescentes y adultos jóvenes (>70%)","guid":"pxIPn_Ki_Y6kE-_elkiRhw","children":[]}]},{"id":"7","parent":"0","text":"## ETIOLOGÍA","guid":"","children":[{"id":"8","parent":"7","text":"- Virus Epstein-Barr (VEB): 80-90%","guid":"AMjrXJJRAYMWKuwX2y5CZA","children":[]},{"id":"9","parent":"7","text":"- Citomegalovirus (CMV): 5-7%","guid":"T0QpYO1FbyWg-ulf2PT57w","children":[]},{"id":"10","parent":"7","text":"- Primoinfección VIH: infrecuente","guid":"IlYgSEtKlSLfPsju71tdmA","children":[]},{"id":"11","parent":"7","text":"- Toxoplasma gondii: infrecuente","guid":"jmd3sfTecU2pJUBLsdjn1Q","children":[]},{"id":"12","parent":"7","text":"- Virus herpes humano 6 (VHH-6): infrecuente","guid":"QTzN4z0HK-Evuh33xTL6Vw","children":[]}]},{"id":"13","parent":"0","text":"## CUADRO\\NCLÍNICO POR VEB","guid":"","children":[{"id":"14","parent":"13","text":"- Fase\\Nprodrómica","guid":"62wWUVX5lhDoDuLh46XPPg","children":[{"id":"15","parent":"14","text":"- Decaimiento","guid":"","children":[]},{"id":"16","parent":"14","text":"- Anorexia","guid":"","children":[]},{"id":"17","parent":"14","text":"- Fatigabilidad","guid":"","children":[]},{"id":"18","parent":"14","text":"- Cefalea","guid":"","children":[]},{"id":"19","parent":"14","text":"- Fiebre","guid":"","children":[]}]},{"id":"20","parent":"13","text":"- Manifestaciones\\Nprincipales","guid":"","children":[{"id":"21","parent":"20","text":"- Fiebre (2-3 semanas)","guid":"","children":[]},{"id":"22","parent":"20","text":"- Faringitis con exudado (~30%)","guid":"_tMwDDMJRxguh8hXNjY2cw","children":[]},{"id":"23","parent":"20","text":"- Adenopatías cervicales anteriores y posteriores","guid":"RZGed7Gxhp7nUd3loxMQGw","children":[]},{"id":"24","parent":"20","text":"- Esplenomegalia (17% al examen físico, 100% en imágenes)","guid":"bzZ3Oxnjj12KGC4hOEE8Hg","children":[]}]},{"id":"25","parent":"13","text":"- Manifestaciones\\Ninfrecuentes","guid":"","children":[{"id":"26","parent":"25","text":"- Obstrucción vía aérea","guid":"","children":[]},{"id":"27","parent":"25","text":"- Dolor abdominal","guid":"","children":[]},{"id":"28","parent":"25","text":"- Exantema (~5%)","guid":"","children":[]},{"id":"29","parent":"25","text":"- Hepatomegalia","guid":"","children":[]},{"id":"30","parent":"25","text":"- Ictericia","guid":"","children":[]},{"id":"31","parent":"25","text":"- Edema palpebral","guid":"","children":[]},{"id":"32","parent":"25","text":"- Exantema máculopapular con ampicilina (90-100%)","guid":"djO_pOGLt6J1NFhXjC86xQ","children":[]}]}]},{"id":"33","parent":"0","text":"## HALLAZGOS DE\\NLABORATORIO","guid":"","children":[{"id":"34","parent":"33","text":"- Linfocitosis ≥ 50% (sensibilidad 66%, especificidad 80%)","guid":"gY30whZlPCbHQVc7CDt03Q","children":[]},{"id":"35","parent":"33","text":"- Linfocitos atípicos ≥ 10% (sensibilidad 74%, especificidad 90%)","guid":"vwBbqEqFz3jdANHxfxZ8Bw","children":[]},{"id":"36","parent":"33","text":"- Trombocitopenia (>50% de casos)","guid":"i6aJYSxxh-d6TcjXPFxCRg","children":[]},{"id":"37","parent":"33","text":"- Anemia hemolítica (3%)","guid":"","children":[]}]},{"id":"38","parent":"0","text":"## DIAGNÓSTICO POR\\NAGENTE ETIOLÓGICO","guid":"","children":[{"id":"39","parent":"38","text":"- VEB","guid":"","children":[{"id":"40","parent":"39","text":"- Anticuerpos heterófilos positivos (sensibilidad 63-84%)","guid":"UoJrQyzQWhHbdeSTNz-ZSw","children":[]},{"id":"41","parent":"39","text":"- IgM contra cápside viral (IgM VCA)","guid":"PlvDc9z_vmSNRHXcOJ-j1Q","children":[]},{"id":"42","parent":"39","text":"- Diagnóstico definitivo: IgM VCA (+) + anticuerpos anti-EBNA (-)","guid":"h71WNcayuVEdOneEGaFAVg","children":[]}]},{"id":"43","parent":"38","text":"- CMV","guid":"","children":[{"id":"44","parent":"43","text":"- Diagnóstico tras descartar VEB","guid":"WrgIe5r9vOL6eTIi2SOecQ","children":[]},{"id":"45","parent":"43","text":"- Métodos\\Ndisponibles","guid":"hqYxvC1jK53HkRkCR4FkaQ","children":[{"id":"46","parent":"45","text":"- Antigenemia CMV","guid":"","children":[]},{"id":"47","parent":"45","text":"- Cultivo viral o shell vial culture","guid":"HrpdiBpQoZIbE0y8olYPuw","children":[]},{"id":"48","parent":"45","text":"- Serología (seroconversión)","guid":"LdqSP--sU1Mgs1WUxCzHBA","children":[]},{"id":"49","parent":"45","text":"- Amplificación génica (RPC)","guid":"RXc5lRLn4mW15XkE2pk5dg","children":[]}]}]},{"id":"50","parent":"38","text":"- VIH","guid":"","children":[{"id":"51","parent":"50","text":"- Leucopenia o franca leucopenia","guid":"R_SDCBtw6-g5-m9E-anhiw","children":[]},{"id":"52","parent":"50","text":"- Trombocitopenia","guid":"","children":[]},{"id":"53","parent":"50","text":"- Diagnóstico","guid":"","children":[{"id":"54","parent":"53","text":"- Amplificación por RPC (positiva desde día 10)","guid":"DauWu67521T7DGqVAbPU2w","children":[]},{"id":"55","parent":"53","text":"- Antígeno p24 (desde día 16)","guid":"h8nILhTPtyAqo0XCy-_7_A","children":[]},{"id":"56","parent":"53","text":"- ELISA tercera generación (desde semana 3)","guid":"dmeBEMb4BFn9qKNgtSgVWA","children":[]},{"id":"57","parent":"53","text":"- ELISA cuarta generación (desde día 16)","guid":"7vIceQy58LjT_Y_qZn03Zg","children":[]}]}]},{"id":"58","parent":"38","text":"- Toxoplasma gondii","guid":"","children":[{"id":"59","parent":"58","text":"- Diagnóstico serológico","guid":"","children":[{"id":"60","parent":"59","text":"- Seroconversión IgG o IgM","guid":"vJzpd9fYIurwEUv9oe0sVQ","children":[]},{"id":"61","parent":"59","text":"- Aumento de títulos IgG (≥2 diluciones)","guid":"A3DSBvfhdjZKIUnRJnOv0g","children":[]}]}]},{"id":"62","parent":"38","text":"- VHH-6","guid":"","children":[{"id":"63","parent":"62","text":"- Diagnóstico por seroconversión IgM","guid":"cupR7MsWCOx5XxHpUlcFjA","children":[]},{"id":"64","parent":"62","text":"- Descartar CMV y factor reumatoideo (falsos positivos)","guid":"QHSA94VtD_yoSTTPnrc0MQ","children":[]}]}]},{"id":"65","parent":"0","text":"## DIAGNÓSTICO\\NDIFERENCIAL","guid":"","children":[{"id":"66","parent":"65","text":"- Adenovirus","guid":"","children":[]},{"id":"67","parent":"65","text":"- Corynebacterium diphtheriae","guid":"vKKcai2jbxZ67il3CP0cTA","children":[]},{"id":"68","parent":"65","text":"- Streptococcus pyogenes","guid":"","children":[]},{"id":"69","parent":"65","text":"- Virus influenza A y B","guid":"","children":[]},{"id":"70","parent":"65","text":"- Rubéola","guid":"","children":[]},{"id":"71","parent":"65","text":"- Hepatitis A","guid":"","children":[]},{"id":"72","parent":"65","text":"- Coxiella burnetti","guid":"","children":[]}]},{"id":"73","parent":"0","text":"## COMPLICACIONES","guid":"","children":[{"id":"74","parent":"73","text":"- Hematológicas: anemia hemolítica, trombocitopenia, granulocitopenia","guid":"x9haEwnqJKrm4bZbu2edmw","children":[]},{"id":"75","parent":"73","text":"- Neurológicas: encefalitis, mielitis, síndrome Guillain-Barré, parálisis facial","guid":"Q-bbni-4IVx-EszhrwiSJg","children":[]},{"id":"76","parent":"73","text":"- Cardíacas: miocarditis, pericarditis","guid":"bK3Mi99RRMxKHBDn3QszPA","children":[]},{"id":"77","parent":"73","text":"- Respiratorias: obstrucción laringotonsilar, neumonía","guid":"V51mscGTH3ssHokTDbfa4Q","children":[]},{"id":"78","parent":"73","text":"- Dermatológicas: exantema, vasculitis","guid":"19flMLf5hIjb098KlE9pMg","children":[]},{"id":"79","parent":"73","text":"- Renales: nefritis, glomerulonefritis","guid":"j72fJ8bNE9-lmclyenJtqA","children":[]},{"id":"80","parent":"73","text":"- Hepáticas: hepatitis, necrosis hepática","guid":"ylX__ipnvs77Y2A7ZJa_6A","children":[]},{"id":"81","parent":"73","text":"- Rotura esplénica (0,1%)","guid":"","children":[]},{"id":"82","parent":"73","text":"- Inmunológicas: anergia,\\Nhipogamaglobulinemia","guid":"","children":[]}]},{"id":"83","parent":"0","text":"## TRATAMIENTO","guid":"","children":[{"id":"84","parent":"83","text":"- Manejo sintomático principalmente","guid":"QE1Wg1nR16l0O5eX972UKg","children":[]},{"id":"85","parent":"83","text":"- No requiere intervenciones específicas en inmunocompetentes","guid":"X459L530sYvwPbLoVjLWTw","children":[]},{"id":"86","parent":"83","text":"- Corticosteroides: sólo en casos de obstrucción faucial","guid":"8xupwGKctT7Fhr0xE8IHKg","children":[]},{"id":"87","parent":"83","text":"- Aciclovir: no mejora evolución clínica","guid":"AifqHMr54s7aoWCube52Fw","children":[]},{"id":"88","parent":"83","text":"- Toxoplasmosis severa: sulfadiazina + pirimetamina + ácido folínico","guid":"zlpsvnW6J1iVssB8LYeegQ","children":[]},{"id":"89","parent":"83","text":"- Indicaciones\\Ngenerales","guid":"wJqysqSLjmq39s8dmBnRvA","children":[{"id":"90","parent":"89","text":"- Evitar actividades con riesgo de traumatismo","guid":"7DmtQ4iLBujoo3G-eCeHzg","children":[]},{"id":"91","parent":"89","text":"- Precauciones por un mes","guid":"NF09QTAOHbHJFzLgHmjUMw","children":[]},{"id":"92","parent":"89","text":"- Advertir sobre complicaciones y consulta precoz","guid":"5VA71Byp0jQlSiH4LXSg-g","children":[]}]}]},{"id":"93","parent":"0","text":"## ALGORITMO\\NDIAGNÓSTICO","guid":"","children":[{"id":"94","parent":"93","text":"- Sospecha inicial (cuadro clínico + linfocitosis atípica)","guid":"8ZRrCuQ19ojBgkRfgKrSqg","children":[]},{"id":"95","parent":"93","text":"- Solicitar anticuerpos heterófilos","guid":"MlTvZfZlfb6eMPU1F_JoXQ","children":[]},{"id":"96","parent":"93","text":"- Si anticuerpos heterófilos positivos → VEB","guid":"DSeuwI00BT0HoL76lxBYfg","children":[]},{"id":"97","parent":"93","text":"- Si anticuerpos heterófilos negativos → solicitar IgM VCA","guid":"64FsaC3Hzh2EJ3nfriE8Ow","children":[]},{"id":"98","parent":"93","text":"- Si IgM VCA positivo → infección aguda VEB","guid":"9CAmwmiikWZtX36G3dlZJA","children":[]},{"id":"99","parent":"93","text":"- Si IgM VCA negativo → estudio para CMV y otras causas","guid":"L2Wmc6ePp8Nihmf1lPm8cg","children":[]}]}]},"node_count":99,"relations":[],"cross_references":[],"specialty":"Infectología","folder":"Entidades clínicas/Infectología","filename":"Paper. Mononucleosis infecciosa-2025","id":"map_1171","resolved_references":[],"title_raw":"Paper. Mononucleosis infecciosa-2025"}