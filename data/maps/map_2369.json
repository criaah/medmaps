{"title":"Intoxicaciones","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Entidades clínicas/Urgencias/Intoxicaciones iPad.smmx","root":{"id":"0","parent":"-1","text":"Intoxicaciones —\\NManejo General y\\NEspecífico","guid":"23rQVAy4kgwgWs7GkBaupg","children":[{"id":"1","parent":"0","text":"Epidemiología","guid":"","children":[{"id":"2","parent":"1","text":"71% exposiciones NO intencionales","guid":"","children":[]},{"id":"3","parent":"1","text":"92% involucran ÚNICO tóxico","guid":"","children":[]},{"id":"4","parent":"1","text":"VÍA ORAL más frecuente","guid":"","children":[]},{"id":"5","parent":"1","text":"Mayor morbimortalidad → ingesta intencional adultos","guid":"","children":[]},{"id":"6","parent":"1","text":"Analgésicos, antidepresivos, sedantes, drogas de abuso","guid":"","children":[]}]},{"id":"7","parent":"0","text":"Apreciación\\NInicial","guid":"5dDZ7Z1JTRGRRG7E0roIKg","children":[{"id":"8","parent":"7","text":"ABC UNIVERSAL → todo intoxicado es potencialmente fatal","guid":"","children":[]},{"id":"9","parent":"7","text":"Proteger al personal de salud","guid":"","children":[]},{"id":"10","parent":"7","text":"VÍA AÉREA → siempre\\Nsospechar compromiso","guid":"r3zYdn1bPqyJDL8cPTXtgQ","children":[{"id":"11","parent":"10","text":"Intubación orotraqueal precoz si riesgo aspiración","guid":"","children":[]},{"id":"12","parent":"10","text":"Injuria inhalatoria/cáusticos → IOT LO ANTES POSIBLE","guid":"","children":[]}]},{"id":"13","parent":"7","text":"Compromiso de conciencia\\N→ CÓCTEL DEL COMA","guid":"xFyYM3x1ywpxvesLIgPuhA","children":[{"id":"14","parent":"13","text":"Glucosa → no descartar hipoglicemia con HGT normal","guid":"","children":[]},{"id":"15","parent":"13","text":"Tiamina 100 mg IV en bolo","guid":"","children":[]},{"id":"16","parent":"13","text":"Naloxona → sin respuesta a 10 mg descarta opioides","guid":"","children":[]}]},{"id":"17","parent":"7","text":"Flumazenil → CONTROVERTIDO\\Nen intoxicación desconocida","guid":"NEwWpsxNdrfqxd3dXyPTbA","children":[{"id":"18","parent":"17","text":"Riesgo de convulsiones","guid":"","children":[]},{"id":"19","parent":"17","text":"Uso seguro: certeza BZD + compromiso vía aérea amenazante","guid":"","children":[]},{"id":"20","parent":"17","text":"Bolos 0.2 mg → 0.3 mg/min hasta 3 mg","guid":"","children":[]}]},{"id":"21","parent":"7","text":"Paro cardíaco con AESP o asistolia → SIEMPRE considerar sobredosis","guid":"","children":[]}]},{"id":"22","parent":"0","text":"Identificación del\\NAgente Tóxico","guid":"ukFYeTaDdkEgDnjho8fvSw","children":[{"id":"23","parent":"22","text":"Interrogatorio","guid":"","children":[{"id":"24","parent":"23","text":"Paciente, familiares, testigos","guid":"","children":[]},{"id":"25","parent":"23","text":"Registros farmacia, ficha clínica, médico personal","guid":"","children":[]},{"id":"26","parent":"23","text":"Revisar frascos, cuantificar fármacos, hora y vía exposición","guid":"","children":[]}]},{"id":"27","parent":"22","text":"Examen físico","guid":"","children":[{"id":"28","parent":"27","text":"Olor → ajo: arsénico/organofosforados","guid":"","children":[]},{"id":"29","parent":"27","text":"Signos vitales → tabla toxidromes","guid":"","children":[]},{"id":"30","parent":"27","text":"Examen ocular → miosis/midriasis, nistagmo","guid":"","children":[]}]},{"id":"31","parent":"22","text":"Toxidromes","guid":"","children":[{"id":"32","parent":"31","text":"ANTICOLINÉRGICO","guid":"","children":[{"id":"33","parent":"32","text":"Delirio, taquicardia, piel SECA, rubor facial","guid":"","children":[]},{"id":"34","parent":"32","text":"Midriasis, retención urinaria, hipertermia","guid":"","children":[]},{"id":"35","parent":"32","text":"Causas: antihistamínicos, atropina, antidepresivos, plantas","guid":"","children":[]}]},{"id":"36","parent":"31","text":"SIMPATICOMIMÉTICO","guid":"","children":[{"id":"37","parent":"36","text":"Agitación, paranoia, taquicardia, hipertensión","guid":"","children":[]},{"id":"38","parent":"36","text":"Hipertermia, diaforesis, midriasis","guid":"","children":[]},{"id":"39","parent":"36","text":"Causas: cocaína, anfetaminas, teofilina, efedrina","guid":"","children":[]}]},{"id":"40","parent":"31","text":"COLINÉRGICO","guid":"","children":[{"id":"41","parent":"40","text":"Miosis, bradicardia, broncorrea, broncoespasmo","guid":"","children":[]},{"id":"42","parent":"40","text":"SLUDGE → Sialorrea, Lacrimación, Uresis, Defecación/GI, Emesis","guid":"","children":[]},{"id":"43","parent":"40","text":"Fasciculaciones, debilidad muscular","guid":"","children":[]},{"id":"44","parent":"40","text":"Causas: organofosforados, carbamatos, fisostigmina","guid":"","children":[]}]},{"id":"45","parent":"31","text":"OPIOIDE/SEDATIVO","guid":"","children":[{"id":"46","parent":"45","text":"TRIADA → coma, depresión respiratoria, MIOSIS","guid":"","children":[]},{"id":"47","parent":"45","text":"Hipotensión, bradicardia, hipotermia","guid":"","children":[]},{"id":"48","parent":"45","text":"Causas: narcóticos, barbitúricos, benzodiacepinas, etanol","guid":"","children":[]}]},{"id":"49","parent":"31","text":"SEROTONINÉRGICO","guid":"","children":[{"id":"50","parent":"49","text":"Agitación, rigidez, temblor, hiperreflexia, clonus","guid":"","children":[]},{"id":"51","parent":"49","text":"Hipertermia, diaforesis, taquicardia, midriasis","guid":"","children":[]},{"id":"52","parent":"49","text":"Causas: ISRS, IMAO, meperidina, cocaína","guid":"","children":[]}]}]},{"id":"53","parent":"22","text":"Laboratorio","guid":"","children":[{"id":"54","parent":"53","text":"ANIÓN GAP ELEVADO → salicilatos, etilenglicol, metanol, CO, paracetamol","guid":"","children":[]},{"id":"55","parent":"53","text":"GAP OSMOLAR ELEVADO → etanol, metanol, etilenglicol, manitol","guid":"","children":[]},{"id":"56","parent":"53","text":"GAP SATURACIÓN ELEVADO → CO, metahemoglobina, cianuro","guid":"","children":[]},{"id":"57","parent":"53","text":"ECG → QRS prolongado (tricíclicos), QTc, arritmias","guid":"","children":[]}]}]},{"id":"58","parent":"0","text":"Descontaminación","guid":"","children":[{"id":"59","parent":"58","text":"Dérmica → agua y jabón abundante, retirar ropa","guid":"","children":[]},{"id":"60","parent":"58","text":"Ocular → irrigación con suero fisiológico profusa","guid":"","children":[]},{"id":"61","parent":"58","text":"CARBÓN ACTIVADO → pilar gastrointestinal","guid":"","children":[{"id":"62","parent":"61","text":"Dosis 1 g/kg","guid":"","children":[]},{"id":"63","parent":"61","text":"Requiere conciencia conservada o vía aérea protegida","guid":"","children":[]},{"id":"64","parent":"61","text":"NO adsorbe: alcoholes, hidrocarburos, litio, hierro, organofosforados","guid":"","children":[]}]},{"id":"65","parent":"58","text":"Lavado gástrico → beneficio solo <1-2h de ingesta","guid":"","children":[{"id":"66","parent":"65","text":"Contraindicado: cáusticos, derivados kerosene","guid":"","children":[]}]},{"id":"67","parent":"58","text":"Dosis repetidas carbón (diálisis GI) → 0.5 g/kg c/2-4h","guid":"","children":[{"id":"68","parent":"67","text":"Útil: baja unión a proteínas, vida media larga","guid":"","children":[]}]},{"id":"69","parent":"58","text":"Irrigación intestinal polietilenglicol → 1-2 L/h","guid":"","children":[{"id":"70","parent":"69","text":"Tabletas liberación sostenida, paquetes drogas ilícitas","guid":"","children":[]}]}]},{"id":"71","parent":"0","text":"Eliminación","guid":"","children":[{"id":"72","parent":"71","text":"Alcalinización de orina → salicilatos, fenobarbital","guid":"","children":[{"id":"73","parent":"72","text":"Bicarbonato sodio IV 3-4 mEq/kg c/4h","guid":"","children":[]},{"id":"74","parent":"72","text":"pH urinario objetivo 7-8, pH plasmático 7.45-7.5","guid":"","children":[]}]},{"id":"75","parent":"71","text":"Hemodiálisis → bajo PM, hidrosoluble, bajo Vol Distribución","guid":"","children":[{"id":"76","parent":"75","text":"Indicado: alcoholes, salicilatos, metales pesados, litio","guid":"","children":[]}]},{"id":"77","parent":"71","text":"Hemoperfusión → fenitoína, carbamazepina, teofilina, fenobarbital","guid":"","children":[]}]},{"id":"78","parent":"0","text":"ANTÍDOTOS ESPECÍFICOS","guid":"","children":[{"id":"79","parent":"78","text":"Paracetamol → N-ACETILCISTEÍNA (NAC)","guid":"","children":[]},{"id":"80","parent":"78","text":"Benzodiacepinas → FLUMAZENIL","guid":"","children":[]},{"id":"81","parent":"78","text":"Opioides → NALOXONA","guid":"","children":[]},{"id":"82","parent":"78","text":"Organofosforados → ATROPINA + PRALIDOXIMA","guid":"","children":[]},{"id":"83","parent":"78","text":"Digoxina → DIGOXINA FAB","guid":"","children":[]},{"id":"84","parent":"78","text":"Metanol/Etilenglicol → FOMEPIZOL (o etanol)","guid":"","children":[]},{"id":"85","parent":"78","text":"Metahemoglobinemia → AZUL DE METILENO","guid":"","children":[]},{"id":"86","parent":"78","text":"Cianuro → HIDROXICOBALAMINA (o nitrito sodio + tiosulfato)","guid":"","children":[]},{"id":"87","parent":"78","text":"Betabloqueadores → GLUCAGÓN","guid":"","children":[]},{"id":"88","parent":"78","text":"Antidepresivos tricíclicos → BICARBONATO DE SODIO","guid":"","children":[]},{"id":"89","parent":"78","text":"Sulfonilureas → OCTREÓTIDE + glucosa","guid":"","children":[]},{"id":"90","parent":"78","text":"Hierro → DEFEROXAMINA","guid":"","children":[]},{"id":"91","parent":"78","text":"Anticolinérgicos severos → FISOSTIGMINA","guid":"","children":[]},{"id":"92","parent":"78","text":"CO → OXÍGENO 100% (cámara hiperbárica si grave)","guid":"","children":[]},{"id":"93","parent":"78","text":"Tramadol/Opioides → NALOXONA","guid":"","children":[]}]},{"id":"94","parent":"0","text":"Intoxicaciones Específicas","guid":"","children":[{"id":"95","parent":"94","text":"PARACETAMOL","guid":"","children":[{"id":"96","parent":"95","text":"Dosis tóxica >7.5g adultos / >150 mg/kg niños","guid":"","children":[]},{"id":"97","parent":"95","text":"Mecanismo → depleción glutatión → NAPQI hepatotóxico","guid":"","children":[]},{"id":"98","parent":"95","text":"4 fases → fase 3 (48-96h) falla hepática PEAK transaminasas","guid":"","children":[]},{"id":"99","parent":"95","text":"Nomograma de Rumack-Matthew → guía indicación NAC","guid":"","children":[]},{"id":"100","parent":"95","text":"NAC oral: carga 140 mg/kg → 70 mg/kg c/4h x17 dosis","guid":"","children":[]},{"id":"101","parent":"95","text":"NAC IV si vía oral no viable","guid":"","children":[]},{"id":"102","parent":"95","text":"FACTORES ALTO RIESGO: alcohólicos, inductores CYP450","guid":"","children":[]}]},{"id":"103","parent":"94","text":"SALICILATOS","guid":"","children":[{"id":"104","parent":"103","text":"Dosis tóxica >150 mg/kg aguda / >100 mg/kg x días crónica","guid":"","children":[]},{"id":"105","parent":"103","text":"Fisiopatología → alcalosis respiratoria inicial → ACIDOSIS metabólica","guid":"","children":[]},{"id":"106","parent":"103","text":"Desacoplan fosforilación oxidativa","guid":"","children":[]},{"id":"107","parent":"103","text":"Clínica: tinnitus, polipnea, fiebre, compromiso conciencia","guid":"","children":[]},{"id":"108","parent":"103","text":"Manejo: alcalinización orina FUNDAMENTAL","guid":"","children":[]},{"id":"109","parent":"103","text":"Diálisis si: coma, convulsiones, falla orgánica múltiple","guid":"","children":[]}]},{"id":"110","parent":"94","text":"ANTIDEPRESIVOS TRICÍCLICOS","guid":"","children":[{"id":"111","parent":"110","text":"Mecanismo: inhibición canales Na+ + anticolinérgico + anti-alfa","guid":"","children":[]},{"id":"112","parent":"110","text":"ECG → QRS >100 ms = alta probabilidad arritmias y convulsiones","guid":"","children":[]},{"id":"113","parent":"110","text":"Desviación eje a la derecha frecuente","guid":"","children":[]},{"id":"114","parent":"110","text":"BICARBONATO SODIO HIPERTÓNICO → todo QRS >100 ms","guid":"","children":[{"id":"115","parent":"114","text":"Bolo 1-2 mEq/kg → pH objetivo 7.5-7.55","guid":"","children":[]}]},{"id":"116","parent":"110","text":"NO fisostigmina → riesgo convulsiones y muerte","guid":"","children":[]}]},{"id":"117","parent":"94","text":"ORGANOFOSFORADOS","guid":"","children":[{"id":"118","parent":"117","text":"Inhiben ACETILCOLINESTERASA irreversiblemente","guid":"","children":[]},{"id":"119","parent":"117","text":"Exposición agrícola, accidental, intencional (gas Sarín)","guid":"","children":[]},{"id":"120","parent":"117","text":"Síndrome muscarínico: SLUDGE + bradicardia + broncoespasmo","guid":"","children":[]},{"id":"121","parent":"117","text":"Síndrome nicotínico: fasciculaciones, debilidad, taquicardia","guid":"","children":[]},{"id":"122","parent":"117","text":"ATROPINA → 1-2 mg IV c/2-3 min hasta atropinización","guid":"","children":[{"id":"123","parent":"122","text":"Endpoint: midriasis + xerostomía + taquicardia","guid":"","children":[]},{"id":"124","parent":"122","text":"Puede requerir infusión 4 mg/h","guid":"","children":[]}]},{"id":"125","parent":"117","text":"PRALIDOXIMA → 1-2g IV en 30 min → 500 mg/h x 24h","guid":"","children":[{"id":"126","parent":"125","text":"NO indicada en carbamatos (unión reversible)","guid":"","children":[]}]}]},{"id":"127","parent":"94","text":"BETABLOQUEADORES","guid":"","children":[{"id":"128","parent":"127","text":"Bradicardia e hipotensión → PREDOMINANTES","guid":"","children":[]},{"id":"129","parent":"127","text":"Lipofílicos (propranolol) → efecto SNC intenso","guid":"","children":[]},{"id":"130","parent":"127","text":"GLUCAGÓN 2-5 mg IV → antídoto más eficiente","guid":"","children":[]},{"id":"131","parent":"127","text":"Atropina útil en bradicardia","guid":"","children":[]},{"id":"132","parent":"127","text":"Sotalol → >24h de efectos tóxicos (vigilancia prolongada)","guid":"","children":[]},{"id":"133","parent":"127","text":"Acebutolol/pindolol → taquicardia + arritmias ventriculares","guid":"","children":[]}]},{"id":"134","parent":"94","text":"LITIO","guid":"","children":[{"id":"135","parent":"134","text":"Carbón activado NO útil","guid":"","children":[]},{"id":"136","parent":"134","text":"Irrigación intestinal → puede reducir absorción","guid":"","children":[]},{"id":"137","parent":"134","text":"Diálisis → >3.5 mEq/L agudo / >2.5 mEq/L crónico o IR","guid":"","children":[]},{"id":"138","parent":"134","text":"Toxicidad crónica → daño neurológico IRREVERSIBLE","guid":"","children":[]},{"id":"139","parent":"134","text":"Complicación renal → diabetes insípida nefrogénica","guid":"","children":[]}]},{"id":"140","parent":"94","text":"COCAÍNA","guid":"","children":[{"id":"141","parent":"140","text":"Simpaticomimético → inhibe recaptura NE + EP","guid":"","children":[]},{"id":"142","parent":"140","text":"Isquemia miocárdica → ↑consumo O2 + ↓aporte","guid":"","children":[]},{"id":"143","parent":"140","text":"HIPERTERMIA severa → potencialmente fatal","guid":"","children":[]},{"id":"144","parent":"140","text":"IAM por cocaína → NO betabloqueadores → fentolamina","guid":"","children":[]},{"id":"145","parent":"140","text":"COKAETILENO (alcohol + cocaína) → mayor cardiotoxicidad","guid":"","children":[]}]},{"id":"146","parent":"94","text":"METANOL/ETILENGLICOL","guid":"","children":[{"id":"147","parent":"146","text":"ANIÓN GAP + GAP OSMOLAR elevados → clave diagnóstica","guid":"","children":[]},{"id":"148","parent":"146","text":"Metanol → metabolito fórmico → toxicidad retina/SNC","guid":"","children":[]},{"id":"149","parent":"146","text":"Etilenglicol → oxalato cálcico → falla renal","guid":"","children":[]},{"id":"150","parent":"146","text":"FOMEPIZOL → inhibe alcohol deshidrogenasa (PRIMERA LÍNEA)","guid":"","children":[]},{"id":"151","parent":"146","text":"Etanol → alternativa si no disponible fomepizol","guid":"","children":[]},{"id":"152","parent":"146","text":"Hemodiálisis → elimina tóxico y metabolitos","guid":"","children":[]}]},{"id":"153","parent":"94","text":"HIDROCARBUROS","guid":"","children":[{"id":"154","parent":"153","text":"CONTRAINDICADO vómito inducido y lavado gástrico","guid":"","children":[]},{"id":"155","parent":"153","text":"Carbón activado NO útil","guid":"","children":[]},{"id":"156","parent":"153","text":"Principal riesgo: ASPIRACIÓN pulmonar","guid":"","children":[]},{"id":"157","parent":"153","text":"80% evolución asintomática","guid":"","children":[]},{"id":"158","parent":"153","text":"Alta si asintomático + RxTx normal a las 6h","guid":"","children":[]}]},{"id":"159","parent":"94","text":"CIANURO","guid":"","children":[{"id":"160","parent":"159","text":"Gap saturación arterial elevado","guid":"","children":[]},{"id":"161","parent":"159","text":"Clínica: agitación → coma → acidosis láctica severa","guid":"","children":[]},{"id":"162","parent":"159","text":"HIDROXICOBALAMINA 5g IV → PRIMERA LÍNEA","guid":"","children":[]},{"id":"163","parent":"159","text":"Alternativa: nitrito sodio + tiosulfato sódico","guid":"","children":[]}]},{"id":"164","parent":"94","text":"SÍNDROME SEROTONINÉRGICO","guid":"","children":[{"id":"165","parent":"164","text":"Triada: cognitivo + neuromuscular + autonómico","guid":"","children":[]},{"id":"166","parent":"164","text":"Clonus + hiperreflexia = clave diagnóstica","guid":"","children":[]},{"id":"167","parent":"164","text":"Diferencial con síndrome neuroléptico maligno (rigidez en rueda)","guid":"","children":[]},{"id":"168","parent":"164","text":"CIPROHEPTADINA → antagonista serotoninérgico","guid":"","children":[]},{"id":"169","parent":"164","text":"Suspensión inmediata del agente causal","guid":"","children":[]}]}]},{"id":"170","parent":"0","text":"Perlas Clínicas","guid":"","children":[{"id":"171","parent":"170","text":"CÓCTEL DEL COMA ante toda alteración inexplicable de conciencia","guid":"","children":[]},{"id":"172","parent":"170","text":"IOT precoz salva vidas → no esperar deterioro completo","guid":"","children":[]},{"id":"173","parent":"170","text":"Flumazenil CONTRAINDICADO si sospecha intoxicación mixta o tricíclicos","guid":"","children":[]},{"id":"174","parent":"170","text":"QRS >100 ms en tricíclicos → bicarbonato INMEDIATO","guid":"","children":[]},{"id":"175","parent":"170","text":"Organofosforados → atropina hasta SECAR las secreciones, no hasta midriasis","guid":"","children":[]},{"id":"176","parent":"170","text":"Cocaína + IAM → NUNCA betabloqueadores","guid":"","children":[]},{"id":"177","parent":"170","text":"Litio → daño neurológico crónico puede ser irreversible","guid":"","children":[]},{"id":"178","parent":"170","text":"Metanol/etilenglicol → anión gap + osmol gap = diagnóstico diferencial SIEMPRE","guid":"","children":[]},{"id":"179","parent":"170","text":"NALOXONA → dosis acumulativa >10mg sin respuesta descarta opioides","guid":"","children":[]},{"id":"180","parent":"170","text":"Carbón activado ANTES de antídoto → no retrasar antídoto por descontaminación","guid":"","children":[]},{"id":"181","parent":"170","text":"Adulto mayor → farmacocinética alterada, mayor susceptibilidad, dosis tóxicas MENORES","guid":"","children":[]},{"id":"182","parent":"170","text":"Embarazada → NAC igual protocolo estándar","guid":"","children":[]}]},{"id":"183","parent":"0","text":"VER TAMBIÉN","guid":"","children":[{"id":"184","parent":"183","text":"→ Delirium UCI (UCI-Geriatría)","guid":"","children":[]},{"id":"185","parent":"183","text":"→ Sedoanalgesia UCI (Farmacología UCI)","guid":"","children":[]},{"id":"186","parent":"183","text":"→ Arritmias manejo (Cardiología)","guid":"","children":[]},{"id":"187","parent":"183","text":"→ Falla hepática aguda (Gastroenterología)","guid":"","children":[]}]},{"id":"188","parent":"0","text":"Referencias","guid":"","children":[{"id":"189","parent":"188","text":"1. Gracaman P, Quezada R. Intoxicaciones. En: Medicina Intensiva. Parte 2 - Urgencia y Reanimación. 2023:96-104.","guid":"","children":[]},{"id":"190","parent":"188","text":"2. Mégarbane B, et al. Toxicological emergencies. N Engl J Med. 2019;381(2):163-174.","guid":"","children":[]},{"id":"191","parent":"188","text":"3. Olson KR, ed. Poisoning & Drug Overdose. 7th ed. McGraw-Hill; 2017.","guid":"","children":[]},{"id":"192","parent":"188","text":"4. Chyka PA, et al. Position paper: single-dose activated charcoal. Clin Toxicol. 2005;43(2):61-87.","guid":"","children":[]},{"id":"193","parent":"188","text":"5. Antman EM, et al. Treatment of 150 cases of life-threatening digitalis intoxication with digoxin-specific Fab antibody fragments. Circulation. 1990;81(6):1744-52.","guid":"","children":[]}]}]},"node_count":193,"relations":[],"cross_references":[],"specialty":"General","folder":"Entidades clínicas/Urgencias","filename":"Intoxicaciones iPad","id":"map_2369","resolved_references":[],"title_raw":"Intoxicaciones iPad"}