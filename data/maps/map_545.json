mm5CSfPCdQ","children":[{"id":"52","parent":"51","text":"Gluconeogenesis y glucogenolisis no suprimidas","guid":"OQ9bxDf1RguMs5u7lVy-Nw","children":[]},{"id":"53","parent":"51","text":"Lipolisis → NEFAs → oxidacion hepatica","guid":"ge6xkgPaT0uXAk11keqLmQ","children":[]},{"id":"54","parent":"51","text":"CETOGENESIS EXCESIVA → cetonemia + acidosis metabolica","guid":"d8qoCW3BT0SrBAGfYQ7Cxw","children":[]}]}]},{"id":"55","parent":"43","text":"HHS","guid":"K0GchjuMQzqjSXV09gzmlA","children":[{"id":"56","parent":"55","text":"Deficiencia RELATIVA de insulina","guid":"x7SvbsHPTJ2fCxSIU_kHCg","children":[]},{"id":"57","parent":"55","text":"Insulina residual suficiente para prevenir cetogenesis","guid":"sml-fNbrSj2hPO4x9rNVUA","children":[]},{"id":"58","parent":"55","text":"INSUFICIENTE para controlar hiperglicemia","guid":"ZZoTBDlZQ9O115CqpCDWAg","children":[]},{"id":"59","parent":"55","text":"Hiperglicemia → diuresis osmotica → deplecion volumen","guid":"TVoMHyilT6Cz233y2d_lTA","children":[]},{"id":"60","parent":"55","text":"Falta ingesta liquidos → hiperosmolaridad → IRA + deterioro cognitivo","guid":"RDCuzUPUT9SgYoynZAX9Gw","children":[]}]},{"id":"61","parent":"43","text":"Estado\\Ninflamatorio","guid":"JJo_i3wIStmH_hanibKZTA","children":[{"id":"62","parent":"61","text":"Hiperglicemia →\\Ncitocinas proinflamatorias","guid":"Z3hnZJG1Tr6e_xUKFaFIKw","children":[{"id":"63","parent":"62","text":"TNF-alfa, IL-1, IL-6, IL-8","guid":"OjSvLmlTQdSZ6PvgmgB01Q","children":[]},{"id":"64","parent":"62","text":"PCR elevada","guid":"6HYGlWcZSSqVQ1WXhT9uFQ","children":[]},{"id":"65","parent":"62","text":"Especies reactivas de oxigeno","guid":"JKWBa5RzRLaSQHpzG9j_Vw","children":[]}]},{"id":"66","parent":"61","text":"Regresa a normalidad en ~24h con insulina + hidratacion","guid":"jXR54LMgQP6PPYuQUOb3bA","children":[]}]}]},{"id":"67","parent":"0","text":"Factores\\Nprecipitantes","guid":"W0UZN6iYQl2bjiTKizMoCQ","children":[{"id":"68","parent":"67","text":"Infecciones (14-58% de casos)","