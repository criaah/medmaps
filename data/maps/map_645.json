guid":"fWGfPlfch7NWW9ITHIVBUQ","children":[]},{"id":"118","parent":"115","text":"- Patofisiología: Posiblemente relacionada con EvW adquirida","guid":"TvC55AquN0doUkbgVv2rbg","children":[]},{"id":"119","parent":"115","text":"- Datos:","guid":"T3YmpgGduiEdujeNTNfF5A","children":[{"id":"120","parent":"119","text":"• Serie 1: 32/172 pacientes (19%) desarrollaron sangrado GI [25]","guid":"FkcEdV_TAiIju_K_UntDpQ","children":[{"id":"121","parent":"120","text":"- Angiodisplasia: 31% de episodios de sangrado","guid":"HYB4TTy25cUGLUjZHFmKCg","children":[]}]},{"id":"122","parent":"119","text":"• Serie 2: 62/391 pacientes (16%) desarrollaron sangrado GI [29]","guid":"T3M-_EZnH-tYLXUATt2nTA","children":[{"id":"123","parent":"122","text":"- Malformaciones vasculares: 27% de episodios de sangrado","guid":"NqzHCHLnudNISDEiPfrpfw","children":[]}]}]}]}]},{"id":"124","parent":"0","text":"Patofisiología de\\Nangiodisplasias:","guid":"bK-1TBZ9LPAJAtBZYKiBWQ","children":[{"id":"125","parent":"124","text":"1. Distribución:","guid":"Y6vasWu0xoIIvD8sdGRQAQ","children":[{"id":"126","parent":"125","text":"- Clásicamente: Colon","guid":"WXpB1XQWCaBpXQc1KGr7uQ","children":[]},{"id":"127","parent":"125","text":"- Realidad: Todo el tracto gastrointestinal (TGI)","guid":"fsRA51GvThZ_aKcnFQtFXA","children":[]},{"id":"128","parent":"125","text":"- Presentación: Única o múltiple en una o varias regiones del TGI","guid":"MYJQOCMkmeZnhokBTwLIhQ","children":[]}]},{"id":"129","parent":"124","text":"2. Morfología:","guid":"AhfhBGZquxo0qtG_VZ-Y2Q","children":[{"id":"130","parent":"129","text":"- Composición: Vasos ectásicos, dilatados, de pared delgada","guid":"X9t_q22z0dprXFKPL06-qA","children":[]},{"id":"131","parent":"129","text":"- Revestimiento: Endotelio ± pequeñas cantidades de músculo liso","guid":"NBrxxUOJx49-LGX0ase4zg","children":[]},{"id":"132","parent":"129","text":"- Característica principal: Venas submucosas dilatadas y tortuosas","guid":"NnGBYkZ0lxYowqJNW-ixYg","children":[]},{"id":"133","