":"77","text":"3. Acción\\Nintermedia:","guid":"ErT2uzILEZj0V-H2GMk9mA","children":[{"id":"93","parent":"92","text":"• NPH (Neutral\\NProtamine Hagedorn):","guid":"8ci1RziajJMUXeBUiyp_jA","children":[{"id":"94","parent":"93","text":"• Comercial: Humulin N, Insulatard.","guid":"Prs7v7-ICNfhrRIPnasXiQ","children":[]},{"id":"95","parent":"93","text":"• Precio aprox.: $11,000 - $16, 000 CLP\\N(viales 10 mL).","guid":"Q7C1ewJbf_JwvdoiVpQspQ","children":[]}]}]},{"id":"96","parent":"77","text":"4. Acción\\Nprolongada:","guid":"eTl61xD47UavPHoqXS-Gkw","children":[{"id":"97","parent":"96","text":"• Glargina:","guid":"dZFvUtqLkIDlpSPMvIW_EA","children":[{"id":"98","parent":"97","text":"• Comercial: Lantus, Toujeo.","guid":"fSXXHVryJOk7MHx4bFxMcg","children":[]},{"id":"99","parent":"97","text":"• Precio aprox.: $45,000 - $60, 000 CLP\\N(plumas 3 mL).","guid":"4Th6JknHXheLZWZSsIOgwg","children":[]}]},{"id":"100","parent":"96","text":"• Detemir:","guid":"-wrzkB1zJqcugzOxxqniCw","children":[{"id":"101","parent":"100","text":"• Comercial: Levemir.","guid":"Y41h6-_x2kKzGlJh6JDEQw","children":[]},{"id":"102","parent":"100","text":"• Precio aprox.: $45,000 - $55, 000 CLP\\N(plumas 3 mL).","guid":"saNe8LCM7keNeAxK8gEyZA","children":[]}]}]},{"id":"103","parent":"77","text":"5. Acción ultra-larga:","guid":"9ZBkPq8zKDXSdnx2EY5sAw","children":[{"id":"104","parent":"103","text":"• Degludec:","guid":"hvChqPvN_YjaBH_KpDTENg","children":[{"id":"105","parent":"104","text":"• Comercial: Tresiba.","guid":"HEA3gbxPac4s33WknbJTkw","children":[]},{"id":"106","parent":"104","text":"• Precio aprox.: $55,000 - $65, 000 CLP\\N(plumas 3 mL).","guid":"2D8u-2yufspw2ubOH_1oCQ","children":[]}]}]},{"id":"107","parent":"77","text":"6. Premezcladas:","guid":"vrRbiDblW0kiO-PJVrzkPg","children":[{"id":"108","parent":"107","text":"• Lispro Mix:","guid":"9MtvpLOxiYVNUv7M5aBahA","children":[{"id":"109","parent":"108","text":"• Comercial: Humalog Mix 50, Humalog Mix 25.","guid":"mEY6txRSZ-CVC4x6gD7j4w","children":[]