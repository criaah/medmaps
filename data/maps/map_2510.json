[]},{"id":"160","parent":"155","text":"Fracaso manejo conservador 48-72h","guid":"-exEuY4-S_Oy-9pT9KY2-w","children":[]},{"id":"161","parent":"155","text":"Obstruccion completa de intestino grueso (sin opcion endoscopica)","guid":"RAMVOM7jRymddJ9of-YOWA","children":[]}]},{"id":"162","parent":"130","text":"PROCEDIMIENTOS QUIRURGICOS","guid":"VaikhNleSp63kqTuE50EDg","children":[{"id":"163","parent":"162","text":"OID por bridas -> adherenciolisis","guid":"Rfjq6YpRSQKHOI6sNfF8DQ","children":[]},{"id":"164","parent":"162","text":"Hernia -> reduccion + reparacion","guid":"LtKhXfuvSOqPjtr44g-k7w","children":[]},{"id":"165","parent":"162","text":"Neoplasia -> reseccion + anastomosis vs ostomia","guid":"FPrCN8fHQAKDyLCVrpYViA","children":[]},{"id":"166","parent":"162","text":"Volvulo sigmoideo -> destorsion endoscopica (1a linea)","guid":"2ku4i_RGTT20APuNATiiGg","children":[{"id":"167","parent":"166","text":"Si recurrencia o necrosis -> sigmoidectomia","guid":"0ZaAByRZRJiqzAACfxrHrg","children":[]}]},{"id":"168","parent":"162","text":"OI grueso maligna -> stent metalico (puente a cirugia) vs Hartmann","guid":"TN3rXn-LTc2Bw4MlcHpspg","children":[]},{"id":"169","parent":"162","text":"Ileo biliar -> enterolitotomia","guid":"S6as5WrjTcGYq1wKyWPfbQ","children":[]}]},{"id":"170","parent":"130","text":"MANEJO EN VOLVULO","guid":"hRJo-KsmRKm8OyEFDVMtnQ","children":[{"id":"171","parent":"170","text":"SIGMOIDEO","guid":"HjJegoV2Q1uiXSMb_x1lHA","children":[{"id":"172","parent":"171","text":"Descompresion endoscopica (colonoscopia/sonda rectal)","guid":"wWbwkyBYRvCzMs1w3KUayQ","children":[]},{"id":"173","parent":"171","text":"Exito 70-90% -> RECURRENCIA 40-60%","guid":"Ow54bJAkQyejzSfO16DMIQ","children":[]},{"id":"174","parent":"171","text":"Sigmoidectomia electiva si buen candidato","guid":"LCY76Sm4T3iy3rwWs22kYg","children":[]},{"id":"175","parent":"171","text":"Si necrosis -> Hartmann de urgencia","guid":"lwVeFAF6SFaZNXv2iFbnLQ","children":[]}]},{"id":"176","parent":"170","text":"CECAL","guid":"MXixu04rRP2CvaTR9eLYJA","children":[{"id":"177","parent":"176","text":"Siempre quirurgico -> cecostomia o hemicolectomia derecha","guid":"HOUvbUZ-SV2Crlk7L0DV7w","children":[]},{"id":"178","parent":"176","text":"No responde a descompresion endoscopica","guid":"y5h28zJzQ72SBkCUfIXmJA","children":[]}]}]}]},{"id":"179","parent":"0","text":"Consideraciones Geriatricas","guid":"FYH5vgjYSGqvvT2ZLnVzXw","children":[{"id":"180","parent":"179","text":"EVALUACION PREOPERATORIA EN AM","guid":"cK77EYSCRjW_aArAF30ebA","children":[{"id":"181","parent":"180","text":"Fragilidad (CFS, FRAIL) -> PRINCIPAL predictor de outcomes","guid":"biFBiq2tQvmgDOqYJsZXBg","children":[{"id":"182","parent":"181","text":"CFS >=5 -> mortalidad postoperatoria 2-3x mayor","guid":"yprWuEyiR9-70oq9MiCF_g","children":[]},{"id":"183","parent":"181","text":"Fragilidad > edad cronologica como predictor","guid":"WzkFBtZDTESbCcBh5MGJ8A","children":[]}]},{"id":"184","parent":"180","text":"Estado funcional basal (Barthel, Lawton)","guid":"MBkQx2wERTamckE-ylWOvg","children":[]},{"id":"185","parent":"180","text":"Comorbilidades (Charlson >= 3 -> alto riesgo)","guid":"PW_mZ4JBRkiKtP5pmVazfQ","children":[]},{"id":"186","parent":"180","text":"Estado nutricional -> albumina <3.0 g/dL = riesgo alto","guid":"VYenGwTjTJyvenBegAHJOQ","children":[]},{"id":"187","parent":"180","text":"Sarcopenia -> masa muscular en TC (L3 psoas index)","guid":"blI2CwahR9SiSoGWTrif7w","children":[]},{"id":"188","parent":"180","text":"Estado cognitivo -> riesgo de delirium postoperatorio","guid":"bERHbvqrQBKjODFUJLAF3A","children":[]},{"id":"189","parent":"180","text":"Medicacion habitual -> anticoagulantes, opioides, anticolinergicos","guid":"77GWdLqiRnCHlF8IYJc3Og","children":[]}]},{"id":"190","parent":"179","text":"PARTICULARIDADES CLINICAS EN AM","guid":"tsPw1lwFQ8iCIKGlO5QJ9g","children":[{"id":"191","parent":"190","text":"Signos peritoneales ATENUADOS -> menor respuesta inflamatoria","guid":"aGvgwOaKTJOJ3VM8AM1Rpg","children":[]},{"id":"192","parent":"190","text":"Taquicardia ausente por betabloqueadores o cronotropismo reducido","guid":"V5jUbjSMQnScU4CbWUiaxw","children":[]},{"id":"193","parent":"190","text":"Leucocitosis menor -> no descarta estrangulacion","guid":"-sYc90PESRGTMFxfG1vyJw","children":[]},{"id":"194","parent":"190","text":"Dolor infraestimado por deterioro cognitivo/neuropatia","guid":"RLTW-mDNSyanU0EM4nl7Kw","children":[]},{"id":"195","parent":"190","text":"RETRASO DIAGNOSTICO frecuente -> mayor morbimortalidad","guid":"Teliv5pfRLOtVME_7GIfqw","children":[]}]},{"id":"196","parent":"179","text":"FARMACOS QUE CAUSAN/EMPEORAN ILEO EN AM","guid":"JldSKC3iS5KUi6A5NS71Tw","children":[{"id":"197","parent":"196","text":"Opioides -> principal causa farmacologica","guid":"i7FdORpHQMaIzkSgUFlyyA","children":[]},{"id":"198","parent":"196","text":"Anticolinergicos (carga >3 -> riesgo significativo)","guid":"ORxJQTURSWC9QsWrYF_ZEg","children":[]},{"id":"199","parent":"196","text":"Calcioantagonistas (verapamilo)","guid":"x7oMevQJRw-YkRaL4bfSSw","children":[]},{"id":"200","parent":"196","text":"Antidepresivos triciclicos","guid":"cPP-2UmGTO20cr2Bq1zfig","children":[]},{"id":"201","parent":"196","text":"Antipsicoticos (quetiapina, clozapina)","guid":"ajeOU32vSGSMsGN79od9cw","children":[]},{"id":"202","parent":"196","text":"Hierro oral","guid":"wUQ4K8YwQCGt3X_KUWa5Dw","children":[]},{"id":"203","parent":"196","text":"Laxantes de volumen sin hidratacion adecuada","guid":"QSJ_BGJjSCycxXPRI0JL3g","children":[]}]},{"id":"204","parent":"179","text":"DECISION QUIRURGICA EN AM","guid":"Om1pgj82T0q61lG6pGAFsw","children":[{"id":"205","parent":"204","text":"Balance riesgo-beneficio INDIVIDUALIZADO","guid":"RP6uAkQgRXSEHtuKIk8G_w","children":[]},{"id":"206","parent":"204","text":"Considerar voluntades anticipadas / directrices previas","guid":"H6FN0geWSCGsAFP5mwjMBw","children":[]},{"id":"207","parent":"204","text":"Discusion con paciente/familia sobre expectativas","guid":"QnLTle83SXaeqlvwykYHNQ","children":[]},{"id":"208","parent":"204","text":"Cirugía de control de danos si inestabilidad","guid":"HHM2b5h-Qyq5L6KwUMs6vQ","children":[]},{"id":"209","parent":"204","text":"Mortalidad postoperatoria Qx urgencia AM -> 15-30%","guid":"Rfm65haJTxiR6RWimAuffA","children":[]},{"id":"210","parent":"204","text":"Predictores de mal outcome","guid":"F-xSnM9sSziy-OAkYqut8g","children":[{"id":"211","parent":"210","text":"Fragilidad (CFS >=5)","guid":"NRnHFD0OSlSrWFdQZDtgYQ","children":[]},{"id":"212","parent":"210","text":"ASA >=3","guid":"bvRXmYlhQJ6JiqctBv0q1g","children":[]},{"id":"213","parent":"210","text":"Lactato >4 mmol/L preoperatorio","guid":"JqUMZcc0RhCZWxdvwy21sA","children":[]},{"id":"214","parent":"210","text":"Necesidad de reseccion intestinal","guid":"mGbUqrVwRs6wm8RCy5ph1w","children":[]},{"id":"215","parent":"210","text":"Retraso quirurgico >24h con estrangulacion","guid":"jzBctxIxQUeChG8qRW73tA","children":[]}]},{"id":"216","parent":"204","text":"OBJETIVO -> \"alive and at home\" (Guttman 2021)","guid":"FX2MAcqvQS2oAPekFjx41w","children":[]}]},{"id":"217","parent":"179","text":"MANEJO PALIATIVO SI CORRESPONDE","guid":"YG1dIeCyRu-YsSLM2XFIJA","children":[{"id":"218","parent":"217","text":"OI maligna irresecable -> decisiones compartidas","guid":"x-XKo2IrTX244XdYN1_v4A","children":[]},{"id":"219","parent":"217","text":"Opciones no quirurgicas","guid":"sjGt8SsCTW6em4gMs4RiLA","children":[{"id":"220","parent":"219","text":"Stent metalico paliativo","guid":"XVbnY55HSRqfaohVaP2qzg","children":[]},{"id":"221","parent":"219","text":"SNG a caida libre + hidratacion subcutanea","guid":"hIbmCfRsS2ur7ghL6xNwtQ","children":[]},{"id":"222","parent":"219","text":"Octreotido 100-300 mcg/dia SC -> reduce secreciones","guid":"gGndCDqqQtqx98V9NcJOww","children":[]},{"id":"223","parent":"219","text":"Dexametasona 8-16mg/dia -> reduce edema peritumoral","guid":"ZxqzWF6zShWWlKkclWPJCQ","children":[]},{"id":"224","parent":"219","text":"Butilbromuro de hioscina -> reduce colico","guid":"vJUny4ILQ2eZUXO-9DHvFA","children":[]}]},{"id":"225","parent":"217","text":"Proporcionalidad terapeutica -> no imponer cirugia futilea","guid":"WHBGquikRU6YjDTYrb1bAw","children":[]}]}]},{"id":"226","parent":"0","text":"LR DIAGNOSTICOS","guid":"8cPPG3z-RgKrgEf8RgZt6Q","children":[{"id":"227","parent":"226","text":"HALLAZGOS CLINICOS (cabecera)","guid":"Iz9C6cHhTJSuKuMeFgDYUQ","children":[{"id":"228","parent":"227","text":"Distension abdominal -> LR+ 5.6 -> LR- 0.42 -> PMID:9752872","guid":"N4_swTGrT2-aTG4oyPj4DA","children":[]},{"id":"229","parent":"227","text":"Cirugia abdominal previa (anamnesis) -> LR+ 3.9 -> LR- 0.45 -> PMID:9752872","guid":"RP0wS_pUSX2am1lEzMMiPg","children":[]},{"id":"230","parent":"227","text":"Ruidos hidroaereos aumentados/metalicos -> LR+ 6.3 -> LR- 0.27 -> PMID:9752872","guid":"n7LktuFZQVOiz5mvAi_hdg","children":[]},{"id":"231","parent":"227","text":"Constipacion / ausencia transito de gases -> LR+ 8.8 -> LR- 0.59 -> PMID:9752872","guid":"47oWufn6RlS07bvysxXkrQ","children":[]},{"id":"232","parent":"227","text":"Vomitos -> LR+ 3.0 -> LR- 0.67 -> PMID:9752872","guid":"ydNNeNcJTiuInIs6twjznQ","children":[]},{"id":"233","parent":"227","text":"Dolor tipo colico -> LR+ ~1.6 -> LR- 0.7 -> PMID:9752872","guid":"X7-8MaPKR2qDPhWNKzuVmw","children":[]},{"id":"234","parent":"227","text":"Signos peritoneales (rebote, rigidez) -> [alerta obstruccion complicada / isquemia]","guid":"-8TQBU0ES_a6-9pdeKsqeg","children":[]}]},{"id":"235","parent":"226","text":"HALLAZGOS LABORATORIO","guid":"eYfy5xeiTZaW0uqphrSPbg","children":[{"id":"236","parent":"235","text":"Leucocitosis >20.000 (alerta estrangulacion) -> LR+ ~3 -> LR- ~0.5 -> (guias ACS)","guid":"M9aPHsmeSfeTP8sO5aCBQQ","children":[]},{"id":"237","parent":"235","text":"Lactato elevado (isquemia mesenterica) -> LR+ ~2 -> LR- ~0.5 -> (guias)","guid":"0Cym75ilTzSeGXYltGuJww","children":[]}]},{"id":"238","parent":"226","text":"HALLAZGOS IMAGEN","guid":"FUsV8BP8RRCNXfqk5hi8OA","children":[{"id":"239","parent":"238","text":"Rx abdomen de pie (niveles hidroaereos, asas dilatadas) -> LR+ 1.6 -> LR- 0.43 -> PMID:10442492","guid":"rx1oOQh6QyqTENHrLvXz2A","children":[]},{"id":"240","parent":"238","text":"TC abdomen con contraste (gold standard) -> LR+ ~3.6 -> LR- ~0.15 -> PMID:8956575","guid":"vUp6KOV5QE6uOmAuSWahKQ","children":[]},{"id":"241","parent":"238","text":"Signos TC de estrangulacion (pneumatosis, neumoperitoneo, liquido libre) -> [definitorios]","guid":"is3vGoGuRJ2hup6MDcRCSg","children":[]}]},{"id":"242","parent":"226","text":"INTERPRETACION","guid":"vQSK1LRmQsa_v8c2bRYvtA","children":[{"id":"243","parent":"242","text":"LR+ >10 o LR- <0.1 -> cambio GRANDE","guid":"dNmpNvOxRbeYTwMMnLQGLA","children":[]},{"id":"244","parent":"242","text":"LR+ 5-10 o LR- 0.1-0.2 -> cambio MODERADO","guid":"xiJrrHV0QNewU7-SLNcsfA","children":[]}]},{"id":"245","parent":"226","text":"GERIATRIA","guid":"jab9YnTHSeK3lgPKRBfMAw","children":[{"id":"246","parent":"245","text":"En AM: impactacion fecal, volvulo sigmoideo (ELEAM), hernias incarceradas, isquemia mesenterica","guid":"M1Tc3fL9SuKYoMe5mKwKbA","children":[]}]}]},{"id":"247","parent":"0","text":"Perlas Clinicas","guid":"AazZDMLSTWeiMT8w2-ebew","children":[{"id":"248","parent":"247","text":"EXPLORAR ORIFICIOS HERNIARIOS en TODO dolor abdominal en urgencias","guid":"1jnTWcsXRbS1QYRrBnhBoQ","children":[]},{"id":"249","parent":"247","text":"Tacto rectal OBLIGATORIO -> fecaloma causa corregible en AM","guid":"2HEEvDLkQ7mvHVKri461aw","children":[]},{"id":"250","parent":"247","text":"TC con contraste es GOLD STANDARD -> no perder tiempo con Rx si hay duda","guid":"AWEPedKaQDmRJLrSFYpiQg","children":[]},{"id":"251","parent":"247","text":"Lactato >2 = sospechar estrangulacion -> no esperar para cirugia","guid":"ivOLq78oR3CaBD1qhOJZkA","children":[]},{"id":"252","parent":"247","text":"Gastrografin es diagnostico Y terapeutico en OID parcial adhesiva (NNT 4-5)","guid":"KXGfKPJgRAalM_Y_a767LA","children":[]},{"id":"253","parent":"247","text":"En AM -> presentacion ATIPICA (delirium, rechazo alimentario, deterioro funcional)","guid":"xi-n8dOGQ2WtKUZA-RjCMg","children":[]},{"id":"254","parent":"247","text":"Fragilidad predice outcomes mejor que edad cronologica","guid":"VRyR_s2VRBKIXTsQ3_UrYQ","children":[]},{"id":"255","parent":"247","text":"Volvulo sigmoideo -> descompresion endoscopica 1a linea, pero RECURRENCIA 40-60%","guid":"6GF06tcbTgqOOftABS91cQ","children":[]},{"id":"256","parent":"247","text":"Ileo biliar -> buscar TRIADA DE RIGLER (aerobilia + calculo ectopico + distension)","guid":"kmp2wCIASfGNRqd78SasBg","children":[]},{"id":"257","parent":"247","text":"Ogilvie -> riesgo perforacion si ciego >12cm -> neostigmina 2mg IV (monitorizado)","guid":"yJnMp8dOQGWFLCb4FB_nwQ","children":[]},{"id":"258","parent":"247","text":"Opioides son la causa mas frecuente de ileo farmacologico en AM","guid":"XQWBzJALSaWkdsNBjifkJg","children":[]},{"id":"259","parent":"247","text":"En OI maligna avanzada -> octreotido + dexametasona como alternativa paliativa","guid":"XFffD9KQTBuMqesCupyHsA","children":[]},{"id":"260","parent":"247","text":"Referencias","guid":"ybUoeTCUQiqSoEQQzyZnzA","children":[{"id":"261","parent":"260","text":"1. Ten Broek RP, et al. Bologna guidelines for diagnosis and management of adhesive SBO. World J Emerg Surg. 2018;13:24.","guid":"RahIIFkjRF25EFwW6DUlFw","children":[]},{"id":"262","parent":"260","text":"2. Catena F, et al. Adhesive SBO: evolutions in diagnosis, management and prevention. World J Gastrointest Surg. 2016;8(3):222.","guid":"wD2OJrhtRqG8dxWN0liZjw","children":[]},{"id":"263","parent":"260","text":"3. Hwang F, et al. SBO in older patients: challenges in surgical management. Surg Endosc. 2022;36(8):5968-75.","guid":"3S7bBPrQTFyvK5BPYEyHmg","children":[]},{"id":"264","parent":"260","text":"4. Li R, et al. Timing to surgery in elderly with SBO: insight on frailty. J Trauma Acute Care Surg. 2024;97(1):92-99.","guid":"Bo80fb-bQDuFIa9Z9QIIBQ","children":[]},{"id":"265","parent":"260","text":"5. Guttman MP, et al. Alive and at home: 5-year outcomes in older adults following EGS. J Trauma Acute Care Surg. 2021;90(6):984-92.","guid":"uEBcHrpJSL-QEwV9ZpMJQQ","children":[]},{"id":"266","parent":"260","text":"6. Vogel JD, et al. Clinical practice guidelines for colon volvulus and acute colonic pseudo-obstruction. Dis Colon Rectum. 2016;59(7):589-600.","guid":"U8SC3z5vTSS4uOYQFT8Z5A","children":[]},{"id":"267","parent":"260","text":"7. Mege D, et al. Emergency surgery in elderly: systematic review. World J Emerg Surg. 2019;14:37.","guid":"8bdM7uS6TEqRh4e7fD679Q","children":[]},{"id":"268","parent":"260","text":"8. Scott JW, et al. Use of national burden to define operative emergency general surgery. JAMA Surg. 2016;151(6):e160480.","guid":"ByIK9lfOSFe8I4kNJYACeQ","children":[]}]}]}]},"node_count":268,"relations":[],"cross_references":[],"specialty":"Medicina de Urgencia","folder":"MUE - Medicina de Urgencia","filename":"MUE_Obstruccion_Intestinal","id":"map_2510","resolved_references":[],"title_raw":"MUE_Obstruccion_Intestinal"}