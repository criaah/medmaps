tificada en imagen","guid":"","children":[]},{"id":"204","parent":"202","text":"Falla de respuesta a tratamiento empirico","guid":"","children":[]},{"id":"205","parent":"202","text":"Sospecha neoplasica","guid":"","children":[]},{"id":"206","parent":"202","text":"ANTES de iniciar corticoides si posible","guid":"","children":[]}]},{"id":"207","parent":"200","text":"Via endoscopica transnasal → via preferida","guid":"","children":[]},{"id":"208","parent":"200","text":"Histologia + cultivos (bacteriano/fúngico/micobacterias)","guid":"","children":[]}]}]},{"id":"209","parent":"0","text":"Manejo","guid":"","children":[{"id":"210","parent":"209","text":"Principios generales","guid":"","children":[{"id":"211","parent":"210","text":"IDENTIFICAR ETIOLOGIA → tratamiento dirigido","guid":"","children":[]},{"id":"212","parent":"210","text":"Emergencias que NO pueden esperar","guid":"","children":[{"id":"213","parent":"212","text":"Mucormicosis → desbridamiento + anfotericina B INMEDIATO","guid":"","children":[]},{"id":"214","parent":"212","text":"Trombosis seno cavernoso → anticoagulacion + ATB","guid":"","children":[]},{"id":"215","parent":"212","text":"Compresion aguda nervio optico → descompresion","guid":"","children":[]}]}]},{"id":"216","parent":"209","text":"Inflamatorio (Tolosa-Hunt y relacionados)","guid":"","children":[{"id":"217","parent":"216","text":"Corticoides → primera linea","guid":"","children":[{"id":"218","parent":"217","text":"Metilprednisolona IV 1g/dia x 3 dias → taper oral","guid":"","children":[]},{"id":"219","parent":"217","text":"Prednisona 1mg/kg/dia → reduccion gradual 4-6 semanas","guid":"","children":[]},{"id":"220","parent":"217","text":"Respuesta dramatica en 24-72h → CRITERIO DIAGNOSTICO","guid":"","children":[]}]},{"id":"221","parent":"216","text":"Agentes ahorradores de esteroides → si recurrencia/dependencia","guid":"","children":[{"id":"222","parent":"221","text":"Metotrexato","guid":"","children":[]},{"id":"223","parent":"221","text":"Azati