0","text":"Inicio <72h del rash → MEJOR pronostico visual","guid":"","children":[]}]}]},{"id":"245","parent":"209","text":"Neoplasico","guid":"","children":[{"id":"246","parent":"245","text":"Segun tipo histologico","guid":"","children":[]},{"id":"247","parent":"245","text":"Cirugia + radioterapia + quimioterapia segun caso","guid":"","children":[]},{"id":"248","parent":"245","text":"Linfoma → quimioterapia/radioterapia","guid":"","children":[]},{"id":"249","parent":"245","text":"Metastasis → paliacion + radioterapia","guid":"","children":[]}]},{"id":"250","parent":"209","text":"Vascular","guid":"","children":[{"id":"251","parent":"250","text":"Fistula carotido-cavernosa → embolizacion endovascular","guid":"","children":[]},{"id":"252","parent":"250","text":"Trombosis seno cavernoso → anticoagulacion + ATB","guid":"","children":[]}]}]},{"id":"253","parent":"0","text":"Consideraciones\\NGeriatricas","guid":"OqVkyEVKbQmtSmvdWnvEUQ","children":[{"id":"254","parent":"253","text":"Mayor incidencia de etiologias graves en AM","guid":"","children":[{"id":"255","parent":"254","text":"HZO-SAO → edad mediana 81a (Dupre 2025)","guid":"","children":[]},{"id":"256","parent":"254","text":"Mucormicosis → DM tipo 2 frecuente","guid":"","children":[]},{"id":"257","parent":"254","text":"Neoplasias → metastasis mas probable","guid":"","children":[]},{"id":"258","parent":"254","text":"Arteritis celulas gigantes → EXCLUSIVA >50a","guid":"","children":[]}]},{"id":"259","parent":"253","text":"Fragilidad como factor pronostico","guid":"","children":[{"id":"260","parent":"259","text":"Peor recuperacion visual en fragiles","guid":"","children":[]},{"id":"261","parent":"259","text":"Mayor mortalidad perioperatoria si cirugia requerida","guid":"","children":[]},{"id":"262","parent":"259","text":"Evaluar CFS antes de definir agresividad terapeutica","guid":"","children":[]}]},{"id":"263","parent":"253","text":"Polifarmacia relevante","guid":"","children":[{"id":"264","parent":"263","text":"Corticoides → riesgo delirium, hiperglicemia, infecciones","guid":"","children":[]},{"id":"265","parent":"263","text":"Inmunosupresores → vigilar funcion renal","guid":"","children":[]},{"id":"266","parent":"263","text":"Interacciones voriconazol → CYP450","guid":"","children":[]}]},{"id":"267","parent":"253","text":"Presentacion atipica","guid":"","children":[{"id":"268","parent":"267","text":"Dolor puede ser minimizado o no reportado","guid":"","children":[]},{"id":"269","parent":"267","text":"Delirium como primera manifestacion","guid":"","children":[]},{"id":"270","parent":"267","text":"Caida como forma de presentacion (deficit visual agudo)","guid":"","children":[]}]},{"id":"271","parent":"253","text":"Pronostico visual","guid":"","children":[{"id":"272","parent":"271","text":"Recuperacion mas lenta y frecuentemente incompleta","guid":"","children":[]},{"id":"273","parent":"271","text":"Midriasis residual en 37.5% post-HZO (Dupre 2025)","guid":"","children":[]},{"id":"274","parent":"271","text":"Inicio precoz de tratamiento es AUN MAS critico","guid":"","children":[]}]}]},{"id":"275","parent":"0","text":"Perlas Clinicas","guid":"","children":[{"id":"276","parent":"275","text":"SAO = perdida visual + oftalmoplejia → SFOS NO tiene compromiso optico","guid":"","children":[]},{"id":"277","parent":"275","text":"Tolosa-Hunt es DIAGNOSTICO DE EXCLUSION → 14-20% falsos positivos → BIOPSIA si duda","guid":"","children":[]},{"id":"278","parent":"275","text":"Mucormicosis en DM descompensado → anfotericina B + cirugia INMEDIATA → mortalidad 32%","guid":"","children":[]},{"id":"279","parent":"275","text":"VI par es el MAS susceptible a compresion → trayecto intracraneal mas largo","guid":"","children":[]},{"id":"280","parent":"275","text":"HZO-SAO ocurre PESE a valaciclovir oral → requiere aciclovir IV neuro-meningeo","guid":"","children":[]},{"id":"281","parent":"275","text":"Tratamiento HZO >72h post-rash → pronostico visual significativamente peor (p=0.045)","guid":"","children":[]},{"id":"282","parent":"275","text":"Signo de Hutchinson (vesiculas punta nasal) → alto riesgo compromiso ocular por HZO","guid":"","children":[]},{"id":"283","parent":"275","text":"En AM → considerar arteritis de celulas gigantes ante SAO + cefalea + VSG elevada","guid":"","children":[]},{"id":"284","parent":"275","text":"AM fragil → evaluar CFS ANTES de definir agresividad terapeutica en SAO","guid":"","children":[]},{"id":"285","parent":"275","text":"TC es SUPERIOR para evaluar erosion osea → RM para tejidos blandos y extension intracraneal","guid":"","children":[]}]},{"id":"286","parent":"0","text":"VER TAMBIEN","guid":"","children":[{"id":"287","parent":"286","text":"→ Delirium (Geriatric Emergency Medicine)","guid":"","children":[]},{"id":"288","parent":"286","text":"→ Presentacion Atipica de Enfermedades (Geriatric Emergency Medicine)","guid":"","children":[]},{"id":"289","parent":"286","text":"→ Fragilidad/CFS (Valoracion Geriatrica)","guid":"","children":[]},{"id":"290","parent":"286","text":"→ Polifarmacia (Farmacologia Geriatrica)","guid":"","children":[]}]},{"id":"291","parent":"0","text":"Referencias","guid":"","children":[{"id":"292","parent":"291","text":"1. Badakere A, Patil-Chhablani P. Orbital Apex Syndrome: A Review. Eye Brain. 2019;11:63-72. doi:10.2147/EB.S180190","guid":"","children":[]},{"id":"293","parent":"291","text":"2. Yeh S, Foroozan R. Orbital apex syndrome. Curr Opin Ophthalmol. 2004;15(6):490-8. doi:10.1097/01.icu.0000144387.12739.9c","guid":"","children":[]},{"id":"294","parent":"291","text":"3. Yuan M, et al. Orbital Apex Syndrome Secondary to Invasive Aspergillus Infection: Case Series and Literature Review. J Neuroophthalmol. 2021;41(4):e631-e638. doi:10.1097/WNO.0000000000001105","guid":"","children":[]},{"id":"295","parent":"291","text":"4. Dupre R, et al. Orbital Apex Syndrome Secondary to HZO: Literature Review and In-Depth Understanding. Semin Ophthalmol. 2025;1-12. doi:10.1080/08820538.2025.2559843","guid":"","childr