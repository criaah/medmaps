"n9ncY5XcDqDeCTetQJvOLg","children":[]},{"id":"222","parent":"220","text":"Menos complicaciones","guid":"","children":[]}]}]},{"id":"223","parent":"211","text":"Médico\\Ninicial","guid":"l0FCzHOS-3ZpImyrUeVY0A","children":[{"id":"224","parent":"223","text":"Paciente sin indicación de cirugía de urgencia","guid":"VVY8tCEp0fe4vsMxvZ7QFQ","children":[]},{"id":"225","parent":"223","text":"Monitorizar\\Nhospitalizado","guid":"","children":[{"id":"226","parent":"225","text":"Residuos SNG","guid":"","children":[]},{"id":"227","parent":"225","text":"Flatulencia","guid":"","children":[]},{"id":"228","parent":"225","text":"Movimientos intestinales","guid":"","children":[]},{"id":"229","parent":"225","text":"Distensión abdominal","guid":"","children":[]},{"id":"230","parent":"225","text":"Signos de cirugía urgente","guid":"zyQVRgEpH4gHwQqSn71KSA","children":[]}]},{"id":"231","parent":"223","text":"Geneal","guid":"","children":[{"id":"232","parent":"231","text":"Hidratación EV","guid":"","children":[]},{"id":"233","parent":"231","text":"Sonda nasogastrica","guid":"","children":[{"id":"234","parent":"233","text":"Succión intermitente \\NDescompresión intestinal","guid":"","children":[]}]},{"id":"235","parent":"231","text":"Manejo de dolor","guid":"","children":[]},{"id":"236","parent":"231","text":"Antemeticos","guid":"","children":[]}]},{"id":"237","parent":"223","text":"ATB\\NAmplio espectro","guid":"","children":[{"id":"238","parent":"237","text":"Evitar infección","guid":"","children":[]},{"id":"239","parent":"237","text":"Limitada evidencia","guid":"","children":[]}]},{"id":"240","parent":"223","text":"Triterapia oral\\Ncon agua 3 veces al día","guid":"","children":[{"id":"241","parent":"240","text":"En obstrucción\\Nintestinal parcial","guid":"","children":[{"id":"242","parent":"241","text":"Acelera resolución ","guid":"","children":[]},{"id":"243","parent":"241","text":"Reduce necesidad quirúrgica","guid":"","children":[]}]},{"id":"244","parent":"240","text":"Óxido de magnesio 500mg","guid":"","children":[]},{"id":"245","parent":"240","text":"Lactobacillus acidophilus 300 mg","guid":"","children":[]},{"id":"246","parent":"240","text":"Simeticona 40mg","guid":"","children":[]}]},{"id":"247","parent":"223","text":"Contraste\\Nsoluble oral","guid":"LQ58HhM-VPiBZ6V_lXfgRA","children":[{"id":"248","parent":"247","text":"Considerar en obstrucción parcial que persiste 48h con manejo no quirúrgico","guid":"VJi2fKVcgL9NpRdnvjPaMQ","children":[]},{"id":"249","parent":"247","text":"Puede predecir posible resolución no quirúrgica","guid":"","children":[]}]}]}]}]},{"id":"250","parent":"0","text":"Obstrucción\\Nintestinal grueso","guid":"y5zdYAR8FI-txnvOyg1WSg","children":[{"id":"251","parent":"250","text":"Definición ","guid":"7pNTSTQPWG0D0f2m3bvlBg","children":[{"id":"252","parent":"251","text":"Interrupción mecánica del flujo del contenido del colon","guid":"Lhr7JhxaALT-K3ywVV9oVQ","children":[]}]},{"id":"253","parent":"250","text":"Epidemiología ","guid":"xjNcotxj9cuuDQ4n9N8qUw","children":[{"id":"254","parent":"253","text":"Representa el 24% de todas las obstrucciones intestinales","guid":"uig4WA8d2cfZuPnuODJq7w","children":[]},{"id":"255","parent":"253","text":"Alta morbilidad (≥ 20 %) y mortalidad (≥ 10 %)\\Ncuando se requiere tratamiento quirúrgico.","guid":"ZbkJQEcOi698mhNTjY2Vsg","children":[]}]},{"id":"256","parent":"250","text":"Causa","guid":"OpdA4_r8NqcO2OJd8SKYjg","children":[{"id":"257","parent":"256","text":"Cáncer colorrectal, la diverticulitis, el\\Nvolvulo y la impactación fecal.","guid":"sQG41HiiS-_sG9VwGXzrQQ","children":[]}]},{"id":"258","parent":"250","text":"Clínica","guid":"eWrXpvZ8Nd3KU-OqhcWj6Q","children":[{"id":"259","parent":"258","text":"Dolor o cólico abdominales, distensión abdominal, irregularidad\\No cambios intestinales y estreñimiento/obstipación.","guid":"URMhdOx9il7tPksnOjj0mg","children":[]}]},{"id":"260","parent":"250","text":"Complicación ","guid":"X1mzY7e6flFBwJe9bNvzXw","children":[{"id":"261","parent":"260","text":"Isquemia, perforación, sepsis y peritonitis.","guid":"YpwzuL707HQceMBxbdUPdQ","children":[]}]},{"id":"262","parent":"250","text":"Diagnostico ","guid":"rFPHDtoohhZv03v8XWJElw","children":[{"id":"263","parent":"262","text":"DD","guid":"","children":[{"id":"264","parent":"263","text":"Diferenciación de la obstrucción del intestino grueso de las imitaciones comunes,\\Ncomo la obstrucción del intestino delgado y la pseudoobstrucción aguda del colon","guid":"GuoAmHPk4qmdj35JCs1fDA","children":[]},{"id":"265","parent":"263","text":"Diferenciación de las causas malignas y benignas de obstrucción","guid":"BzJjcOQ1Ur6beFsF7ZciUQ","children":[]},{"id":"266","parent":"263","text":"Diferenciación de las causas mecánicas y funcionales de la obstrucción","guid":"vdwxMSorLpzbcjnAnlteOg","children":[]},{"id":"267","parent":"263","text":"Determinación de isquemia, perforación y/o sepsis, que\\Nafectan a la urgencia y las modalidades de tratamiento","guid":"iuD8SziFX4SnU4dl-yrnUA","children":[]}]},{"id":"268","parent":"262","text":"La evaluación inicial implica historia y física, lo que puede\\Nproporcionar información que puede ser útil para determinar la\\Nintegridad de la obstrucción y la presencia de peritonitis.","guid":"eEmEBpXQ6oSr3aYr_D4ZvA","children":[{"id":"269","parent":"268","text":"Las diferentes etiologías de la obstrucción del intestino grueso\\Npueden tener presentaciones superpuestas. El diagnóstico\\Nbasado en la presentación clínica es un desafío.","guid":"933FLaxaReoAQrH1YGw25Q","children":[]}]},{"id":"270","parent":"262","text":"El examen inicial también debe incluir análisis de\\Nsangre para detectar infecciones, isquemia y\\Npresencia de anomalías electrolíticas.","guid":"gdNs3E0vTNf0pKlzPcuuBg","children":[]},{"id":"271","parent":"262","text":"Los estudios de imagen son las principales modalidades\\Nde diagnóstico para diferenciar las etiologías o imitaciones\\Nde la obstrucción del intestino grueso y la detección de\\Nisquemia y perforación.","guid":"weyA2BPVVSLgw7BO88cr5Q","children":[{"id":"272","parent":"271","text":"Los hallazgos por imágenes que diagnostican la\\Nobstrucción del intestino grueso son el intestino grueso\\Ndilatado proximal al punto de transición y el intestino\\Ndescomprimido distal a la obstrucción.","guid":"LjBWA-5XderZvDlRGlIPbg","children":[]},{"id":"273","parent":"271","text":"La radiografía abdominal suele ser la\\Nmodalidad de imagen inicial.","guid":"E9doYXYgNUAHI5NIggZjFQ","children":[]},{"id":"274","parent":"271","text":"La tomografía computarizada es la\\Nmodalidad de imagen más importante.","guid":"7nSffdu3TdZWlqIWtR3ZxA","children":[]},{"id":"275","parent":"271","text":"Los enemas de contraste pueden\\Nser necesarios para determinar\\Netiologías específicas.","guid":"CkuWEelGaIwWOvtC-8iQSg","children":[]},{"id":"276","parent":"271","text":"La colonoscopia es necesaria si no se realiza la\\Ncirugía, especialmente para la diferenciación de las\\Netiologías benignas y malignas.","guid":"r_vVs-A40oPhUUQJkLc-zw","children":[]}]}]},{"id":"277","parent":"250","text":"Manejo","guid":"","children":[{"id":"278","parent":"277","text":"El manejo inicial implica la reanimación con líquidos intravenosos\\Ny la corrección de cualquier desequilibrio metabólico.","guid":"9fYYqDuk9MaOL2tHPJyTaA","children":[]},{"id":"279","parent":"277","text":"Para los pacientes con sospecha de isquemia, perforación actual o\\Ninminente, o sepsis por peritonitis, se indica una cirugía de emergencia.\\NLos pacientes también deben recibir antibióticos de amplio espectro.","guid":"Lbox80WQvEE40z6jms4DCw","children":[]},{"id":"280","parent":"277","text":"Para los pacientes sin indicaciones emergentes, las opciones de manejo pueden\\Nincluir cirugía electiva o procedimientos endoscópicos para aliviar la obstrucción.","guid":"aGdLkXucL_B2iTT7_AnRfQ","children":[]}]}]}]},"node_count":280,"relations":[],"cross_references":[],"specialty":"General","folder":"Entidades clínicas/Cirugía","filename":"Qx Obstrucción intestinal","id":"map_406","resolved_references":[]}