{"title":"Cortisol Estres Cronico","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Entidades clínicas/General/Cortisol Estres Cronico iPad.smmx","root":{"id":"0","parent":"-1","text":"Cortisol — Estrés Crónico,\\NNeurodegeneración y Psiquiatría","guid":"6TpRgvfoqyOj2a2SFYRV1w","children":[{"id":"1","parent":"0","text":"FISIOLOGÍA\\NDEL CORTISOL","guid":"IyuWhtABwkiiqDgIvzptAw","children":[{"id":"2","parent":"1","text":"Glucocorticoide producido por glándulas suprarrenales","guid":"","children":[]},{"id":"3","parent":"1","text":"Regula: metabolismo, inflamación, respuesta al estrés","guid":"","children":[]},{"id":"4","parent":"1","text":"5% libre (activo biológicamente) / 95% unido a CBG y albúmina","guid":"","children":[]},{"id":"5","parent":"1","text":"Cortisol libre → ingresa a células → interacción con receptores GC/MC","guid":"","children":[]},{"id":"6","parent":"1","text":"Ritmo circadiano → regulado por núcleo supraquiasmático","guid":"","children":[]}]},{"id":"7","parent":"0","text":"EJE HPA\\N(Hipotálamo-Pituitaria-Adrenal)","guid":"YAgr7Uidw3JrTfki8mIhJQ","children":[{"id":"8","parent":"7","text":"Sistema neuroendocrino central en respuesta al estrés","guid":"","children":[]},{"id":"9","parent":"7","text":"Cascada de\\Nactivación","guid":"TXJbxSVsKMijIFq9VYDvRA","children":[{"id":"10","parent":"9","text":"Estrés percibido → Hipotálamo → CRH","guid":"","children":[]},{"id":"11","parent":"9","text":"CRH → Pituitaria anterior → ACTH","guid":"","children":[]},{"id":"12","parent":"9","text":"ACTH → Corteza adrenal → Cortisol","guid":"","children":[]}]},{"id":"13","parent":"7","text":"Retroalimentación\\Nnegativa","guid":"2CGUhl8Jhsj9U4Cli49wew","children":[{"id":"14","parent":"13","text":"Hipocampo: alta densidad de receptores GC → inhibe HPA","guid":"","children":[]},{"id":"15","parent":"13","text":"GRs actúan bajo niveles ALTOS de cortisol → retroalimentación REACTIVA","guid":"","children":[]},{"id":"16","parent":"13","text":"MRs: alta afinidad, retroalimentación PROACTIVA","guid":"","children":[]}]},{"id":"17","parent":"7","text":"Receptores","guid":"","children":[{"id":"18","parent":"17","text":"GRs (Receptores Glucocorticoides): distribuidos en todo el SNC","guid":"","children":[]},{"id":"19","parent":"17","text":"MRs (Receptores Mineralocorticoides): concentrados en estructuras límbicas (hipocampo)","guid":"","children":[]}]}]},{"id":"20","parent":"0","text":"ESTRÉS CRÓNICO\\N— FISIOPATOLOGÍA","guid":"dAz8ydM_FG-z4PEv_iTfEw","children":[{"id":"21","parent":"20","text":"Liberación prolongada de cortisol → desensibilización eje HPA","guid":"","children":[]},{"id":"22","parent":"20","text":"Resistencia a glucocorticoides → inmunidad desensibilizada","guid":"","children":[]},{"id":"23","parent":"20","text":"Cascada\\Nproinflamatoria","guid":"jnjbsHqsYV7ggYZ0jent8A","children":[{"id":"24","parent":"23","text":"Activación SNS + eje HPA → ↑ Norepinefrina (NE)","guid":"","children":[]},{"id":"25","parent":"23","text":"↑ NE → ↑ IL-1, IL-6, TNF-α","guid":"","children":[]},{"id":"26","parent":"23","text":"↓ Respuesta antiinflamatoria efectiva","guid":"","children":[]}]},{"id":"27","parent":"20","text":"Bucle inflamatorio\\Nperpetuado","guid":"py6s9bYWlJYf_1kmbUz_lQ","children":[{"id":"28","parent":"27","text":"↑ IL-1β → NE → cortisol y melatonina intentan contrarrestar","guid":"","children":[]},{"id":"29","parent":"27","text":"Estrés crónico → resistencia a cortisol → inflamación sostenida","guid":"","children":[]},{"id":"30","parent":"27","text":"→ Síntomas de comportamiento de enfermedad","guid":"","children":[]}]},{"id":"31","parent":"20","text":"Impacto\\Nsistémico","guid":"O323jArMAczzTFpCgsCU8g","children":[{"id":"32","parent":"31","text":"Sistema inmunológico: inflamación persistente","guid":"","children":[]},{"id":"33","parent":"31","text":"Sistema nervioso: neuroinflamación, atrofia hipocampal","guid":"","children":[]},{"id":"34","parent":"31","text":"Sistema endocrino: disfunción eje HPA","guid":