KXAI4g","children":[]},{"id":"120","parent":"115","text":"Cirugía, trauma","guid":"CIePT1sZRGGS1UZdaavqrw","children":[]},{"id":"121","parent":"115","text":"Debut DM2 en adulto mayor","guid":"XnqOrLKJRe2fHg2kFI6XNA","children":[]}]},{"id":"122","parent":"96","text":"Presentacion clinica","guid":"Xi_6c6BPSma3ap6TiGV38Q","children":[{"id":"123","parent":"122","text":"Poliuria, polidipsia (dias a semanas de evolucion)","guid":"L1Hq2XL-RSSUkjz4s7KtyA","children":[]},{"id":"124","parent":"122","text":"Deshidratacion severa","guid":"CCIW4NgiSrunebrc9hM6KA","children":[]},{"id":"125","parent":"122","text":"Alteracion de conciencia → desde confusion a coma","guid":"2prj_OvhSeOQub7LkEFFrw","children":[{"id":"126","parent":"125","text":"Correlaciona con osmolaridad","guid":"mMPQPjQNS26Peh6oxk2E0w","children":[]},{"id":"127","parent":"125","text":"Osm >340 → letargia/estupor","guid":"GK_qdniORrWAi287ft1gOQ","children":[]},{"id":"128","parent":"125","text":"Osm >360 → coma","guid":"oNxuK_iVTUylc6jjdlSTAw","children":[]}]},{"id":"129","parent":"122","text":"Focalidad neurologica → puede simular ACV","guid":"k2Hf5f0aQ3my5oQywdK8mQ","children":[]},{"id":"130","parent":"122","text":"Convulsiones (hasta 25%)","guid":"8YVSXbCHS8OvsrOYRupe9g","children":[]},{"id":"131","parent":"122","text":"Hipotermia","guid":"jZj_hdgITIeLk_9-5BTFow","children":[]},{"id":"132","parent":"122","text":"EN ADULTO MAYOR → puede ser primera manifestacion DM2","guid":"6GfHSwNGRe6zJGvANzlH3w","children":[]}]},{"id":"133","parent":"96","text":"Laboratorio","guid":"PqTxk5t5RPqJiTR-4YyoJA","children":[{"id":"134","parent":"133","text":"Glicemia → frecuentemente >800-1000 mg/dL","guid":"2weESVWpR4iKSgFm1ErM6Q","children":[]},{"id":"135","parent":"133","text":"Osmolaridad calculada → 2xNa + glicemia/18 + BUN/2.8","guid":"gKKeHmwNSh6QtZTV57YoOQ","children":[]},{"id":"136","parent":"133","text":"Osmolaridad efectiva → 2xNa + glicemia/18","guid":"SOXIqXrkRVm8yxTWIRAtqQ","children":[]},{"id":"137","parent":"133","tex