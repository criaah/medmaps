74aOw","children":[]},{"id":"15","parent":"11","text":"- Visión alterada (ej. visión borrosa)","guid":"zgpRL7EfMmcfgtuHq24XVg","children":[]},{"id":"16","parent":"11","text":"- Examen fundoscópico","guid":"","children":[{"id":"17","parent":"16","text":"- Hemorragias retinianas","guid":"","children":[]},{"id":"18","parent":"16","text":"- Venas retinianas dilatadas, congestionadas y segmentadas","guid":"9ALMjNUcS6-Ae42l91rwag","children":[]}]},{"id":"19","parent":"11","text":"- Audición alterada","guid":"","children":[]},{"id":"20","parent":"11","text":"- Dolores de cabeza","guid":"","children":[]}]},{"id":"21","parent":"5","text":"- Función renal y hepática alterada","guid":"cDbrwkNsHHt8oBYPpr2nUQ","children":[]},{"id":"22","parent":"5","text":"- Posible agrandamiento de ganglios linfáticos","guid":"_QHb7Fjd8y2_UBHlZWtO-g","children":[]},{"id":"23","parent":"5","text":"- Síntomas constitucionales (ej. fatiga)","guid":"uzDH-46TFzgB8lW8AmXgfg","children":[]}]},{"id":"24","parent":"0","text":"## Diagnóstico","guid":"","children":[{"id":"25","parent":"24","text":"- Criterios diagnósticos pueden ayudar a establecer diagnóstico","guid":"wGAlyZgMzHcERjTlPLIgUA","children":[]}]},{"id":"26","parent":"0","text":"- Estudios rutinarios","guid":"","children":[{"id":"27","parent":"26","text":"- Hemograma completo, perfil\\Nmetabólico completo","guid":"","children":[]},{"id":"28","parent":"26","text":"- Aumento de VSG, ácido úrico,\\NLDH y fosfatasa alcalina","guid":"","children":[]},{"id":"29","parent":"26","text":"- Nivel sérico de β2\\Nmicroglobulina","guid":"","children":[]}]},{"id":"30","parent":"0","text":"- Estudios de\\Ninmunoglobulina","guid":"","children":[{"id":"31","parent":"30","text":"- SPEP y UPEP con\\Ninmunofijación","guid":"","children":[]},{"id":"32","parent":"30","text":"- Niveles cuantitativos de\\Ninmunoglobulina sérica","guid":"","children":[]}]},{"id":"33","parent":"0","text":"- Biopsia y aspirado de médula ósea: ≥\\N10% células plasmáticas anormales\\Ncon cuerpos de Dutcher","guid":"","children":[]},{"id":"34","parent":"0","text":"- Estudios de imagen:\\NConsiderar TC con contraste\\Nde tórax, abdomen y pelvis","guid":"","children":[]},{"id":"35","parent":"0","text":"- Estudios adicionales para\\Nsíndrome de\\Nhiperviscosidad\\Nsospechado","guid":"","children":[{"id":"36","parent":"35","text":"- Medición de\\Nviscosidad sérica","guid":"","children":[]},{"id":"37","parent":"35","text":"- Evaluación\\Noftalmológica","guid":"","children":[]}]},{"id":"38","parent":"0","text":"- Sobreproducción de IgM monoclonal\\Nsugiere macroglobulinemia de Waldenstrom\\Nen lugar de mieloma múltiple","guid":"","children":[]},{"id":"39","parent":"0","text":"## Tratamiento","guid":"","children":[]},{"id":"40","parent":"0","text":"- Generalmente reservado para\\Npacientes sintomáticos","guid":"","children":[]},{"id":"41","parent":"0","text":"- Tratamiento dirigido:","guid":"","children":[{"id":"42","parent":"41","text":"- Anticuerpos\\Nanti-CD20 (ej.\\Nrituximab)","guid":"","children":[]},{"id":"43","parent":"41","text":"- Inhibidores de tirosina quinasa\\Nde Bruton (ej. ibrutinib)","guid":"","children":[]},{"id":"44","parent":"41","text":"- Análogos de nucleósidos de purina\\N(fludarabina y cladribina)","guid":"","children":[]},{"id":"45","parent":"41","text":"- Agentes alquilantes\\N(ej. ciclofosfamida)","guid":"","children":[]}]},{"id":"46","parent":"0","text":"- Síndrome de\\Nhiperviscosidad:\\Nplasmaféresis","guid":"","children":[]},{"id":"47","parent":"0","text":"## Pronóstico","guid":"","children":[]},{"id":"48","parent":"0","text":"- Bueno, ya que es un tipo\\Nde linfoma indolente","guid":"","children":[]}]},"node_count":48,"relations":[],"cross_references":[],"specialty":"Hematología","folder":"Entidades clínicas/Hematología","filename":"AMBOSS Macroglobulinemia de Waldenstrom-2025-1","id":"map_1041","resolved_references":[]}