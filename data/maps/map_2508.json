{"title":"MUE_IC_Descompensada","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/MUE - Medicina de Urgencia/MUE_IC_Descompensada.smmx","root":{"id":"0","parent":"-1","text":"IC DESCOMPENSADA AGUDA EN URGENCIAS","guid":"gvel9Q0oTEq1HndyF5ddWQ","children":[{"id":"1","parent":"0","text":"DEFINICIÓN Y CLASIFICACIÓN","guid":"XPqCCI3DT0yz4PcxHHH1cg","children":[{"id":"2","parent":"1","text":"Inicio rápido o empeoramiento de síntomas/signos de IC","guid":"MpwBlppAT2CtAi8gzkw1Xg","children":[]},{"id":"3","parent":"1","text":"Requiere evaluación y tratamiento urgente","guid":"b4dEHUjMSlKFcMCNq8fWyg","children":[]},{"id":"4","parent":"1","text":"CLASIFICACIÓN CLÍNICA (perfil hemodinámico)","guid":"LaBA_dgjT4ygkcvsX4_28w","children":[{"id":"5","parent":"4","text":"PERFIL CALIENTE-HÚMEDO (67%)","guid":"HHS-w0SXTLefXUzNOUaY6Q","children":[{"id":"6","parent":"5","text":"Congestión + perfusión conservada","guid":"CVi_ZZVOQDS_XqKBinj3yA","children":[]},{"id":"7","parent":"5","text":"Más frecuente en urgencias","guid":"-vqM1NEcQVWKfiA3-8yOug","children":[]},{"id":"8","parent":"5","text":"Manejo: diuréticos + vasodilatadores","guid":"CYYxXpO7RqK3iJfCE_de5g","children":[]}]},{"id":"9","parent":"4","text":"PERFIL FRÍO-HÚMEDO (28%)","guid":"7bmp1lJeQUCFeJAXSrXOSg","children":[{"id":"10","parent":"9","text":"Congestión + hipoperfusión","guid":"7A8auVHvSM25JGmZA9LzMg","children":[]},{"id":"11","parent":"9","text":"Peor pronóstico","guid":"E_y7ozVkQESVLGODh10T1Q","children":[]},{"id":"12","parent":"9","text":"Manejo: inotrópicos + diuréticos","guid":"3piEe4vHSx-gvWfsZuWihQ","children":[]}]},{"id":"13","parent":"4","text":"PERFIL FRÍO-SECO (5%)","guid":"h2-SEVWYR_eJ3_PNga4VlA","children":[{"id":"14","parent":"13","text":"Hipoperfusión sin congestión","guid":"sPKU_EvDQYqa_Tb7mBg6Fg","children":[]},{"id":"15","parent":"13","text":"Manejo: volumen cauteloso + inotrópicos","guid":"VQHSRvmER52OhPxWzsvB1Q","children":[]}]},{"id":"16","parent":"4","text":"PERFIL CALIENTE-SECO",