":"69","parent":"64","text":"Hipotensión (PAS <90 mmHg) → shock cardiogénico","guid":"t7ElRz2wTOmqDKn_av8tSw","children":[]}]},{"id":"70","parent":"51","text":"PRESENTACIÓN ATÍPICA EN AM","guid":"LxHGRE5PThKdFBwLCEdifw","children":[{"id":"71","parent":"70","text":"Confusión/delirium como debut","guid":"YOOpX69PRHmoBD1MehSgKg","children":[]},{"id":"72","parent":"70","text":"Astenia progresiva sin disnea evidente","guid":"K0LSx4sgTSmqVyNqfyx6xw","children":[]},{"id":"73","parent":"70","text":"Deterioro funcional agudo","guid":"cJMqv-jKQbmkZCadSdYd6Q","children":[]},{"id":"74","parent":"70","text":"Caídas recurrentes","guid":"zyB66riiTE2FiyRDDFDLlg","children":[]},{"id":"75","parent":"70","text":"Anorexia/náuseas (congestión esplácnica)","guid":"DiodL2uETjGWdeT-1TWc8A","children":[]},{"id":"76","parent":"70","text":"Tos nocturna aislada","guid":"IgZu1u_nS9CCRHacDaavOA","children":[]},{"id":"77","parent":"70","text":"Síncope","guid":"lab3FFxIT7agyE1Ao0qvuA","children":[]}]},{"id":"78","parent":"51","text":"EDEMA PULMONAR AGUDO (EPA)","guid":"A3_6cS6GSjSOUymqS6E-BA","children":[{"id":"79","parent":"78","text":"Disnea severa, taquipnea, crepitantes difusos","guid":"ze8vqtNwQIKFyEBAI36Yiw","children":[]},{"id":"80","parent":"78","text":"Esputo rosado espumoso","guid":"J7nXfjHfRC-1WxB1pHm6Vw","children":[]},{"id":"81","parent":"78","text":"SatO2 <90%","guid":"H1iqlgIFR52VzdxZLdT-gw","children":[]},{"id":"82","parent":"78","text":"→ EMERGENCIA → VMNI inmediata + furosemida IV + NTG","guid":"5i27BI7XR2O5vH23MSwp-A","children":[]}]}]},{"id":"83","parent":"0","text":"EVALUACIÓN INICIAL","guid":"SR6G5qSkSr-kr-18OiArIg","children":[{"id":"84","parent":"83","text":"ABC Y ESTABILIZACIÓN","guid":"0LwAxPrSR9S6gElQ8nqbUg","children":[{"id":"85","parent":"84","text":"Posición sentada/semisentada","guid":"Velj6b6GSDiLD_VaRLcEgw","children":[]},{"id":"86","parent":"84","text":"O2 si SatO2 <90% → objetivo 92-96%","guid":"xXd5vC5_SCyjJAuA7Mf2YA","children":[]},{"id":"87","parent":"84","tex