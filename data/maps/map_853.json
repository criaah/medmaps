ldren":[]},{"id":"167","parent":"165","text":"DEFICIENCIA: <70 mcg/dL → tratar si sintomas (disgeusia, ardor, cicatrizacion lenta)","guid":"","children":[]},{"id":"168","parent":"165","text":"OBJETIVO POST-TRATAMIENTO: 80-100 mcg/dL","guid":"","children":[]},{"id":"169","parent":"165","text":"Suplementacion: sulfato de zinc 220 mg\\N(50 mg Zn elemental) c/12-24h","guid":"1xLxUQkMDPf9g-hzFa4y0Q","children":[{"id":"170","parent":"169","text":"Con alimentos (reduce nauseas)","guid":"","children":[]},{"id":"171","parent":"169","text":"Duracion: 3 meses y reevaluar","guid":"","children":[]}]},{"id":"172","parent":"165","text":"INTERACCIONES: zinc reduce absorcion de hierro y cobre → separar por 2h","guid":"","children":[]},{"id":"173","parent":"165","text":"SEGUIMIENTO: zinc plasmatico a los 3 meses","guid":"","children":[]}]},{"id":"174","parent":"120","text":"VITAMINA D (relevante en SBA\\Npor mecanismos neuropaticos)","guid":"a2Dq-wLWcFDz0RTQknIkZA","children":[{"id":"175","parent":"174","text":"Niveles optimos en AM: 30-60 ng/mL (75-150 nmol/L)","guid":"","children":[]},{"id":"176","parent":"174","text":"DEFICIENCIA: <20 ng/mL → tratar","guid":"","children":[]},{"id":"177","parent":"174","text":"INSUFICIENCIA: 20-30 ng/mL → suplementar en AM","guid":"","children":[]},{"id":"178","parent":"174","text":"Suplementacion:","guid":"","children":[{"id":"179","parent":"178","text":"Deficiencia: colecalciferol 50.000 UI/semana x 8-12 semanas (fase carga)","guid":"","children":[]},{"id":"180","parent":"178","text":"Mantenimiento AM: 1.000-2.000 UI/dia indefinido","guid":"","children":[]}]},{"id":"181","parent":"174","text":"SEGUIMIENTO: 25-OH vitamina D a los 3 meses post-carga","guid":"","children":[]},{"id":"182","parent":"174","text":"Nota: asociacion SBA-deficit vit D emergente (estudios observacionales)","guid":"","children":[]}]},{"id":"183","parent":"120","text":"VITAMINAS B1 (tiamina)\\Ny B6 (piridoxina)","guid":"L8m89uukn0AkUlF41WdAXQ","children":[{"id":"184","parent"