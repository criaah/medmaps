":"202","parent":"201","text":"Clonazepam 0.5mg\\Ntopico","guid":"d_cgEWLd7YZEjwk5cFiKAA","children":[{"id":"203","parent":"202","text":"Disolver en boca 3 min → escupir (no deglutir)","guid":"","children":[]},{"id":"204","parent":"202","text":"1-3 veces/dia","guid":"","children":[]},{"id":"205","parent":"202","text":"Evidencia favorable (meta-analisis)","guid":"","children":[]}]},{"id":"206","parent":"201","text":"Capsaicina\\Ntopica 0.025%","guid":"tNDCp2H8upZ141DkUrD2hg","children":[{"id":"207","parent":"206","text":"3-4 veces/dia","guid":"","children":[]},{"id":"208","parent":"206","text":"Mecanismo: desensibilizacion fibras C nociceptivas","guid":"","children":[]},{"id":"209","parent":"206","text":"Eficacia en estudios controlados","guid":"","children":[]}]},{"id":"210","parent":"201","text":"Bencidamina 0. 15%\\Nenjuague","guid":"ca2UV16_uboX3RRBnsD1Fw","children":[{"id":"211","parent":"210","text":"Efecto antiinflamatorio y analgesico local","guid":"","children":[]},{"id":"212","parent":"210","text":"3 veces/dia","guid":"","children":[]}]}]},{"id":"213","parent":"200","text":"SISTEMICOS\\N(segunda linea)","guid":"x9R5E3vMFts0IPP4hca0Jg","children":[{"id":"214","parent":"213","text":"Clonazepam oral\\N0.25-3 mg/dia","guid":"umB8-18dJrq4Lay4CDYYuw","children":[{"id":"215","parent":"214","text":"Iniciar 0.25 mg nocturno → titular","guid":"","children":[]},{"id":"216","parent":"214","text":"PRECAUCION en AM: sedacion, riesgo caidas","guid":"","children":[]}]},{"id":"217","parent":"213","text":"Alpha-Lipóico Acido (ALA) 600\\Nmg/dia x 2-3 meses","guid":"RFijWsfdNq4hoVaxDYuzwA","children":[{"id":"218","parent":"217","text":"Antioxidante neuroprotector","guid":"","children":[]},{"id":"219","parent":"217","text":"Eficacia modesta en revision sistematica (Tan et al. 2021)","guid":"","children":[]},{"id":"220","parent":"217","text":"Mejor perfil seguridad en AM","guid":"","children":[]}]},{"id":"221","parent":"213","text":"Antidepresivos","guid":"","children":[{"id":"222","parent":"221","text":"Paroxetina 10-20 mg/dia (iniciar 10 mg en AM)","guid":"","children":[]},{"id":"223","parent":"221","text":"Sertralina 25-50 mg/dia (iniciar 25 mg)","guid":"","children":[]},{"id":"224","parent":"221","text":"Amitriptilina 10-25 mg/dia NOCTURNA (carga anticolinergica: evitar en AM fragil)","guid":"","children":[]},{"id":"225","parent":"221","text":"Duloxetina 30-60 mg/dia (neuropatia)","guid":"","children":[]}]},{"id":"226","parent":"213","text":"Gabapentina/Pregabalina","guid":"","children":[{"id":"227","parent":"226","text":"Util si componente neuropatico predominante","guid":"","children":[]},{"id":"228","parent":"226","text":"Ajustar dosis segun TFGe","guid":"","children":[]}]}]},{"id":"229","parent":"200","text":"NO\\NFARMACOLOGICOS","guid":"ep65yF0teIiU8ErEJR5CQA","children":[{"id":"230","parent":"229","text":"Terapia Cognitivo-Conductual\\N(TCC)","guid":"bE64r2v9zG17sPuVMttstQ","children":[{"id":"231","parent":"230","text":"EVIDENCIA FAVORABLE en revision sistematica (Tan et al. 2021)","guid":"","children":[]},{"id":"232","parent":"230","text":"Aborda catastrofizacion del dolor, estrategias de afrontamiento","guid":"","children":[]}]},{"id":"233","parent":"229","text":"Terapia laser de baja intensidad\\N(LLLT)","guid":"cNVwhRXgVAuHi8wOtITqSw","children":[{"id":"234","parent":"233","text":"Evidencia emergente positiva","guid":"","children":[]},{"id":"235","parent":"233","text":"Sin efectos adversos sistemicos → atractivo en AM","guid":"","children":[]}]},{"id":"236","parent":"229","text":"Acupuntura","guid":"","children":[{"id":"237","parent":"236","text":"Evidencia preliminar","guid":"","children":[]}]}]}]},{"id":"238","parent":"118","text":"Consideraciones\\Ngeriátricas","guid":"-aeVogOJ-47TrQaUZFscMg","children":[{"id":"239","parent":"238","text":"Priorizar tratamientos TOPICOS → menor riesgo sistemico","guid":"","children":[]},{"id":"240","parent":"238","text":"Clonazepam topico > sistemico en AM","guid":"","children":[]},{"id":"241","parent":"238","text":"EVITAR amitriptilina en fragil → carga anticolinergica (Criterios Beers)","guid":"","children":[]},{"id":"242","parent":"238","text":"Revisar TODOS los farmacos (STOPP/START) antes de agregar nuevo","guid":"","children":[]},{"id":"243","parent":"238","text":"IECA → considerar cambio si ardor coincide con inicio","guid":"","children":[]},{"id":"244","parent":"238","text":"Candidiasis en AM: pensar siempre en DM subyacente no diagnosticada","guid":"","children":[]},{"id":"245","parent":"238","text":"Deficiencias B12/Fe muy frecuentes en AM → laboratorio SIEMPRE","guid":"","children":[]},{"id":"246","parent":"238","text":"Valorar estado nutricional: MNA, albumina","guid":"","children":[]}]}]},{"id":"247","parent":"0","text":"Seguimiento Deficiencias\\NNutricionales - RESUMEN","guid":"N6X8A04j1gjk8KsRKM5IPg","children":[{"id":"248","parent":"247","text":"Basal (antes de iniciar)","guid":"","children":[{"id":"249","parent":"248","text":"B12, folato, hemograma + VCM","guid":"","children":[]},{"id":"250","parent":"248","text":"Ferritina + Fe serico + saturacion transferrina","guid":"","children":[]},{"id":"251","parent":"248","text":"Zinc (si disponible)","guid":"","children":[]},{"id":"252","parent":"248","text":"25-OH vitamina D","guid":"","children":[]},{"id":"253","parent":"248","text":"Glicemia/HbA1c, TSH (contexto SBA)","guid":"","children":[]}]},{"id":"254","parent":"247","text":"Semana 4","guid":"","children":[{"id":"255","parent":"254","text":"Hemograma + reticulocitos (si ferropenia o anemia megaloblastica)","guid":"","children":[]},{"id":"256","parent":"254","text":"Respuesta esperada: ↑ reticulocitos 7-10 dias, ↑ Hb a las 4 semanas","guid":"","children":[]}]},{"id":"257","parent":"247","text":"Mes 3","guid":"","children":[{"id":"258","parent":"257","text":"B12 serico → objetivo >400 pg/mL","guid":"","children":[]},{"id":"259","parent":"257","text":"Ferritina → objetivo >30-50 ng/mL","guid":"","children":[]},{"id":"260","parent":"257","text":"Folato serico → objetivo >4 ng/mL","guid":"","children":[]},{"id":"261","parent":"257","text":"Zinc (si se suplemento) → objetivo 80-100 mcg/dL","guid":"","children":[]},{"id":"262","parent":"257","text":"25-OH vitamina D → objetivo 30-60 ng/mL","guid":"","children":[]},{"id":"263","parent":"257","text":"Reevaluar sintomas SBA con EVA o NRS (0-10)","guid":"","children":[]}]},{"id":"264","parent":"247","text":"Mes 6","guid":"","children":[{"id":"265","parent":"264","text":"Repetir panel completo","guid":"","children":[]},{"id":"266","parent":"264","text":"Si sintomas SBA persisten con valores normales → SBA primario confirmado","guid":"","children":[]},{"id":"267","parent":"264","text":"Iniciar manejo neuropatico (clonazepam topico / ALA / TCC)","guid":"","children":[]}]},{"id":"268","parent":"247","text":"PERLA: no mejoría a los 3 meses\\Nde corregir deficiencias","guid":"ELU0pa450I9H2ye8DlUtuA","children":[{"id":"269","parent":"268","text":"→ Buscar causa de SBA primario","guid":"","children":[]},{"id":"270","parent":"268","text":"→ O deficiencia no completamente resuelta (revisar adherencia/absorcion)","guid":"","children":[]}]},{"id":"271","parent":"247","text":"Cuando sospechar malabsorcion\\N(no solo dietetica)","guid":"nBiTpHoKEP91YJpSfO0nbg","children":[{"id":"272","parent":"271","text":"B12 persistentemente baja a pesar de suplementacion oral adecuada","guid":"","children":[]},{"id":"273","parent":"271","text":"Asociacion con diarrea, perdida de peso, anemia refractaria","guid":"","children":[]},{"id":"274","parent":"271","text":"Estudios: anticuerpos anti-factor intrinseco, anti-celulas parietales","guid":"","children":[]},{"id":"275","parent":"271","text":"Si positivos → anemia perniciosa → IM de por vida obligatorio","guid":"","children":[]}]},{"id":"276","parent":"247","text":"Formas\\NClinicas","guid":"w0yWica77NSWkeHXRzDJZA","children":[{"id":"277","parent":"276","text":"Pseudomembranosa (muguet): placas blancas desprendibles → clasica","guid":"","children":[]},{"id":"278","parent":"276","text":"Eritematosa/atrofica: LENGUA DEPAPILADA ROJA sin placa → subadiagnosticada","guid":"","children":[]},{"id":"279","parent":"276","text":"Hiperplasica: placa blanca NO desprendible (candida cronica)","guid":"","children":[]},{"id":"280","parent":"276","text":"Angular (queilitis): comisuras labiales","guid":"","children":[]}]},{"id":"281","parent":"247","text":"Factores\\Nde Riesgo","guid":"nq3j30_HvaseB3qoEmR8jg","children":[{"id":"282","parent":"281","text":"Xerostomia (cualquier causa)","guid":"","children":[]},{"id":"283","parent":"281","text":"Protesis dentales mal ajustadas","guid":"","children":[]},{"id":"284","parent":"281","text":"DM no controlada","guid":"","children":[]},{"id":"285","parent":"281","text":"Uso de corticoides inhalados (no enjuagar)","guid":"","children":[]},{"id":"286","parent":"281","text":"Inmunosupresion (corticoides sistemicos, VIH)","guid":"","children":[]},{"id":"287","parent":"281","text":"Antibioticos de amplio espectro recientes","guid":"","children":[]},{"id":"288","parent":"281","text":"Hipoalbuminemia/desnutricion","guid":"","children":[]}]},{"id":"289","parent":"247","text":"Diagnostico","guid":"","children":[{"id":"290","parent":"289","text":"Clinico: aspecto + se desprende con torula","guid":"","children":[]},{"id":"291","parent":"289","text":"Cultivo: Candida albicans (80%)","guid":"","children":[]},{"id":"292","parent":"289","text":"No siempre necesario para inicio de tratamiento","guid":"","children":[]}]},{"id":"293","parent":"247","text":"Tratamiento","guid":"","children":[{"id":"294","parent":"293","text":"Miconazol gel 2%: 2.5 mL, 4 veces/dia,\\Npost-comidas, 14 dias","guid":"w_jWOXKixN62Tq01gNpkvQ","children":[{"id":"295","parent":"294","text":"INTERACCION IMPORTANTE: inhibe CYP2C9 y CYP3A4","guid":"","children":[]},{"id":"296","parent":"294","text":"Potencia warfarina (INR puede dispararse)","guid":"","children":[]},{"id":"297","parent":"294","text":"Potencia sulfonilureas (hipoglicemia)","guid":"","children":[]},{"id":"298","parent":"294","text":"Potencia estatinas → miopatia","guid":"","children":[]}]},{"id":"299","parent":"293","text":"Nistatina suspension 100.000 UI/mL:\\N4-6 veces/dia, enjuagar y deglutir","guid":"F_3UXjffFW-P_Oi2d7zlYw","children":[{"id":"300","parent":"299","text":"Menos eficaz que miconazol pero MENOR interacciones","guid":"","children":[]},{"id":"301","parent":"299","text":"Primera opcion si polifarmacia compleja","guid":"","children":[]}]},{"id":"302","parent":"293","text":"Fluconazol 150 mg oral dosis unica\\N(o 100 mg/dia x 7 dias)","guid":"_LGrA5s8jr5OYwdbyJvuRg","children":[{"id":"303","parent":"302","text":"Para casos moderados/severos o refractarios","guid":"","children":[]},{"id":"304","parent":"302","text":"Interacciones: warfarina, benzodiacepinas, estatinas, hipoglicemiantes","guid":"","children":[]}]},{"id":"305","parent":"293","text":"Limpiar protesis dentales con nistatina o clorhexidina 0.12%","guid":"","children":[]}]}]},{"id":"306","parent":"0","text":"Perlas\\NClinicas","guid":"fqFs7UxrBgDMy5GF2emOSQ","children":[{"id":"307","parent":"306","text":"Candidiasis eritematosa = lengua roja sin placa → NO siempre hay placa","guid":"","children":[]},{"id":"308","parent":"306","text":"TODA lengua depapilada/enrojecida en AM → cultivo + iniciar empirico si alta sospecha","guid":"","children":[]},{"id":"309","parent":"306","text":"Miconazol en usuario de warfarina → RIESGO HEMORRAGICO → preferir nistatina","guid":"","children":[]},{"id":"310","parent":"306","text":"Antes de diagnosticar SBA primario: niveles B12 + ferritina SIEMPRE","guid":"","children":[]},{"id":"311","parent":"306","text":"Ardor que ALIVIA al comer → mas SBA neuropatico (patron tipico)","guid":"","children":[]},{"id":"312","parent":"306","text":"Ardor que EMPEORA al comer → sospechar ERGE o candidiasis erosiva","guid":"","children":[]},{"id":"313","parent":"306","text":"EDA en SBA: solo si sintomas digestivos concomitantes claros","guid":"","children":[]},{"id":"314","parent":"306","text":"IECAs → ardor metalico u oral → cambiar a ARA-II si controlado","guid":"","children":[]},{"id":"315","parent":"306","text":"Clonazepam topico (masticar-escupir): eficaz con minima absorcion sistemica","guid":"","children":[]},{"id":"316","parent":"306","text":"TCC = tratamiento con mayor evidencia a largo plazo en SBA primario","guid":"","children":[]},{"id":"317","parent":"306","text":"En AM fragil: ALA + TCC antes de iniciar psicofarmacos","guid":"","children":[]}]},{"id":"318","parent":"0","text":"VER\\NTAMBIÉN","guid":"T5GOLYk6ZIOn98qIRhVfKw","children":[{"id":"319","parent":"318","text":"→ Xerostomia-Hiposalivacion (Salud Oral)","guid":"","children":[]},{"id":"320","parent":"318","text":"→ Candidiasis Sistemica (Infecciones)","guid":"","children":[]},{"id":"321","parent":"318","text":"→ Neuropatia Diabetica (Diabetes)","guid":"","children":[]},{"id":"322","parent":"318","text":"→ Depresion AM (Geriatria Psiquiatrica)","guid":"","children":[]}]},{"id":"323","parent":"0","text":"Referencias","guid":"","children":[{"id":"324","parent":"323","text":"1. Tan HL, Smith JG, Hoffmann J, Renton T. A systematic review of treatment for patients with burning mouth syndrome. Cephalalgia. 2021;42(2):128-161. doi:10.1177/03331024211036152","guid":"","children":[]},{"id":"325","parent":"323","text":"2. Khawaja SN, Alaswaiti OF, Scrivani SJ. Burning Mouth Syndrome. Dent Clin North Am. 2022;67(1):49-60. doi:10.1016/j.cden.2022.07.004","guid":"","children":[]},{"id":"326","parent":"323","text":"3. Klein B, Thoppay JR, De Rossi SS, Ciarrocca K. Burning Mouth Syndrome. Dermatol Clin. 2020;38(4):477-483. doi:10.1016/j.det.2020.05.008","guid":"","children":[]},{"id":"327","parent":"323","text":"4. Reyad AA, Mishriky R, Girgis E. Pharmacological and non-pharmacological management of burning mouth syndrome: A systematic review. Dent Med Probl. 2020;57(3):295-304. doi:10.17219/dmp/120991","guid":"","children":[]},{"id":"32