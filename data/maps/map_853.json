{"title":"SBA iPad","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Entidades clínicas/General/SBA iPad.smmx","root":{"id":"0","parent":"-1","text":"Sindrome de\\NBoca Ardiente\\N(SBA)","guid":"IC6E1foGXmPqDjeWaY6jAg","children":[{"id":"1","parent":"0","text":"Definicion y\\NClasificacion","guid":"0DfBWUQlFczbIkyuu99iQA","children":[{"id":"2","parent":"1","text":"Dolor/quemazón cronico intraoral SIN causa local/sistemica identificable","guid":"","children":[]},{"id":"3","parent":"1","text":"Sinonimos: glosodinia, estomatodinia, estomatopirosis","guid":"","children":[]},{"id":"4","parent":"1","text":"Criterios IASP: ardor >=3 meses, continuo o recurrente, sin lesiones visibles","guid":"","children":[]},{"id":"5","parent":"1","text":"Tipo 1 - PRIMARIO\\N/ ESENCIAL","guid":"AJF0zEdVOXkW6P4vLZJzAQ","children":[{"id":"6","parent":"5","text":"Origen NEUROPATICO central","guid":"","children":[]},{"id":"7","parent":"5","text":"Mecanismo: sensitizacion central + disfuncion dopaminergica","guid":"","children":[]},{"id":"8","parent":"5","text":"Patron ritmo diario: aumenta a lo largo del dia","guid":"","children":[]},{"id":"9","parent":"5","text":"Sin causa identificable tras estudio completo","guid":"","children":[]}]},{"id":"10","parent":"1","text":"Tipo 2 -\\NSECUNDARIO","guid":"MQ_OHJOo8hQRPoYR4au6jw","children":[{"id":"11","parent":"10","text":"Surge de causa local, sistemica o psicologica identificable","guid":"","children":[]},{"id":"12","parent":"10","text":"TRATABLE al corregir causa subyacente","guid":"","children":[]}]}]},{"id":"13","parent":"0","text":"Epidemiologia","guid":"","children":[{"id":"14","parent":"13","text":"Prevalencia: 0.7-15% poblacion general","guid":"","children":[]},{"id":"15","parent":"13","text":"Predominio MUJER perimenopausica/posmenopausica","guid":"","children":[]},{"id":"16","parent":"13","text":"Ratio mujer:hombre ~ 7:1 (algunos estudios hasta 33:1)","guid":"","children":[]},{"id":"17","parent":"13","text":"Peak 50-70 anos","guid":"","children":[]},{"id":"18","parent":"13","text":"MAYOR frecuencia en AM por polifarmacia y comorbilidades","guid":"62_YAEBWM0IfHHzOU9PLtg","children":[]}]},{"id":"19","parent":"0","text":"Fisiopatologia","guid":"","children":[{"id":"20","parent":"19","text":"SBA Primario -\\NMecanismos","guid":"Zxgtp1SDTE0xrOmpoTE4dQ","children":[{"id":"21","parent":"20","text":"Neuropatia periferia de fibras C y A-delta (biopsia lengua)","guid":"","children":[]},{"id":"22","parent":"20","text":"Disfuncion sistema opioide endogeno","guid":"","children":[]},{"id":"23","parent":"20","text":"Deficiencia dopaminergica (cuerpo estriado)","guid":"","children":[]},{"id":"24","parent":"20","text":"MENOPAUSIA → caida estrogenos → desmielinizacion fibras trigeminales","guid":"","children":[]},{"id":"25","parent":"20","text":"Sensitizacion central → dolor mantenido sin estimulo","guid":"","children":[]}]},{"id":"26","parent":"19","text":"SBA Secundario\\N- Causas","guid":"4IYG44VEj3G1hY_mTLjCpA","children":[{"id":"27","parent":"26","text":"DEFICIENCIAS NUTRICIONALES\\N(causa secundaria tratable)","guid":"vZLeh1DudTiwlAuicwbZhQ","children":[{"id":"28","parent":"27","text":"Vitamina B12 → glositis atrofica + parestesias","guid":"","children":[]},{"id":"29","parent":"27","text":"Hierro (ferritina) → glositis + sindrome de piernas inquietas","guid":"","children":[]},{"id":"30","parent":"27","text":"Folato → glositis + macrocitosis","guid":"","children":[]},{"id":"31","parent":"27","text":"Vitamina B1, B2, B6 → neuropatia periferica","guid":"","children":[]},{"id":"32","parent":"27","text":"Zinc → disgeusia + cicatrizacion deteriorada","guid":"","children":[]}]},{"id":"33","parent":"26","text":"CANDIDIASIS ORAL\\N(EXCLUIR SIEMPRE)","guid":"WcRAZfCFTt-lajfAg2wDYw","children":[{"id":"34","parent":"33","text":"Lengua depapilada/enrojecida + placa blanquecina desprendible → CANDIDA","guid":"","children":[]},{"id":"35","parent":"33","text":"Tratamiento: miconazol 2% gel 4 veces/dia x 14 dias","guid":"","children":[]},{"id":"36","parent":"33","text":"Alternativa: fluconazol 150mg oral dosis unica o 100mg/dia x 7 dias","guid":"","children":[]}]},{"id":"37","parent":"26","text":"XEROSTOMIA/\\NHIPOSALIVACION","guid":"ql0yPmnwXRB7f0fjPx4v1w","children":[{"id":"38","parent":"37","text":"Polifarmacia → antihistaminicos, antidepresivos TCA, diureticos, antihipertensivos","guid":"JYWM5IU9EX8WcG_oy5BRCQ","children":[]},{"id":"39","parent":"37","text":"↓ flujo salival → mucosa vulnerable → ardor","guid":"","children":[]}]},{"id":"40","parent":"26","text":"ERGE (reflujo\\Ngastroesofagico)","guid":"eeSYRqvAeJkokvdFGwTYRA","children":[{"id":"41","parent":"40","text":"Acido gastrico → mucosa oral","guid":"9CWymS-FOS7jQTS7qB45YA","children":[]},{"id":"42","parent":"40","text":"Confirmar con cuestionario GERD-Q + pH-metria si duda","guid":"","children":[]}]},{"id":"43","parent":"26","text":"DIABETES\\NMELLITUS","guid":"vwKoHp1bKy-Dx3WCNV6tKg","children":[{"id":"44","parent":"43","text":"Neuropatia autonoma + microangiopatia → cambios mucosa","guid":"","children":[]},{"id":"45","parent":"43","text":"Candidiasis recurrente en DM descompensada","guid":"","children":[]}]},{"id":"46","parent":"26","text":"HIPOTIROIDISMO","guid":"","children":[{"id":"47","parent":"46","text":"↓ T3/T4 → cambios mucosa oral, disgeusia","guid":"","children":[]}]},{"id":"48","parent":"26","text":"ALERGIAS DE CONTACTO","guid":"","children":[{"id":"49","parent":"48","text":"Acrilicos (protesis dentales), saborizantes, conservantes","guid":"","children":[]}]},{"id":"50","parent":"26","text":"MEDICAMENTOS","guid":"","children":[{"id":"51","parent":"50","text":"IECAs → ardor/disgeusia","guid":"","children":[]},{"id":"52","parent":"50","text":"Bisfosfonatos","guid":"","children":[]},{"id":"53","parent":"50","text":"Quimioterapia","guid":"","children":[]}]},{"id":"54","parent":"26","text":"LIQUEN\\NPLANO ORAL","guid":"ehXt5AQJTZyv_-2Sc1R3oA","children":[{"id":"55","parent":"54","text":"Lesiones bl