dYLZToiILIBCgy10rQ","children":[]}]},{"id":"94","parent":"81","text":"FLUENTE + Comprensión alterada + Repetición preservada → TRANSCORTICAL SENSORIAL","guid":"NxTdv3_YSJqawLocHSw7mg","children":[{"id":"95","parent":"94","text":"Lesión → adyacente a Wernicke (zona watershed)","guid":"PqJoyMkxTuy-KLMlCz3ekQ","children":[]},{"id":"96","parent":"94","text":"Ecolalia posible","guid":"K6EZXHL_SBO4ZB8YpsG1VA","children":[]},{"id":"97","parent":"94","text":"Lee en voz alta SIN comprender","guid":"cULav1O1TcCJWPC7kt5qvg","children":[]},{"id":"98","parent":"94","text":"Sin déficits motores típicamente","guid":"iOWgSI8LTxuUCezYdKTefA","children":[]}]},{"id":"99","parent":"81","text":"FLUENTE + Comprensión preservada + Repetición preservada → ANÓMICA","guid":"iIyrHHMiQl2q5CIIBsXgzQ","children":[{"id":"100","parent":"99","text":"Déficit AISLADO de denominación","guid":"C1sd5RQQTAeUA4N_lM9npQ","children":[]},{"id":"101","parent":"99","text":"Circunloquios frecuentes","guid":"VjsTUafcQQqUTrNp5fr0Qw","children":[]},{"id":"102","parent":"99","text":"Múltiples localizaciones → temporal basal, temporoparietal, parietal inferior","guid":"YQzpkRcFTxOyOIBV7R3IyQ","children":[]},{"id":"103","parent":"99","text":"Forma MÁS LEVE de afasia","guid":"Br2NPazzQEGSmSIe-mazoQ","children":[]}]},{"id":"104","parent":"81","text":"NO FLUENTE + Comprensión preservada + Repetición alterada → BROCA","guid":"HQkarAshQDG_ZcUFR88f3w","children":[{"id":"105","parent":"104","text":"Lesión → giro frontal inferior posterior izq","guid":"P2pBn7MwRi2O1scMqapNRQ","children":[]},{"id":"106","parent":"104","text":"Agramatismo → omite palabras funcionales","guid":"6hj3088UQyW2h2JbcjQXVQ","children":[]},{"id":"107","parent":"104","text":"Hemiparesia derecha frecuente","guid":"GXSKQf_SRZON-LsjuA270w","children":[]},{"id":"108","parent":"104","text":"Apraxia oral común","guid":"0my5vWSNQ8-kD9uOqDVfXA","children":[]},{"id":"109","parent":"104","text":"Escritura proporcionalmente afectada","guid":"d4pfRii0Qpqn5-CFuomJNg","children":[]}]},{"id":"110","parent":"81","text":"NO FLUENTE + Comprensión preservada + Repetición preservada → TRANSCORTICAL MOTORA","guid":"vqh0hQNfQsKbRT14yq03yQ","children":[{"id":"111","parent":"110","text":"Lesión → watershed anterior (ACA/ACM)","guid":"0EbmCSxKS5Gt1FgKov5e-Q","children":[]},{"id":"112","parent":"110","text":"Dificultad para INICIAR el habla","guid":"v2ew8Mf5Q2SxJ_VaRFUxQQ","children":[]},{"id":"113","parent":"110","text":"Puede presentar apatía y signos frontales","guid":"adKe-dyHSgaxTu3g4AzeWA","children":[]}]},{"id":"114","parent":"81","text":"NO FLUENTE + Comprensión alterada + Repetición alterada → GLOBAL","guid":"qC9FAMIPRZq0uFdBuR59QQ","children":[{"id":"115","parent":"114","text":"Lesión EXTENSA perisilviana (Broca + Wernicke)","guid":"tvnKrqFxRaCxxX89hbPtHg","children":[]},{"id":"116","parent":"114","text":"Mutismo o expresiones automáticas","guid":"Iy5ZiNXvTTGRSSbst9lb7g","children":[]},{"id":"117","parent":"114","text":"Hemiparesia derecha + hemianopsia","guid":"a7P4J8Q7R-O5cj024OpVPg","children":[]},{"id":"118","parent":"114","text":"PEOR pronóstico de recuperación","guid":"-4awra7XQxKcZ_JO9BXdDA","children":[]}]},{"id":"119","parent":"81","text":"NO FLUENTE + Comprensión alterada + Repetición preservada → TRANSCORTICAL MIXTA","guid":"-bODaLTtSB6wSwwOloP8YA","children":[{"id":"120","parent":"119","text":"Lesión watershed anterior + posterior bilateral","guid":"6P61v9UeTIiT0yt1FAnCUQ","children":[]},{"id":"121","parent":"119","text":"Similar a global pero REPITE","guid":"A9q7VRzLSp-YKHlzeWwixA","children":[]},{"id":"122","parent":"119","text":"Puede completar frases automáticas sobreaprendidas","guid":"MSKQYyBkTS-gWBXNTZHprw","children":[]}]}]},{"id":"123","parent":"0","text":"Trastornos Relacionados","guid":"slwdIw50TY-ZYBYHOuy8lw","children":[{"id":"124","parent":"123","text":"Sordera pura para palabras","guid":"gkoW2C8PTn6kxDCmhlboMw","children":[{"id":"125","parent":"124","text":"Comprensión escrita preservada, oral alterada","guid":"vlQ0oavXS-u8hayLMu9-9g","children":[]},{"id":"126","parent":"124","text":"Lenguaje espontáneo normal","guid":"uUZn-tQwSVS4u3Yt3yRZiQ","children":[]},{"id":"127","parent":"124","text":"Lesión → giro temporal superior bilateral","guid":"137uf-lKQYGKql5rowO0wQ","children":[]}]},{"id":"128","parent":"123","text":"Alexia sin agrafia (alexia pura)","guid":"WoYXnq1oQt-BrcnSJ6wayA","children":[{"id":"129","parent":"128","text":"Escribe pero no lee lo escrito","guid":"mOc4_EKMTxm2JlBU5J1qqA","children":[]},{"id":"130","parent":"128","text":"Lesión → occipital izq + esplenio calloso","guid":"xnd_wF9kQqiIw82Gguuybw","children":[]},{"id":"131","parent":"128","text":"Hemianopsia derecha asociada","guid":"y0axd_fOQKWVVECnTbHUQQ","children":[]}]},{"id":"132","parent":"123","text":"Afemia (mutismo puro para palabras)","guid":"6ne0GpwwRTiUbntEid4RFw","children":[{"id":"133","parent":"132","text":"Déficit en producción del habla","guid":"YR9Qze5RSKajb5OheGxd5A","children":[]},{"id":"134","parent":"132","text":"Comprensión y escritura PRESERVADAS","guid":"rpEs2ZdeTG-LWJB513CwIg","children":[]},{"id":"135","parent":"132","text":"Lesión → área de Broca o adyacente","guid":"QUhhmfdqT9GYY9BnHC0wJA","children":[]}]}]},{"id":"136","parent":"0","text":"Clasificación de Disartrias (Mayo Clinic)","guid":"QTzKxRfdQkeNucu64ppUQg","children":[{"id":"137","parent":"136","text":"Espástica → MOTONEURONA SUPERIOR","guid":"4INJHkhbRMyk3YRj80F3LA","children":[{"id":"138","parent":"137","text":"Voz tensa-estrangulada","guid":"ouZbofzoSSeZTq9CovPLWg","children":[]},{"id":"139","parent":"137","text":"Articulación imprecisa","guid":"XcNHOQ1EQ96Lq_mxj0o5Xw","children":[]},{"id":"140","parent":"137","text":"Frases cortas, prosodia monótona","guid":"Caasd_cjSuOU3wnGyM6MJA","children":[]},{"id":"141","parent":"137","text":"Hipernasalidad leve","guid":"ylwNnutMTHG-IqGH6V9njA","children":[]},{"id":"142","parent":"137","text":"Asociado → espasticidad, hiperreflexia, Babinski","guid":"686hbXaqSSu88rY4QvntLw","children":[]},{"id":"143","parent":"137","text":"Causas → ACV bilateral, ELA (componente superior), parálisis pseudobulbar","guid":"aSxQ0bQQTdmgr9h2R2a1Ow","children":[]}]},{"id":"144","parent":"136","text":"Flácida → MOTONEURONA INFERIOR","guid":"9fj9yBmDQXadGXKr2JdVwA","children":[{"id":"145","parent":"144","text":"Voz soplada, hipofónica","guid":"Kbf7lj8ITfin0_08C-Plkg","children":[]},{"id":"146","parent":"144","text":"Hipernasalidad MARCADA (velo palatino)","guid":"XxfRSHczRyWwkjwunrPMlA","children":[]},{"id":"147","parent":"144","text":"Fasciculaciones linguales → sospechar ELA","guid":"Bh5DYCf8Rqu96CSsa6q-Gg","children":[]},{"id":"148","parent":"144","text":"Causas → lesión bulbar, neuropatía craneal, miastenia gravis, Guillain-Barré","guid":"b312_KzaSHOP31rsJRoqZA","children":[]}]},{"id":"149","parent":"136","text":"Atáxica → CEREBELOSA","guid":"zBxO6WX2RcuUzsl8CN5NtA","children":[{"id":"150","parent":"149","text":"Habla escándida (scanning speech) → PATOGNOMÓNICA","guid":"Yh8I9831QuW23IgwlUB7bQ","children":[]},{"id":"151","parent":"149","text":"Articulación irregular","guid":"dxuNcCmlQ1qcUtzP-6TeNQ","children":[]},{"id":"152","parent":"149","text":"Prosodia excesiva (explosive speech)","guid":"Yf-b1oyIQs6SkJIsi6UfHA","children":[]},{"id":"153","parent":"149","text":"Asociado → dismetría, temblor intencional, ataxia de la marcha","guid":"xrDt_FHPRO28_eOD9VatMg","children":[]},{"id":"154","parent":"149","text":"Causas → ACV cerebeloso, EM, degeneración cerebelosa, daño por OH crónico","guid":"v88XqdfARxeIGt2zb3A0zw","children":[]}]},{"id":"155","parent":"136","text":"Hipocinética → EXTRAPIRAMIDAL (Parkinson)","guid":"PEWgKRbTRt-FZQ7iWZimlQ","children":[{"id":"156","parent":"155","text":"Voz monótona, hipofónica","guid":"-ZWdceL7T1ik1QkOSCtBAA","children":[]},{"id":"157","parent":"155","text":"Articulación imprecisa","guid":"cgESwTZtTVSkV_0biAinZg","children":[]},{"id":"158","parent":"155","text":"Taquifemia (aceleración progresiva)","guid":"q2oM1SRXTLaAUxcKa1u4lg","children":[]},{"id":"159","parent":"155","text":"Palilalia (repetición involuntaria de sílabas)","guid":"nLsZIx-uSvu-xufuyzCuMg","children":[]},{"id":"160","parent":"155","text":"Asociado → bradicinesia, rigidez, temblor de reposo","guid":"0jgiGn5iTp25eXqqAVqlhA","children":[]},{"id":"161","parent":"155","text":"Micrografía acompaña frecuentemente","guid":"3uoznfh6Qgu3wtNb8AnHEg","children":[]}]},{"id":"162","parent":"136","text":"Hipercinética → EXTRAPIRAMIDAL (corea, distonía)","guid":"8IkEl549SwydJv_QHn-2og","children":[{"id":"163","parent":"162","text":"Interrupciones involuntarias del habla","guid":"B2fjPZdgTgq2fqtSOt0geg","children":[]},{"id":"164","parent":"162","text":"Variabilidad en volumen y tono","guid":"7wd6PR81SJCX5K4OPKCAQA","children":[]},{"id":"165","parent":"162","text":"Distonía laríngea → voz estrangulada intermitente","guid":"InJi2kf7Svy2dOqzul9Omg","children":[]},{"id":"166","parent":"162","text":"Causas → Huntington, distonía, mioclonías","guid":"-SptaEFHRwyua0w2_pUbBQ","children":[]}]},{"id":"167","parent":"136","text":"Mixta → MÁS DE UN SISTEMA","guid":"HIRiDW3vTDCLpLVLbwraxg","children":[{"id":"168","parent":"167","text":"ELA → espástica + flácida (MÁS FRECUENTE combinación mixta)","guid":"n5YUyDbQQeity11ci1eQwQ","children":[]},{"id":"169","parent":"167","text":"EM → espástica + atáxica","guid":"sSHTagIwR8KM-hQiFjbxXQ","children":[]},{"id":"170","parent":"167","text":"Enfermedad de Wilson → espástica + atáxica + hipercinética","guid":"dtISoclATWadAM65e5HRDA","children":[]}]}]},{"id":"171","parent":"0","text":"Biomecánica del Habla en Disartria","guid":"ogyXPAyyRk6Zcs2nl3Tyyw","children":[{"id":"172","parent":"171","text":"Errores fonéticos predecibles según músculo afectado","guid":"fQShvJvjSJqEoIc78jOLlg","children":[{"id":"173","parent":"172","text":"Bilabiales /P/, /B/, /M/ → orbicular de labios (VII par)","guid":"X9JIjdIISTeEK3ULMid1cQ","children":[{"id":"174","parent":"173","text":"Falla cierre hermético labial","guid":"gUe8V-qTSsy5YlDD_nd5tA","children":[]},{"id":"175","parent":"173","text":"Sonido soplado en vez de explosivo","guid":"nTy46KCfQj-QU5VU9Ba-uw","children":[]}]},{"id":"176","parent":"172","text":"Linguoalveolares /L/, /T/, /D/ → longitudinal superior lengua (XII par)","guid":"KnlWQWKSTAmvzHrlFuteSA","children":[{"id":"177","parent":"176","text":"Escape de aire lateral no controlado","guid":"h8pLO2meT2yyOtAp2PNOJw","children":[]}]},{"id":"178","parent":"172","text":"Velares /K/, /G/ → elevador del paladar (X par)","guid":"qM9FCOBNTUmy_EN_jX99XA","children":[{"id":"179","parent":"178","text":"Hipernasalidad por incompetencia velofaríngea","guid":"1fNX1MCxQ-eHNfepC1UpDw","children":[]}]}]},{"id":"180","parent":"171","text":"Prosodia → musculatura espiratoria","guid":"Ti6a1du0QLum7WjmHGuUCg","children":[{"id":"181","parent":"180","text":"Incoordinación neumofónica","guid":"xSeU95eQQC-w-ytERh8ZtQ","children":[]},{"id":"182","parent":"180","text":"Hipofonía, frases cortas, voz monótona","guid":"ma6wAVmdSeyEf4qcbb3uUA","children":[]}]}]},{"id":"183","parent":"0","text":"Apraxia del Habla (diagnóstico diferencial)","guid":"RGpiJYmPRsK5NjRwfkk7Ng","children":[{"id":"184","parent":"183","text":"NO es disartria NI afasia → trastorno de PROGRAMACIÓN motora","guid":"BE6q8L__TFC9A9vZwqAXyg","children":[]},{"id":"185","parent":"183","text":"Errores INCONSISTENTES de articulación","guid":"s4XitXRCQZ6eeK5_vq1EEA","children":[]},{"id":"186","parent":"183","text":"Groping articulatorio (tanteo con boca)","guid":"RaaxlAqbTxy4S3ilZ5Tefg","children":[]},{"id":"187","parent":"183","text":"Mayor dificultad en palabras largas y complejas","guid":"0ksV4iy2SVCfah0lHfXjhA","children":[]},{"id":"188","parent":"183","text":"Prosodia alterada con patrón de ensayo-error","guid":"kmCr4DcDTNC_4zArusYWTQ","children":[]},{"id":"189","parent":"183","text":"Lesión → ínsula anterior izquierda / Broca profundo","guid":"AMRVQoV8Rdy7OfsjZVSiUQ","children":[]},{"id":"190","parent":"183","text":"Frecuentemente coexiste con afasia de Broca","guid":"nsX3Owo1SW-Q6_G49xikuw","children":[]}]},{"id":"191","parent":"0","text":"Evaluación Complementaria","guid":"yn-hDDHkSZuTwjKtBXPyjA","children":[{"id":"192","parent":"191","text":"Neuroimagen","guid":"K8EJcJoDTcuJKtk7bLktEQ","children":[{"id":"193","parent":"192","text":"TC cerebral → urgencia (ACV hemorrágico vs isquémico)","guid":"2Ydc7XZ3RU2mJ8h7t47x8A","children":[]},{"id":"194","parent":"192","text":"RM cerebral → GOLD STANDARD","guid":"Eq8k5CgLQtS6OWeZSCeHOg","children":[{"id":"195","parent":"194","text":"DWI → isquemia aguda","guid":"GRJB8PQYTx2uYqg6WhbLcw","children":[]},{"id":"196","parent":"194","text":"FLAIR → lesiones desmielinizantes","guid":"qNahZySrS4aAHyqhrCRudw","children":[]},{"id":"197","parent":"194","text":"T1 con gadolinio → tumores, abscesos","guid":"Eu5L4k7dQUmrarCcMM2kQQ","children":[]}]},{"id":"198","parent":"192","text":"Angio-TC/RM → patología vascular","guid":"QCUrnF8XSu2v_yISqvqG1Q","children":[]}]},{"id":"199","parent":"191","text":"Pruebas estandarizadas de lenguaje","guid":"YFGj9gzlSsG7R5U9iy12hg","children":[{"id":"200","parent":"199","text":"Test de Boston (BDAE) → evaluación completa de afasia","guid":"U0SMRA9ATjiTttTW6zb4aQ","children":[]},{"id":"201","parent":"199","text":"Western Aphasia Battery (WAB) → clasifica síndromes","guid":"8xUeOqulRQmk3iztEwlANA","children":[]},{"id":"202","parent":"199","text":"Token Test → comprensión sintáctica (descrito arriba)","guid":"2DY55cR3TeiljdoK5sFmrA","children":[]},{"id":"203","parent":"199","text":"Fluencia verbal fonémica (FAS) y semántica (animales en 1 min)","guid":"GOFfYKaaT-Sq925c8nA8Ow","children":[]}]},{"id":"204","parent":"191","text":"Evaluación fonoaudiológica","guid":"FT2WUrtdSbGdT9b9k8blfw","children":[{"id":"205","parent":"204","text":"Frenchay Dysarthria Assessment → disartria","guid":"5eCqvj7HQq-sM_C0olJxJA","children":[]},{"id":"206","parent":"204","text":"Diadococinesias → /pa-ta-ka/ rápido","guid":"1SeqAwi9Qbijy61sWZWLUQ","children":[]}]},{"id":"207","parent":"191","text":"EEG → si sospecha crisis epiléptica (afasia ictal)","guid":"KuBKyKVlR6idSsLE6jcTag","children":[]},{"id":"208","parent":"191","text":"EMG/VCN → si sospecha miastenia o neuropatía craneal","guid":"_AWNQtfLQDeG-yOnb7TTlQ","children":[]}]},{"id":"209","parent":"0","text":"Consideraciones Geriátricas","guid":"GbbL6mNxRkCniwEJrZp2bA","children":[{"id":"210","parent":"209","text":"Afasia en AM → SIEMPRE descartar ACV primero","guid":"RMotg0CkR5Cq4rv66lED2w","children":[]},{"id":"211","parent":"209","text":"Afasia primaria progresiva (APP) → neurodegenerativa","guid":"o6Cv0-VmRheqlMobRtBqsA","children":[{"id":"212","parent":"211","text":"Variante no fluente/agramática → degeneración frontotemporal","guid":"A9Wi0neFTSGNjhCxo3uo9Q","children":[]},{"id":"213","parent":"211","text":"Variante semántica → atrofia temporal anterior","guid":"IWPp_NbgQliGBGR_zrQnbg","children":[]},{"id":"214","parent":"211","text":"Variante logopénica → Alzheimer atípico (la más común en AM)","guid":"ZDexLXKgRDeBI__TqY3rNw","children":[]}]},{"id":"215","parent":"209","text":"Disartria en AM → causas más frecuentes","guid":"lW8cbRUOTR2D_IlSKPMWrQ","children":[{"id":"216","parent":"215","text":"ACV (la más común)","guid":"Z482bcflTp-gVWs2pFJsiA","children":[]},{"id":"217","parent":"215","text":"Parkinsonismo","guid":"NdUTy3dGTlG3OV60x_Es8g","children":[]},{"id":"218","parent":"215","text":"ELA de inicio bulbar → disartria + disfagia temprana","guid":"z6KDKANqQGGDIGF1BjalWg","children":[]},{"id":"219","parent":"215","text":"Polifarmacia → BZD, antiepilépticos, antipsicóticos causan disartria","guid":"qf_phceBRSGzL-ogUzvDtw","children":[]}]},{"id":"220","parent":"209","text":"Prótesis dental desajustada → SIMULA o EXACERBA disartria","guid":"ZIJH_kvXSh6oXlReaK8j6Q","children":[{"id":"221","parent":"220","text":"Evaluar ajuste protésico SIEMPRE antes de planificar tratamiento","guid":"wP3_h3jyT5KPXFkdCcsXig","children":[]},{"id":"222","parent":"220","text":"Ninguna terapia será efectiva sin corrección odontológica","guid":"SGLbrJr5ScGbvc5PRLMZNQ","children":[]}]},{"id":"223","parent":"209","text":"Presbifagia + disartria → evaluar riesgo de aspiración","guid":"ZiaPxHGsSpiP-NXDsdXZsA","children":[{"id":"224","parent":"223","text":"Voz húmeda post-ingesta → asumir aspiración silente","guid":"I8k34-hKTpW_PeBtqOTCsw","children":[]},{"id":"225","parent":"223","text":"EMST (entrenamiento fuerza muscular espiratoria) → protector","guid":"a_njX1GLRPqaLwWpprREBg","children":[]}]},{"id":"226","parent":"209","text":"Delirium → alteración fluctuante del lenguaje NO es afasia","guid":"5EBSsHVITRe0l9gQdUmzyg","children":[]},{"id":"227","parent":"209","text":"Hipoacusia → descartar ANTES de evaluar comprensión","guid":"ghkwrj9_SseAl5ytsQee2Q","children":[]},{"id":"228","parent":"209","text":"Daño en sustancia blanca → reduce ancho de banda atencional","guid":"Ee9xATZPQ3mVGpjZnheH3w","children":[{"id":"229","parent":"228","text":"\"Stop Walking While Talking\" → signo de interferencia cognitivo-motora","guid":"IhWFiRmLQZu2fFBrVctSBg","children":[]}]}]},{"id":"230","parent":"0","text":"Pronóstico y Rehabilitación","guid":"X7Cfc8RKTvmM73XfnjFKhA","children":[{"id":"231","parent":"230","text":"Factores pronósticos en afasia","guid":"U9-KQUcHSiSP-kXsHKzEHw","children":[{"id":"232","parent":"231","text":"Tipo → no fluentes recuperan más que global","guid":"pZQw0ynlQ5ilJNk7U8W7jQ","children":[]},{"id":"233","parent":"231","text":"Edad → jóvenes mejor pronóstico","guid":"2s5QFUJJQNG3WZeKvrzizw","children":[]},{"id":"234","parent":"231","text":"Tamaño y localización de lesión","guid":"l5MQrIA8QDGq1fIvcEpnTg","children":[]},{"id":"235","parent":"231","text":"Tiempo de inicio del tratamiento → precoz = mejor","guid":"uKIRFfCfSYu6mJ4BO03XOQ","children":[]},{"id":"236","parent":"231","text":"Afasias subcorticales → mejor que corticales","guid":"5gXLN_ygSoOAUjiXFZavCA","children":[]}]},{"id":"237","parent":"230","text":"Tratamiento afasia","guid":"fwYV1Oo7TV6r5-QkKqUjLg","children":[{"id":"238","parent":"237","text":"Terapia fonoaudiológica intensiva → estándar","guid":"tJu36pg5Rti_9M_BCWoueQ","children":[]},{"id":"239","parent":"237","text":"Estimulación cerebral no invasiva (TMS, tDCS) → emergente","guid":"uESIRmGzQK2kBLvghY6gTw","children":[]},{"id":"240","parent":"237","text":"Sistemas de comunicación aumentativa (CAA)","guid":"GuCWt66WTMa8bmnrFXMJTA","children":[]}]},{"id":"241","parent":"230","text":"Tratamiento disartria","guid":"mAQdowcvR6eO7BgLsAhjtw","children":[{"id":"242","parent":"241","text":"Ejercicios oromotores específicos según tipo","guid":"9hlKLWBuQwShFdU3BGHBgA","children":[]},{"id":"243","parent":"241","text":"EMST → válvula umbral presión (regla de los 5: 5 rep x 5 series x 5 días/sem)","guid":"FP4HpxiyTp-m_4cZ4l8R7g","children":[]},{"id":"244","parent":"241","text":"Corrección de factores mecánicos (prótesis dental)","guid":"pSjC7UAsR7KwsiHW2NUMqQ","children":[]},{"id":"245","parent":"241","text":"Entrenamiento en doble tarea → re-automatización del habla","guid":"dfevPEhtT821DFKBiyIGZA","children":[]}]}]},{"id":"246","parent":"0","text":"Perlas Clínicas","guid":"AioiZEstT0OmsyI7Atn9ow","children":[{"id":"247","parent":"246","text":"Escritura preservada + comprensión intacta = DISARTRIA, no afasia","guid":"DIUNiJIxTkK8iD0pl0efWQ","children":[]},{"id":"248","parent":"246","text":"Afasias PERISILVIANAS alteran la repetición → regla de oro clasificatoria","guid":"1CQsNqaBSPiXFmxPn2YvJA","children":[]},{"id":"249","parent":"246","text":"Token Test detecta afasias leves que pasan screening clínico habitual","guid":"4Aqv2bbkQFm5CB6Ssj5PlQ","children":[]},{"id":"250","parent":"246","text":"Habla escándida (scanning) = CEREBELO hasta demostrar lo contrario","guid":"_0vS_1yAReuOSUQO_iLOZg","children":[]},{"id":"251","parent":"246","text":"Disartria espástica + flácida combinadas = pensar ELA","guid":"yV_qzcMSRqSezMZYPKD0fw","children":[]},{"id":"252","parent":"246","text":"Prótesis dental desajustada simula disartria → revisar SIEMPRE en AM","guid":"GPXAgKCLRbS2JiHyICofyg","children":[]},{"id":"253","parent":"246","text":"Afasia progresiva variante logopénica orienta a Alzheimer en AM","guid":"9eJ5dgovTyOoq4X9P65mSA","children":[]},{"id":"254","parent":"246","text":"Voz húmeda post-ingesta en disártrico → aspiración silente → EMST protector","guid":"3iqpx3FqSJi4um478hcnnQ","children":[]},{"id":"255","parent":"246","text":"Disartria hipocinética + micrografía → Parkinson","guid":"LYRcylN0QXeTMSuCHDvPFQ","children":[]},{"id":"256","parent":"246","text":"Anosognosia del déficit → típico de Wernicke","guid":"6Iwcj1yIQJyahJHmnR3Vyw","children":[]},{"id":"257","parent":"246","text":"Afasia ictal (crisis epiléptica) → transitoria, confirmar con EEG","guid":"gA7bHgjaTUqcenfrGPJeZQ","children":[]},{"id":"258","parent":"246","text":"Dominancia hemisférica izquierda en >95% diestros → lesión izq = afasia","guid":"F34R5X13TUuQOO5fcZoXwg","children":[]},{"id":"259","parent":"246","text":"No confundir con delirium → la afasia es ESTABLE, el delirium FLUCTÚA","guid":"3OOHMDJITvyNeKnHiIR5Kw","children":[]},{"id":"260","parent":"246","text":"\"Stop Walking While Talking\" → daño sustancia blanca con disartria","guid":"TyHDwHoeR-6Sbc3QmMc0og","children":[]}]},{"id":"261","parent":"0","text":"Referencias","guid":"rUip98_bRRapYD4rnQKuzw","children":[{"id":"262","parent":"261","text":"1. Duffy JR. Motor Speech Disorders. 4th Ed. Elsevier. 2019.","guid":"xKXuA3wrSSqZoKd4fUB_rg","children":[]},{"id":"263","parent":"261","text":"2. Darley FL, et al. Differential Diagnostic Patterns of Dysarthria. J Speech Hear Res. 1969;12(2):246-69.","guid":"kP-5CdUJReu2dP_XzSLo0w","children":[]},{"id":"264","parent":"261","text":"3. Hillis AE. Aphasia: Progress in the Last Quarter of a Century. Neurology. 2007;69(2):200-13.","guid":"rwf-sPFoRbaHZfWEytxd2w","children":[]},{"id":"265","parent":"261","text":"4. Mesulam M. Primary Progressive Aphasia. Ann Neurol. 2001;49(4):425-32.","guid":"VzSWKlGrRU6mVG9iqgCrew","children":[]},{"id":"266","parent":"261","text":"5. De Renzi E, Vignolo LA. The Token Test. Brain. 1962;85:665-78.","guid":"sh3OyGV4TemY0mRfA9pO1g","children":[]},{"id":"267","parent":"261","text":"6. Enderby P. Frenchay Dysarthria Assessment. Int J Lang Commun Disord. 1983;18(2):159-70.","guid":"GxAjJdCDQh-iRWYfSxeWMg","children":[]},{"id":"268","parent":"261","text":"7. Acevedo C. Guía Caso Clínico Disartria Subcortical. INGER. 2025.","guid":"kwg_IT3WQP6H5U_OMND8qA","children":[]}]}]},"node_count":268,"relations":[],"cross_references":[],"specialty":"General","folder":"Entidades clínicas/Neurología","filename":"Semiologia_Disartria_Afasia-1","id":"map_1450","resolved_references":[]}