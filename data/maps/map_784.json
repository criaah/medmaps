{"title":"ImplantacionEmbrionaria","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Entidades clínicas/General/ImplantacionEmbrionaria iPad.smmx","root":{"id":"0","parent":"-1","text":"Aumento de Probabilidades de\\NImplantación Embrionaria","guid":"UgZfRF-c3n5sT-fmeKtBEg","children":[{"id":"1","parent":"0","text":"FISIOPATOLOGÍA DE\\NLA IMPLANTACIÓN","guid":"0zYvRl4_AXAUjOQPQXXiyQ","children":[{"id":"2","parent":"1","text":"Ventana de implantación (WOI)\\N→ LH+6 a LH+10","guid":"VumHI82pdwI71WI-AkD_yA","children":[{"id":"3","parent":"2","text":"Duración ~4 días en ciclo natural","guid":"","children":[]},{"id":"4","parent":"2","text":"En FET hormonal → P4 día 5-6 post inicio","guid":"","children":[]},{"id":"5","parent":"2","text":"DESPLAZAMIENTO del WOI → causa frecuente de fallo silencioso","guid":"","children":[]}]},{"id":"6","parent":"1","text":"Triada\\Nnecesaria","guid":"VJwAFXtH7-dwNos-vSPrkQ","children":[{"id":"7","parent":"6","text":"Embrión viable y euploide","guid":"","children":[]},{"id":"8","parent":"6","text":"Endometrio receptivo → arquitectura + expresión génica","guid":"","children":[]},{"id":"9","parent":"6","text":"Sincronía embrión-endometrio → timing preciso","guid":"","children":[]}]},{"id":"10","parent":"1","text":"Marcadores de\\Nreceptividad endometrial","guid":"SdnOPKAyAcB85dufSV2fkA","children":[{"id":"11","parent":"10","text":"Pinópodos → protrusiones epiteliales LH+7","guid":"","children":[]},{"id":"12","parent":"10","text":"VEGF → angiogénesis, ↓VEGF = fallo implantación","guid":"","children":[]},{"id":"13","parent":"10","text":"HOXA10/HOXA11 → genes maestros endometriales","guid":"","children":[{"id":"14","parent":"13","text":"Hipermetilación → bloquea expresión → ↓receptividad","guid":"","children":[]}]},{"id":"15","parent":"10","text":"LIF, IL-1β, TGF-β → citoquinas pro-receptividad","guid":"","children":[]},{"id":"16","parent":"10","text":"Efecto Warburg → glucólisis aeróbica en microambiente implantatorio","guid":"","children":[]}]}]},{"id":"17","parent":"0","text":"FACTOR\\NEMBRIONARIO","guid":"Q5YyCikLl1OnPxVd1nMYUA","children":[{"id":"18","parent":"17","text":"Calidad\\Nembrionaria","guid":"f31h_P5CcLwTLTw3HCJthw","children":[{"id":"19","parent":"18","text":"Blastocisto expandido → mejor tasa implantación vs D3","guid":"","children":[]},{"id":"20","parent":"18","text":"Clasificación Gardner → 3AA mínimo para transferencia","guid":"","children":[]},{"id":"21","parent":"18","text":"VITRIFICACIÓN → tasas supervivencia >95%, NO inferior a fresco","guid":"","children":[]}]},{"id":"22","parent":"17","text":"Aneuploidía → causa #1 fallo\\Nimplantación en >35 años","guid":"4HfHwdEonSf-hGNP9CSMRw","children":[{"id":"23","parent":"22","text":"35 años → ~50% embriones aneuploides","guid":"1hFYPSMXYw4salEWaPqlvQ","children":[]},{"id":"24","parent":"22","text":"TEST GENÉTICO\\NPREIMPLANTACIONAL\\N(PGT-A)","guid":"aTGpr1VUmRooZCbi9onsKg","children":[{"id":"25","parent":"24","text":"↑tasa implantación por embrión transferido (60-70% vs ~40%)","guid":"kzXI_L61guwMarba2AnSYQ","children":[]},{"id":"26","parent":"24","text":"INDICACIÓN en caso\\Nde Cristian/Javiera","guid":"lCimj1Cife9-iKtQzEPAiA","children":[{"id":"27","parent":"26","text":"DNA fragmentación elevada en esperma → ↑riesgo aneuploidía","guid":"","children":[]},{"id":"28","parent":"26","text":"Antecedente familiar anomalías congénitas → considerar PGT-M","guid":"","children":[]}]},{"id":"29","parent":"24","text":"Limitación → no aumenta tasa acumulada en pacientes normales","guid":"","children":[]}]}]},{"id":"30","parent":"17","text":"Fragmentación DNA espermático →\\Nimpacto en desarrollo embrionario","guid":"nfLZmpQCVsJ7y0IuR8Zbiw","children":[{"id":"31","parent":"30","text":"↑DFI → peor calidad embrionaria → ↓tasa implantación","guid":"","children":[]},{"id":"32","parent":"30","text":"MANEJO → ICSI selectivo +\\Nreducción DFI previo a colecta","guid":"oGphE0QlarilTHOitL1yNQ","children":[{"id":"33","parent":"32","text":"Antioxidantes: CoQ10 200-400mg, vitamina C+E, zinc","guid":"","children":[]},{"id":"34","parent":"32","text":"Abstinencia <3 días → ↓DFI","guid":"","children":[]},{"id":"35","parent":"32","text":"Refrigeración espermática rápida en lab","guid":"","children":[]}]}]}]},{"id":"36","parent":"0","text":"FACTOR\\NENDOMETRIAL","guid":"LVlVvRz6wRd6AdPyvSk3RQ","children":[{"id":"37","parent":"36","text":"GROSOR\\NENDOMETRIAL","guid":"jjPbYkbo4PiJnY11S8uQeA","children":[{"id":"38","parent":"37","text":"Mínimo aceptado → 7mm (idealmente ≥8mm)","guid":"","children":[]},{"id":"39","parent":"37","text":"Óptimo → 9-12mm, patrón trilaminar","guid":"","children":[]},{"id":"40","parent":"37","text":"<7mm → ↓tasa implantación significativa","guid":"","children":[]},{"id":"41","parent":"37","text":"ESTRATEGIAS\\Nante endometrio\\Nfino","guid":"3A-gyZFycZ28JCVxWT8_3g","children":[{"id":"42","parent":"41","text":"↑dosis estradiol oral/vaginal/transdérmico","guid":"","children":[]},{"id":"43","parent":"41","text":"Sildenafil vaginal 25mg 4 veces/día → vasodilatación","guid":"","children":[]},{"id":"44","parent":"41","text":"G-CSF intrauterino → evidencia limitada pero emergente","guid":"","children":[]},{"id":"45","parent":"41","text":"Aspirina 100mg → mejora flujo uterino (evidencia moderada)","guid":"","children":[]}]}]},{"id":"46","parent":"36","text":"PREPARACIÓN ENDOMETRIAL\\NEN CRIOTRANSFERENCIA","guid":"uAz9DDhbBWIU1n1RN8buDg","children":[{"id":"47","parent":"46","text":"Ciclo artificial → estradiol + progesterona → más controlado","guid":"","children":[]},{"id":"48","parent":"46","text":"Ciclo natural modificado → menor riesgo suprafisiológico","guid":"","children":[]},{"id":"49","parent":"46","text":"PROGESTERONA →\\Nclave en fase lútea","guid":"_84ccqszaZ0sStwQ9pDrkA","children":[{"id":"50","parent":"49","text":"Vía vaginal → niveles locales superiores","guid":"","children":[]},{"id":"51","parent":"49","text":"Inicio P4 → día de colecta o según protocolo","guid":"","children":[]},{"id":"52","parent":"49","text":"Monitorizar niveles séricos día transferencia → >10ng/mL ideal","guid":"","children":[]},{"id":"53","parent":"49","text":"SUPLEMENTACIÓN EXTENDIDA → al menos 10-12 semanas post transfer","guid":"","children":[]}]}]},{"id":"54","parent":"36","text":"CRONOTRANSFERENCIA\\NPERSONALIZADA\\N(ERA/ERPeak)","guid":"tcJcq_7-UeA1CUNls-MiMw","children":[{"id":"55","parent":"54","text":"ERA test → biopsia endometrial LH+7 → análisis transcriptoma","guid":"","children":[]},{"id":"56","parent":"54","text":"RCT JAMA 2022 → ERA NO mejora tasa nacido vivo en pacientes estándar","guid":"","children":[{"id":"57","parent":"56","text":"(58.5% vs 61.9%, RR 0.95, IC95% 0.79-1.13, p=0.38)","guid":"","children":[]}]},{"id":"58","parent":"54","text":"METAANÁLISIS Fertil Steril 2023 → sin diferencia significativa (OR 1.38, IC 0.79-2.41)","guid":"","children":[]},{"id":"59","parent":"54","text":"INDICACIÓN REAL → fallo implantación recurrente (>2 transferencias fallidas)","guid":"","children":[{"id":"60","parent":"59","text":"En esas pacientes → ERA guía pET → mejora tasa embarazo","guid":"","children":[]}]},{"id":"61","parent":"54","text":"CONCLUSIÓN → NO recomendado de rutina en primer ciclo","guid":"","children":[]}]},{"id":"62","parent":"36","text":"PATOLOGÍA UTERINA →\\NCORREGIR PREVIO a transferencia","guid":"n4swCCdDi0XBiKoRkolwRg","children":[{"id":"63","parent":"62","text":"Pólipo endometrial → histeroscopia","guid":"","children":[]},{"id":"64","parent":"62","text":"Mioma submucoso → miomectomía","guid":"","children":[]},{"id":"65","parent":"62","text":"Adherencias (Asherman) → lisis histeroscópica","guid":"","children":[]},{"id":"66","parent":"62","text":"Hidrosálpinx → salpingectomía antes de FET → ↑implantación","guid":"","children":[]}]},{"id":"67","parent":"36","text":"MICROBIOMA\\NENDOMETRIAL","guid":"QinVWEu6faAG65g2jDrfdQ","children":[{"id":"68","parent":"67","text":"Lactobacillus spp. →dominancia = mejor receptividad","guid":"","children":[]},{"id":"69","parent":"67","text":"Disbiosis → asociada con fallo implantación recurrente","guid":"","children":[]},{"id":"70","parent":"67","text":"ESTRATEGIA → probióticos vaginales → evidencia emergente","guid":"","children":[]}]}]},{"id":"71","parent":"0","text":"FACTOR HORMONAL\\NE INMUNOLÓGICO","guid":"0-3h6q_VQ_SRi-GjN9Z1Wg","children":[{"id":"72","parent":"71","text":"ESTRÓGENOS","guid":"","children":[{"id":"73","parent":"72","text":"Niveles suprafisiológicos en estimulación fresca → ↓receptividad","guid":"","children":[]},{"id":"74","parent":"72","text":"→ Estrategia FREEZE-ALL → evitar efecto adverso en endometrio","guid":"","children":[{"id":"75","parent":"74","text":"Indicaciones: SHO alto riesgo, progesterona >1.5 día HCG, LH prematura","guid":"","children":[]},{"id":"76","parent":"74","text":"Beneficio reproducible → en poblaciones con pobre receptividad fresca","guid":"","children":[]}]},{"id":"77","parent":"72","text":"Rango óptimo E2 día transferencia → 200-400pg/mL en ciclo hormonal","guid":"","children":[]}]},{"id":"78","parent":"71","text":"PROGESTERONA","guid":"","children":[{"id":"79","parent":"78","text":"Inicio tardío → desincroniza WOI","guid":"","children":[]},{"id":"80","parent":"78","text":"Niveles bajos día HCG → peor pronóstico","guid":"","children":[]},{"id":"81","parent":"78","text":"↓P4 sérica durante fase lútea → miscarriage precoz","guid":"","children":[]}]},{"id":"82","parent":"71","text":"MODULACIÓN INMUNE →\\Nevidencia limitada pero creciente","guid":"tA3rP8bQDdcqvqtaCkxmVA","children":[{"id":"83","parent":"82","text":"Intralipid → indicación en NK uterinas elevadas","guid":"","children":[]},{"id":"84","parent":"82","text":"Prednisona 5-10mg → indicación controvertida","guid":"","children":[]},{"id":"85","parent":"82","text":"LMWH (heparina) → beneficio en trombofilia + fallo recurrente","guid":"","children":[]},{"id":"86","parent":"82","text":"Hydroxicloroquina → en contexto autoinmune","guid":"","children":[]}]}]},{"id":"87","parent":"0","text":"ESTRATEGIAS PREVIAS A TRANSFERENCIA\\N(INTERVENCIONES ACTIVAS)","guid":"8pSbW0A3h5V-tUhWsHKQCw","children":[{"id":"88","parent":"87","text":"SCRATCHING ENDOMETRIAL\\N(legrado superficial)","guid":"Jp6FVKF5igttWXsOXEg2Aw","children":[{"id":"89","parent":"88","text":"Mecanismo → inflamación controlada → ↑citoquinas → ↑receptividad","guid":"","children":[]},{"id":"90","parent":"88","text":"EVIDENCIA\\NMIXTA","guid":"gYlX3hd8ImddVnEf4l981g","children":[{"id":"91","parent":"90","text":"RCT recientes NO confirman beneficio consistente en población general","guid":"","children":[]},{"id":"92","parent":"90","text":"Posible beneficio en fallo implantación recurrente (RIF)","guid":"","children":[]}]},{"id":"93","parent":"88","text":"TIMING → ciclo previo a transferencia","guid":"","children":[]}]},{"id":"94","parent":"87","text":"PRP (Plasma Rico en Plaquetas)\\Nintrauterino","guid":"8AZfZAPWi4vb5CoQb5I29A","children":[{"id":"95","parent":"94","text":"Mecanismo → factores de crecimiento → regeneración endometrial","guid":"","children":[]},{"id":"96","parent":"94","text":"Indicación principal → endometrio refractario/fino","guid":"","children":[]},{"id":"97","parent":"94","text":"Evidencia → observacional, sin RCT de alta calidad","guid":"","children":[]}]},{"id":"98","parent":"87","text":"G-CSF\\Nintrauterino","guid":"LVw7stZm9phMo3WddM4e-w","children":[{"id":"99","parent":"98","text":"Estimula reclutamiento células madre endometriales","guid":"","children":[]},{"id":"100","parent":"98","text":"Evidencia → estudios pequeños, prometedor en endometrio fino","guid":"","children":[]}]},{"id":"101","parent":"87","text":"OPTIMIZACIÓN\\NSISTÉMICA","guid":"QFVLlukE6lZob7Z0NyWreA","children":[{"id":"102","parent":"101","text":"Vitamina D → corregir deficiencia (<30ng/mL) → mejora receptividad","guid":"","children":[]},{"id":"103","parent":"101","text":"Omega-3 → antiinflamatorio, mejora flujo uterino","guid":"","children":[]},{"id":"104","parent":"101","text":"Ácido fólico → 400-800mcg → continuar hasta semana 12","guid":"","children":[]},{"id":"105","parent":"101","text":"CoQ10 → mejora calidad ovocitaria y espermática","guid":"","children":[]},{"id":"106","parent":"101","text":"DIETA MEDITERRÁNEA → asociada con mejores outcomes IVF","guid":"","children":[]},{"id":"107","parent":"101","text":"PESO CORPORAL → IMC 19-25 → óptimo, IMC >30 → ↓tasa implantación","guid":"","children":[]}]}]},{"id":"108","parent":"0","text":"ESTRATEGIA FREEZE-ALL\\N(Criopreservación total)","guid":"LQXPqaf5zJ1lo4hkRaeAPg","children":[{"id":"109","parent":"108","text":"DEFINICIÓN → congelar todos los embriones → transferir en ciclo posterior","guid":"","children":[]},{"id":"110","parent":"108","text":"VENTAJAS","guid":"","children":[{"id":"111","parent":"110","text":"Evita efecto estrógenossuprafisiológicos sobre endometrio","guid":"","children":[]},{"id":"112","parent":"110","text":"Tiempo para test genético (PGT-A) si indicado","guid":"","children":[]},{"id":"113","parent":"110","text":"Sincronización óptima endometrio-embrión","guid":"","children":[]}]},{"id":"114","parent":"108","text":"INDICACIONES ESPECÍFICAS según revisión\\N(Reprod Biomed Online 2021)","guid":"Y-1nKPIVkzgkA1S84emW1g","children":[{"id":"115","parent":"114","text":"SHO moderado-severo → SIEMPRE freeze-all","guid":"","children":[]},{"id":"116","parent":"114","text":"E2 elevado día HCG (>3000pg/mL) → freeze-all","guid":"","children":[]},{"id":"117","parent":"114","text":"Progesterona elevada día HCG (>1.5ng/mL) → freeze-all","guid":"","children":[]},{"id":"118","parent":"114","text":"Receptividad subóptima → endometrio irregular","guid":"","children":[]},{"id":"119","parent":"114","text":"Necesidad PGT → siempre freeze-all","guid":"","children":[]}]},{"id":"120","parent":"108","text":"APLICACIÓN EN\\NCASO JAVIERA","guid":"TeHAKbY7151UffbzH6e2MQ","children":[{"id":"121","parent":"120","text":"EMBRIONES CRIOPRESERVADOS → transferencia septiembre 2026","guid":"","children":[]},{"id":"122","parent":"120","text":"Permite evaluación PGT-A si hay indicación confirmada","guid":"","children":[]},{"id":"123","parent":"120","text":"Permite optimización factores modificables entre ahora y sept 2026","guid":"","children":[]}]}]},{"id":"124","parent":"0","text":"EPIGENÉTICA ENDOMETRIAL\\N→ LÍNEA EMERGENTE","guid":"hqI-9SwWcCWGJnN5_C-8eQ","children":[{"id":"125","parent":"124","text":"HOXA10/HOXA11 →\\Ngenes maestros de\\Nreceptividad","guid":"taDXDyrO1nixAyhyJf56SQ","children":[{"id":"126","parent":"125","text":"Hipermetilación de promotores → condiciones: endometriosis, miomas, PCOS, endometritis","guid":"","children":[]},{"id":"127","parent":"125","text":"ESTRATEGIA\\NEMERGENTE","guid":"IznLgP8sGbWsH_TJP_V0mQ","children":[{"id":"128","parent":"127","text":"Epigallocatechin-3-gallate (EGCG) → demetilación → restaura expresión","guid":"","children":[]},{"id":"129","parent":"127","text":"Indol-3-carbinol → efecto similar","guid":"","children":[]}]},{"id":"130","parent":"125","text":"Potencial biomarcador diagnóstico futuro","guid":"","children":[]}]},{"id":"131","parent":"124","text":"CRONOTERAPIA EPIGENÉTICA → investigación activa","guid":"","children":[]}]},{"id":"132","parent":"0","text":"APLICACIÓN AL CASO JAVIERA\\N(septiembre 2026)","guid":"V9S3msrFWLdPy2gvLfGS2g","children":[{"id":"133","parent":"132","text":"ENTRE HOY Y TRANSFERENCIA →\\NVENTANA DE OPTIMIZACIÓN ~6 MESES","guid":"XSO_fMqT8ygQZ-fU0DTY6A","children":[{"id":"134","parent":"133","text":"Confirmar indicación PGT-A con Dr. Sánchez","guid":"","children":[]},{"id":"135","parent":"133","text":"Reducir DFI de Cristian → CoQ10 + vitamina C + E + zinc","guid":"","children":[]},{"id":"136","parent":"133","text":"Javiera → dieta mediterránea, normalizar vitamina D, ácido fólico continuo","guid":"","children":[]},{"id":"137","parent":"133","text":"Evaluar microbioma vaginal/endometrial si antecedente de disbiosis","guid":"","children":[]},{"id":"138","parent":"133","text":"Histeroscopia diagnóstica previa → descartar patología cavitaria","guid":"","children":[]}]},{"id":"139","parent":"132","text":"PROTOCOLO\\NCRIOTRANSFERENCIA","guid":"phhJugFljZYmA7h_GojqMw","children":[{"id":"140","parent":"139","text":"Ciclo hormonal artificial → control preciso de timing","guid":"","children":[]},{"id":"141","parent":"139","text":"Grosor endometrial ≥9mm + patrón trilaminar → día de transferencia","guid":"6ClQKyMC4tFYv8Lzeh-P-A","children":[]},{"id":"142","parent":"139","text":"P4 sérica día transferencia → verificar >10ng/mL","guid":"","children":[]},{"id":"143","parent":"139","text":"ERA → NO indicado en primer ciclo (sin RIF previo)","guid":"","children":[]}]},{"id":"144","parent":"132","text":"MONITOREO\\NPOST-TRANSFERENCIA","guid":"eOB4egQq16qy2M3Q6wNnaQ","children":[{"id":"145","parent":"144","text":"P4 semanal hasta semana 8-10","guid":"","children":[]},{"id":"146","parent":"144","text":"β-hCG a los 10-12 días post transferencia","guid":"","children":[]},{"id":"147","parent":"144","text":"Ecografía semana 5-6 → latido cardiaco","guid":"","children":[]}]}]},{"id":"148","parent":"0","text":"Perlas\\NClínicas","guid":"9NT_ySKW2zVlGB9M-wAgwA","children":[{"id":"149","parent":"148","text":"ERA no mejora resultados en primer ciclo → reservar para RIF (>2 fallos)","guid":"","children":[]},{"id":"150","parent":"148","text":"Freeze-all = decisión acertada en caso de Javiera → embriones disponibles septiembre","guid":"","children":[]},{"id":"151","parent":"148","text":"DFI elevado en Cristian → intervenir AHORA → 6 meses de optimización antes de transferencia","guid":"","children":[]},{"id":"152","parent":"148","text":"Progesterona vaginal → niveles locales superiores a oral → preferir vía vaginal","guid":"","children":[]},{"id":"153","parent":"148","text":"Grosor <7mm día transferencia → suspender ciclo y replantear protocolo","guid":"","children":[]},{"id":"154","parent":"148","text":"Vitamina D y ácido fólico → micronutrientes con mayor evidencia → chequear niveles ya","guid":"","children":[]},{"id":"155","parent":"148","text":"PGT-A → contemplar dada fragmentación DNA + historia familiar anomalías congénitas","guid":"","children":[]},{"id":"156","parent":"148","text":"Freeze-all no garantiza mejor resultado global → sí mejor endometrio en transferencia","guid":"","children":[]},{"id":"157","parent":"148","text":"Aneuploidía → causa #1 de fallo; a mayor edad materna, mayor prevalencia","guid":"","children":[]},{"id":"158","parent":"148","text":"Dieta mediterránea → única intervención dietética con evidencia en IVF (OR ~1.5 tasa nacido vivo)","guid":"","children":[]}]},{"id":"159","parent":"0","text":"Referencias","guid":"","children":[{"id":"160","parent":"159","text":"1. Doyle N et al. Effect of Timing by Endometrial Receptivity Testing vs Standard Timing. JAMA. 2022;328(21):2117-2125. https://doi.org/10.1001/jama.2022.20438","guid":"","children":[]},{"id":"161","parent":"159","text":"2. Arian SE et al. Endometrial receptivity array before frozen embryo transfer: systematic review and meta-analysis. Fertil Steril. 2022;119(2):229-238. https://doi.org/10.1016/j.fertnstert.2022.11.012","guid":"","children":[]},{"id":"162","parent":"159","text":"3. Bourdon M et al. The freeze-all strategy after IVF: which indications? Reprod Biomed Online. 2021;42(3):529-545. https://doi.org/10.1016/j.rbmo.2020.11.013","guid":"","children":[]},{"id":"163","parent":"159","text":"4. Parisi F et al. Pathophysiological role of estrogens in early pregnancy. Hum Reprod Update. 2023;29(6):699-720. https://doi.org/10.1093/humupd/dmad016","guid":"","children":[]},{"id":"164","parent":"159","text":"5. Kudlay D et al. HOXA10 and HOXA11 Methylation: Epigenetic Barriers to Endometrial Receptivity. Genes (Basel). 2025;16(10). https://doi.org/10.3390/genes16101230","guid":"","children":[]},{"id":"165","parent":"159","text":"6. Bui BN et al. The endometrial transcriptome of infertile women with and without implantation failure. Acta Obstet Gynecol Scand. 2024;103(7):1348-1365. https://doi.org/10.1111/aogs.14822","guid":"","children":[]},{"id":"166","parent":"159","text":"7. Jia Y et al. ERA-guided pET vs conventional FET in Chinese women with RIF. Med Sci Monit. 2022;28:e935634. https://doi.org/10.12659/MSM.935634","guid":"","children":[]},{"id":"167","parent":"159","text":"8. Zhang X et al. Linking the Warburg effect to endometrial receptivity. Front Cell Dev Biol. 2025;13:1683790. https://doi.org/10.3389/fcell.2025.1683790","guid":"","children":[]}]}]},"node_count":167,"relations":[],"cross_references":[],"specialty":"General","folder":"Entidades clínicas/General","filename":"ImplantacionEmbrionaria iPad","id":"map_784","resolved_references":[],"title_raw":"ImplantacionEmbrionaria iPad"}