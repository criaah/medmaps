n":[]},{"id":"131","parent":"129","text":"- Ajuste individualizado","guid":"","children":[]}]},{"id":"132","parent":"110","text":"- H-ARS:","guid":"","children":[{"id":"133","parent":"132","text":"- 10 mcg/kg/día (SC)","guid":"","children":[]},{"id":"134","parent":"132","text":"- Inicio: ASAP post-exposición >2 Gy","guid":"Ix2MFugoW7J3OuvrYohHzg","children":[]}]},{"id":"135","parent":"110","text":"- Neutropenia VIH:","guid":"","children":[{"id":"136","parent":"135","text":"- Inicio: 1 mcg/kg/día (SC)","guid":"","children":[]},{"id":"137","parent":"135","text":"- Titular hasta RAN >2x10⁹/L (máx 4 mcg/kg/d)","guid":"S_-G6YQw6fdKklaaj1i3QQ","children":[]}]}]},{"id":"138","parent":"109","text":"B. Dosis Recomendadas de\\NPegfilgrastim por Indicación","guid":"","children":[{"id":"139","parent":"138","text":"- NIQ (No mieloide):","guid":"","children":[{"id":"140","parent":"139","text":"- Adultos/Pediátricos ≥45kg: 6 mg SC (dosis única/ciclo)","guid":"9kw-0FBbU_UzC0pUqtqpDA","children":[]},{"id":"141","parent":"139","text":"- Pediátricos <45kg\\N(ajuste por peso):","guid":"","children":[{"id":"142","parent":"141","text":"- <10 kg: 0.1 mg/kg","guid":"","children":[]},{"id":"143","parent":"141","text":"- 10-20 kg: 1.5 mg","guid":"","children":[]},{"id":"144","parent":"141","text":"- 21-30 kg: 2.5 mg","guid":"","children":[]},{"id":"145","parent":"141","text":"- 31-44 kg: 4 mg","guid":"","children":[]}]},{"id":"146","parent":"139","text":"- No administrar entre 14d antes y 24h después de QT","guid":"dwOObCzGDab89Io5R0h9Yw","children":[]}]},{"id":"147","parent":"138","text":"- H-ARS\\N(Neulasta®/Udenyca®):","guid":"","children":[{"id":"148","parent":"147","text":"- Dos dosis separadas por 1 semana","guid":"8ZiE8nwKGMh7enp0-cZg2Q","children":[]},{"id":"149","parent":"147","text":"- Primera dosis: ASAP post-exposición","guid":"dqDd2WEwaqrSKKtA2SEtLA","children":[]}]}]},{"id":"150","parent":"109","text":"C. Vías y Métodos de\\NAdministración","guid":"","children":[{"id":"151","pa