{"title":"Modelos","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Entidades clínicas/Ortogeriatría/Orto Modelos-2026.smmx","root":{"id":"0","parent":"-1","text":"MODELOS DE ORTOGERIATRÍA","guid":"","children":[{"id":"1","parent":"0","text":"Definición y Fundamento","guid":"","children":[{"id":"2","parent":"1","text":"Fractura de cadera → enfermedad\\Ngeriátrica, no solo ortopédica","guid":"","children":[]},{"id":"3","parent":"1","text":"**Paciente frágil** con alta\\Ncomplejidad médica requiere\\Nabordaje interdisciplinario","guid":"","children":[]},{"id":"4","parent":"1","text":"Objetivos → ↓ mortalidad, ↓ complicaciones, ↓\\Nestancia, preservar funcionalidad","guid":"","children":[]},{"id":"5","parent":"1","text":"Evidencia nivel moderado apoya\\Nimplementación (metaanálisis 37\\Nestudios, n=37.294)","guid":"","children":[]}]},{"id":"6","parent":"0","text":"","guid":"","children":[]},{"id":"7","parent":"0","text":"Modelo 1 → Servicio de\\NInterconsulta Geriátrica (GCS)","guid":"","children":[{"id":"8","parent":"7","text":"**Geriatric Consultation Service**","guid":"","children":[]},{"id":"9","parent":"7","text":"Estructura","guid":"","children":[{"id":"10","parent":"9","text":"Paciente en sala de\\Ntraumatología/ortopedia","guid":"","children":[]},{"id":"11","parent":"9","text":"Geriatra actúa como consultor →\\Nevaluación a demanda o proactiva","guid":"","children":[]},{"id":"12","parent":"9","text":"Equipo ortopédico mantiene\\Nresponsabilidad principal","guid":"","children":[]}]},{"id":"13","parent":"7","text":"Ventajas","guid":"","children":[{"id":"14","parent":"13","text":"Implementación más sencilla","guid":"","children":[]},{"id":"15","parent":"13","text":"Menor costo inicial","guid":"","children":[]},{"id":"16","parent":"13","text":"No requiere\\Nreestructuración de\\Ncamas","guid":"","children":[]}]},{"id":"17","parent":"7","text":"Limitaciones","guid":"","children":[{"id":"18","parent":"17","text":"Menor integración →\\Nintervenció