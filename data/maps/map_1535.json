.9","guid":"","children":[]},{"id":"40","parent":"36","text":"68.7% retorno a domicilio previo","guid":"","children":[]}]}]},{"id":"41","parent":"25","text":"Limitaciones","guid":"","children":[{"id":"42","parent":"41","text":"Requiere infraestructura\\Nespecífica (camas geriátricas)","guid":"","children":[]},{"id":"43","parent":"41","text":"Cirujano puede sentir\\Npérdida de \"ownership\"","guid":"","children":[]},{"id":"44","parent":"41","text":"Posible demora quirúrgica si\\Ngeriatra debe estabilizar primero","guid":"","children":[]}]}]},{"id":"45","parent":"0","text":"","guid":"","children":[]},{"id":"46","parent":"0","text":"Modelo 3 → Cuidado\\NIntegrado/Compartido (ICM)","guid":"","children":[{"id":"47","parent":"46","text":"**Integrated Care Model / Shared\\NCare / Co-management**","guid":"","children":[]},{"id":"48","parent":"46","text":"Estructura","guid":"","children":[{"id":"49","parent":"48","text":"**Responsabilidad compartida**\\Ngeriatra + traumatólogo","guid":"","children":[]},{"id":"50","parent":"48","text":"Ambos especialistas\\Ncon rol equivalente","guid":"","children":[]},{"id":"51","parent":"48","text":"Protocolos conjuntos predefinidos","guid":"","children":[]},{"id":"52","parent":"48","text":"Reuniones diarias de equipo","guid":"","children":[]},{"id":"53","parent":"48","text":"Ubicación → puede ser ortopedia o\\Nunidad dedicada ortogeriatría","guid":"","children":[]}]},{"id":"54","parent":"46","text":"Ventajas","guid":"","children":[{"id":"55","parent":"54","text":"**Mayor integración** →\\Nmejor comunicación","guid":"","children":[]},{"id":"56","parent":"54","text":"Decisiones conjuntas\\Npreoperatorias y postoperatorias","guid":"","children":[]},{"id":"57","parent":"54","text":"Optimización preqx y manejo\\Nperioperatorio coordinado","guid":"","children":[]},{"id":"58","parent":"54","text":"Estudio Oslo → ICM vs GCS","guid":"","children":[{"id":"59","parent":"58","text":"Mejor bloqueo nervioso\\Npreoperatorio (OR 2.0)","guid":"","children"