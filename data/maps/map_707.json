{"title":"Cáncer de pulmón-2024-1","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Entidades clínicas/General/Cáncer de pulmón-2024-1.smmx","root":{"id":"0","parent":"-1","text":"Cáncer de pulmón","guid":"sE1BE8eLj8ekhvJMjexdog","children":[{"id":"1","parent":"0","text":"Clasificación del\\Ncáncer de pulmón","guid":"f__ALeGStxeqj6vSkxyv3g","children":[{"id":"2","parent":"1","text":"1. Por tipo\\Nhistológico (1)","guid":"PKTr83_tIztxUJDUSfcUNw","children":[{"id":"3","parent":"2","text":"- Cáncer de pulmón de células no pequeñas\\N(CPCNP) (85%)","guid":"_SxNiOGxWSjnZ6onfJruZw","children":[{"id":"4","parent":"3","text":"- Adenocarcinoma (40%)","guid":"p_nPWCDXi2MODcdu9mKAqQ","children":[]},{"id":"5","parent":"3","text":"- Carcinoma de células escamosas (25-30%)","guid":"OpMgFnokz4OuIXroFtzClQ","children":[]},{"id":"6","parent":"3","text":"- Carcinoma de células grandes (10-15%)","guid":"orh6tP1vQPLHSRBsZ_MS3w","children":[]}]},{"id":"7","parent":"2","text":"- Cáncer de pulmón de células pequeñas\\N(CPCP) (15%)","guid":"s87jlE8IPHdsaRDETzCYBQ","children":[]}]},{"id":"8","parent":"1","text":"2. Por extensión\\Nanatómica (TNM) (2)","guid":"bMrob2hpITRzOtWKjQikug","children":[{"id":"9","parent":"8","text":"- T (Tumor primario)","guid":"O101nMY4bw3Sz4JrC38wqw","children":[{"id":"10","parent":"9","text":"- Tx: No se puede evaluar","guid":"wUGxdPf_ruGOBcGM0ExH0g","children":[]},{"id":"11","parent":"9","text":"- T0: Sin evidencia de tumor primario","guid":"7_-w4m6gRZgbCjiiUmhTCw","children":[]},{"id":"12","parent":"9","text":"- Tis: Carcinoma in situ","guid":"cekf6K3-PeewvgzXtaiz8w","children":[]},{"id":"13","parent":"9","text":"- T1-4: Tamaño y extensión local del tumor primario","guid":"2mpeyw_dZSTGjntilp5kDA","children":[]}]},{"id":"14","parent":"8","text":"- N (Ganglios linfáticos\\Nregionales)","guid":"gp2vV-iCmo1JQzQcVwligg","children":[{"id":"15","parent":"14","text":"- Nx: No se pueden evaluar","guid":"u5T_Dp2KPGXPxkdaJAq1zw","children":[]},{"