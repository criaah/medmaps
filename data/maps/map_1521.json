{"title":"Anemia","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Entidades clínicas/Ortogeriatría/Orto Anemia-2026.smmx","root":{"id":"0","parent":"-1","text":"Anemia en Ortogeriatría","guid":"H5qAZXPIOUODgwkglo-KNw","children":[{"id":"1","parent":"0","text":"Epidemiología","guid":"","children":[{"id":"2","parent":"1","text":"Prevalencia preoperatoria **~50%** de\\Npacientes con fractura de cadera","guid":"","children":[]},{"id":"3","parent":"1","text":"Reducción media Hb\\Npostoperatoria **0.7-2.5 g/dL**","guid":"","children":[]},{"id":"4","parent":"1","text":"**~30%** requieren transfusión\\Npese a política restrictiva","guid":"","children":[]},{"id":"5","parent":"1","text":"Deficiencia de hierro al ingreso\\N**~60%** de pacientes","guid":"","children":[]}]},{"id":"6","parent":"0","text":"Definición y Clasificación","guid":"","children":[{"id":"7","parent":"6","text":"OMS → Hb <13 g/dL\\Nhombres, <12 g/dL mujeres","guid":"","children":[]},{"id":"8","parent":"6","text":"Anemia moderada-severa → Hb **<10\\Ng/dL** (punto de corte crítico)","guid":"","children":[]},{"id":"9","parent":"6","text":"Clasificación etiológica en anciano","guid":"","children":[{"id":"10","parent":"9","text":"Ferropénica → pérdida GI\\Noculta, malabsorción","guid":"","children":[]},{"id":"11","parent":"9","text":"Inflamatoria/enfermedad\\Ncrónica → hepcidina ↑","guid":"","children":[]},{"id":"12","parent":"9","text":"Déficit B12/folato → macrocítica","guid":"","children":[]},{"id":"13","parent":"9","text":"Insuficiencia renal → déficit EPO","guid":"","children":[]},{"id":"14","parent":"9","text":"**Mixta** → más\\Nfrecuente en geriátrico","guid":"","children":[]}]}]},{"id":"15","parent":"0","text":"Factores de Riesgo para Transfusión","guid":"","children":[{"id":"16","parent":"15","text":"Relacionados con paciente","guid":"","children":[{"id":"17","parent":"16","text":"Edad **>75 años** (OR 1.\\N03 por año adicional)","guid":"","children":[]},{"id":"18","parent":"16","text":"Sexo femenino (OR 1.61)","guid":"","children":[]},{"id":"19","parent":"16","text":"Anemia preoperatoria (OR **4.69**)","guid":"","children":[]},{"id":"20","parent":"16","text":"ASA elevado (OR 1.14)","guid":"","children":[]},{"id":"21","parent":"16","text":"EPOC (OR 1.30)","guid":"","children":[]},{"id":"22","parent":"16","text":"Hipertensión (OR 1.17)","guid":"","children":[]},{"id":"23","parent":"16","text":"IMC bajo (OR 0.97)","guid":"","children":[]},{"id":"24","parent":"16","text":"Hipocalcemia → tasa transfusión\\N**16% vs 8%** (p<0.05)","guid":"","children":[]}]},{"id":"25","parent":"15","text":"Relacionados con fractura","guid":"","children":[{"id":"26","parent":"25","text":"Fractura\\N**peritrocantérica**\\N(OR 2.99)","guid":"","children":[]},{"id":"27","parent":"25","text":"Fractura\\N**subtrocantérica** (OR\\N**5.07**)","guid":"","children":[]},{"id":"28","parent":"25","text":"Fractura intracapsular\\N→ menor sangrado","guid":"","children":[]}]},{"id":"29","parent":"15","text":"Regla de riesgo de sangrado","guid":"","children":[{"id":"30","parent":"29","text":"**≥2 factores** = alto riesgo","guid":"","children":[{"id":"31","parent":"30","text":"Fractura peritrocantérica","guid":"","children":[]},{"id":"32","parent":"30","text":"Hb **<12 g/dL**","guid":"","children":[]},{"id":"33","parent":"30","text":"Edad **>75 años**","guid":"","children":[]}]}]}]},{"id":"34","parent":"0","text":"Impacto Clínico de la Anemia","guid":"","children":[{"id":"35","parent":"34","text":"Outcomes a corto plazo","guid":"","children":[{"id":"36","parent":"35","text":"Mortalidad 30 días → transfusión:\\N**8.4% vs 6.4%** (OR 1.29)","guid":"","children":[]},{"id":"37","parent":"35","text":"Estancia hospitalaria\\Nprolongada → **7.3 vs 6.3\\Ndías**","guid":"","children":[]},{"id":"38","parent":"35","text":"Readmisión 30 días → **9.4%\\Nvs 7.7%** (OR 1.27)","guid":"","children":[]}]},{"id":"39","parent":"34","text":"Outcomes a 6 meses","guid":"","children":[{"id":"40","parent":"39","text":"Hb preop **<10 g/dL** → peor\\Nfunción y calidad de vida","guid":"","children":[]},{"id":"41","parent":"39","text":"↓ HHS (Harris Hip Score)","guid":"","children":[]},{"id":"42","parent":"39","text":"↓ PMS (Parker Mobility Scale)","guid":"","children":[]},{"id":"43","parent":"39","text":"↓ SF-36 función física y rol físico","guid":"","children":[]}]},{"id":"44","parent":"34","text":"Outcomes a 1 año","guid":"","children":[{"id":"45","parent":"44","text":"Mortalidad hasta **30%**","guid":"","children":[]},{"id":"46","parent":"44","text":"Deterioro cognitivo","guid":"","children":[]},{"id":"47","parent":"44","text":"Declive funcional","guid":"","children":[]}]}]},{"id":"48","parent":"0","text":"Umbrales de Transfusión","guid":"","children":[{"id":"49","parent":"48","text":"Estudio **FOCUS** (N=2016)","guid":"","children":[{"id":"50","parent":"49","text":"Liberal (Hb **10 g/dL**) vs Restrictivo\\N(Hb **<8 g/dL** + síntomas)","guid":"","children":[]},{"id":"51","parent":"49","text":"Mediana transfundida → Liberal:\\N2U vs Restrictivo: 0U","guid":"","children":[]},{"id":"52","parent":"49","text":"Outcome primario (muerte o\\Nincapacidad marcha 60d)","guid":"","children":[{"id":"53","parent":"52","text":"Liberal **35.2%** vs\\NRestrictivo **34.7%**","guid":"","children":[]},{"id":"54","parent":"52","text":"OR 1.01 (IC 95% 0.84-1.22)\\N→ **sin diferencia**","guid":"","children":[]}]},{"id":"55","parent":"49","text":"Mortalidad 60 días → 7.6% vs\\N6.6% (sin diferencia)","guid":"","children":[]},{"id":"56","parent":"49","text":"IAM hospitalario → posible beneficio\\Nliberal (RR 0.59, IC 0.36-0.96)","guid":"","children":[]}]},{"id":"57","parent":"48","text":"Revisión **Cochrane 2015** (6\\NRCTs, 2722 pacientes)","guid":"","children":[{"id":"58","parent":"57","text":"Sin diferencia mortalidad 30 días\\N→ RR 0.92 (IC 0.67-1.26)","guid":"","children":[]},{"id":"59","parent":"57","text":"Sin diferencia recuperación funcional 60\\Ndías → RR 1.00 (IC 0.87-1.15)","guid":"","children":[]},{"id":"60","parent":"57","text":"Sin diferencia TEP, ACV,\\Ninfección herida, neumonía","guid":"","children":[]},{"id":"61","parent":"57","text":"Calidad evidencia **baja**","guid":"","children":[]}]},{"id":"62","parent":"48","text":"Recomendación práctica","guid":"","children":[{"id":"63","parent":"62","text":"Umbral restrictivo **Hb <8 g/dL**\\No síntomas → preferido","guid":"","children":[]},{"id":"64","parent":"62","text":"No evidencia beneficio\\Numbral liberal 10 g/dL","guid":"","children":[]},{"id":"65","parent":"62","text":"Considerar síntomas → taquicardia,\\Nhipotensión, disnea, dolor torácico","guid":"","children":[]}]}]},{"id":"66","parent":"0","text":"Estrategias de\\NReducción de\\NTransfusión","guid":"","children":[{"id":"67","parent":"66","text":"Patient Blood Management (PBM)","guid":"","children":[{"id":"68","parent":"67","text":"Pilar 1 → Optimizar masa eritrocitaria","guid":"","children":[]},{"id":"69","parent":"67","text":"Pilar 2 → Minimizar sangrado","guid":"","children":[]},{"id":"70","parent":"67","text":"Pilar 3 → Optimizar\\Ntolerancia a anemia","guid":"","children":[]}]},{"id":"71","parent":"66","text":"Hierro Intravenoso","guid":"","children":[{"id":"72","parent":"71","text":"**Solo** → sin diferencia\\Nsignificativa en transfusión","guid":"","children":[]},{"id":"73","parent":"71","text":"Derisomaltosa férrica **20\\Nmg/kg** dosis única preop","guid":"","children":[]},{"id":"74","parent":"71","text":"Efectividad → solo en\\Ncombinación con TXA","guid":"","children":[]},{"id":"75","parent":"71","text":"Mantiene Hb más alta\\Ndía 30 (+0.42 g/dL)","guid":"","children":[]}]},{"id":"76","parent":"66","text":"Ácido Tranexámico (TXA)","guid":"","children":[{"id":"77","parent":"76","text":"**Solo** → sin diferencia\\Nsignificativa en transfusión","guid":"","children":[]},{"id":"78","parent":"76","text":"Reduce sangrado pero no\\Ntransfusión como monoterapia","guid":"","children":[]},{"id":"79","parent":"76","text":"Efecto sobre Hb → días 3-7,\\Npero se pierde día 30","guid":"","children":[]}]},{"id":"80","parent":"66","text":"**Combinación Hierro +\\NTXA** (Ensayo HiFIT)","guid":"","children":[{"id":"81","parent":"80","text":"Diseño factorial 2x2, doble ciego","guid":"","children":[]},{"id":"82","parent":"80","text":"Población → Hb **9.5-13\\Ng/dL** preoperatoria","guid":"","children":[]},{"id":"83","parent":"80","text":"Intervención combinada","guid":"","children":[{"id":"84","parent":"83","text":"Derisomaltosa férrica **20\\Nmg/kg** IV preop","guid":"","children":[]},{"id":"85","parent":"83","text":"TXA **1g bolo** + **1g\\Ninfusión 8h** preop","guid":"","children":[]},{"id":"86","parent":"83","text":"TXA **3g tópico** intraoperatorio","guid":"","children":[]}]},{"id":"87","parent":"80","text":"Resultado primario → Transfusión","guid":"","children":[{"id":"88","parent":"87","text":"Combinado **15%** vs\\NPlacebo **30%**","guid":"","children":[]},{"id":"89","parent":"87","text":"**RR 0.51** (IC 98.3% 0.\\N27-0.97, p=0.012)","guid":"","children":[]},{"id":"90","parent":"87","text":"→ **Reducción 50%**\\Nnecesidad transfusión","guid":"","children":[]}]},{"id":"91","parent":"80","text":"Hb día 30 → +0.62 g/dL vs\\Nplacebo (p=0.002)","guid":"","children":[]},{"id":"92","parent":"80","text":"Seguridad → sin ↑\\Neventos tromboembólicos","guid":"","children":[]},{"id":"93","parent":"80","text":"Subanálisis favorables","guid":"","children":[{"id":"94","parent":"93","text":"Sin anticoagulación crónica (RR 0.44)","guid":"","children":[]},{"id":"95","parent":"93","text":"Deficiencia hierro basal (RR 0.44)","guid":"","children":[]},{"id":"96","parent":"93","text":"Fractura intracapsular (RR 0.32)","guid":"","children":[]},{"id":"97","parent":"93","text":"Cirugía <48h (RR 0.48)","guid":"","children":[]}]}]},{"id":"98","parent":"66","text":"Protocolo coreano sin\\Ntransfusión (Hb <10 g/dL)","guid":"","children":[{"id":"99","parent":"98","text":"EPO **4000 U** 3 veces/semana","guid":"","children":[]},{"id":"100","parent":"98","text":"Hierro oral **100 mg** diario","guid":"","children":[]},{"id":"101","parent":"98","text":"Cell saver intraoperatorio","guid":"","children":[]},{"id":"102","parent":"98","text":"TXA intraoperatorio","guid":"","children":[]},{"id":"103","parent":"98","text":"Continuar hasta Hb **≥10 g/dL**","guid":"","children":[]},{"id":"104","parent":"98","text":"Resultado → 34 pacientes\\Noperados sin transfusión","guid":"","children":[]}]}]},{"id":"105","parent":"0","text":"Timing Quirúrgico y Anemia","guid":"","children":[{"id":"106","parent":"105","text":"Regla **24-48 horas** →\\Ncirugía dentro de este plazo","guid":"","children":[]},{"id":"107","parent":"105","text":"Retraso >48h","guid":"","children":[{"id":"108","parent":"107","text":"TEP asintomático **19%**\\Nen mayores 60 años","guid":"","children":[]},{"id":"109","parent":"107","text":"↑ Mortalidad","guid":"","children":[]},{"id":"110","parent":"107","text":"↑ Úlceras por presión","guid":"","children":[]},{"id":"111","parent":"107","text":"↑ Complicaciones médicas","guid":"","children":[]}]},{"id":"112","parent":"105","text":"Factores que\\N**requieren** corrección\\Npreop","guid":"","children":[{"id":"113","parent":"112","text":"Deshidratación","guid":"","children":[]},{"id":"114","parent":"112","text":"Anemia sintomática","guid":"","children":[]},{"id":"115","parent":"112","text":"Hipoxia","guid":"","children":[]},{"id":"116","parent":"112","text":"Alteraciones electrolíticas","guid":"","children":[]},{"id":"117","parent":"112","text":"Arritmias","guid":"","children":[]}]},{"id":"118","parent":"105","text":"Factores que **NO\\Nrequieren** corrección preop","guid":"","children":[{"id":"119","parent":"118","text":"Deterioro cognitivo","guid":"","children":[]},{"id":"120","parent":"118","text":"ICC crónica estable","guid":"","children":[]},{"id":"121","parent":"118","text":"ERC crónica","guid":"","children":[]}]}]},{"id":"122","parent":"0","text":"Evaluación Preoperatoria","guid":"","children":[{"id":"123","parent":"122","text":"Laboratorio obligatorio","guid":"","children":[{"id":"124","parent":"123","text":"Hemograma completo + plaquetas","guid":"","children":[]},{"id":"125","parent":"123","text":"INR/TP","guid":"","children":[]},{"id":"126","parent":"123","text":"Panel metabólico básico","guid":"","children":[]},{"id":"127","parent":"123","text":"Uroanálisis","guid":"","children":[]}]},{"id":"128","parent":"122","text":"Estudios opcionales según clínica","guid":"","children":[{"id":"129","parent":"128","text":"Ferritina, hierro sérico, TIBC","guid":"","children":[]},{"id":"130","parent":"128","text":"Vitamina B12, folato","guid":"","children":[]},{"id":"131","parent":"128","text":"Función renal","guid":"","children":[]},{"id":"132","parent":"128","text":"Calcio corregido →\\Nhipocalcemia ↑ sangrado","guid":"","children":[]}]},{"id":"133","parent":"122","text":"ECG → recomendación fuerte","guid":"","children":[]},{"id":"134","parent":"122","text":"Ecocardiograma → **NO** de rutina","guid":"","children":[]}]},{"id":"135","parent":"0","text":"Perlas Clínicas ⭐","guid":"","children":[{"id":"136","parent":"135","text":"Anemia preop Hb <10 g/dL predice peor\\Nfunción y calidad de vida a 6 meses","guid":"","children":[]},{"id":"137","parent":"135","text":"Umbral transfusión **Hb <8 g/dL +\\Nsíntomas** → sin desventaja vs liberal","guid":"","children":[]},{"id":"138","parent":"135","text":"**Monoterapia** hierro o TXA → NO reduce\\Ntransfusiones significativamente","guid":"","children":[]},{"id":"139","parent":"135","text":"**Combinación Hierro IV + TXA**\\N→ única estrategia con\\Nreducción 50% transfusión","guid":"","children":[]},{"id":"140","parent":"135","text":"Fractura subtrocantérica = mayor\\Nriesgo sangrado → OR 5.07","guid":"","children":[]},{"id":"141","parent":"135","text":"Hipocalcemia frecuente (~33%) →\\Nduplica tasa transfusión","guid":"","children":[]},{"id":"142","parent":"135","text":"No retrasar cirugía para \"optimizar\"\\Nanemia crónica estable","guid":"","children":[]},{"id":"143","parent":"135","text":"IAM perioperatorio → posible\\Nbeneficio umbral liberal (RR 0.59,\\Nevidencia muy baja)","guid":"","children":[]},{"id":"144","parent":"135","text":"HiFIT excluye Hb <9.5 g/dL →\\Nestos pacientes probablemente\\Nrequieran transfusión","guid":"","children":[]},{"id":"145","parent":"135","text":"Cell saver + EPO + hierro oral =\\Nalternativa en pacientes que\\Nrechazan transfusión","guid":"","children":[]}]}]},"node_count":156,"relations":[],"cross_references":[],"specialty":"Geriatría","folder":"Entidades clínicas/Ortogeriatría","filename":"Orto Anemia-2026","id":"map_1521","resolved_references":[],"title_raw":"Orto Anemia-2026"}