,{"id":"253","parent":"0","text":"ALGORITMO RESUMEN","guid":"QjV9SPbsS6KJnk1EjfmLAQ","children":[{"id":"254","parent":"253","text":"Sospecha HD → ABC, reanimación, laboratorio","guid":"kOjjYhLLQge_T1L0ydloSA","children":[]},{"id":"255","parent":"253","text":"Diferenciar HDA vs HDB (clínica, BUN/Cr, SNG)","guid":"q4540W1PTw-iqEj-viJXBA","children":[]},{"id":"256","parent":"253","text":"HDA → GBS/AIMS65 → EDA <24h (urgente si inestable)","guid":"y6RzGBZQRyaSJw-LsqDkBg","children":[{"id":"257","parent":"256","text":"Terapia endoscópica según hallazgo","guid":"4Yo1Q--LRcOYeIZZbfbWZw","children":[]},{"id":"258","parent":"256","text":"IBP IV alta dosis post-EDA","guid":"R10aB1zRTvKaiNZ5rw-q4Q","children":[]},{"id":"259","parent":"256","text":"Falla → angiografía/cirugía","guid":"qnFEN9ADSGq-KlueVZ8XCg","children":[]}]},{"id":"260","parent":"253","text":"HDB → Oakland score → colonoscopía si estable","guid":"Sl0xWJX1QiqtZ1YlXIZKKg","children":[{"id":"261","parent":"260","text":"Masiva → angio-TC → embolización/cirugía","guid":"kWha4Mu9TcCxchN8GY2WwQ","children":[]}]},{"id":"262","parent":"253","text":"En AM SIEMPRE","guid":"EnEuuea4S0G7aEu89BQBmQ","children":[{"id":"263","parent":"262","text":"Estrategia transfusional restrictiva","guid":"Uj9n21r7QTGv7QYy2A0GGA","children":[]},{"id":"264","parent":"262","text":"Evaluar polifarmacia (AINEs, anticoagulantes)","guid":"kawT7oFNRHm3zdNwwf0T_A","children":[]},{"id":"265","parent":"262","text":"Considerar fragilidad y proporcionalidad","guid":"sKoyXtKFSNGR266qPGishw","children":[]},{"id":"266","parent":"262","text":"Buscar neoplasia oculta si >50 años + anemia","guid":"q_wxbUBvTfuwZRQ42sw7YQ","children":[]}]}]},{"id":"267","parent":"0","text":"LR DIAGNOSTICOS","guid":"xyeo684zQgipLO7eZmsSDg","children":[{"id":"268","parent":"267","text":"HALLAZGOS CLINICOS (cabecera)","guid":"KJRUFEyfSX2QUz6X9pjLHQ","children":[{"id":"269","parent":"268","text":"Melena visualizada en tacto rectal -> LR+ 25 -> LR- NR -> PMID:22416103","guid":"le9PjtL5Qum0YMamrCLfog","children":[]},{"id":"270","parent":"268","text":"Aspirado NG con sangre o coffee ground -> LR+ 9.6 -> LR- 0.58 -> PMID:22416103","guid":"Hl1nyd9VRDCJs8FXOh6-LQ","children":[]},{"id":"271","parent":"268","text":"Melena reportada por paciente -> LR+ 5.1-5.9 -> LR- 0.73 -> PMID:22416103","guid":"DIPl_2CMTLqeJIAk2kpYpQ","children":[]},{"id":"272","parent":"268","text":"Coagulos sin sangre roja en tacto (hacia abajo) -> LR+ 0.35 -> PMID:22416103","guid":"EUYq9tPEQvudY0xl-1UoQQ","children":[]},{"id":"273","parent":"268","text":"Sangre roja fresca en tacto (DESCARTA HDA) -> LR+ 0.05 -> PMID:22416103","guid":"sHEX1ZmrSa-tgLmTRSdnnw","children":[]},{"id":"274","parent":"268","text":"Hematemesis franca -> [definitorio HDA]","guid":"Oc8BeKKhTwG2jks4aDiYow","children":[]}]},{"id":"275","parent":"267","text":"HALLAZGOS LABORATORIO","guid":"k5Kw6ReOSh-Qqtdvkdvhzg","children":[{"id":"276","parent":"275","text":"BUN/Creatinina ratio >=30 (mg/dL) -> LR+ 7.5 -> LR- 0.57 -> PMID:22416103","guid":"8v6F90xaQ2agy0zeoDUWdg","children":[]},{"id":"277","parent":"275","text":"BUN/Cr 20-30 -> LR+ ~2 -> LR- ~0.7 -> PMID:22416103","guid":"qQGC7B_wSQeSma3eyiDetA","children":[]},{"id":"278","parent":"275","text":"Hb <10 en sangrado agudo -> marcador severidad","guid":"tMJdbTqGRReKpwEJ4M3FmQ","children":[]}]},{"id":"279","parent":"267","text":"SCORE / REGLA CLINICA","guid":"izwE2262TVaQCZM0vka2Ug","children":[{"id":"280","parent":"279","text":"Glasgow-Blatchford Score 0 (DESCARTA necesidad intervencion) -> LR+ NR -> LR- 0.02 -> PMID:19091393","guid":"N_-MDrfkTmuLvAkT7WkDDQ","children":[]},{"id":"281","parent":"279","text":"Glasgow-Blatchford >=12 -> LR+ ~5 -> LR- NR -> PMID:19091393","guid":"q4lNTzWFRXucnjwIkevsOQ","children":[]},{"id":"282","parent":"279","text":"AIMS65 >=2 (mortalidad intrahospitalaria) -> LR+ 2.9 -> LR- 0.35 -> PMID:21907980","guid":"O8OCU79KTWWuHHdpW-LEgw","children":[]},{"id":"283","parent":"279","text":"Rockall pre-endoscopico >=3 -> LR+ ~3.5 -> LR- ~0.4 -> PMID:8675081","guid":"Z4qqVq7ST2O42yQSXkGkAw","children":[]}]},{"id":"284","parent":"267","text":"HALLAZGOS ENDOSCOPICOS (Forrest)","guid":"Txh5QtVrQhaVAGT2YlVzqw","children":[{"id":"285","parent":"284","text":"Forrest Ia (sangrado arterial activo) -> resangrado 55% sin tratamiento","guid":"WjSY0ModTkC1O0GqAWVwGw","children":[]},{"id":"286","parent":"284","text":"Forrest Ib (sangrado venoso activo) -> resangrado 22%","guid":"U_X1J_WqQiufyp58UnNWMg","children":[]},{"id":"287","parent":"284","text":"Forrest IIa (vaso visible) -> resangrado 43%","guid":"ckopjvSXSaSUmiV8L1iOfg","children":[]},{"id":"288","parent":"284","text":"Forrest IIb (coagulo adherido) -> resangrado 22%","guid":"0Uhf3vmhSHW-IAHJ8eZXNg","children":[]},{"id":"289","parent":"284","text":"Forrest IIc (mancha plana) -> resangrado 7%","guid":"WGuRxn_jTlmSzkAUeSS3jQ","children":[]},{"id":"290","parent":"284","text":"Forrest III (base limpia) -> resangrado 5%","guid":"JpReui1OTimXW1bJFx6vuw","children":[]}]},{"id":"291","parent":"267","text":"INTERPRETACION","guid":"E0Lvfu3yQW2vZIHhFW9nlw","children":[{"id":"292","parent":"291","text":"LR+ >10 o LR- <0.1 -> cambio GRANDE","guid":"VWz7MVYiTIyU24gG4ZcUaQ","children":[]},{"id":"293","parent":"291","text":"LR+ 5-10 o LR- 0.1-0.2 -> cambio MODERADO","guid":"N72IXuRaRk6bmw4rz53LhQ","children":[]}]},{"id":"294","parent":"267","text":"GERIATRIA","guid":"OiHIz2YjTw-FEqM1GXtX_A","children":[{"id":"295","parent":"294","text":"AM + AINEs/AAS + delirium + anemia -> sospechar HDA aun sin melena reportada","guid":"f6AnH_kYTiqIR9ZVIj9NwQ","children":[]},{"id":"296","parent":"294","text":"Tacto rectal OBLIGATORIO","guid":"Y3cvtzcIRzqj7rO5qObr8w","children":[]}]}]},{"id":"297","parent":"0","text":"Perlas Clinicas","guid":"AgblZqzuTeqvWzf4AjyyZQ","children":[{"id":"298","parent":"297","text":"Glasgow-Blatchford Score = 0-1 → manejo ambulatorio\\Nseguro en HDA no variceal (LR- 0.02).","guid":"WzAdQMZ7QP6CTWD3aEbl9g","children":[]},{"id":"299","parent":"297","text":"Forrest Ia/Ib/IIa requieren terapia endoscopica\\Ndual (inyeccion + termico/clip).","guid":"lv74fAimSNm0FPG1pgs_KA","children":[]},{"id":"300","parent":"297","text":"Transfusion restrictiva (Hb objetivo 7-8 g/dL)\\Nmejora supervivencia vs liberal en HDA\\N(TRIGGER trial NEJM 2013).","guid":"JbyYQCzEQZ6iE0FfpLv2pA","children":[]},{"id":"301","parent":"297","text":"IBP IV bolo + infusion (80 mg → 8 mg/h) reduce\\Nresangrado tras endoscopia en lesiones\\Nde alto riesgo (ACG 2021).","guid":"uPp1FJL2S4K0oTiQyPGrew","children":[]},{"id":"302","parent":"297","text":"Acido tranexamico NO se recomienda en HDA\\N(HALT-IT Lancet 2020: ↑ eventos tromboticos).","guid":"DhxhPDyoRmmfI-yzHimS6A","children":[]},{"id":"303","parent":"297","text":"Eritromicina 250 mg IV 30-90 min pre-endoscopia\\Nmejora visualizacion gastrica (ACG 2021).","guid":"_Xb_zmvNSEC9TtaEAkyqNQ","children":[]},{"id":"304","parent":"297","text":"Ceftriaxona 1g/d x 5-7d en HDA por varices\\No DHC: ↓ infecciones y mortalidad (Baveno VII).","guid":"NdPcuzjvTU20qPwE7r3Q0g","children":[]},{"id":"305","parent":"297","text":"Octreotide/terlipresina + endoscopia precoz\\N(<12 h) en HDA variceal (Baveno VII).","guid":"p7BkjWJoQxOJmQbEPqp3uA","children":[]},{"id":"306","parent":"297","text":"AM con AINE/AAS + delirium + anemia → sospechar\\NHDA aun sin melena reportada; tacto rectal SIEMPRE.","guid":"a9sMS68MRVKxiNpCBXBLPw","children":[]},{"id":"307","parent":"297","text":"HDB: TC angio mesenterica si rectorragia masiva\\Ny hemodinamia inestable (BSG 2019).","guid":"kkdymgyQT0i2fLKGpQEUrQ","children":[]},{"id":"308","parent":"297","text":"Anticoagulados con HDA: revertir si hemorragia\\Ngrave; reanudar tras 7-14d en alto riesgo trombotico.","guid":"yaRvLGwRQKqJLSisoqxspg","children":[]},{"id":"309","parent":"297","text":"Score Rockall ≥6 → mortalidad >10%, manejo en UCI.","guid":"RMXi4QbmS4-8uIGb77J64Q","children":[]},{"id":"310","parent":"297","text":"REFERENCIAS","guid":"m3ViGP3JT8aTZwwiCEiMZQ","children":[{"id":"311","parent":"310","text":"ACG 2021 Upper GI Bleeding Guidelines (Laine et al)","guid":"7j2HLLqNRZmzhmaiyYVN8w","children":[]},{"id":"312","parent":"310","text":"BSG 2019 Acute Lower GI Bleeding Guidelines","guid":"L6XdqQCzTDyEIIcYCUFXTA","children":[]},{"id":"313","parent":"310","text":"TRIGGER trial → transfusión restrictiva en HDA (Villanueva et al, NEJM 2013)","guid":"_sG8J3RsR_Knyzzv7xgUCg","children":[]},{"id":"314","parent":"310","text":"HALT-IT trial → ácido tranexámico en HDA (Lancet 2020)","guid":"HZeZvcNNQ-CGlFg9shppsQ","children":[]},{"id":"315","parent":"310","text":"Baveno VII → consenso hipertensión portal (de Franchis et al, J Hepatol 2022)","guid":"kxMg6y-uR4KLzcv4Ym7_xw","children":[]},{"id":"316","parent":"310","text":"International Consensus Upper GI Bleeding (Barkun et al, Ann Intern Med 2019)","guid":"bBkwM2-8SLiiZ4I-BQZKRA","children":[]},{"id":"317","parent":"310","text":"Minsal Chile → GPC Hemorragia Digestiva Alta 2013","guid":"68GrD-XOSV6LQ95ykCejEw","children":[]}]}]}]},"node_count":317,"relations":[],"cross_references":[],"specialty":"Geriatría","folder":"Entidades clínicas/Geriatría","filename":"Dolor-2026","id":"map_101","resolved_references":[]}