,"children":[]},{"id":"37","parent":"35","text":"Tumor del angulo pontocerebeloso","guid":"","children":[]},{"id":"38","parent":"35","text":"EVALUAR SIEMPRE con RM → descartar retrococlear","guid":"","children":[]}]},{"id":"39","parent":"18","text":"Otras causas\\Nidentificables","guid":"6sEIcYz8FmxBfMSILRzYKA","children":[{"id":"40","parent":"39","text":"Enfermedad de Meniere: forma de presentacion inicial","guid":"","children":[]},{"id":"41","parent":"39","text":"Sifilis otologica → VDRL/FTA-ABS","guid":"","children":[]},{"id":"42","parent":"39","text":"Hipoacusia subita bilateral → causas sistemicas (LES, vasculitis, linfoma)","guid":"","children":[]}]}]},{"id":"43","parent":"0","text":"Presentacion\\NClinica","guid":"iE89tXWQ5Ip-WCAM_YaJuQ","children":[{"id":"44","parent":"43","text":"Inicio subito → frecuentemente al despertar","guid":"","children":[]},{"id":"45","parent":"43","text":"Hipoacusia unilateral (>95%)","guid":"","children":[]},{"id":"46","parent":"43","text":"Sensacion de oido taponado o lleno","guid":"","children":[]},{"id":"47","parent":"43","text":"Tinnitus → presente en ~70% de casos","guid":"","children":[]},{"id":"48","parent":"43","text":"Vertigo o inestabilidad → presente en ~30% de casos","guid":"","children":[]},{"id":"49","parent":"43","text":"Factor pronostico NEGATIVO si vertigo acompana","guid":"","children":[]},{"id":"50","parent":"43","text":"Autofonia, hiperacusia","guid":"","children":[]},{"id":"51","parent":"43","text":"Sintomas neurologicos focales → ALERTA causa secundaria urgente","guid":"","children":[]}]},{"id":"52","parent":"0","text":"Factores\\NPronosticos","guid":"HUL1q_2wKL2s0osfBat0-Q","children":[{"id":"53","parent":"52","text":"Pronostico\\NFAVORABLE","guid":"um0ze3nv7Lqilk2oqBYIZg","children":[{"id":"54","parent":"53","text":"Hipoacusia moderada (perdida <60 dB)","guid":"","children":[]},{"id":"55","parent":"53","text":"Compromiso en frecuencias medias (configuracion U)","guid":"","children":[]},{"id":"56","parent":"53","text":"Ausencia de vertigo","guid":"","children":[]},{"id":"57","parent":"53","text":"Tratamiento precoz (< 7-14 dias del inicio)","guid":"","children":[]},{"id":"58","parent":"53","text":"Edad joven","guid":"","children":[]}]},{"id":"59","parent":"52","text":"Pronostico\\NDESFAVORABLE","guid":"JJ0rZ-uVHpJcQYKQOcYqog","children":[{"id":"60","parent":"59","text":"Hipoacusia profunda (perdida >90 dB)","guid":"","children":[]},{"id":"61","parent":"59","text":"Compromiso en frecuencias altas","guid":"","children":[]},{"id":"62","parent":"59","text":"VERTIGO asociado → factor de mayor impacto","guid":"","children":[]},{"id":"63","parent":"59","text":"Inicio tardio del tratamiento","guid":"","children":[]},{"id":"64","parent":"59","text":"Edad avanzada (relativo → estudio Zhang et al. no mostro diferencia)","guid":"","children":[]},{"id":"65","parent":"59","text":"Comorbilidades CV: DM, HTA","guid":"","children":[]}]}]},{"id":"66","parent":"0","text":"Diagnostico","guid":"","children":[{"id":"67","parent":"66","text":"Historia\\NClinica","guid":"epkMBsw-GBjTMPvQi8Xlig","children":[{"id":"68","parent":"67","text":"Inicio y evolucion temporal","guid":"","children":[]},{"id":"69","parent":"67","text":"Sintomas acompanantes: tinnitus, vertigo, otalgia","guid":"","children":[]},{"id":"70","parent":"67","text":"Antecedentes: trauma, barotrauma, esfuerzos","guid":"","children":[]},{"id":"71","parent":"67","text":"Medicamentos ototoxicos (aminoglucosidos, furosemida, cisplatino)","guid":"","children":[]},{"id":"72","parent":"67","text":"Enfermedades sistemicas: autoinmune, infecciosa, CV, oncologica","guid":"","children":[]},{"id":"73","parent":"67","text":"Viajes recientes, exposicion a ruido","guid":"","children":[]}]},{"id":"74","parent":"66","text":"Examen\\NFisico","guid":"zHuUeaiEP9Z8VB3iVoo5cQ","children":[{"id":"75","parent":"74","text":"Otoscopia → descartar causa conductiva (cera, OMA, perforacion)","guid":"","children":[]},{"id":"76","parent":"74","text":"Pruebas de diapason:\\NWeber y Rinne","guid":"9ErCc5A0ydV5WS0rs8mVyw","children":[{"id":"77","parent":"76","text":"Weber lateraliza al OIDO SANO en HSNS","guid":"","children":[]},{"id":"78","parent":"76","text":"Rinne positivo bilateral (CA > CO) en HSNS","guid":"","children":[]}]},{"id":"79","parent":"74","text":"Examen neurologico: pares craneales, nistasmo, coordinacion","guid":"iHKvKp3JrdtY1Y4MguKwrQ","children":[]},{"id":"80","parent":"74","text":"Palpacion de parotida, ganglios cervicales","guid":"","children":[]}]},{"id":"81","parent":"66","text":"Audiometria Tonal\\N(URGENTE)","guid":"T-WoASxjx9xs5lejZ-mYbw","children":[{"id":"82","parent":"81","text":"Confirmar HSNS vs hipoacusia conductiva","guid":"","children":[]},{"id":"83","parent":"81","text":"REALIZAR dentro de 14 dias del inicio (guia AAO-HNS)","guid":"","children":[]},{"id":"84","parent":"81","text":"Patron: caida neurosensorial unilateral","guid":"","children":[]},{"id":"85","parent":"81","text":"Umbral basal para seguimiento postratamiento","guid":"","children":[]}]},{"id":"86","parent":"66","text":"Examenes\\NComplementarios","guid":"sjtHBmlgaoXrV_H2DiP7Og","children":[{"id":"87","parent":"86","text":"NO solicitar hemograma/bioquimica de rutina → evidencia no avala","guid":"","children":[]},{"id":"88","parent":"86","text":"NO solicitar TAC craneal de rutina → no util en evaluacion inicial","guid":"","children":[]},{"id":"89","parent":"86","text":"SOLICITAR RM con gadolinio →\\Ndescartar neurinoma\\Nacustico/patologia retrococlear","guid":"Jnpuqpxtq_HvmCNibN_VAw","children":[{"id":"90","parent":"89","text":"RM o TAC si RM contraindicada","guid":"","children":[]},{"id":"91","parent":"89","text":"Potenciales evocados auditivos (BERA) como alternativa","guid":"","children":[]}]},{"id":"92","parent":"86","text":"Estudios dirigidos segun\\Nsospecha clinica","guid":"l4Et3I6puTctn-n5ceKjGw","children":[{"id":"93","parent":"92","text":"VDRL/FTA-ABS si sospecha sifilis","guid":"","children":[]},{"id":"94","parent":"92","text":"ANA, ANCA si sospecha autoinmune","guid":"","children":[]},{"id":"95","parent":"92","text":"Hemograma si sospecha hematologica o infecciosa","guid":"","children":[]}]}]}]},{"id":"96","parent":"0","text":"Tratamiento","guid":"","children":[{"id":"97","parent":"96","text":"Ventana\\NTerapeutica","guid":"nuDldYgkHZO0fYlWW1v-3w","children":[{"id":"98","parent":"97","text":"OPTIMA: dentro de 7-14 dias del inicio de sintomas","guid":"","children":[]},{"id":"99","parent":"97","text":"SALVAGE (rescate): hasta 2-6 semanas del inicio","guid":"","children":[]},{"id":"100","parent":"97","text":"Tratamiento tardio (>1 mes): escasa evidencia de beneficio","guid":"","children":[]}]},{"id":"101","parent":"96","text":"Corticoides Sistemicos\\N(PRIMERA LINEA)","guid":"FK3ufNiAcoqGCbsYSmAB8Q","children":[{"id":"102","parent":"101","text":"Opcion de tratamiento en <= 2 semanas del inicio","guid":"","children":[]},{"id":"103","parent":"101","text":"Prednisona/prednisolona: 1 mg/kg/dia (max 60 mg/dia) x 7-14 dias + tapering","guid":"","children":[]},{"id":"104","parent":"101","text":"Metilprednisolona EV: en hospitalizados o disfagia","guid":"","children":[]},{"id":"105","parent":"101","text":"Mecanismo: antiinflamatorio + inmunosupresor en cocleas inflamadas","guid":"","children":[]},{"id":"106","parent":"101","text":"Controversia: estudios con limitaciones metodologicas → falta ECA definitivo","guid":"","children":[]},{"id":"107","parent":"101","text":"Consideraciones\\Nen adulto mayor","guid":"NWCWoSQws2S9xDJj5PKASw","children":[{"id":"108","parent":"107","text":"Diabetes: controlar glicemia → corticoides elevan glicemia","guid":"","children":[]},{"id":"109","parent":"107","text":"Osteoporosis: ciclos cortos menos riesgosos","guid":"","children":[]},{"id":"110","parent":"107","text":"HTA: monitorizar PA","guid":"","children":[]},{"id":"111","parent":"107","text":"Infeccion activa: CONTRAINDICACION relativa","guid":"","children":[]},{"id":"112","parent":"107","text":"Delirium: riesgo aumentado con dosis altas en fragilidad","guid":"","children":[]}]}]},{"id":"113","parent":"96","text":"Corticoides\\NIntratimpanicos\\N(IT)","guid":"elebKKD2Gbdjv5hVxE--Bw","children":[{"id":"114","parent":"113","text":"Primera linea (alternativa) O terapia de rescate","guid":"","children":[]},{"id":"115","parent":"113","text":"Indicacion primaria: OPCION dentro de 2 semanas","guid":"","children":[]},{"id":"116","parent":"113","text":"Indicacion RESCATE: recuperacion incompleta 2-6 semanas post inicio","guid":"","children":[]},{"id":"117","parent":"113","text":"Dexametasona 24 mg/mL o 10-24 mg/mL → inyeccion IT 0.3-0.5 mL","guid":"","children":[]},{"id":"118","parent":"113","text":"Metilprednisolona 40 mg/mL","guid":"","children":[]},{"id":"119","parent":"113","text":"Frecuencia: 1-4 inyecciones semanales","guid":"","children":[]},{"id":"120","parent":"113","text":"VENTAJA en adulto mayor: evita efectos sistemicos de corticoides","guid":"","children":[]},{"id":"121","parent":"113","text":"Estudio Chrysouli 2023: IT + sistemicos SUPERIOR a cada uno por separado","guid":"","children":[]},{"id":"122","parent":"113","text":"Resultados IT vs oral: comparables en tratamiento primario","guid":"","children":[]},{"id":"123","parent":"113","text":"Procedimiento realizabel en consulta → importante en fragil/comorbilidades","guid":"","children":[]}]},{"id":"124","parent":"96","text":"Terapia Combinada\\N(Sistemica + IT)","guid":"TR-jlp5NBtuEraKCzN7uuA","children":[{"id":"125","parent":"124","text":"Probablemente superior a monoterapia (evidencia creciente)","guid":"","children":[]},{"id":"126","parent":"124","text":"Considerar en hipoacusia severa/profunda inicial","guid":"","children":[]},{"id":"127","parent":"124","text":"Protocolo: corticoides orales desde dia 1 + IT desde dia 1-7","guid":"","children":[]}]},{"id":"128","parent":"96","text":"Oxigeno\\NHiperbarico\\N(OHB)","guid":"_zc8zc7nYfzfsTRlMCqlYQ","children":[{"id":"129","parent":"128","text":"OPCION (no recomendacion fuerte) combinado con corticoides","guid":"","children":[]},{"id":"130","parent":"128","text":"Dentro de 2 semanas como terapia inicial","guid":"","children":[]},{"id":"131","parent":"128","text":"Dentro de 1 mes como terapia de rescate","guid":"","children":[]},{"id":"132","parent":"128","text":"Mecanismo: aumento de PO2 en endolinfa","guid":"","children":[]},{"id":"133","parent":"128","text":"Limitaciones: acceso, costo, contraindicaciones (EPOC, claustrofobia)","guid":"","children":[]}]},{"id":"134","parent":"96","text":"NO RECOMENDADOS\\N(guia AAO-HNS 2019)","guid":"O7T2XkgBeTIOvY-p4gPTuA","children":[{"id":"135","parent":"134","text":"Antivirales de rutina (aciclovir, valaciclovir)","guid":"","children":[{"id":"136","parent":"135","text":"EXCEPCION: Sd. Ramsay Hunt → aciclovir EV urgente","guid":"","children":[]}]},{"id":"137","parent":"134","text":"Trombooliticos, vasodilatadores, sustancias vasoactivas","guid":"","children":[]},{"id":"138","parent":"134","text":"Diureticos de rutina","guid":"","children":[]}]},{"id":"139","parent":"96","text":"Rehabilitacion\\NAuditiva","guid":"jBqWoAbgQIYiweHK80ziDw","children":[{"id":"140","parent":"139","text":"Indicar si persiste hipoacusia residual","guid":"","children":[]},{"id":"141","parent":"139","text":"Audiofonos: mejoran comunicacion y calidad de vida","guid":"","children":[]},{"id":"142","parent":"139","text":"En adulto mayor con HSNS + presbiacusia preexistente: audifono URGENTE","guid":"","children":[]},{"id":"143","parent":"139","text":"Implante coclear: considerar si HSNS lleva a hipoacusia profunda bilateral","guid":"","children":[]}]}]},{"id":"144","parent":"0","text":"Seguimiento","guid":"","children":[{"id":"145","parent":"144","text":"Audiometria al finalizar tratamiento","guid":"","children":[]},{"id":"146","parent":"144","text":"Audiometria adicional dentro de 6 meses post-tratamiento","guid":"","children":[]},{"id":"147","parent":"144","text":"Evaluar tinnitus residual → terapia sonora, 