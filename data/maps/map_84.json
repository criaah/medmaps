ren":[]},{"id":"18","parent":"11","text":"Infecciones","guid":"","children":[]}]},{"id":"19","parent":"0","text":"Complicaciones\\Ngraves","guid":"XZi_XPsSbMdIqijQAS-Icw","children":[{"id":"20","parent":"19","text":"\\\\*Lesión renal aguda que requiere diálisis\\\\*","guid":"52xRHcBtlb9TdSZbjSkAsA","children":[]},{"id":"21","parent":"19","text":"\\\\*Paro cardíaco\\\\*","guid":"3L7tsKBcXamOJCpqjfKvsA","children":[]},{"id":"22","parent":"19","text":"\\\\*Coagulación intravascular diseminada\\\\*","guid":"8rZ2bNVnkT5YPrscPKk7BA","children":[]}]},{"id":"23","parent":"0","text":"Valoración","guid":"","children":[]},{"id":"24","parent":"0","text":"Presentación\\Nclínica","guid":"9lu5-pqVyt_cPbCdvP3W0g","children":[{"id":"25","parent":"24","text":"Variable","guid":"kod0-tvyM-COOgfwTn0PaA","children":[{"id":"26","parent":"25","text":"\\\\*Desde mialgias leves hasta lesiones\\Nrenales agudas graves\\\\*","guid":"YyZRqLOngtJ8F0b3255Itg","children":[]}]},{"id":"27","parent":"24","text":"Diagnóstico\\Nsospechoso","guid":"MaVMuA-chpHJ8uSJQyJkbg","children":[{"id":"28","parent":"27","text":"Factores de\\Nriesgo conocidos","guid":"TpHswYblsGITVmMsQzw6kw","children":[]},{"id":"29","parent":"27","text":"\"Tríada\\Nclásica\"","guid":"z9XPg4LcPmx0GyHdPpGpJw","children":[{"id":"30","parent":"29","text":"Dolor muscular (que va de leve a grave)","guid":"YH76jxPr6UdmOThv4KutWg","children":[]},{"id":"31","parent":"29","text":"Debilidad e hinchazón de los músculos lesionados","guid":"rPBdbG_04-OIgjY3LXxdbA","children":[]},{"id":"32","parent":"29","text":"Orina de color té\\N(mioglobinuria)","guid":"HhJHPN3ITtYO5ZQY-CFPAg","children":[{"id":"33","parent":"32","text":"Rosa, marrón rojizo\\No negra","guid":"","children":[]}]}]}]}]},{"id":"34","parent":"0","text":"Diagnóstico ","guid":"w3dXFk6Xv-yf-T9HvZzhmw","children":[{"id":"35","parent":"34","text":"Niveles elevados de creatina\\Nquinasa (CK) en suero","guid":"ffNVkaZfHEXT8lVX5Emf0g","children":[{"id":"36","parent":"35","text":"500-1.000 unidades/L","guid":"","children":[]}]},{"id":"37","parent":"34","text":"Niveles séricos\\Nde mioglobina","guid":"j_HVqdJAYSpl1i8F85OIpg","children":[{"id":"38","parent":"37","text":"Resulta en falsos negativos","guid":"uPMUDfTCgfjGmdEU2VQbDA","children":[]},{"id":"39","parent":"37","text":"No tan sensibles como la CK","guid":"STnVPRkxaUHob7iEyVV9GA","children":[]},{"id":"40","parent":"37","text":"Corta vida media","guid":"--I5EAlGKkHJYs85Hw_Bbw","children":[]}]}]},{"id":"41","parent":"0","text":"Estudio\\Ncomplementario","guid":"46XpP67_g51cLkdyuRRqHg","children":[{"id":"42","parent":"41","text":"Sangre","guid":"m82FWdNtoLPWYPRnAwDyDw","children":[{"id":"43","parent":"42","text":"Creatinina sérica","guid":"J6F0fIPFpzkSanQcHj5qxw","children":[]},{"id":"44","parent":"42","text":"Electrolitos (incluidos potasio, calcio, fosfato)","guid":"_e_wv6e73EriFRLXxJATaw","children":[]},{"id":"45","parent":"42","text":"Ácido úrico","guid":"Ly9fZH8dYBdppZVo51SuNA","children":[]},{"id":"46","parent":"42","text":"Pruebas de función hepática","guid":"A-0O0b5fiR9ddvZjYj3G4A","children":[]}]},{"id":"47","parent":"41","text":"Test de\\Norina","guid":"DW-76UecTJ3B9QSIVEuZvg","children":[{"id":"48","parent":"47","text":"Orina positiva para la sangre en ausencia de hematuria\\Nsignificativa sugiere mioglobinuria o hemoglobinuria","guid":"mMIywXLQJ0SphIw8I5bxIA","children":[]}]},{"id":"49","parent":"41","text":"Orina","guid":"b58ScHHH7Pu6dIw7ElHVdw","children":[{"id":"50","parent":"49","text":"Proteína","guid":"5Ad7dPq2U4oQwsNvnjqzzQ","children":[]},{"id":"51","parent":"49","text":"Cilindros  pigmentados marrones","guid":"8wpjeabux7yCjlKkRRtj4Q","children":[]},{"id":"52","parent":"49","text":"Cristales de ácido úrico","guid":"joEi7jQbN-030fUhr-ovUw","children":[]},{"id":"53","parent":"49","text":"Hematuria","guid":"OkzCSasVbtR766BZrQ-Ncw","children":[]}]},{"id":"54","parent":"41","text":"EKG","guid":"N3H3KBEm8KFH9qwNVv9qYA","children":[{"id":"55","parent":"54","text":"Controlar las arritmias cardíacas debidas a\\Ndesequilibrios electrolíticos","guid":"UCakQtZaMpMNPLmKj6dN4w","children":[]}]}]},{"id":"56","parent":"0","text":"Manejo","guid":"","children":[{"id":"57","parent":"56","text":"Tratamiento de la causa subyacente.","guid":"dxwbemzb77GFfZhMaH9L9w","children":[]},{"id":"58","parent":"56","text":"Comience con líquidos intravenosos\\Ntempranos y agresivos","guid":"ZC3qFNJh-qjDWOLKFxIaAA","children":[{"id":"59","parent":"58","text":"Tasa ideal de\\Nadministración","guid":"6XrIf8_RSbEUv2G8gxwFaA","children":[{"id":"60","parent":"59","text":"No está establecida","guid":"_SnBPQ1Vy9ihoHw_TwOd4w","children":[]},{"id":"61","parent":"59","text":"Depende de la gravedad de la rabdomiolisis","guid":"DnVZqmAquCfFM4nLMqFgQQ","children":[]}]},{"id":"62","parent":"58","text":"Considere iniciar la terapia a una velocidad de 400 ml/hora con un objetivo\\Nterapéutico de producción de orina de 1-3 ml/kg/hora, y hasta 300 ml/hora.","guid":"MTOm26NGh9b5cl6NL5tczg","children":[]},{"id":"63","parent":"58","text":"Los líquidos intravenosos necesitan una titulación cuidadosa en\\Nfunción del estado del volumen y la producción de orina","guid":"PGxFrNCVlupMWzl2rj222Q","children":[]}]},{"id":"64","parent":"56","text":"No utilice la alcalinización de la orina con bicarbonato\\Nde sodio o terapia diurética ","guid":"Q3I09DRms89SZaf98xE_Wg","children":[{"id":"65","parent":"64","text":"Sin embargo, el uso de estos medicamentos puede seguir siendo apropiado en\\Npacientes con complicaciones como sobrecarga de volumen y acidosis sistémica.","guid":"BArJJC3FJavyiMC-QbVMKQ","children":[]}]},{"id":"66","parent":"56","text":"Potasio ","guid":"","children":[{"id":"67","parent":"66","text":"Compruebe el nivel de potasio sérico cada 4 horas si el nivel de creatina\\Nquinasa (CK) es > 60.000 unidades/L o si se sospecha que hay toxicidad.","guid":"MDp8CNi8ut0I-_DamgYoHA","children":[]},{"id":"68","parent":"66","text":"Los niveles de potasio se pueden reducir transitoriamente\\Ncon insulina intravenosa más glucosa y otras estrategias.","guid":"aG4J2Pvz1F5Jsg7bY_2dNQ","children":[]},{"id":"69","parent":"66","text":"Si el nivel de potasio es > 6 mEq/L (6 mmol/L) en el contexto de\\Nlesión renal aguda, considere la terapia de reemplazo renal","guid":"5QPT8tWHWVk8R3DWd8Ci6g","children":[]}]},{"id":"70","parent":"56","text":"Considere la supervisión cardíaca y\\Nla admisión en una unidad de\\Ncuidados intensivos (UCI) si:","guid":"SV7K2P799bBR0d0pHQCZYg","children":[{"id":"71","parent":"70","text":"El nivel de potasio sérico es\\N> 6 mEq/L (6 mmol/L)","guid":"vtoj400fcihenWzJbTfPYw","children":[]},{"id":"72","parent":"70","text":"Anomalías en el electrocardiograma\\N(ECG)","guid":"xCvohzyyOEUQoIV_9sOlUw","children":[]},{"id":"73","parent":"70","text":"Niveles de potasio que aumentan rápidamente","guid":"lFlDXn_Ir4bStgvl58bswQ","children":[]}]},{"id":"74","parent":"56","text":"Cálcio","guid":"R1Auxb2aRC1J7YCwYoLp2A","children":[{"id":"75","parent":"74","text":"Solo considere la corrección de la hipocalcemia si es sintomática (tetánica, convulsiones)\\No hiperpotasemia concomitante con cambios significativos en el ECG.","guid":"TGWTRnpKOgfLdnjPd7IwBQ","children":[]}]},{"id":"76","parent":"56","text":"Diálisis de urgencia\\NAEIOU","guid":"","children":[{"id":"77","parent":"76","text":"Comience la terapia de reemplazo renal si hay una incapacidad para\\Ncorregir la sobrecarga de volumen, la acidosis o hiperpotasemia","guid":"tLX-rbcbgMW8V0-DVomzMw","children":[]}]}]}]},"node_count":77,"relations":[],"cross_references":[],"specialty":"General","folder":"Entidades clínicas","filename":"- Rabdomiolisis","id":"map_84","resolved_references":[],"title_raw":"- Rabdomiolisis"}