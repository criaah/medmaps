{"title":"SindromesApexOrbitario","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Entidades clínicas/General/SindromesApexOrbitario iPad.smmx","root":{"id":"0","parent":"-1","text":"Sindromes del Apex\\NOrbitario","guid":"4HfyJZ06RFcw5lTJ_2Ms1Q","children":[{"id":"1","parent":"0","text":"Anatomia del\\NApex Orbitario","guid":"31Cn6cBjyddN_1pQ-ouseg","children":[{"id":"2","parent":"1","text":"Canal\\Noptico","guid":"4MHlYBlkBQ6tAu8OShq88Q","children":[{"id":"3","parent":"2","text":"Nervio optico (II NC)","guid":"","children":[]},{"id":"4","parent":"2","text":"Arteria oftalmica","guid":"","children":[]}]},{"id":"5","parent":"1","text":"Fisura orbitaria\\Nsuperior (FOS)","guid":"9zRLI0WjNYpZdb00TPHR7A","children":[{"id":"6","parent":"5","text":"NC III (oculomotor) → division superior e inferior","guid":"","children":[]},{"id":"7","parent":"5","text":"NC IV (troclear)","guid":"","children":[]},{"id":"8","parent":"5","text":"NC VI (abducens) → LIBRE dentro del seno cavernoso","guid":"","children":[]},{"id":"9","parent":"5","text":"NC V1 (oftalmico del trigemino)","guid":"","children":[]},{"id":"10","parent":"5","text":"Vena oftalmica superior","guid":"","children":[]}]},{"id":"11","parent":"1","text":"Seno\\Ncavernoso","guid":"t-EPqgbX4Y9uQ7KHVdP1RA","children":[{"id":"12","parent":"11","text":"Pared lateral → NC III, IV, V1, V2","guid":"","children":[]},{"id":"13","parent":"11","text":"Interior → NC VI + arteria carotida interna","guid":"","children":[]},{"id":"14","parent":"11","text":"SIN VALVAS → permite propagacion bilateral","guid":"","children":[]},{"id":"15","parent":"11","text":"Senos intercavernosos → comunicacion derecha-izquierda","guid":"","children":[]}]},{"id":"16","parent":"1","text":"Anillo de Zinn → origen musculos extraoculares","guid":"","children":[]}]},{"id":"17","parent":"0","text":"Clasificacion\\Nde Sindromes","guid":"Oa53ITEIwqTTkN8wPnKSpg","children":[{"id":"18","parent":"17","text":"Sindrome del\\NApex Orbitario\\N(Jacod)","guid":"-bVzoLjcgEh0nnKJ2Qc8vg","children":[{"id":"19","parent":"18","text":"FOS + canal optico afectados","guid":"","children":[]},{"id":"20","parent":"18","text":"COMPROMISO OPTICO → diferenciador clave","guid":"","children":[]},{"id":"21","parent":"18","text":"NC II + III + IV + V1 + VI","guid":"","children":[]},{"id":"22","parent":"18","text":"Discromatopsia, perdida visual + oftalmoplegia","guid":"","children":[]}]},{"id":"23","parent":"17","text":"Sindrome de la Fisura\\NOrbitaria Superior\\N(Rochon-Duvigneaud)","guid":"-H7gk0E0mK4XycRbhYCz8A","children":[{"id":"24","parent":"23","text":"Solo FOS afectada","guid":"","children":[]},{"id":"25","parent":"23","text":"NC III + IV + V1 + VI","guid":"","children":[]},{"id":"26","parent":"23","text":"SIN compromiso optico","guid":"","children":[]},{"id":"27","parent":"23","text":"Oftalmoplegia + hipoestesia V1","guid":"","children":[]}]},{"id":"28","parent":"17","text":"Sindrome del\\NSeno Cavernoso","guid":"_D6wCgIGu6DWx6reJUYHtw","children":[{"id":"29","parent":"28","text":"NC III + IV + V1 + V2 + VI","guid":"","children":[]},{"id":"30","parent":"28","text":"Sindrome de Horner por afeccion simpatica pericarotidea","guid":"","children":[]},{"id":"31","parent":"28","text":"Proptosis por congestion venosa","guid":"","children":[]},{"id":"32","parent":"28","text":"BILATERALIZACION en 24-48h → PATOGNOMONICO de trombosis","guid":"","children":[]}]}]},{"id":"33","parent":"0","text":"Etiologia","guid":"","children":[{"id":"34","parent":"33","text":"INFECCIOSA","guid":"","children":[{"id":"35","parent":"34","text":"Sinusitis esfenoidal/etmoidal → >50% de TSC septica","guid":"","children":[]},{"id":"36","parent":"34","text":"Infeccion dental →\\N<10% pero alta\\Nmorbimortalidad","guid":"Bcvguuew8iP46MJf0T49uA","children":[{"id":"37","parent":"36","text":"Via pterigoidea → espacio bucal/pterigomandibular → plexo pterigoideo → seno cavernoso","guid":"","children":[]},{"id":"38","parent":"36","text":"Extraccion dental como puerta de entrada","guid":"","children":[]},{"id":"39","parent":"36","text":"Triangulo peligroso de la cara → angulos boca a puente nasal","guid":"","children":[]}]},{"id":"40","parent":"34","text":"Celulitis orbitaria","guid":"","children":[]},{"id":"41","parent":"34","text":"Mucormicosis rinocerebral\\N→ DIABETICOS,\\NINMUNOSUPRIMIDOS","guid":"VTCp0Ld_Kvlaaiw6Lz71_A","children":[{"id":"42","parent":"41","text":"Aspergillus y Mucor → angioinvasivos","guid":"","children":[]},{"id":"43","parent":"41","text":"Mortalidad alta aun con tratamiento","guid":"","children":[]}]},{"id":"44","parent":"34","text":"Herpes zoster oftalmico → inmunocomprometidos","guid":"","children":[]},{"id":"45","parent":"34","text":"Bacteriemia hematogena","guid":"","children":[]},{"id":"46","parent":"34","text":"Patogenos → S. aureus (70%), Streptococcus, anaerobios (odontogenico)","guid":"","children":[]}]},{"id":"47","parent":"33","text":"INFLAMATORIA","guid":"","children":[{"id":"48","parent":"47","text":"Sindrome de Tolosa-Hunt →\\Ngranuloma idiopatico","guid":"IalZSmb-QDFjQ-gEQ1zE8g","children":[{"id":"49","parent":"48","text":"Dolor retroorbitario + oftalmoplegia","guid":"","children":[]},{"id":"50","parent":"48","text":"RESPONDE A CORTICOIDES → criterio diagnostico","guid":"","children":[]},{"id":"51","parent":"48","text":"Puede recidivar","guid":"","children":[]},{"id":"52","parent":"48","text":"ICHD-3 → criterios diagnosticos","guid":"","children":[]}]},{"id":"53","parent":"47","text":"Pseudotumor orbitario (inflamacion orbitaria idiopatica)","guid":"","children":[]},{"id":"54","parent":"47","text":"Sarcoidosis → granulomas no caseificantes","guid":"","children":[]},{"id":"55","parent":"47","text":"Granulomatosis con poliangeitis (Wegener)","guid":"","children":[]},{"id":"56","parent":"47","text":"Enfermedad relacionada a IgG4","guid":"","children":[]},{"id":"57","parent":"47","text":"Oftalmopatia tiroidea → descompresion del apex","guid":"","children":[]}]},{"id":"58","parent":"33","text":"NEOPLASICA →\\Ncausa mas frecuente\\Nde SAO en general\\N(55%)","guid":"5N1fs7amOznkJyvzx2Lpkw","children":[{"id":"59","parent":"58","text":"Tumores cabeza y cuello con extension local","guid":"","children":[]},{"id":"60","parent":"58","text":"Linfoma → sindrome compartimental","guid":"","children":[]},{"id":"61","parent":"58","text":"Meningioma del ala del esfenoides","guid":"","children":[]},{"id":"62","parent":"58","text":"Metastasis (pulmon, mama, prostata)","guid":"","children":[]},{"id":"63","parent":"58","text":"Adenoma hipofisario con extension lateral","guid":"","children":[]}]},{"id":"64","parent":"33","text":"VASCULAR","guid":"","children":[{"id":"65","parent":"64","text":"Trombosis del seno cavernoso (TSC)","guid":"","children":[{"id":"66","parent":"65","text":"Septica → URGENCIA con mortalidad 20-30%","guid":"","children":[]},{"id":"67","parent":"65","text":"Aseptica → trombofilia, embarazo, ACO","guid":"","children":[]}]},{"id":"68","parent":"64","text":"Fistula carotido-cavernosa","guid":"","children":[]},{"id":"69","parent":"64","text":"Aneurisma de carotida intracavernosa","guid":"HAsGj8OI5Z6SFKelELDsIg","children":[]},{"id":"70","parent":"64","text":"Aneurisma de comunicante posterior → comprime III NC","guid":"","children":[]}]},{"id":"71","parent":"33","text":"TRAUMATICA/IATROGENICA","guid":"","children":[{"id":"72","parent":"71","text":"Fractura del apex orbitario","guid":"","children":[]},{"id":"73","parent":"71","text":"Cirugia endoscopica sinusal","guid":"","children":[]},{"id":"74","parent":"71","text":"Bloqueo anestesico del nervio ASP → plexo pterigoideo","guid":"","children":[]}]}]},{"id":"75","parent":"0","text":"Enfoque Diagnostico","guid":"","children":[{"id":"76","parent":"75","text":"Historia clinica\\NDIRIGIDA","guid":"FQl_eQGVjdNa_INorX2adQ","children":[{"id":"77","parent":"76","text":"Foco infeccioso previo → dental, sinusal, otico, cutaneo","guid":"","children":[]},{"id":"78","parent":"76","text":"Temporalidad → agudo (infeccion/vascular) vs subagudo (inflamatorio) vs cronico (neoplasia)","guid":"","children":[]},{"id":"79","parent":"76","text":"Inmunosupresion → DM, VIH, quimioterapia, trasplante","guid":"","children":[]},{"id":"80","parent":"76","text":"Sintomas constitucionales → fiebre, sudoracion nocturna, baja de peso","guid":"","children":[]},{"id":"81","parent":"76","text":"Dolor → presente en infeccion e inflamacion, variable en neoplasia","guid":"","children":[]}]},{"id":"82","parent":"75","text":"Examen neurologico\\Nsistematico","guid":"vfS7PuAnPaiBJbTKmhiHXQ","children":[{"id":"83","parent":"82","text":"Agudeza visual + campimetria confrontacional","guid":"","children":[]},{"id":"84","parent":"82","text":"DISCROMATOPSIA → test de Ishihara → nervio optico","guid":"","children":[]},{"id":"85","parent":"82","text":"Reflejo fotomotor directo y consensual","guid":"","children":[]},{"id":"86","parent":"82","text":"DEFECTO PUPILAR AFERENTE RELATIVO (DPAR/Marcus Gunn) → nervio optico","guid":"","children":[]},{"id":"87","parent":"82","text":"Motilidad ocular en 9 posiciones","guid":"","children":[]},{"id":"88","parent":"82","text":"Ptosis → III NC (elevador del parpado)","guid":"","children":[]},{"id":"89","parent":"82","text":"Sensibilidad facial V1-V2-V3","guid":"","children":[]},{"id":"90","parent":"82","text":"Fondo de ojo → papila, bordes, hemorragias, congestion venosa","guid":"","children":[]},{"id":"91","parent":"82","text":"Proptosis → medicion con exoftalmometro de Hertel","guid":"","children":[]},{"id":"92","parent":"82","text":"HIT → evalua via vestibular (VIII NC)","guid":"","children":[]}]},{"id":"93","parent":"75","text":"Laboratorio","guid":"","children":[{"id":"94","parent":"93","text":"Hemograma + PCR/VHS → infeccion, inflamacion","guid":"","children":[]},{"id":"95","parent":"93","text":"Hemocultivos (2 sets) → TSC septica","guid":"","children":[]},{"id":"96","parent":"93","text":"Coagulacion + D-dimero","guid":"","children":[]},{"id":"97","parent":"93","text":"Perfil tiroideo → oftalmopatia de Graves","guid":"","children":[]},{"id":"98","parent":"93","text":"ANCA → vasculitis","guid":"","children":[]},{"id":"99","parent":"93","text":"ECA (enzima convertidora de angiotensina) → sarcoidosis","guid":"","children":[]},{"id":"100","parent":"93","text":"IgG4 serico","guid":"","children":[]},{"id":"101","parent":"93","text":"VIH, glucosa, HbA1c → inmunosupresion","guid":"","children":[]},{"id":"102","parent":"93","text":"Puncion lumbar → si sospecha meningitis o linfoma","guid":"","children":[]}]},{"id":"103","parent":"75","text":"Neuroimagen →\\NMANDATORIA","guid":"IFI7AcYWfkHDyTaMH5LsTA","children":[{"id":"104","parent":"103","text":"RM cerebro y orbitas\\NCON GADOLINIO →\\Ngold standard","guid":"Q3blbTibCHdmoMIzbEQnXA","children":[{"id":"105","parent":"104","text":"Secuencias T1, T2, FLAIR, difusion","guid":"","children":[]},{"id":"106","parent":"104","text":"Supresion grasa → ideal para apex orbitario y seno cavernoso","guid":"","children":[]},{"id":"107","parent":"104","text":"Venografia RM → TSC","guid":"","children":[]}]},{"id":"108","parent":"103","text":"TC cerebro y\\Norbitas con\\Ncontraste","guid":"F5fmWTTfF9sysVDcMCsbGA","children":[{"id":"109","parent":"108","text":"Util en trauma, evaluacion osea","guid":"","children":[]},{"id":"110","parent":"108","text":"Defectos de llenado en seno cavernoso","guid":"","children":[]},{"id":"111","parent":"108","text":"Dilatacion vena oftalmica superior → signo indirecto","guid":"","children":[]}]},{"id":"112","parent":"103","text":"Angiografia → fistula carotido-cavernosa (DSA gold standard)","guid":"","children":[]}]},{"id":"113","parent":"75","text":"Biopsia → si imagen no concluyente o sospecha neoplasia","guid":"","children":[]}]},{"id":"114","parent":"0","text":"Diagnostico Diferencial\\Npor Patron Clinico","guid":"huZykgs-N_DsMa0IZSZjbg","children":[{"id":"115","parent":"114","text":"III NC aislado +\\Npupila comprometida","guid":"QzIPfZCndR1mwsd3EsHHYg","children":[{"id":"116","parent":"115","text":"Aneurisma de comunicante posterior → EMERGENCIA","guid":"","children":[]},{"id":"117","parent":"115","text":"Herniacion uncal","guid":"","children":[]},{"id":"118","parent":"115","text":"TSC temprana","guid":"","children":[]}]},{"id":"119","parent":"114","text":"III NC + nervio optico\\N(DPAR + discromatopsia)","guid":"N853x2OoK0LOsDiApb9HSQ","children":[{"id":"120","parent":"119","text":"SINDROME DEL APEX ORBITARIO","guid":"","children":[]},{"id":"121","parent":"119","text":"Invasion tumoral","guid":"","children":[]},{"id":"122","parent":"119","text":"Mucormicosis","guid":"","children":[]}]},{"id":"123","parent":"114","text":"Oftalmoplegia\\Ndolorosa","guid":"yHfaF3-sVq-s6iJIx8FJBg","children":[{"id":"124","parent":"123","text":"Tolosa-Hunt","guid":"","children":[]},{"id":"125","parent":"123","text":"TSC septica","guid":"","children":[]},{"id":"126","parent":"123","text":"Herpes zoster oftalmico","guid":"","children":[]}]},{"id":"127","parent":"114","text":"Bilateral\\Ncon fiebre","guid":"UoePur6f1G6soK_31MexAw","children":[{"id":"128","parent":"127","text":"TSC septica → bilateralizacion en 24-48h","guid":"","children":[]},{"id":"129","parent":"127","text":"Mucormicosis avanzada","guid":"","children":[]},{"id":"130","parent":"127","text":"Trombosis venosa cerebral","guid":"","children":[]}]}]},{"id":"131","parent":"0","text":"Manejo","guid":"","children":[{"id":"132","parent":"131","text":"INFECCIOSO","guid":"","children":[{"id":"133","parent":"132","text":"ATB empiricos IV → nafcilina/oxacilina + ceftriaxona + metronidazol","guid":"","children":[{"id":"134","parent":"133","text":"Si sospecha SAMR → vancomicina 1g c/12h IV","guid":"","children":[]},{"id":"135","parent":"133","text":"Anaerobios → metronidazol 500mg c/8h (odontogenico/sinusal)","guid":"","children":[]},{"id":"136","parent":"133","text":"Duracion 3-4 semanas minimo","guid":"","children":[]}]},{"id":"137","parent":"132","text":"Antifungicos → mucormicosis/aspergillosis","guid":"","children":[{"id":"138","parent":"137","text":"Anfotericina B liposomal → primera linea","guid":"","children":[]},{"id":"139","parent":"137","text":"Posaconazol, isavuconazol → alternativas","guid":"","children":[]}]},{"id":"140","parent":"132","text":"Anticoagulacion → CONTROVERSIAL en TSC septica","guid":"","children":[{"id":"141","parent":"140","text":"Enoxaparina SC → puede reducir morbilidad si inicio precoz (5-7 dias)","guid":"","children":[]},{"id":"142","parent":"140","text":"Evidencia limitada → sin RCTs","guid":"","children":[]}]},{"id":"143","parent":"132","text":"Drenaje quirurgico","guid":"","children":[{"id":"144","parent":"143","text":"Sinusitis subyacente sin respuesta ATB 24h","guid":"","children":[]},{"id":"145","parent":"143","text":"Absceso dental → extraccion pieza + drenaje","guid":"","children":[]},{"id":"146","parent":"143","text":"Debridamiento en mucormicosis (incluye exenteracion)","guid":"","children":[]}]}]},{"id":"147","parent":"131","text":"INFLAMATORIO","guid":"","children":[{"id":"148","parent":"147","text":"Corticoides sistemicos → primera linea","guid":"","children":[{"id":"149","parent":"148","text":"Metilprednisolona 1g IV x 3 dias (pulsos)","guid":"","children":[]},{"id":"150","parent":"148","text":"Luego prednisona 1 mg/kg VO con descenso lento","guid":"","children":[]},{"id":"151","parent":"148","text":"RESPUESTA A CTC → sugiere Tolosa-Hunt (criterio diagnostico)","guid":"","children":[]}]},{"id":"152","parent":"147","text":"Si NO responde a CTC → repetir imagen + biopsia","guid":"","children":[]},{"id":"153","parent":"147","text":"Inmunosupresores → azatioprina, micofenolato en refractarios","guid":"","children":[]}]},{"id":"154","parent":"131","text":"NEOPLASICO","guid":"","children":[{"id":"155","parent":"154","text":"Segun histologia → cirugia, QT, RT","guid":"","children":[]},{"id":"156","parent":"154","text":"Radioterapia estereotaxica para meningiomas","guid":"","children":[]}]},{"id":"157","parent":"131","text":"VASCULAR","guid":"","children":[{"id":"158","parent":"157","text":"Fistula CC → embolizacion endovascular","guid":"","children":[]},{"id":"159","parent":"157","text":"Aneurisma → clipaje o coiling","guid":"","children":[]}]},{"id":"160","parent":"131","text":"CORTICOIDES COMO COADYUVANTE","guid":"","children":[{"id":"161","parent":"160","text":"Dexametasona 10mg IV c/6h → disfuncion de NC en TSC","guid":"","children":[]},{"id":"162","parent":"160","text":"PRECAUCION → no usar si no se ha descartado infeccion fungica","guid":"","children":[]}]}]},{"id":"163","parent":"0","text":"Pronostico","guid":"","children":[{"id":"164","parent":"163","text":"TSC septica → mortalidad 20-30% con ATB","guid":"","children":[]},{"id":"165","parent":"163","text":"Neoplasico → peor pronostico visual (p=0.035)","guid":"","children":[]},{"id":"166","parent":"163","text":"Inflamatorio → mejor pronostico con CTC","guid":"","children":[]},{"id":"167","parent":"163","text":"Visual → 37% mejoria tras tratamiento (serie 73 pacientes)","guid":"","children":[]},{"id":"168","parent":"163","text":"Secuelas residuales frecuentes → estrabismo, neuropatia V, ceguera","guid":"","children":[]},{"id":"169","parent":"163","text":"DPAR persistente → mal pronostico de recuperacion visual","guid":"","children":[]}]},{"id":"170","parent":"0","text":"CORRELACION\\NCASO CLINICO","guid":"9Ly-6XfqXBjJxcMVutHr5A","children":[{"id":"171","parent":"170","text":"Hombre 75a, HTA, AAA operado","guid":"","children":[]},{"id":"172","parent":"170","text":"Infeccion dental en China (3 sem) → extraccion incisivo Q2, sin ATB","guid":"","children":[]},{"id":"173","parent":"170","text":"Evolucion → cefalea frontal izq, sudoracion nocturna, diploplia","guid":"","children":[]},{"id":"174","parent":"170","text":"Hallazgos\\Noftalmologicos","guid":"JwUIB2QBfWJ9al-PHC92JQ","children":[{"id":"175","parent":"174","text":"Ptosis palpebral izquierda → III NC","guid":"","children":[]},{"id":"176","parent":"174","text":"Reflejo fotomotor OI hiporreactivo → III NC/parasimpatico","guid":"","children":[]},{"id":"177","parent":"174","text":"DPAR izquierdo → nervio optico afectado","guid":"","children":[]},{"id":"178","parent":"174","text":"Discromatopsia OI → nervio optico","guid":"","children":[]},{"id":"179","parent":"174","text":"Fondo de ojo normal → sin papiledema","guid":"","children":[]}]},{"id":"180","parent":"170","text":"HINTS → HIT (+), nistagmo (-), skew (-)","guid":"","children":[]},{"id":"181","parent":"170","text":"TC cerebro CLC 31/03 → reportado normal","guid":"","children":[]},{"id":"182","parent":"170","text":"DIAGNOSTICO DE TRABAJO → Sindrome del apex orbitario izquierdo","guid":"","children":[{"id":"183","parent":"182","text":"III NC + nervio optico = APEX, no solo FOS","guid":"","children":[]},{"id":"184","parent":"182","text":"Etiologia probable → extension infeccion odontogenica","guid":"","children":[]}]},{"id":"185","parent":"170","text":"CONDUCTA\\NURGENTE","guid":"sdD3qPsDl3AGD9jJ-mzAUg","children":[{"id":"186","parent":"185","text":"RM cerebro/orbitas con gadolinio + supresion grasa","guid":"","children":[]},{"id":"187","parent":"185","text":"Venografia RM → descartar TSC","guid":"","children":[]},{"id":"188","parent":"185","text":"Hemocultivos + hemograma + PCR + VHS","guid":"","children":[]},{"id":"189","parent":"185","text":"Evaluacion neurologica urgente","guid":"","children":[]},{"id":"190","parent":"185","text":"Considerar ATB empiricos si confirmacion imagenologica","guid":"","children":[]}]}]},{"id":"191","parent":"0","text":"Perlas Clinicas","guid":"","children":[{"id":"192","parent":"191","text":"DISCROMATOPSIA diferencia apex orbitario de fisura orbitaria superior","guid":"","children":[]},{"id":"193","parent":"191","text":"DPAR = compromiso nervio optico = APEX orbitario, NO solo FOS","guid":"","children":[]},{"id":"194","parent":"191","text":"TSC dental <10% pero mortalidad 20-30% → no subestimar foco dental","guid":"","children":[]},{"id":"195","parent":"191","text":"VI NC es el PRIMERO afectado en TSC (libre dentro del seno)","guid":"","children":[]},{"id":"196","parent":"191","text":"Bilateralizacion en 24-48h es PATOGNOMONICO de TSC","guid":"","children":[]},{"id":"197","parent":"191","text":"CTC en sospecha infecciosa puede EMPEORAR mucormicosis","guid":"","children":[]},{"id":"198","parent":"191","text":"TC normal NO descarta TSC temprana → RM con gadolinio es gold standard","guid":"","children":[]},{"id":"199","parent":"191","text":"Infeccion dental puede propagarse via plexo pterigoideo al seno cavernoso","guid":"","children":[]},{"id":"200","parent":"191","text":"En AM → considerar inmunosenescencia como factor de riesgo para TSC","guid":"","children":[]},{"id":"201","parent":"191","text":"Respuesta a CTC sugiere Tolosa-Hunt pero NUNCA iniciar sin descartar infeccion/neoplasia","guid":"","children":[]},{"id":"202","parent":"191","text":"HIT (+) en este contexto → probable falso positivo o componente vestibular asociado","guid":"","children":[]}]},{"id":"203","parent":"0","text":"Referencias","guid":"","children":[{"id":"204","parent":"203","text":"1. Yeh S, Foroozan R. Orbital apex syndrome. Curr Opin Ophthalmol. 2004;15(6):490-498.","guid":"","children":[]},{"id":"205","parent":"203","text":"2. Goyal P, Lee S, Gupta N, et al. Orbital apex disorders: imaging findings and management. Neuroradiol J. 2018;31(2):104-125.","guid":"","children":[]},{"id":"206","parent":"203","text":"3. Badakere A, Patil-Chhablani P. Orbital Apex Syndrome: A Review. Eye Brain. 2019;11:63-72.","guid":"","children":[]},{"id":"207","parent":"203","text":"4. StatPearls. Orbital Apex Syndrome. 2023.","guid":"","children":[]},{"id":"208","parent":"203","text":"5. Lee YC, Shao SC, Lee KL. Orbital Apex Syndrome: A Case Series. Front Med. 2022;9:845411.","guid":"","children":[]},{"id":"209","parent":"203","text":"6. Caranfa JT, Yoon MK. Septic cavernous sinus thrombosis: A review. Surv Ophthalmol. 2021;66(6):1021-1030.","guid":"","children":[]},{"id":"210","parent":"203","text":"7. Park JG, et al. Cavernous sinus thrombosis caused by a dental infection. J Korean Assoc Oral Maxillofac Surg. 2014;40:195-198.","guid":"","children":[]},{"id":"211","parent":"203","text":"8. Misra UK, Kalita J, Bansal V. Bilateral cavernous sinus thrombosis and facial palsy from dental abscess. Natl J Maxillofac Surg. 2013;3:124.","guid":"","children":[]},{"id":"212","parent":"203","text":"9. StatPearls. Cavernous Sinus Thrombosis. 2023.","guid":"","children":[]},{"id":"213","parent":"203","text":"10. Kline LB, Hoyt WF. The Tolosa-Hunt syndrome. J Neurol Neurosurg Psychiatry. 2001;71(5):577-582.","guid":"","children":[]}]}]},"node_count":213,"relations":[],"cross_references":[],"specialty":"General","folder":"Entidades clínicas/General","filename":"SindromesApexOrbitario iPad","id":"map_865","resolved_references":[],"title_raw":"SindromesApexOrbitario iPad"}