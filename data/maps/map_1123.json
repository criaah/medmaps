lG06XBhq5nBi1j8eUNA","children":[{"id":"55","parent":"54","text":"Bencilpenicilina\\N(Penicilina G)","guid":"dVQqm1kpYcbfG0p-W4lZPg","children":[]},{"id":"56","parent":"54","text":"• Penicilina VK","guid":"mYvDqdZ69IUurKFUxTceNw","children":[]}]},{"id":"57","parent":"0","text":"Aminopenicilinas","guid":"yg8MbUmaJgSKiVlBCSYGFw","children":[{"id":"58","parent":"57","text":"1. Agentes:","guid":"","children":[{"id":"59","parent":"58","text":"• Ampicilina (IV y oral).","guid":"KiD6eA-HJS2Ulp5sekG7OQ","children":[]},{"id":"60","parent":"58","text":"• Amoxicilina (oral).","guid":"8ot-gvkWJ-Zya_t9O4YgwA","children":[]}]},{"id":"61","parent":"57","text":"2. Ventajas de Amoxicilina\\Nsobre Ampicilina oral:","guid":"","children":[{"id":"62","parent":"61","text":"• ↑ Absorción gastrointestinal.","guid":"dO1tzWKSbTYamVsafppQvw","children":[]},{"id":"63","parent":"61","text":"• ↓ Incidencia de diarrea.","guid":"E_sSVVNftOtQDkc57ZM9QQ","children":[]},{"id":"64","parent":"61","text":"• Dosificación: 3 veces/día vs 4 veces/día.","guid":"a7yWtL1ia5R0Ufl_bP5hww","children":[]}]},{"id":"65","parent":"57","text":"3. Espectro de\\Nactividad:","guid":"Sd800cggCZqisgMv0paS1g","children":[{"id":"66","parent":"65","text":"• Gram (+):","guid":"uSSLSN89Q4S2VhU2uv9tiA","children":[{"id":"67","parent":"66","text":"• Amplía el espectro de las penicilinas naturales.","guid":"-lPhqrqx6XjKtpdsYg0ctQ","children":[]}]},{"id":"68","parent":"65","text":"• Gram (-):","guid":"QO5ucunim33G5roWuzoBEQ","children":[{"id":"69","parent":"68","text":"• E. coli.","guid":"HjM56s9o5IcT0RI8DidJSA","children":[]},{"id":"70","parent":"68","text":"• Proteus mirabilis.","guid":"YjOP0Ep87kw2NXcDpR-WfA","children":[]},{"id":"71","parent":"68","text":"• Salmonella.","guid":"4ik-0ZeidLEer5_pPYLYFg","children":[]},{"id":"72","parent":"68","text":"• Shigella (amoxicilina < ampicilina).","guid":"7YzsO3Vs6mN_jfVJ9bB_xg","children":[]},{"id":"73","parent":"68","text":"• Haemophilus influenzae (60%-70% si no produce β-lactamasa).","guid":"Owb61UlXrGVUMEsEUNn0MQ","children":[]},{"id":"74","parent":"68","text":"• Moraxella catarrhalis (<20% si no produce β-lactamasa).","guid":"jthf8MvNT2e_F_uUPADVYw","children":[]}]},{"id":"75","parent":"65","text":"• Mecanismos de\\Nresistencia:","guid":"QXxiRDktJtjSMWakn08PYQ","children":[{"id":"76","parent":"75","text":"• Producción de β-lactamasa.","guid":"KWTOuuiKEz9-m1d5wR8jxg","children":[]},{"id":"77","parent":"75","text":"• Alteración en las proteínas de unión a penicilina (PBP).","guid":"Djlo5b_21KHIM2k85AS7EQ","children":[]}]}]},{"id":"78","parent":"57","text":"4. Farmacocinética:","guid":"","children":[{"id":"79","parent":"78","text":"• Similares a las penicilinas naturales.","guid":"jYeLYcBGO6diHLSvnQ5Iyw","children":[]},{"id":"80","parent":"78","text":"• Vida media corta.","guid":"0XOePgA-WahMv6ADzP04tw","children":[]},{"id":"81","parent":"78","text":"• Eliminación renal.","guid":"IFzWEYu7hGIqbTwx2N0JSg","children":[]}]},{"id":"82","parent":"57","text":"5. Usos\\Nclínicos:","guid":"CCxmylTLA7ArQCIs8MVqCQ","children":[{"id":"83","parent":"82","text":"• Otitis media causada por S. pneumoniae o H. influenzae\\N(β-lactamasa negativo).","guid":"mppZ9PshwGrvmFN0ZQexQg","children":[]},{"id":"84","parent":"82","text":"• Infecciones por enterococos susceptibles.","guid":"krGxN-LF1KbvzW8WMR62Jw","children":[]},{"id":"85","parent":"82","text":"• Profilaxis de endocarditis en procedimientos GI o GU.","guid":"Qi6GcSwcYGaRvfFX_yXOeQ","children":[]},{"id":"86","parent":"82","text":"• Meningitis por Listeria (ampicilina IV).","guid":"UmvJhOT55Kk7pWN9eHqMwA","children":[]},{"id":"87","parent":"82","text":"• Infecciones por E. coli susceptibles (↑ resistencia → ya no son elección empírica en ITU).","guid":"MvmgPK0nmhWcAf1AbcLszA","children":[]}]},{"id":"88","parent":"57","text":"6. Agentes de\\Nprimera línea:","guid":"","children":[{"id":"89","parent":"88","text":"• Tratamiento de otitis media.","guid":"qv0X4VB8mulMQqXy1OkBig","children":[]},{"id":"90","parent":"88","text":"• Infecciones enterocócicas susceptibles.","guid":"qWllXINmL6dubN7QKfNgNQ","children":[]},{"id":"91","parent":"88","text":"• Meningitis por Listeria.","guid":"d0R1JToFrbMcwq2080DbGA","children":[]}]}]},{"id":"92","parent":"0","text":"Penicilinas antipseudomonas","guid":"CXjXWwtrM56CCXhMl4tKRA","children":[{"id":"93","parent":"92","text":"1. Agentes:","guid":"4vaM6B2BseVcGFHWE8r4Tw","children":[{"id":"94","parent":"93","text":"• Carboxipenicilinas:","guid":"DRJXStebD9A7tHxN9YuEqg","children":[{"id":"95","parent":"94","text":"• Carbenicilina.","guid":"LJbwFMHthWCIqL7w6RYrzA","children":[]},{"id":"96","parent":"94","text":"• Ticarcilina.","guid":"U6TDGlDDAfvQ-FZDi8pXNQ","children":[]}]},{"id":"97","parent":"93","text":"• Ureidopenicilina:","guid":"Id95DugEiGgWMpo15O6bLw","children":[{"id":"98","parent":"97","text":"• Piperacilina.","guid":"-Y9LDefwfSReMhBx1RHKaw","children":[{"id":"99","parent":"98","text":"• Piperacilina-tazobactam\\N(Zosyn, Tazocin)","guid":"ikRsRS6t28Isanc4-hYLdw","children":[]}]}]}]},{"id":"100","parent":"92","text":"2. Espectro\\Nde actividad:","guid":"L2aPyyuQcAyJEOWapGtSiA","children":[{"id":"101","parent":"100","text":"• Carboxipenicilinas:","guid":"uMxeoe8LW4X9QbjAj0W0FA","children":[{"id":"102","parent":"101","text":"• Gram (-): espectro ampliado comparado con ampicilina.","guid":"Uc_JdPCmFs_BW6y013T1ew","children":[]},{"id":"103","parent":"101","text":"• Pseudomonas aeruginosa (uso combinado con aminoglucósido o ciprofloxacino).","guid":"7mRoB3UbW-QvQNl8lmIEvw","children":[]},{"id":"104","parent":"101","text":"• Poca actividad contra estafilococos, estreptococos.","guid":"zwncSSenx0xxZJqrLhvC4g","children":[]},{"id":"105","parent":"101","text":"• Casi sin actividad contra enterococos o Klebsiella spp.","guid":"qUcJrfpRsQfL4Y_f-BnQDw","children":[{"id":"106","parent":"105","text":"Hidrolizada por β-lactamasas de Enterobacterales","guid":"BzBX4KS0tlc9dcnQsnt4uQ","children":[]}]}]},{"id":"107","parent":"100","text":"• Piperacilina:","guid":"tD76g8LcMMJCCTT1iQ_BfA","children":[{"id":"108","parent":"107","text":"• Gram (-): amplio espectro, incluyendo Klebsiella, Enterobacteriaceae, y Pseudomonas aeruginosa.","guid":"a41-tER8oU5_eUgnnhiZtg","children":[]},{"id":"109","parent":"107","text":"• ↑ actividad que carbenicilina y ticarcilina contra Enterobacteriaceae y Bacteroides fragilis.","guid":"f4bUvcWddtQ8uzjAUDmPIQ","children":[]},{"id":"110","parent":"107","text":"• ↓ actividad que penicilina G y ampicilina contra estreptococos y enterococos.","guid":"iLqhIqomDjmdAf3BJqLWRA","children":[]},{"id":"111","parent":"107","text":"• Pseudomonas aeruginosa (dosis alta, combinar con aminoglucósido o ciprofloxacino en infecciones graves).","guid":"0rSfpIsstg0uDNo86i38VA","children":[]}]}]},{"id":"112","parent":"92","text":"3. Farmacocinética:","guid":"_XayZFtQoiuAioKWpRRkpQ","children":[{"id":"113","parent":"112","text":"• Eliminación renal, ajuste en IR.","guid":"wh0otiW45_pc2_vY6uFkFg","children":[]},{"id":"114","parent":"112","text":"• Vida media corta → administración frecuente.","guid":"ICQJU8yjLIgHUigyVhLAmw","children":[]}]},{"id":"115","parent":"92","text":"4. Usos\\Nclínicos:","guid":"_hKn3UAAnZdrJ8VjEMIjzg","children":[{"id":"116","parent":"115","text":"• Infecciones polimicrobianas y nosocomiales por Gram (-).","guid":"V3SRTgLyEYBX44nuGL1Xqw","children":[]},{"id":"117","parent":"115","text":"• Carboxipenicilinas:","guid":"XgHKm6bhj0aUAEYcmKRtXQ","children":[{"id":"118","parent":"117","text":"• Mejor actividad Gram (-) que penicilinas naturales o aminopenicilinas.","guid":"kqCF8IKLiiPxxjO5XZsz7g","children":[]},{"id":"119","parent":"117","text":"• Limitada utilidad contra Gram (+), enterococos, Klebsiella spp.","guid":"lOy8BNfbGkd9pSSL0aj9ZQ","children":[]}]},{"id":"120","parent":"115","text":"• Piperacilina:","guid":"uY7EVMMxh8HmUfq68Qjs8A","children":[{"id":"121","parent":"120","text":"• Infecciones por Gram (-), incluyendo Klebsiella y Enterobacteriaceae.","guid":"po3QGwYxNqLw_v-h1dAusg","children":[]},{"id":"122","parent":"120","text":"• Actividad anaerobia contra Bacteroides fragilis.","guid":"prHbpkRCtp9WZkS6wSzRzw","children":[]},{"id":"123","parent":"120","text":"• Utilizada en combinación para infecciones graves por Pseudomonas y Enterobacter.","guid":"-lw22kHANcVIy6RoJFovAQ","children":[]}]}]}]},{"id":"124","parent":"0","text":"Penicilinas antiestafilocócicas","guid":"-d2e9RwAs0NBWjCpCdSpzw","children":[{"id":"125","parent":"124","text":"1. Agentes:","guid":"P4bkG6EcHcPE47-3Qupz9A","children":[{"id":"126","parent":"125","text":"• Oxacilina (IV).","guid":"u5Llf273EpSTuAapJCjRUA","children":[]},{"id":"127","parent":"125","text":"• Nafcilina (IV).","guid":"3cQK32-878XFKtN12IGm_w","children":[]},{"id":"128","parent":"125","text":"• Dicloxacilina (oral).","guid":"DrkMGFS2kmuuJ0XskGKrnw","children":[]},{"id":"129","parent":"125","text":"• Cloxacilina (oral).","guid":"U-5JvJtKHaCGo-tCJ-_YFQ","children":[]}]},{"id":"130","parent":"124","text":"2. Espectro de\\Nactividad:","guid":"4lv30aEN53DOkeR7ohJV-w","children":[{"id":"131","parent":"130","text":"• Estreptococcus grupo A.","guid":"7kv1ruhBTwcTjUHF4uyOuA","children":[]},{"id":"132","parent":"130","text":"• Staphylococcus aureus susceptible a meticilina (MSSA).","guid":"yF7bbGO40ht9lZ7J2NSvbQ","children":[]},{"id":"133","parent":"130","text":"• No activos contra:","guid":"SD2b4cPm5z-ovXsqGta6ow","children":[{"id":"134","parent":"133","text":"• Gram (-).","guid":"O6hg8z7ZPedv9RpgMBUEbA","children":[]},{"id":"135","parent":"133","text":"• Enterococos.","guid":"HhfGl_u6WuCmv7DTRCOQ5w","children":[]},{"id":"136","parent":"133","text":"• Anaerobios.","guid":"MvGQDO4Gp-SFSBcHybYswg","children":[]}]}]},{"id":"137","parent":"124","text":"3. Farmacocinética:","guid":"k9XXoymtOVye1SFzp2vjyQ","children":[{"id":"138","parent":"137","text":"• Eliminación:","guid":"DJR-pEz_Sbau-RAArIfFPQ","children":[{"id":"139","parent":"138","text":"• No renal (únicas penicilinas con esta característica).","guid":"MivWxqOxIrMWDAPLM6EnGw","children":[]},{"id":"140","parent":"138","text":"• Nafcilina: eliminación hepatobiliar → no requiere ajuste en IR.","guid":"kU7Vfy512F8oLvygZGDy4A","children":[]}]},{"id":"141","parent":"137","text":"• Vida media corta → administración frecuente o infusión continua.","guid":"HKdgesfQA9j-o5rcEzy8Dg","children":[]},{"id":"142","parent":"137","text":"• Penetración SNC en presencia de inflamación (IV).","guid":"3wY0FUMZRLafZORWGXd-XQ","children":[]}]},{"id":"143","parent":"124","text":"4. Usos\\Nclínicos:","guid":"lQwnlLICfTy0leVvIEMVnw","children":[{"id":"144","parent":"143","text":"• Infecciones de piel y\\Ntejidos blandos:","guid":"GJQ4OqMNMhl-SqGDnW-qZg","children":[{"id":"145","parent":"144","text":"• Buena actividad contra estreptococos grupo A y MSSA.","guid":"4yPBebSyfmd7p8WirJ0uQg","children":[]},{"id":"146","parent":"144","text":"• Infecciones graves por MSSA (ej. bacteriemia, endocarditis).","guid":"xZJswKhNnM5rN-LKWy4S8Q","children":[]},{"id":"147","parent":"144","text":"• Más activos que vancomicina en este contexto.","guid":"3fEFyibe7upH213JztEhcA","children":[]}]}]},{"id":"148","parent":"124","text":"5. Agentes de\\Nelección:","guid":"XNRe4rjbERMDGv5yjnIeMA","children":[{"id":"149","parent":"148","text":"• Infecciones por estreptococos grupo A y MSSA.","guid":"s6H9meFd6Uh181KUEI4mAw","children":[]},{"id":"150","parent":"148","text":"• Infecciones de piel y tejidos blandos por estos patógenos.","guid":"EiNhoJYmc3N_Tj_iMNbrUg","children":[]},{"id":"151","parent":"148","text":"• Infecciones graves por MSSA (ej. endocarditis).","guid":"V-7wtqEtTlvivzHo4MM5Iw","children":[]}]}]},{"id":"152","parent":"0","text":"Inhibidores de\\Nβ-Lactamasa","guid":"ZDmVWg2ZAykKuy5dGEUZ5w","children":[{"id":"153","parent":"152","text":"1. Agentes:","guid":"","children":[{"id":"154","parent":"153","text":"• Amoxicilina-clavulanato","guid":"Qr-YFZEJ7xgM2T24YEdjGA","children":[]},{"id":"155","parent":"153","text":"• Ampicilina-sulbactam (Unasyn)","guid":"pW7glCaCWqFAeFbta6aWFA","children":[]},{"id":"156","parent":"153","text":"• Ticarcilina-clavulanato (Timentin).","guid":"Yj0FxgNKHQSWsddThzckaA","children":[]},{"id":"157","parent":"153","text":"• Piperacilina-tazobactam (Zosyn).","guid":"_CkoH5uMGFy0CXq3zjuZZQ","children":[]}]},{"id":"158","parent":"152","text":"2. Espectro de\\Nactividad:","guid":"BWsb02UI2tkDg3FjJOB64Q","children":[{"id":"159","parent":"158","text":"• Mejorado con la adición del\\Ninhibidor de β-lactamasa:","guid":"9munfijgkg4yId-NorKs0w","children":[{"id":"160","parent":"159","text":"• S. aureus (meticilina-sensible).","guid":"lSByLh_Y86owMA-tNrE-zg","children":[]},{"id":"161","parent":"159","text":"• Bacteroides fragilis.","guid":"VP6xFM_Kgg1FMDG7BgU7Uw","children":[]},{"id":"162","parent":"159","text":"• Klebsiella pneumoniae (la mayoría de cepas).","guid":"GLczYV7udr05oDSqcWfkFA","children":[]},{"id":"163","parent":"159","text":"• H. influenzae.","guid":"ndy_vagotBzlGylJhmFGww","children":[]},{"id":"164","parent":"159","text":"• M. catarrhalis.","guid":"a856vS4Eg5l6j0cJJa2aGw","children":[]}]},{"id":"165","parent":"158","text":"• No activos contra:","guid":"4aFt6I9u3lSJ_IL8tuhNEw","children":[{"id":"166","parent":"165","text":"• S. aureus resistente a meticilina (MRSA).","guid":"SuG6wnZRbttyARHN51eF_A","children":[]},{"id":"167","parent":"165","text":"• No afecta actividad contra la mayoría de\\Ncepas de Pseudomonas o Enterobacter.","guid":"1KJl7M3RfSPd4f-eeYizhA","children":[]}]}]},{"id":"168","parent":"152","text":"3. Usos clínicos:","guid":"","children":[{"id":"169","parent":"168","text":"• Amoxicilina-clavulanato y\\Nampicilina-sulbactam:","guid":"8LskY-uq1lAMz4rQ0tHzDw","children":[{"id":"170","parent":"169","text":"• Infecciones polimicrobianas de piel y tejidos blandos (ej. heridas por\\Nmordedura, úlceras infectadas, celulitis, infecciones orofaríngeas).","guid":"c75p4DmOTpkG9Ol8TMbsQg","children":[]},{"id":"171","parent":"169","text":"• Otitis media.","guid":"ZXMl89WUO-B84HrcMroqQw","children":[]},{"id":"172","parent":"169","text":"• Sinusitis.","guid":"7tdzhZv0qCKH5MjyhWMV1Q","children":[]},{"id":"173","parent":"169","text":"• Neumonía por aspiración.","guid":"-e0pb93BnnfoJaARlTQL8Q","children":[]},{"id":"174","parent":"169","text":"• Alternativas para neumonía adquirida en la comunidad, infecciones\\Nintraabdominales adquiridas en la comunidad, y infecciones urinarias.","guid":"BlKQ6nwXWFPAUwC2kyIp-w","children":[]}]},{"id":"175","parent":"168","text":"• Piperacilina-tazobactam y\\Nticarcilina-clavulanato:","guid":"OI31CzkN88HZixj6966xrg","children":[{"id":"176","parent":"175","text":"• Cobertura para infecciones mixtas (Gram (-), Gram (+) y anaerobios), incluyendo infecciones intraabdominales\\Ncomplicadas, infecciones complicadas de piel y tejidos blandos, e infecciones respiratorias nosocomiales.","guid":"AY80TgBfmpCYhxLqKK1qnA","children":[]},{"id":"177","parent":"175","text":"• Terapia empírica de amplio espectro para infecciones polimicrobianas.","guid":"xpu4kYJOEu3KZewc7z40wQ","children":[]},{"id":"178","parent":"175","text":"• Mayor cobertura contra Enterobacter, P. aeruginosa, y otros Gram (-) en infecciones\\Nnosocomiales comparado con ampicilina-sulbactam o amoxicilina-clavulanato.","guid":"J90S_u5SKFrfUWwWnQJ9kQ","children":[]}]}]},{"id":"179","parent":"152","text":"4. Limitaciones:","guid":"","children":[{"id":"180","parent":"179","text":"• No activos contra S. aureus resistente a meticilina (MRSA).","guid":"LjIz5-8xxo7XjQXdQeD9Cw","children":[]},{"id":"181","parent":"179","text":"• Ningún β-lactámico disponible es activo contra MRSA.","guid":"4gzOZTl7VihJOCsgMH0X9Q","children":[]}]}]},{"id":"182","parent":"0","text":"Temocilina","guid":"k_W38zOGrJkW5qCKCN8aeg","children":[]}]},"node_count":182,"relations":[],"cross_references":[],"specialty":"Infectología","folder":"Entidades clínicas/Infectología","filename":"ATB Penicilinas-2024","id":"map_1123","resolved_references":[],"title_raw":"ATB Penicilinas-2024"}