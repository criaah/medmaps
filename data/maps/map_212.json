ww","children":[{"id":"89","parent":"88","text":"betabloqueantes y digoxina;\\Nel sotalol y la flecainida","guid":"g9bc4iKDRtkHJyDaX3d6FQ","children":[]},{"id":"90","parent":"88","text":"Rara vez se usa amiodarona debido\\Na su potencial teratógeno","guid":"","children":[]}]}]},{"id":"91","parent":"78","text":"inhibidores de la ECA, los BRA y\\Nlos antagonistas de la aldosterona","guid":"BO4Ae47E7k6EUvVk8GJWpw","children":[{"id":"92","parent":"91","text":"evitar durante el embarazo","guid":"C4aO1swbA-WRwQ8rR--jcw","children":[{"id":"93","parent":"92","text":"efectos teratógenos","guid":"vDxKikC31ehNlPtmDYEImA","children":[]}]},{"id":"94","parent":"91","text":"algunos inhibidores de la ECA es\\Nseguro durante la lactancia","guid":"DDJWQqC8Ef6iWpXakPFg6Q","children":[{"id":"95","parent":"94","text":"espironolactona se considera\\Ncompatible con la lactancia.","guid":"3KKYbIekduT75oKpgFAszg","children":[]}]},{"id":"96","parent":"91","text":"No existen datos concluyentes sobre la\\Ninocuidad de los BRA durante la lactancia","guid":"4MMLBHZM2GVMCT68vgh-Ug","children":[]}]},{"id":"97","parent":"78","text":"LactMed ","guid":"N_CdU9-QHRFv1wf9Q9iu_Q","children":[]}]},{"id":"98","parent":"22","text":"diagnóstico de\\Nhipertensión arterial","guid":"ryvEQpZAxp_EQvF6VO-LAg","children":[{"id":"99","parent":"98","text":"antes de la semana 20 de gestación es más indicativo de un\\Ndiagnóstico reciente de hipertensión crónica que de preeclampsia","guid":"0po3Rd2GE8uOSrSVcEmfOQ","children":[]},{"id":"100","parent":"98","text":"recomienda iniciar el tratamiento farmacológico\\Nde la hipertensión crónica durante el embarazo","guid":"I880qRIwgGnWMk7cqiC0rQ","children":[{"id":"101","parent":"100","text":"limitar el daño orgánico materno","guid":"YB3H12zO55JiXMwFqemDYg","children":[]},{"id":"102","parent":"100","text":"No existe evidencia de que el\\Ncontrol prevenga la preeclampsia","guid":"Xdvw6ZoITnb-fO2j3cWeIA","children":[]}]},{"id":"103","parent":"98","text":"\\\\*umbral\\\\* para iniciar\\Nel tratamiento","guid":"Yq4W8AELYAbNL-wD-5GXbQ","children":[{"id":"104","parent":"103","text":"en mujeres sin síntomas ni evidencia de\\Nlesión orgánica secundaria a la hipertensión","guid":"gwnS_IJrFHDwRHTaM80nQQ","children":[]},{"id":"105","parent":"103","text":"American College of Obstetricians\\Nand Gynecologists","guid":"pMVA5HkEksv2VQibrbsYmg","children":[{"id":"106","parent":"105","text":"sistólicos ≥160 mmHg o\\Ndiastólicos ≥105 mmHg.","guid":"loSc8isoQQkmidKsQQRB_w","children":[]}]},{"id":"107","parent":"103","text":"Sociedad Europea\\Nde Cardiología","guid":"ehyuAznP3Y_Rje6YbhV0PQ","children":[{"id":"108","parent":"107","text":"sistólicos ≥150 mmHg\\No diastólicos ≥95","guid":"LH_3zX57WJHo1X-vf19tfQ","children":[]}]}]},{"id":"109","parent":"98","text":"metildopa y el labetalol parecen ser los más\\Nseguros durante la gestación","guid":"","children":[]}]},{"id":"110","parent":"22","text":"Tratamiento anticoagulante\\Ndurante el embarazo","guid":"ZyxXB4MhG4TRSOC-xqEG5w","children":[{"id":"111","parent":"110","text":"embarazo se asocia a un estado de hipercoagulabilidad","guid":"Y5ARvJXy9GDDrZh73iP7DA","children":[]},{"id":"112","parent":"110","text":"indicaciones, los\\Nregímenes\\Nrecomendados y los\\Nparámetros de\\Nseguimiento","guid":"HMIACVb0g1iHQm4Ik0sRxg","children":[]},{"id":"113","parent":"110","text":"puede\\Nusar","guid":"ooNZ6L9lv-Urx0MEmmwyww","children":[{"id":"114","parent":"113","text":"warfarina, heparina no fraccionada y\\Nheparina de bajo peso molecular","guid":"","children":[]}]},{"id":"115","parent":"110","text":"warfarina","guid":"Y1vafKrstvNy8bmAd38tqw","children":[{"id":"116","parent":"115","text":"primer trimestre del embarazo puede causar\\Nembriopatía si la dosis diaria es superior a 5 mg","guid":"gTD4MafwPxgVLmfi-SEoOw","children":[]},{"id":"117","parent":"115","text":"teratogénicos, aborto espontáneo y pérdida fetal\\Ndebido a hemorragia intracraneal","guid":"4n-1o78QKDLtmfYkcGIZ-g","children":[]},{"id":"118","parent":"115","text":"suspender antes\\Ndel parto","guid":"BXVSsXtNe1xxPtvoI6rLZw","children":[{"id":"119","parent":"118","text":"riesgo de hemorragia intracraneal fetal si el trabajo de parto espontáneo y el\\Nparto vaginal tienen lugar mientras la madre (y por tanto el feto) recibe warfarina.","guid":"fNKZP4VQ3ZUZIOegxufR7A","children":[]}]},{"id":"120","parent":"115","text":"mujeres con una prótesis\\Nvalvular mecánica","guid":"iboWw1f_kMc4wIovBuxBeA","children":[{"id":"121","parent":"120","text":"pueden presentar trombosis valvular,\\Nhemorragia y morbimortalidad fetal","guid":"rTnxLH4U7NIyLw9sFoXhng","children":[]},{"id":"122","parent":"120","text":"warfarina parece ser el\\Nfármaco más seguro","guid":"6GlBGwckgzmJZ41sV1HmKg","children":[]},{"id":"123","parent":"120","text":"heparina de bajo peso molecular y la heparina no\\Nfraccionada son más seguras para el feto que la warfarina","guid":"zZrkBkE8IrJ-UILlx8gY0g","children":[{"id":"124","parent":"123","text":"pero pueden aumentar el riesgo de\\Ntrombosis en una válvula protésica materna.","guid":"tyUZ4b-UPlW47QfmXr9D4w","children":[]}]},{"id":"125","parent":"120","text":"control semanal del nivel de anticoagulación durante el embarazo,\\Nindependientemente del tratamiento, con los ajustes necesarios de la dosis.","guid":"YAIxlXhvJgp0_LzQYmdlqg","children":[]},{"id":"126","parent":"120","text":"guías del\\NACC y la AHA","guid":"MNpGlF0H2eEI8-30Zu29rQ","children":[{"id":"127","parent":"126","text":"primer trimestre","guid":"","children":[{"id":"128","parent":"127","text":"warfarina si la dosis diaria es ≤5 mg en el momento de la concepción","guid":"VL8B0LxSSLZNUBQA4tobgQ","children":[]},{"id":"129","parent":"127","text":"Si la dosis de warfarina\\Nes >5 mg/día","guid":"co_EMpcdo36BofYPS2wrLQ","children":[{"id":"130","parent":"129","text":"heparina no fraccionada intravenosa o heparina\\Nde bajo peso molecular en dosis ajustadas","guid":"5WUMnFDsDU9vQihcNGYTVA","children":[]}]}]},{"id":"131","parent":"126","text":"segundo trimestre y el\\Ncomienzo del tercero","guid":"5X2HzcL3JMgs9AiF5V002Q","children":[{"id":"132","parent":"131","text":"prefiere la warfarina","guid":"O0pKoKDwa-rVgBwsHskJaQ","children":[]}]},{"id":"133","parent":"126","text":"cerca del momento del parto","guid":"qgTOduueJiklwn6KMmBxNw","children":[{"id":"134","parent":"133","text":"heparina no fraccionada intravenosa","guid":"","children":[]}]}]}]},{"id":"135","parent":"115","text":"limitados datos disponibles sugieren que la exposición a anticoagulantes\\Norales no antagonistas de la vitamina K no confiere un alto riesgo de\\Nembriopatía o complicaciones neonatales","guid":"WocmWyMpZXjy-M6pFQkbqA","children":[]}]}]}]}]},"node_count":135,"relations":[],"cross_references":[],"specialty":"Cardiología","folder":"Entidades clínicas/Cardiología","filename":"13. Embarazo y enfermedad cardiovascular-2021","id":"map_212","resolved_references":[]}