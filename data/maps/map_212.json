:[{"id":"30","parent":"29","text":"menos pérdida de sangre","guid":"E7IMe9khfKNEpkb5VD3K2g","children":[]},{"id":"31","parent":"29","text":"recuperación más rápida","guid":"Ccqnl5kjorm-QTYsZC4Hnw","children":[]},{"id":"32","parent":"29","text":"riesgo más bajo de trombosis","guid":"","children":[]}]},{"id":"33","parent":"23","text":"cesárea se recomienda por\\Nrazones obstétricas","guid":"EEGgAjZsH8aWbX83LeHuMw","children":[{"id":"34","parent":"33","text":"mujeres con enfermedad\\Ncardiovascular descompensada grave","guid":"ueuF-cS_trkuvyhQeYclSg","children":[]},{"id":"35","parent":"33","text":"dilatación aórtica grave","guid":"L3nmNcMaxiD_9u8jb-IcuQ","children":[]}]},{"id":"36","parent":"23","text":"tratamiento con warfarina\\Nindicada la cesárea","guid":"W2twwkg5foVUN4ATur82LA","children":[{"id":"37","parent":"36","text":"reducir el riesgo de hemorragia intracraneal fetal\\Nporque el feto está completamente anticoagulado","guid":"5LviD5foac0LFZ-0NpAX8g","children":[]}]}]},{"id":"38","parent":"22","text":"Miocardiopatía\\Nperiparto","guid":"vO0PjiQ3N2icsLkxQUs5Jw","children":[{"id":"39","parent":"38","text":"disfunción sistólica ventricular izquierda que se manifiesta hacia el final del\\Nembarazo o en los meses siguientes al parto en ausencia de otra causa identificable","guid":"A1Gq8-vmd4V7s8Waxzuf2Q","children":[]},{"id":"40","parent":"38","text":"factores de riesgo","guid":"ySrsK9Qtbqoxg458QDaIDw","children":[{"id":"41","parent":"40","text":"multiparidad, edad mayor de 30 años, ascendencia africana, embarazo\\Nmúltiple, hipertensión gestacional, preeclampsia, un episodio previo de\\Nmiocardiopatía periparto y el tratamiento con un agente tocolítico.","guid":"QBokXoZt1okLcH-eEih-zA","children":[]}]},{"id":"42","parent":"38","text":"Complicaciones ","guid":"","children":[{"id":"43","parent":"42","text":"mayoría se recuperan completamente","guid":"pRR4WwyEV_Nr10ddkA6IAw","children":[{"id":"44","parent":"43","text":"intervalo hasta la recuperación\\Nes de seis meses","guid":"YyfPfvUXwwdEqUo_ViF4Rw","children":[]}]},{"id":"45","parent":"42","text":"13% sufren eventos cardiovasculares\\Ngraves o miocardiopatía grave persistente","guid":"-MeiaXszNOS-dMNgVQ8NhQ","children":[]}]},{"id":"46","parent":"38","text":"muerte asociada","guid":"AOFPRhfMihtN51ODydQ_Ng","children":[{"id":"47","parent":"46","text":"insuficiencia cardíaca, eventos\\Ntromboembólicos y arritmias","guid":"husvBgT5aZK47p5SMSNR8w","children":[]}]},{"id":"48","parent":"38","text":"factores pronósticos\\Npeor desenlace","guid":"cvmvKveDvteGzaiRdIynYw","children":[{"id":"49","parent":"48","text":"disfunción o dilatación ventricular\\Nizquierda grave y la raza negra","guid":"PXyhkpebwnDMnWH35vr6cA","children":[]}]},{"id":"50","parent":"38","text":"tratamiento médico\\Ninmediato","guid":"H8TDxqVFJ9T_Acc41RNYpw","children":[{"id":"51","parent":"50","text":"betabloqueantes, digoxina,\\Nhidralazina, nitratos o diuréticos","guid":"ocdC6O_b0k8GzMCmz4OFgQ","children":[]},{"id":"52","parent":"50","text":"teratogénicos","guid":"5TvcIuanQXpkwyQejVM_AA","children":[{"id":"53","parent":"52","text":"inhibidores de la ECA, los BRA y\\Nlos antagonistas de la aldosterona","guid":"w3W_tubpnVFTbpD-h0tmzA","children":[]}]},{"id":"54","parent":"50","text":"recomienda iniciar la anticoagulación\\Ncuando FEVI sea menor del 35%","guid":"eG5FVgCDEIFZXh0u99pfpw","children":[{"id":"55","parent":"54","text":"heparina o warfarina","guid":"f2U1B_7iIvKfApZ9Ij4Tvg","children":[{"id":"56","parent":"55","text":"decisión se debe tomar\\Njunto con un cardiólogo","guid":"c8dT1YMrCNEMSom0LLJyyQ","children":[]}]},{"id":"57","parent":"54","text":"anticoagulación se debe administrar durante ocho semanas como\\Nmínimo, pero se puede suspender antes si la FEVI se normaliza.","guid":"b2dE_axoHY9Lc3VxkJI7Iw","children":[]}]},{"id":"58","parent":"50","text":"insuficiencia cardíaca\\Nrefractaria grave","guid":"7IGWjqulcbfiHgSvOpdkeQ","children":[{"id":"59","parent":"58","text":"dispositivo de asistencia ventricular\\No trasplante de corazón.","guid":"N5CZs28AbKEiJ7VIQpKvzA","children":[]},{"id":"60","parent":"58","text":"bromocriptina","guid":"4NVt-t97gLzuRW0Qv-mdIg","children":[{"id":"61","parent":"60","text":"evidencia limitada","guid":"h-ElGfSOZnes-xPFEMLVPQ","children":[{"id":"62","parent":"61","text":"fase de investigación","guid":"","children":[]}]},{"id":"63","parent":"60","text":"bloquea la secreción de prolactina, mejora la FEVI y los resultados clínicos\\Ncuando se añade al tratamiento de la insuficiencia cardíaca periparto","guid":"4-0Hl4SLJVoCWslDEp2c7g","children":[]}]}]}]},{"id":"64","parent":"38","text":"episodio previo de miocardiopatía periparto y disfunción\\Nventricular izquierda persistente que eviten futuros embarazos","guid":"N-L1zX2ZKDQLkdnhv12y5g","children":[]}]},{"id":"65","parent":"22","text":"Otros trastornos\\Ncardiovasculares","guid":"dI_r2u4A3z0rKIpejSgNNg","children":[{"id":"66","parent":"65","text":"síndrome de\\NMarfan","guid":"a59MKFdkGwmcHHdHXX2vOA","children":[{"id":"67","parent":"66","text":"mayor riesgo de disección aórtica\\Nrelacionada con el embarazo","guid":"MeVvlmEMAFZ0Giv3ymYWUw","children":[{"id":"68","parent":"67","text":"embarazo se considera seguro con\\Nun diámetro aórtico <4,0 cm.","guid":"Z5pEDPKCSpsezDmxiNICpg","children":[]}]},{"id":"69","parent":"66","text":"reparación aórtica antes del embarazo en mujeres con\\Nsíndrome de Marfan y diámetro aórtico ≥4,5 cm","guid":"82yJyEn2X95pgnruLLbVCA","children":[]},{"id":"70","parent":"66","text":"aconsejar el reemplazo aórtico antes del embarazo\\Nfactores de riesgo","guid":"Wcv62FMQ4Tg3glhyacFbEQ","children":[{"id":"71","parent":"70","text":"dilatación rápida de la aorta","guid":"0xYbfCXcI9pLw54mk_aP6w","children":[]},{"id":"72","parent":"70","text":"antecedentes personales o\\Nfamiliares de disección aórtica","guid":"","children":[]}]}]},{"id":"73","parent":"65","text":"disecciones coronarias espontáneas","guid":"iS344Dv4wZDSh6UEGidDsA","children":[{"id":"74","parent":"73","tex