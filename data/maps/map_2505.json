:"202","text":"Mayor riesgo de hipoglicemia severa","guid":"GaCrFQ_RRcCRqzAyNE_LZg","children":[]}]}]},{"id":"206","parent":"167","text":"Manejo","guid":"SALM8oXaS5WvmpQMkQEuPQ","children":[{"id":"207","parent":"206","text":"PACIENTE CONSCIENTE","guid":"VfEoJI9GSEaBzWldutd3kQ","children":[{"id":"208","parent":"207","text":"15-20 g carbohidratos de absorcion rapida","guid":"aIXLUxd1RaeEvhQY-GATbQ","children":[]},{"id":"209","parent":"207","text":"Jugo de frutas 150 mL, tabletas glucosa","guid":"jPXJimHaQ-qet3574tCiqA","children":[]},{"id":"210","parent":"207","text":"Remedir en 15 min → repetir si <70","guid":"A1A4e2FpSleQJ-WaO_wPgg","children":[]},{"id":"211","parent":"207","text":"Regla del 15 (15g cada 15 min)","guid":"LElJ0RwjT3OIvp2xLaNegw","children":[]}]},{"id":"212","parent":"206","text":"PACIENTE INCONSCIENTE O NO TOLERA VO","guid":"PXhCtb6STlSf3XRfb53ODw","children":[{"id":"213","parent":"212","text":"Dextrosa 50% → 25-50 mL IV (12.5-25 g)","guid":"dVVCtqluS4K07hwRXQwFLQ","children":[{"id":"214","parent":"213","text":"Puede repetirse cada 5-10 min","guid":"UAzBIeZmSC2WKHvqNnwnNQ","children":[]},{"id":"215","parent":"213","text":"En AM → considerar Dx 10% o 25% por riesgo flebitis","guid":"pjBkZi40Seajbk88b53h9w","children":[]}]},{"id":"216","parent":"212","text":"Glucagon 1 mg IM/SC","guid":"q-MMvd3NTviA7wNGGLjiWA","children":[{"id":"217","parent":"216","text":"Alternativa si no acceso IV","guid":"N_0hu18GTyutzf-ZL08UDw","children":[]},{"id":"218","parent":"216","text":"Puede ser menos efectivo si deplecion glucogeno","guid":"R09u8KNaSrGC_PgszBbYJQ","children":[]},{"id":"219","parent":"216","text":"Glucagon intranasal 3 mg → disponible en algunos paises","guid":"N9jG3zcXQiSM7C_OkVQ0pQ","children":[]}]}]},{"id":"220","parent":"206","text":"POR SULFONILUREAS → CUIDADO ESPECIAL","guid":"wgpF5UMxTAOqx-LxjP3hnQ","children":[{"id":"221","parent":"220","text":"Hipoglicemia prolongada (24-72h)","guid":"ET_3YhsPTNu8Bw-rwWgcKA","children":[]},{"id":"222","parent":"220","text":"HOSPITALIZACION SIEMPRE","guid":"cNm2O8eiSIKSzdfEx8cz3A","children":[]},{"id":"223","parent":"220","text":"Infusion continua SG 10%","guid":"emNqXgjtSq2TtvespxO7eQ","children":[]},{"id":"224","parent":"220","text":"Octreotide 50 mcg SC cada 6-8h","guid":"xxBSpHLgS-qyFgVSmZgxsw","children":[{"id":"225","parent":"224","text":"Inhibe secrecion insulina","guid":"9K89VIxOScqO0f0jIqMhgg","children":[]},{"id":"226","parent":"224","text":"Mas efectivo que dextrosa sola","guid":"Hl1LCOGWSuimFS89ANKSSg","children":[]}]}]},{"id":"227","parent":"206","text":"BUSCAR CAUSA Y PREVENIR RECURRENCIA","guid":"A2PhQTmKTOmIHtoQ2ralqQ","children":[{"id":"228","parent":"227","text":"Revisar medicamentos → ajustar/suspender","guid":"EGGJRuRfSymGf1O7ZbIA7g","children":[]},{"id":"229","parent":"227","text":"Metas glicemicas MENOS estrictas en AM fragil","guid":"uqTj5FvLQNmKZzzry7JXAw","children":[{"id":"230","parent":"229","text":"ADA/AGS → HbA1c <8-8.5% en fragil","guid":"qiiVnLNwT0GWnEtbkukgYw","children":[]},{"id":"231","parent":"229","text":"Evitar glicemias <100 mg/dL","guid":"YOLgiKwYTRGfMM3-UyiH_A","children":[]}]},{"id":"232","parent":"227","text":"Educacion paciente y cuidador","guid":"cJLFTpSTRt2_XK6-bN6E-w","children":[]},{"id":"233","parent":"227","text":"CGM si disponible y episodios frecuentes","guid":"8BE6WPFVTceUo6gfpSrLmg","children":[]}]}]}]},{"id":"234","parent":"0","text":"DIAGNOSTICO DIFERENCIAL ENTRE CAD vs EHH vs MIXTO","guid":"GWom5-gmTs-4TNNdUPq6UA","children":[{"id":"235","parent":"234","text":"30% de pacientes tienen sobreposicion CAD/EHH","guid":"ehR1YFXdQ3awnTG2I8yYAA","children":[]},{"id":"236","parent":"234","text":"Claves diferenciales","guid":"1xTQYJtoQXCNOcpCL7HgMQ","children":[{"id":"237","parent":"236","text":"CAD → pH bajo, cetonas altas, osmolaridad variable","guid":"JeRrEjX6SdqP2gjONiZ_LA","children":[]},{"id":"238","parent":"236","text":"EHH → pH normal, cetonas bajas, osmolaridad MUY alta","guid":"o-4sg1t2RLmRzs_y7K1gMA","children":[]},{"id":"239","parent":"236","text":"Mixto → acidosis + hiperosmolaridad","guid":"RuA-86f9TPKHm0vasjLitQ","children":[]}]},{"id":"240","parent":"234","text":"En adulto mayor → EHH es MAS frecuente que CAD pura","guid":"JRC-tZy7QGCx43tbmSzkUw","children":[]}]},{"id":"241","parent":"0","text":"CONSIDERACIONES GERIATRICAS TRANSVERSALES","guid":"TbHKejWsQvKJvLZhBt4-Pw","children":[{"id":"242","parent":"241","text":"Metas glicemicas individualizadas","guid":"fY4Mo2_3RKiINyN6SCREWA","children":[{"id":"243","parent":"242","text":"Robusto → HbA1c <7-7.5%","guid":"tIL-ILWFQJCwH5oFDCN-fg","children":[]},{"id":"244","parent":"242","text":"Fragil/multimorbido → HbA1c <8-8.5%","guid":"tX6HiYoVTaG9U8L2-i1dbg","children":[]},{"id":"245","parent":"242","text":"Fin de vida → evitar hipo e hiperglicemia sintomatica","guid":"dEOhYm28Q8qsHCIG5lW8LQ","children":[]}]},{"id":"246","parent":"241","text":"Deprescripcion","guid":"XtQt3guZQKCdtVJ6HVisGw","children":[{"id":"247","parent":"246","text":"Revisar sulfonilureas → cambiar a opciones mas seguras","guid":"U4Bc7lw8QES_wvK4QEkJtA","children":[]},{"id":"248","parent":"246","text":"Glibenclamida → NUNCA en adulto mayor","guid":"8RDnErRPRDSVfXEAluYJZw","children":[]},{"id":"249","parent":"246","text":"iSGLT2 → riesgo CAD euglicemica + deshidratacion","guid":"mjL31TnyRk6dmSy-SKDrxA","children":[]},{"id":"250","parent":"246","text":"Metformina → ajustar por funcion renal","guid":"AmGW2PksQd6F9cB0CbwQUQ","children":[]}]},{"id":"251","parent":"241","text":"Riesgo de delirium","guid":"oXbUNdR-TtenhbnpAc-QaQ","children":[{"id":"252","parent":"251","text":"Tanto hipo como hiperglicemia → precipitantes de delirium","guid":"TwbJXFW8RImh3wYGztMr5A","children":[]},{"id":"253","parent":"251","text":"Buscar activamente en todo AM con emergencia diabetica","guid":"6eWANPq3RbWlnzqYTBTmsg","children":[]}]},{"id":"254","parent":"241","text":"Fragilidad y funcionalidad","guid":"ZiSsvFUvQYyY7NQ3eJW4UA","children":[{"id":"255","parent":"254","text":"Evaluar capacidad de automanejo","guid":"BDgfeSxPRzSItRPgoXIU_w","children":[]},{"id":"256","parent":"254","text":"Considerar soporte familiar/cuidador","guid":"2IJ-pj5TQ5WXnPV0pbB9RQ","children":[]},{"id":"257","parent":"254","text":"Simplificar esquema insulinico al alta","guid":"QPRo1M-yQEC609U5RU0RKA","children":[]}]},{"id":"258","parent":"241","text":"Nutricion","guid":"hXCrGUI5QDSJnUjNUdCcoQ","children":[{"id":"259","parent":"258","text":"Sarcopenia + desnutricion → menor reserva","guid":"DNbsYpvLS2GjYE5XiIgR5A","children":[]},{"id":"260","parent":"258","text":"Valoracion nutricional post evento","guid":"rJxwV3BKS3-XigRp2LR61g","children":[]}]}]},{"id":"261","parent":"0","text":"LR DIAGNOSTICOS","guid":"BzaliauQRtWhsv9K0l4A8A","children":[{"id":"262","parent":"261","text":"CRITERIOS BIOQUIMICOS (ADA 2009)","guid":"gr1FR0OVRfqpHWdXFRLTxw","children":[{"id":"263","parent":"262","text":"DKA -> Glucosa >250 + cetonas + pH <7.30 + HCO3 <18 + anion gap >12 -> PMID:19564476","guid":"V97TywvCS_GQ70eotKikew","children":[]},{"id":"264","parent":"262","text":"DKA leve -> pH 7.25-7.30 / HCO3 15-18","guid":"y9WpfthPSxuFGh-fL5aivw","children":[]},{"id":"265","parent":"262","text":"DKA moderada -> pH 7.00-7.24 / HCO3 10-15","guid":"_0sVceDRRgaqMUR0m0IQOg","children":[]},{"id":"266","parent":"262","text":"DKA severa -> pH <7.00 / HCO3 <10","guid":"jx7iCH17Sk66HrU5pQRyDg","children":[]},{"id":"267","parent":"262","text":"EHH -> Glucosa >600 + Osm efectiva >320 + pH >7.30 + HCO3 >18 + sin cetonas significativas -> PMID:19564476","guid":"a8GTiUDDSG2tRU9JkKsSYw","children":[]}]},{"id":"268","parent":"261","text":"HALLAZGOS CLINICOS (cabecera)","guid":"xN3-bghyQ_-HDHvJsIBzyQ","children":[{"id":"269","parent":"268","text":"Respiracion de Kussmaul -> [LR no consolidado formalmente, signo de acidosis severa]","guid":"Hdxz6NhfSD2qZNR653yZrw","children":[]},{"id":"270","parent":"268","text":"Aliento cetonico (fruity breath) -> [LR no consolidado, especifico pero insensible]","guid":"kv7Q62CrTAmHNVkU0RpQQw","children":[]},{"id":"271","parent":"268","text":"Deshidratacion severa (mucosas secas, turgor) -> marcador severidad no LR especifico","guid":"GePmZxCSR0Cjn3R0D4lJYQ","children":[]},{"id":"272","parent":"268","text":"Poliuria / polidipsia / polifagia -> hiperglicemia general no DKA/EHH","guid":"YkPNg9qpQjKAeiZcFF6moA","children":[]},{"id":"273","parent":"268","text":"Alteracion sensorio + Osm calculada >320 -> [definitorio EHH]","guid":"fr6hc_8XRyqHPbaz170NWQ","children":[]},{"id":"274","parent":"268","text":"Dolor abdominal en DKA (hasta 40 porciento) -> frecuente pero inespecifico","guid":"OTCZAE5dSt6OIS7T2zbgfQ","children":[]}]},{"id":"275","parent":"261","text":"HALLAZGOS LABORATORIO","guid":"ZBZWxzVqRaeCn3I2kK-BvQ","children":[{"id":"276","parent":"275","text":"Cetonemia capilar beta-hidroxibutirato >=3.0 mmol/L + glicemia + pH -> [diagnostico DKA] -> PMID:18184896","guid":"ZOpj2K9kQpyFEgdUbMkPkA","children":[]},{"id":"277","parent":"275","text":"Cetonuria 3+ en DKA -> apoya dx","guid":"r-nyew9wQNaBqEiHZEjPlQ","children":[]},{"id":"278","parent":"275","text":"Brecha anionica >12 mEq/L -> acidosis metabolica con AG aumentado","guid":"Zq80gst6TgOlKHfYikSUdw","children":[]},{"id":"279","parent":"275","text":"Hipokalemia inicial en DKA -> K total corporal DISMINUIDO aunque serico variable","guid":"zpRA5DeVRpWepyGe56rGnQ","children":[]},{"id":"280","parent":"275","text":"Osmolaridad efectiva = 2Na + glucosa/18 -> definitorio EHH si >320","guid":"SmxU0t9pQOSS_s4nEbJ19g","children":[]}]},{"id":"281","parent":"261","text":"INTERPRETACION","guid":"gTEnkom9SAGLQq6-C1QDVw","children":[{"id":"282","parent":"281","text":"DKA y EHH son DIAGNOSTICOS POR CRITERIOS BIOQUIMICOS COMPUESTOS","guid":"7uR9axj7SCC1Y7j3Q7jmTQ","children":[]},{"id":"283","parent":"281","text":"Signos clinicos clasicos son ESPECIFICOS PERO INSENSIBLES","guid":"4xOz9EjbSBOpYx3vRVwCUA","children":[]},{"id":"284","parent":"281","text":"LRs individuales no publicados formalmente por ese motivo","guid":"UDuac7UIQAyYfMZQjmlpDQ","children":[]}]},{"id":"285","parent":"261","text":"GERIATRIA","guid":"JZl5BANTSua2JK-koTXqKQ","children":[{"id":"286","parent":"285","text":"EHH es 10x mas frecuente que DKA en AM","guid":"2FI_KRwwTgC99XHmU9d5Qg","children":[]},{"id":"287","parent":"285","text":"Mortalidad EHH 5-20 porciento","guid":"8F7bbu-VRmG4vpAnYyptgA","children":[]},{"id":"288","parent":"285","text":"Infeccion como precipitante en mayoria de casos","guid":"yPAXLHwFRAao-M9dNSWxvQ","children":[]},{"id":"289","parent":"285","text":"Alteracion sensorial puede ser unico signo","guid":"q6X3AXwlRfKdd3VnouU1WA","children":[]}]}]},{"id":"290","parent":"0","text":"REFERENCIAS","guid":"blS06KzaTE-eRdnM9KXScA","children":[{"id":"291","parent":"290","text":"Mustafa 2023 → guia JBDS manejo EHH (PMID:36370077, DOI:10.1111/dme.15005)","guid":"KzcFa7uHRlCT-a9NpmwGjg","children":[]},{"id":"292","parent":"290","text":"Willix 2019 → presentaciones hiperglicemicas en DM2 (PMID:31129935, DOI:10.31128/AJGP-12-18-4785)","guid":"MDWMcxRbQHq2B7lEmTSdCA","children":[]},{"id":"293","parent":"290","text":"Hritani 2018 → IAM tipo 2 en descompensacion diabetica (PMID:29518369, DOI:10.1016/j.amjmed.2018.02.007)","guid":"r9msBsOlQwC54RqFOW0LLA","children":[]},{"id":"294","parent":"290","text":"Lee 2018 → hipoglicemia severa y eventos CV (PMID:29127240, DOI:10.2337/dc17-1669)","guid":"WnWe-oozQIW_5XGJ01x3qA","children":[]},{"id":"295","parent":"290","text":"Burgess 2023 → DM y caidas en AM urgencia (PMID:37612537, DOI:10.1007/s41999-023-00848-0)","guid":"SZNAGOc8QcCRcT5svxi_Gw","children":[]},{"id":"296","parent":"290","text":"ADA Standards of Care 2024 → metas glicemicas en AM","guid":"nd1GiUj3SkqvtCQtTC_HnA","children":[]},{"id":"297","parent":"290","text":"Kitabchi 2009 → protocolo CAD/EHH (PMID:19564476)","guid":"uq3KY3c1TR6eK-xwtI7VTA","children":[]}]}]},"node_count":297,"relations":[],"cross_references":[],"specialty":"Medicina de Urgencia","folder":"MUE - Medicina de Urgencia","filename":"MU