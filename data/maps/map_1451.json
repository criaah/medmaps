últiples localizaciones posibles","guid":"1ZumUbVtSFOjme8fupe55w","children":[]}]},{"id":"65","parent":"47","text":"NO FLUENTE + Comprensión preservada + Repetición alterada → BROCA","guid":"-7WgOvTvTJeacb3phDrQRQ","children":[{"id":"66","parent":"65","text":"Lesión → giro frontal inferior posterior izq","guid":"mciiPgY1QhG4eGnYD3ZIjg","children":[]},{"id":"67","parent":"65","text":"Agramatismo → omite palabras funcionales","guid":"Ypnyo415R6uiRk4shfJQpA","children":[]},{"id":"68","parent":"65","text":"Hemiparesia derecha frecuente","guid":"YJnFr2AxRQG60F0V8tHs-w","children":[]},{"id":"69","parent":"65","text":"Apraxia oral común","guid":"vpMlDng1S6GQirt5NNUTIw","children":[]}]},{"id":"70","parent":"47","text":"NO FLUENTE + Comprensión preservada + Repetición preservada → TRANSCORTICAL MOTORA","guid":"eR9rStAQRMOehMtrRVjMnA","children":[{"id":"71","parent":"70","text":"Lesión → watershed anterior (ACA/ACM)","guid":"Qz6IykbaT6-d7Lisofu8_g","children":[]},{"id":"72","parent":"70","text":"Dificultad para iniciar habla","guid":"SMqeDsVYQaWMPpp7T5vpJw","children":[]},{"id":"73","parent":"70","text":"Puede presentar apatía","guid":"oShvuvHGRzyF_Uy5VkC09Q","children":[]}]},{"id":"74","parent":"47","text":"NO FLUENTE + Comprensión alterada + Repetición alterada → GLOBAL","guid":"vkIzFHvzSkS99YLi13yMvg","children":[{"id":"75","parent":"74","text":"Lesión extensa perisilviana (Broca + Wernicke)","guid":"-7ux5zgaTGGB62J1RpqBzg","children":[]},{"id":"76","parent":"74","text":"Mutismo o expresiones automáticas","guid":"Y64HgGTiQfGskrU46A5SvA","children":[]},{"id":"77","parent":"74","text":"Hemiparesia derecha + hemianopsia","guid":"MHREdWoZQjubxSLBdLn-bw","children":[]}]},{"id":"78","parent":"47","text":"NO FLUENTE + Comprensión alterada + Repetición preservada → TRANSCORTICAL MIXTA","guid":"49mG0AiBQhypCEcsO09VDg","children":[{"id":"79","parent":"78","text":"Lesión watershed anterior + posterior bilateral","guid":"xO-20otjT3qfHVFU-5OCIA","children":[]},{"id":"80","parent":"78","text":"Similar a global pero repite","guid":"hzcCOT1STlKxJwmqx9ZkEQ","children":[]},{"id":"81","parent":"78","text":"Puede completar frases automáticas","guid":"tn4Hy25WRw6PGCcAdUjnGw","children":[]}]}]},{"id":"82","parent":"0","text":"Clasificación de Disartrias (Mayo Clinic)","guid":"7jLsDIFxRJmOwsCkYzCqqw","children":[{"id":"83","parent":"82","text":"Espástica → MOTONEURONA SUPERIOR","guid":"ayTxe4HnQUyBclRZN19WNw","children":[{"id":"84","parent":"83","text":"Voz tensa-estrangulada","guid":"9n-DHfKvRQ2hzvjaZtqVHg","children":[]},{"id":"85","parent":"83","text":"Articulación imprecisa","guid":"B6YONZ55S4iwcmE_S1P_gA","children":[]},{"id":"86","parent":"83","text":"Frases cortas, prosodia monótona","guid":"ZaKMJSwcT4CpE_cPlL1aKA","children":[]},{"id":"87","parent":"83","text":"Hipernasalidad leve","guid":"J_Uuh-0YRsKSYjR8BFvy3w","children":[]},{"id":"88","parent":"83","text":"Asociado → espasticidad, hiperreflexia, Babinski","guid":"zxZ4SSuGSYOooMUINxn6IQ","children":[]},{"id":"89","parent":"83","text":"Causas → ACV bilateral, ELA (componente superior), parálisis pseudobulbar","guid":"ptZv6e9rSw2LcMJOs0wfRg","children":[]}]},{"id":"90","parent":"82","text":"Flácida → MOTONEURONA INFERIOR","guid":"POoGKdLFTMaERfm2ZQUjDw","children":[{"id":"91","parent":"90","text":"Voz soplada, hipofónica","guid":"GnSZJbwuTNCSLkCNvZRScQ","children":[]},{"id":"92","parent":"90","text":"Hipernasalidad marcada (velo palatino)","guid":"mKRtalBWREeSIsnQkR3yoQ","children":[]},{"id":"93","parent":"90","text":"Fasciculaciones linguales → ELA","guid":"Yh8_Z2PfT_qhjD7KQ_EzTA","children":[]},{"id":"94","parent":"90","text":"Causas → lesión bulbar, neuropatía craneal, miastenia gravis, Guillain-Barré","guid":"EompgG2WRpiaDM9d_rXkoQ","children":[]}]},{"id":"95","parent":"82","text":"Atáxica → CEREBELOSA","guid":"QLP_a85ZRE-kGksfK3C8Rw","children":[{"id":"96","parent":"95","text":"Habla escándida (scanning speech) → PATOGNOMÓNICA","guid":"QrS-VKgFRD6X7mGsOtrBsQ","children":[]},{"id":"97","parent":"95","text":"Articulación irregular","guid":"moItiZFdRhOHdWg3xl4m1w","children":[]},{"id":"98","parent":"95","text":"Prosodia excesiva (explosive speech)","guid":"NKrmoqYnQB-FwX1idhmjeA","children":[]},{"id":"99","parent":"95","text":"Asociado → dismetría, temblor intencional, ataxia marcha","guid":"7nkQYYY9R72Ub5_ehQ2eSg","children":[]},{"id":"100","parent":"95","text":"Causas → ACV cerebeloso, EM, degeneración cerebelosa","guid":"PNeUlvlKS9mgKujGQ3Frhw","children":[]}]},{"id":"101","parent":"82","text":"Hipocinética → EXTRAPIRAMIDAL (Parkinson)","guid":"l_o6_-6ASca2sAS66FWzVw","children":[{"id":"102","parent":"101","text":"Voz monótona, hipofónica","guid":"I6FRwLaHTJWwbihWgYFsuw","children":[]},{"id":"103","parent":"101","text":"Articulación imprecisa","guid":"2ksUjzxdSFeQ6dEbK3hguQ","children":[]},{"id":"104","parent":"101","text":"Taquifemia (aceleración progresiva)","guid":"y72x17tYSpu_xIKNi3Ltmw","children":[]},{"id":"105","parent":"101","text":"Palilalia (repetición involuntaria)","guid":"3TAlAlh9RmycpzqYoUp5rg","children":[]},{"id":"106","parent":"101","text":"Asociado → bradicinesia, rigidez, temblor reposo","guid":"4ReXr_STR_m1oazfg124Dw","children":[]}]},{"id":"107","parent":"82","text":"Hipercinética → EXTRAPIRAMIDAL (corea, distonía)","guid":"673_bFP0RjqmCFFIBE5J0Q","children":[{"id":"108","parent":"107","text":"Interrupciones involuntarias del habla","guid":"v4zOyELPQvqtxkPWqf0IKQ","children":[]},{"id":"109","parent":"107","text":"Variabilidad en volumen y tono","guid":"8cAEHJd5Rz2OWgk7RE31zw","children":[]},{"id":"110","parent":"107","text":"Distonía laríngea → voz estrangulada intermitente","guid":"UGbVZPgoQ4qZt1RXge0ltQ","children":[]},{"id":"111","parent":"107","text":"Causas → Huntington, distonía, mioclonías","guid":"42IQD3nPTaWrnjKE39wDAA","children":[]}]},{"id":"112","parent":"82","text":"Mixta → MÁS DE UN SISTEMA","guid":"tJ2CedeqRyu1nXrxZqkYvQ","children":[{"id":"113","parent":"112","text":"ELA → espástica + flácida (MÁS FRECUENTE mixta)","