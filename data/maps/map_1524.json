"text":"85+ → **153.2** ambos sexos","guid":"","children":[]}]},{"id":"20","parent":"5","text":"Chile (2001-2008)","guid":"","children":[{"id":"21","parent":"20","text":"40.966 fracturas de cadera totales","guid":"","children":[]},{"id":"22","parent":"20","text":"80+ años → **22.227 casos**\\N(grupo más afectado)","guid":"","children":[]}]}]},{"id":"23","parent":"0","text":"Impacto Multidimensional","guid":"","children":[{"id":"24","parent":"23","text":"Biomédico","guid":"","children":[{"id":"25","parent":"24","text":"↑ morbimortalidad","guid":"","children":[]},{"id":"26","parent":"24","text":"Descompensación\\Npatologías crónicas","guid":"","children":[]},{"id":"27","parent":"24","text":"Polifarmacia (causa y consecuencia)","guid":"","children":[]}]},{"id":"28","parent":"23","text":"Funcional","guid":"","children":[{"id":"29","parent":"28","text":"↑ dependencia","guid":"","children":[]},{"id":"30","parent":"28","text":"Uso ayudas técnicas","guid":"","children":[]},{"id":"31","parent":"28","text":"Institucionalización","guid":"","children":[]}]},{"id":"32","parent":"23","text":"Cognitivo/Afectivo","guid":"","children":[{"id":"33","parent":"32","text":"Deterioro cognitivo","guid":"","children":[]},{"id":"34","parent":"32","text":"**Miedo a caer**\\N(Síndrome Post-Caída)","guid":"","children":[]},{"id":"35","parent":"32","text":"Trastornos afectivos","guid":"","children":[]}]},{"id":"36","parent":"23","text":"Social","guid":"","children":[{"id":"37","parent":"36","text":"Sobrecarga del cuidador","guid":"","children":[]},{"id":"38","parent":"36","text":"Gasto económico elevado → fractura\\Ncadera ~$8.400.000 (Isapres 2013)","guid":"","children":[]}]},{"id":"39","parent":"23","text":"Carga global (GBD 2017)","guid":"","children":[{"id":"40","parent":"39","text":"**4% de salud plena**\\Nperdida con ≥1 caída","guid":"","children":[]},{"id":"41","parent":"39","text":"DALYs ↓13.9%","guid":"","children":[]}]}]},{"id":"42","parent":"0","text":"Fisiología de la Marcha","guid":"","children":[{"id":"43","parent":"42","text":"Sistemas implicados","guid":"","children":[{"id":"44","parent":"43","text":"Aferente → visual +\\Nvestibular + propioceptivo","guid":"","children":[]},{"id":"45","parent":"43","text":"Ejecución SNC → corteza frontal + ganglios\\Nbasales + cerebelo + médula","guid":"","children":[]},{"id":"46","parent":"43","text":"Efector → cardiovascular +\\Nhuesos + articulaciones + pies","guid":"","children":[]},{"id":"47","parent":"43","text":"**Cognitivo** → atención y función\\Nejecutiva influyen directamente","guid":"","children":[]}]},{"id":"48","parent":"42","text":"Cambios del envejecimiento","guid":"","children":[{"id":"49","parent":"48","text":"Velocidad de marcha\\Nestable hasta 70 años","guid":"","children":[]},{"id":"50","parent":"48","text":"Después → **↓15%/década** marcha\\Ncomún, **↓20%** marcha rápida","guid":"","children":[]},{"id":"51","parent":"48","text":"Tiempo doble apoyo → Jóvenes\\N18% vs AM **>26%**","guid":"","children":[]},{"id":"52","parent":"48","text":"Postura inclinada\\Nadelante (cifosis dorsal)","guid":"","children":[]}]},{"id":"53","parent":"42","text":"\"Marcha senil\" → **NO existe\\Ncomo entidad normal**","guid":"","children":[{"id":"54","parent":"53","text":"Alteraciones son marcadores\\Nprecoces de patología","guid":"","children":[]}]}]},{"id":"55","parent":"0","text":"Factores de Riesgo","guid":"","children":[{"id":"56","parent":"55","text":"Intrínsecos (JAMA 2024)","guid":"","children":[{"id":"57","parent":"56","text":"MAYOR (OR >2)","guid":"","children":[{"id":"58","parent":"57","text":"**Neuropatía periférica**","guid":"","children":[]},{"id":"59","parent":"57","text":"**Parkinson**","guid":"","children":[]},{"id":"60","parent":"57","text":"**Deterioro cognitivo** → MMSE <22\\N↑riesgo; cada punto menos ↑20%","guid":"","children":[]},{"id":"61","parent":"57","text":"ACV","guid":"","children":[]},{"id":"62","parent":"57","text":"**Anormalidad de la marcha**","guid":"","children":[]},{"id":"63","parent":"57","text":"Vértigo/Mareo","guid":"","children":[]}]},{"id":"64","parent":"56","text":"MODERADO (OR 1.5-2.0)","guid":"","children":[{"id":"65","parent":"64","text":"Artritis","guid":"","children":[]},{"id":"66","parent":"64","text":"**Fragilidad** (pérdida peso,\\Nagotamiento, debilidad, marcha lenta)","guid":"","children":[]},{"id":"67","parent":"64","text":"Hipotensión ortostática → 30% en\\N>65a, 70% institucionalizados","guid":"","children":[]},{"id":"68","parent":"64","text":"Incontinencia urinaria","guid":"","children":[]},{"id":"69","parent":"64","text":"Déficit visual/auditivo","guid":"","children":[]},{"id":"70","parent":"64","text":"Dolor","guid":"","children":[]}]},{"id":"71","parent":"56","text":"MENOR (OR <1.5)","guid":"","children":[{"id":"72","parent":"71","text":"Diabetes → insulina **RR 2.76**","guid":"","children":[]},{"id":"73","parent":"71","text":"Enfermedad cardíaca → IC\\N↑14%, FA **OR 1.98**","guid":"","children":[]},{"id":"74","parent":"71","text":"IMC bajo ≤18.5 o alto ≥30","guid":"","children":[]}]}]},{"id":"75","parent":"55","text":"Extrínsecos (ambientales)","guid":"","children":[{"id":"76","parent":"75","text":"**Interruptor lejos puerta baño**\\N→ RR **9.26** (el mayor)","guid":"","children":[]},{"id":"77","parent":"75","text":"Entrada con desnivel → RR **5.54**","guid":"","children":[]},{"id":"78","parent":"75","text":"Baño sin barras en\\Nducha → RR **4.69**","guid":"","children":[]},{"id":"79","parent":"75","text":"Baño sin barras en\\NWC → RR **3.91**","guid":"","children":[]},{"id":"80","parent":"75","text":"Alfombras sueltas cocina → RR 3.02","guid":"","children":[]},{"id":"81","parent":"75","text":"Animales domésticos → RR 2.1","guid":"","children":[]}]},{"id":"82","parent":"55","text":"Determinantes sociales","guid":"","children":[{"id":"83","parent":"82","text":"Menor nivel\\Neconómico → más\\Ncaídas","guid":"","children":[]},{"id":"84","parent":"82","text":"Mujeres caen más\\N(sarcopenia, polifarmacia)","guid":"","children":[]},{"id":"85","parent":"82","text":"Hombres →\\Nconsecuencias más\\Ngraves","guid":"","children":[]}]},{"id":"86","parent":"55","text":"Precipitantes","guid":"","children":[{"id":"87","parent":"86","text":"Resbalones, tropiezos","guid":"","children":[]},{"id":"88","parent":"86","text":"Síncope, mareos agudos","guid":"","children":[]},{"id":"89","parent":"86","text":"Convulsiones","guid":"","children":[]},{"id":"90","parent":"86","text":"Introducción nuevo fármaco","guid":"","children":[]}]}]},{"id":"91","parent":"0","text":"Osteosarcopenia","guid":"","children":[{"id":"92","parent":"91","text":"Sarcopénicos → **caen más**","guid":"","children":[]},{"id":"93","parent":"91","text":"Osteoporóticos → **se\\Nfracturan más**","guid":"","children":[]},{"id":"94","parent":"91","text":"**Osteosarcopénicos** → peores\\Nresultados (caen más + fracturas)","guid":"","children":[]}]},{"id":"95","parent":"0","text":"Evaluación Clínica","guid":"","children":[{"id":"96","parent":"95","text":"Screening anual obligatorio","guid":"","children":[{"id":"97","parent":"96","text":"3 preguntas clave","guid":"","children":[{"id":"98","parent":"97","text":"1. ¿≥1 caída últimos 12 meses?","guid":"","children":[]},{"id":"99","parent":"97","text":"2. ¿Se siente inestable al\\Nponerse de pie o caminar?","guid":"","children":[]},{"id":"100","parent":"97","text":"3. ¿Tiene miedo a caer?","guid":"","children":[]}]},{"id":"101","parent":"96","text":"**≥1 respuesta \"Sí\"** →\\Nevaluar marcha y equilibrio","guid":"","children":[]}]},{"id":"102","parent":"95","text":"Criterio evaluación exhaustiva","guid":"","children":[{"id":"103","parent":"102","text":"≥2 caídas","guid":"","children":[]},{"id":"104","parent":"102","text":"1 caída que requirió atención médica","guid":"","children":[]},{"id":"105","parent":"102","text":"Inestabilidad reportada","guid":"","children":[]}]},{"id":"106","parent":"95","text":"Estratificación de riesgo","guid":"","children":[{"id":"107","parent":"106","text":"Bajo (<30%) → 0 caídas, todo \"No\"","guid":"","children":[]},{"id":"108","parent":"106","text":"Intermedio → ≥1 \"Sí\" con\\Npruebas normales","guid":"","children":[]},{"id":"109","parent":"106","text":"**Alto (70%)** → lesión, ≥2 caídas, fragilidad,\\Nsíncope, incapacidad levantarse","guid":"","children":[]}]},{"id":"110","parent":"95","text":"Tests funcionales","guid":"","children":[{"id":"111","parent":"110","text":"**TUG (Time Up and Go)**","guid":"","children":[{"id":"112","parent":"111","text":"Normal → <10 seg","guid":"","children":[]},{"id":"113","parent":"111","text":"Riesgo leve → 11-19 seg","guid":"","children":[]},{"id":"114","parent":"111","text":"**Alto riesgo** → >20\\Nseg (NICE >15 seg)","guid":"","children":[]}]},{"id":"115","parent":"110","text":"**Velocidad de marcha**","guid":"","children":[{"id":"116","parent":"115","text":"Normal → 0.8-1.3 m/s","guid":"","children":[]},{"id":"117","parent":"115","text":"**Patológico** → ≤0.8 m/s","guid":"","children":[]}]},{"id":"118","parent":"110","text":"Estancia unipodal","guid":"","children":[{"id":"119","parent":"118","text":"Normal → ≥5 seg","guid":"","children":[]},{"id":"120","parent":"118","text":"Patológico → <5 seg","guid":"","children":[]}]},{"id":"121","parent":"110","text":"**Tinetti (POMA)**","guid":"","children":[{"id":"122","parent":"121","text":"Alto riesgo → <18 puntos","guid":"","children":[]},{"id":"123","parent":"121","text":"Moderado → 19-23","guid":"","children":[]},{"id":"124","parent":"121","text":"Bajo → ≥24","guid":"","children":[]}]},{"id":"125","parent":"110","text":"**SPPB**","guid":"","children":[{"id":"126","parent":"125","text":"<10 → predice deterioro\\Nfuncional y caídas","guid":"","children":[]}]},{"id":"127","parent":"110","text":"Dual task","guid":"","children":[{"id":"128","parent":"127","text":"Alteración de marcha en doble\\Ntarea → **x3 riesgo de caer**","guid":"","children":[]}]}]},{"id":"129","parent":"95","text":"VGI en alto riesgo","guid":"","children":[{"id":"130","parent":"129","text":"Movilidad → equilibrio, marcha,\\Nfuerza (Handgrip), pies/calzado","guid":"","children":[]},{"id":"131","parent":"129","text":"Sensorial → visión, audición,\\Nvestibular (Hallpike)","guid":"","children":[]},{"id":"132","parent":"129","text":"Cognitivo → función\\Nejecutiva, delirium","guid":"","children":[]},{"id":"133","parent":"129","text":"CV → hipotensión\\Nortostática, ECG/Holter","guid":"","children":[]},{"id":"134","parent":"129","text":"Fármacos → revisión crítica FRIDs","guid":"","children":[]}]},{"id":"135","parent":"95","text":"Examen físico específico","guid":"","children":[{"id":"136","parent":"135","text":"Hipotensión ortostática → ↓PAS ≥20 o\\N↓PAD ≥10 mmHg tras 3 min de pie","guid":"","children":[]},{"id":"137","parent":"135","text":"Mareo postural sin caída PA →\\Nconsiderar equivalente","guid":"","children":[]}]}]},{"id":"138","parent":"0","text":"Fármacos y Caídas (FRIDs)","guid":"","children":[{"id":"139","parent":"138","text":"Cambios farmacocinéticos en AM","guid":"","children":[{"id":"140","parent":"139","text":"↑ pH gástrico, ↓ flujo GI","guid":"","children":[]},{"id":"141","parent":"139","text":"↓ agua corporal, ↓\\Nalbúmina → ↑ fracción\\Nlibre","guid":"","children":[]},{"id":"142","parent":"139","text":"↓ masa magra, ↑ grasa →\\Nacumulación lipofílicos","guid":"","children":[]},{"id":"143","parent":"139","text":"↓ VFG y flujo renal","guid":"","children":[]}]},{"id":"144","parent":"138","text":"Medicamentos de alto\\Nriesgo (JAMA 2024)","guid":"","children":[{"id":"145","parent":"144","text":"**Antiepilépticos** → OR **2.42**","guid":"","children":[]},{"id":"146","parent":"144","text":"**Opiáceos** → OR **1.60**","guid":"","children":[]},{"id":"147","parent":"144","text":"**Antidepresivos** → OR **1.48**\\N(evitar ATC y paroxetina)","guid":"","children":[]},{"id":"148","parent":"144","text":"Ansiolíticos → OR **1.40**","guid":"","children":[]},{"id":"149","parent":"144","text":"Antipsicóticos → OR\\N**1.38** (crudo 2.30)","guid":"","children":[]},{"id":"150","parent":"144","text":"Sedantes/Hipnóticos →\\NOR crudo **2.05**","guid":"","children":[]}]},{"id":"151","parent":"138","text":"Otros fármacos","guid":"","children":[{"id":"152","parent":"151","text":"**Insulina** → RR **2.76**","guid":"","children":[]},{"id":"153","parent":"151","text":"Digitálicos → OR crudo 2.06","guid":"","children":[]},{"id":"154","parent":"151","text":"Antihipertensivos → OR 1.24","guid":"","children":[]},{"id":"155","parent":"151","text":"Diuréticos → OR 1.07 (mínimo,\\Nriesgo por urgencia miccional)","guid":"","children":[]},{"id":"156","parent":"151","text":"Betabloqueadores → no significativo","guid":"","children":[]}]},{"id":"157","parent":"138","text":"Deprescripción aislada **NO\\Nbasta** (BMJ Open 2021)","guid":"","children":[{"id":"158","parent":"157","text":"Posible\\Ndescompensación\\Npatología base","guid":"","children":[]},{"id":"159","parent":"157","text":"Debe ser parte de\\Nestrategia\\Nmulticomponente","guid":"","children":[]}]}]},{"id":"160","parent":"0","text":"Manejo e Intervenciones","guid":"","children":[{"id":"161","parent":"160","text":"Principio fundamental","guid":"","children":[{"id":"162","parent":"161","text":"**Multicomponente** >\\Nintervención única","guid":"","children":[]},{"id":"163","parent":"161","text":"Vitamina D sola, educación sola, adaptaciones\\Nvivienda solas → **NO impacto**","guid":"","children":[]}]},{"id":"164","parent":"160","text":"Ejercicio (Recomendación A)","guid":"","children":[{"id":"165","parent":"164","text":"RR **0.78** (Cochrane)","guid":"","children":[]},{"id":"166","parent":"164","text":"Dosis efectiva → mínimo **2\\Nhrs/semana x 25 semanas**","guid":"","children":[]},{"id":"167","parent":"164","text":"Frecuencia óptima →\\N≥5 veces/semana","guid":"","children":[]},{"id":"168","parent":"164","text":"**Entrenamiento integrado** → SMD **3.\\N16** (p=0.002) más efectivo","guid":"","children":[]},{"id":"169","parent":"164","text":"Duración >32 semanas →\\Nmayor efectividad","guid":"","children":[]},{"id":"170","parent":"164","text":"**Efecto se pierde si no se\\Nmantiene** (Age and Ageing 2023)","guid":"","children":[]},{"id":"171","parent":"164","text":"Componentes","guid":"","children":[{"id":"172","parent":"171","text":"**Equilibrio** (fundamental) → tándem,\\NTai Chi, transferencias peso","guid":"","children":[]},{"id":"173","parent":"171","text":"**Fuerza** → especial utilidad\\Nen frágiles/sarcopénicos","guid":"","children":[]},{"id":"174","parent":"171","text":"Aeróbico solo NO suficiente","guid":"","children":[]}]},{"id":"175","parent":"164","text":"Tai Chi → RR **0.71** en comunidad","guid":"","children":[]}]},{"id":"176","parent":"160","text":"Vivifrail (clasificación funcional)","guid":"","children":[{"id":"177","parent":"176","text":"Discapacidad → SPPB\\N0-3, VM <0.5 m/s","guid":"","children":[]},{"id":"178","parent":"176","text":"Fragilidad → SPPB 4-6,\\NVM 0.5-0.8 m/s","guid":"","children":[]},{"id":"179","parent":"176","text":"Pre-fragilidad → SPPB\\N7-9, VM 0.9-1 m/s","guid":"","children":[]},{"id":"180","parent":"176","text":"Robusto → SPPB 10-12, VM >1 m/s","guid":"","children":[]}]},{"id":"181","parent":"160","text":"Intervención ambiental","guid":"","children":[{"id":"182","parent":"181","text":"TO con visitas\\Ndomiciliarias →\\Nefectivo","guid":"","children":[]},{"id":"183","parent":"181","text":"Visita enfermería\\Naislada → sin efecto","guid":"","children":[]}]},{"id":"184","parent":"160","text":"Ayudas técnicas","guid":"","children":[{"id":"185","parent":"184","text":"Beneficio en movilidad","guid":"","children":[]},{"id":"186","parent":"184","text":"**Sin claro beneficio** en\\Nprevención si no se entrenan","guid":"","children":[]}]},{"id":"187","parent":"160","text":"Protectores de cadera","guid":"","children":[{"id":"188","parent":"187","text":"RR 0.82 en\\Ninstitucionalizados\\N(Cochrane 2014)","guid":"","children":[]},{"id":"189","parent":"187","text":"Problema → baja adherencia","guid":"","children":[]}]},{"id":"190","parent":"160","text":"Vitamina D/Calcio","guid":"","children":[{"id":"191","parent":"190","text":"**NO recomendado para\\Nprevención per se**","guid":"","children":[]},{"id":"192","parent":"190","text":"Solo suplementar si\\Ndéficit <20-30 ng/mL","guid":"","children":[]}]},{"id":"193","parent":"160","text":"Oftalmología","guid":"","children":[{"id":"194","parent":"193","text":"Lentes multifocales pueden ↑ riesgo\\N(alteran percepción profundidad)","guid":"","children":[]},{"id":"195","parent":"193","text":"Cirugía cataratas → 1ª puede reducir\\Ncaídas, pero riesgo post-operatorio","guid":"","children":[]}]},{"id":"196","parent":"160","text":"Clínicas de Prevención de\\NCaídas (Maturitas 2019)","guid":"","children":[{"id":"197","parent":"196","text":"6 meses de seguimiento","guid":"","children":[{"id":"198","parent":"197","text":"Miedo a caer muy preocupado → 28.\\N4% → **13.7%** (p=0.0015)","guid":"","children":[]},{"id":"199","parent":"197","text":"Sin caídas últimos 6m → 4.6%\\N→ **67.9%** (p<0.00001)","guid":"","children":[]},{"id":"200","parent":"197","text":"Lesiones serias → 30.5% →\\N**6.1%** (p<0.00001)","guid":"","children":[]}]}]}]},{"id":"201","parent":"0","text":"Miedo a Caer (Síndrome Post-Caída)","guid":"","children":[{"id":"202","parent":"201","text":"Definición","guid":"","children":[{"id":"203","parent":"202","text":"Pérdida de confianza para evitar\\Ncaídas en actividades esenciales","guid":"","children":[]},{"id":"204","parent":"202","text":"Evitación de actividades que el\\Nsujeto es capaz de realizar","guid":"","children":[]}]},{"id":"205","parent":"201","text":"Ciclo vicioso","guid":"","children":[{"id":"206","parent":"205","text":"Miedo → ↓actividad → ↓masa\\Nmuscular/equilibrio → ↑riesgo →\\Ncaída → más miedo","guid":"","children":[]}]},{"id":"207","parent":"201","text":"Prevalencia","guid":"","children":[{"id":"208","parent":"207","text":"25% de caídas generales","guid":"","children":[]},{"id":"209","parent":"207","text":"**50%** tras fractura de cadera","guid":"","children":[]}]},{"id":"210","parent":"201","text":"Evaluación → Short FES-I (7 ítems)","guid":"","children":[{"id":"211","parent":"210","text":"7-8 → preocupación baja","guid":"","children":[]},{"id":"212","parent":"210","text":"9-13 → moderada","guid":"","children":[]},{"id":"213","parent":"210","text":"14-28 → **alta**","guid":"","children":[]}]},{"id":"214","parent":"201","text":"Factores asociados","guid":"","children":[{"id":"215","parent":"214","text":"Alto riesgo (Downton\\N≥3) → OR **7.0**","guid":"","children":[]},{"id":"216","parent":"214","text":"Caídas previas → OR **6.1**","guid":"","children":[]},{"id":"217","parent":"214","text":"Fuerza MMII\\Ndisminuida → OR **5.\\N0**","guid":"","children":[]},{"id":"218","parent":"214","text":"VM disminuida → OR **4.8**","guid":"","children":[]}]},{"id":"219","parent":"201","text":"Factores de riesgo para desarrollarlo","guid":"","children":[{"id":"220","parent":"219","text":"Long lie (>1 hora en suelo)","guid":"","children":[]},{"id":"221","parent":"219","text":">3 caídas/año","guid":"","children":[]},{"id":"222","parent":"219","text":"No poder levantarse solo","guid":"","children":[]}]},{"id":"223","parent":"201","text":"Intervenciones efectivas","guid":"","children":[{"id":"224","parent":"223","text":"TCC","guid":"","children":[]},{"id":"225","parent":"223","text":"Tai Chi grupal","guid":"","children":[]},{"id":"226","parent":"223","text":"Ejercicios multicomponente","guid":"","children":[]},{"id":"227","parent":"223","text":"Ajuste fármacos","guid":"","children":[]},{"id":"228","parent":"223","text":"Protector de cadera","guid":"","children":[]}]}]},{"id":"229","parent":"0","text":"Caídas Recurrentes (≥2/año)","guid":"","children":[{"id":"230","parent":"229","text":"Dominios que predicen (Jehu\\Net al, Maturitas 2020)","guid":"","children":[{"id":"231","parent":"230","text":"Balance y movilidad → RR **1.32**","guid":"","children":[]},{"id":"232","parent":"230","text":"Medicación → RR **1.53**","guid":"","children":[]},{"id":"233","parent":"230","text":"Psicológico → RR **1.35**","guid":"","children":[]},{"id":"234","parent":"230","text":"Sensorial/neuromuscular\\N→ RR **1.51**","guid":"","children":[]}]},{"id":"235","parent":"229","text":"Marcadores de fragilidad →\\Nhasta **53% más probabilidad**\\Nde caídas recurrentes","guid":"","children":[]}]},{"id":"236","parent":"0","text":"Long Lie (Permanencia en suelo)","guid":"","children":[{"id":"237","parent":"236","text":"**50%** de AM no\\Nlogra levantarse solo","guid":"","children":[]},{"id":"238","parent":"236","text":"Riesgos","guid":"","children":[{"id":"239","parent":"238","text":"UPP","guid":"","children":[]},{"id":"240","parent":"238","text":"Deshidratación","guid":"","children":[]},{"id":"241","parent":"238","text":"Rabdomiólisis","guid":"","children":[]},{"id":"242","parent":"238","text":"Deterioro ABVD","guid":"","children":[]}]}]},{"id":"243","parent":"0","text":"Perlas Clínicas ⭐","guid":"","children":[{"id":"244","parent":"243","text":"Pregunta obligatoria anual → \"¿Se ha caído?\\N¿Inestabilidad? ¿Miedo a caer?\"","guid":"","children":[]},{"id":"245","parent":"243","text":"**1 respuesta positiva activa\\Nevaluación** de marcha y equilibrio","guid":"","children":[]},{"id":"246","parent":"243","text":"Velocidad de marcha <0.8 m/s →\\N**signo vital patológico**","guid":"","children":[]},{"id":"247","parent":"243","text":"Interruptores lejos de puerta baño → mayor\\Npeligro extrínseco (**RR 9.26**)","guid":"","children":[]},{"id":"248","parent":"243","text":"Deterioro cognitivo NO amnésico\\N(frontal/ejecutivo) → cae más que\\NAlzheimer típico","guid":"","children":[]},{"id":"249","parent":"243","text":"Deprescripción aislada NO basta →\\Nestrategia multicomponente obligatoria","guid":"","children":[]},{"id":"250","parent":"243","text":"Ejercicio debe ser\\N**multicomponente** (fuerza +\\Nequilibrio) y **mantenido** en el\\Ntiempo","guid":"","children":[]},{"id":"251","parent":"243","text":"Caída en casa → paciente frágil/enfermo;\\NCaída en calle → paciente activo","guid":"","children":[]},{"id":"252","parent":"243","text":"Institucionalización → **21% cae el\\Nprimer mes** (vigilancia extrema)","guid":"","children":[]},{"id":"253","parent":"243","text":"Lentes multifocales → precaución en\\Nalto riesgo (distorsionan suelo)","guid":"","children":[]},{"id":"254","parent":"243","text":"\"Le toma a un niño 1 año adquirir la marcha y hasta 10 años\\Nla independencia; la persona mayor puede perder ambos el\\Nmismo día\" (Prof. Bernard Isaacs)","guid":"","children":[]}]}]},"node_count":263,"relations":[],"cross_references":[],"specialty":"Geriatría","folder":"Entidades clínicas/Ortogeriatría","filename":"Orto Caidas-2026","id":"map_1524","resolved_references":[],"title_raw":"Orto Caidas-2026"}