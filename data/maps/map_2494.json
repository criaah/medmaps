,"children":[]}]},{"id":"121","parent":"0","text":"Valoración de la Lesión","guid":"A0ekZY9QXgNTi0u0LYXqlA","children":[{"id":"122","parent":"121","text":"TIME / DOMINATE","guid":"rVOhK2vGuA4ygMnurgmF-Q","children":[{"id":"123","parent":"122","text":"T → Tejido (granulación, esfacelo, necrosis, epitelización %)","guid":"7chYCiPR60uuoLtAPKmyOA","children":[]},{"id":"124","parent":"122","text":"I → Infección / Inflamación","guid":"c4Rx5ru63p27UqJY1pTAqw","children":[]},{"id":"125","parent":"122","text":"M → Humedad (Moisture) / exudado","guid":"A2XriV2alFyiFK2DoedRmA","children":[]},{"id":"126","parent":"122","text":"E → Epidermis / bordes","guid":"iSmR-bNrnqHxkIinl1HFZQ","children":[]}]},{"id":"127","parent":"121","text":"Parámetros medibles","guid":"lpOUu1La6fN1TFB10RR0gA","children":[{"id":"128","parent":"127","text":"Tamaño (largo x ancho x profundidad, cm)","guid":"yAgD6Uqc-75SoYcbXxPiXQ","children":[]},{"id":"129","parent":"127","text":"Tunelizaciones / socavaciones","guid":"uIh-C_R7gCXof9cNnc65DQ","children":[]},{"id":"130","parent":"127","text":"Exudado (cantidad, color, olor)","guid":"GZjbrNBnfZ69KrAHrnl5YQ","children":[]},{"id":"131","parent":"127","text":"Dolor → EVA","guid":"ZLecJy_K5HTG9dEZCuUT4w","children":[]},{"id":"132","parent":"127","text":"Piel perilesional","guid":"t9qPlBCv3-lcNeGBOlxXLw","children":[]}]},{"id":"133","parent":"121","text":"VACAB (Chile)","guid":"-M94m95DawtsBKb0Dt0z5w","children":[{"id":"134","parent":"133","text":"Valoración de Carga Bacteriana","guid":"7m7yDlR-BnR2EbH8_j0D5w","children":[]},{"id":"135","parent":"133","text":"Clasifica colonización vs infección","guid":"Z-psodOnkHF311S3bDffwQ","children":[]},{"id":"136","parent":"133","text":"Define uso de antimicrobianos tópicos","guid":"QyfEBvF4fuLFTO69UaTHXw","children":[]}]},{"id":"137","parent":"121","text":"Signos de infección","guid":"6v0USRG8jXU6lZvX7lNPPA","children":[{"id":"138","parent":"137","text":"Clásicos → calor, rubor, dolor, pus","guid":"1haqZQF47ufFxRBM-8rcpg",