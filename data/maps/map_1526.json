onstipados","guid":"","children":[]}]},{"id":"60","parent":"45","text":"Neurológico","guid":"","children":[{"id":"61","parent":"60","text":"**Enfermedad de Parkinson** →\\Nsíntoma temprano,\\Ndegeneración plexo mientérico","guid":"","children":[]},{"id":"62","parent":"60","text":"Demencia → dismotilidad rectal,\\Nignora impulso defecar","guid":"","children":[]},{"id":"63","parent":"60","text":"ACV → 60% en rehabilitación","guid":"","children":[]},{"id":"64","parent":"60","text":"Esclerosis múltiple","guid":"","children":[]}]},{"id":"65","parent":"45","text":"Otros","guid":"","children":[{"id":"66","parent":"65","text":"**Inmovilidad** → tránsito hasta 3\\Nsemanas en postrados","guid":"","children":[]},{"id":"67","parent":"65","text":"Deshidratación","guid":"","children":[]},{"id":"68","parent":"65","text":"Depresión","guid":"","children":[]},{"id":"69","parent":"65","text":"Obstrucción mecánica\\N(tumor, rectocele)","guid":"","children":[]},{"id":"70","parent":"65","text":"Cáncer colorrectal → >2x riesgo si\\N<2 deposiciones/semana","guid":"","children":[]}]}]}]},{"id":"71","parent":"0","text":"Factores de riesgo","guid":"","children":[{"id":"72","parent":"71","text":"**Polifarmacia** (≥5 medicamentos)","guid":"","children":[]},{"id":"73","parent":"71","text":"Bajo consumo líquidos (<1.5L/día)","guid":"","children":[]},{"id":"74","parent":"71","text":"Baja fibra dietética","guid":"","children":[]},{"id":"75","parent":"71","text":"Movilidad reducida → correlato más\\Nfuerte uso intensivo laxantes","guid":"","children":[]},{"id":"76","parent":"71","text":"Demencia","guid":"","children":[]},{"id":"77","parent":"71","text":"Neumonía","guid":"","children":[]},{"id":"78","parent":"71","text":"Hipotiroidismo","guid":"","children":[]},{"id":"79","parent":"71","text":"Artritis/hipertensión → por\\Nmedicamentos asociados","guid":"","children":[]}]},{"id":"80","parent":"0","text":"Complicaciones","guid":"","children":[{"id":"81","parent":"80","text":"**Impactación fecal** → 27% diagnóstico\\Nprimario en hospitalizados geriátricos","guid":"","children":[]},{"id":"82","parent":"80","text":"IF por rebalse → fuga pasiva heces\\Nlíquidas (confundida con \"diarrea\")","guid":"","children":[]},{"id":"83","parent":"80","text":"Obstrucción intestinal","guid":"","children":[]},{"id":"84","parent":"80","text":"Perforación estercoral","guid":"","children":[]},{"id":"85","parent":"80","text":"Vólvulo sigmoideo","guid":"","children":[]},{"id":"86","parent":"80","text":"Retención urinaria","guid":"","children":[]},{"id":"87","parent":"80","text":"Delirium/anorexia/deterioro\\Nfuncional inespecífico","guid":"","children":[]}]},{"id":"88","parent":"0","text":"Evaluación","guid":"","children":[{"id":"89","parent":"88","text":"Historia clínica","guid":"","children":[{"id":"90","parent":"89","text":"Diario de heces 1 semana","guid":"","children":[]},{"id":"91","parent":"89","text":"**Escala Bristol** → tipos 1-2\\Nindican tránsito lento","guid":"","children":[]},{"id":"92","parent":"89","text":"Frecuencia, consistencia, pujo,\\Nevacuación incompleta","guid":"","children":[]},{"id":"93","parent":"89","text":"Uso maniobras manuales","guid":"","children":[]},{"id":"94","parent":"89","text":"Síntomas alarma → pérdida\\Npeso, sangrado rectal, anemia,\\Ncambio reciente hábito","guid":"","children":[]}]},{"id":"95","parent":"88","text":"Examen físico","guid":"","children":[{"id":"96","parent":"95","text":"**Tacto rectal IMPRESCINDIBLE**","guid":"","children":[{"id":"97","parent":"96","text":"Evaluar tono esfínter interno/externo","guid":"","children":[]},{"id":"98","parent":"96","text":"Impactación no siempre dura → puede\\Nser heces blandas retenidas","guid":"","children":[]},{"id":"99","parent":"96","text":"**Recto vacío NO excluye\\Nimpactación** → puede ser colónica","guid":"","children":[]}]},{"id":"100","parent":"95","text":"Inspección perianal →\\Nhemorroides, prolapso, fisuras","guid":"","children":[]},{"id":"101","parent":"95","text":"Maniobras diagnósticas:","guid":"","children":[{"id":"102","parent":"101","text":"\"Apriete\" (squeeze) →\\Nevalúa esfínter anal","guid":"","children":[]},{"id":"103","parent":"101","text":"\"Empuje\" (push) → debe relajar esfínter\\Nexterno + descenso perineal","guid":"","children":[]}]},{"id":"104","parent":"95","text":"Palpación/auscultación abdominal","guid":"","children":[]}]},{"id":"105","parent":"88","text":"Estudios","guid":"","children":[{"id":"106","parent":"105","text":"**Rx abdomen simple** indicaciones:","guid":"","children":[{"id":"107","parent":"106","text":"Recto vacío con\\Nsospecha impactación","guid":"","children":[]},{"id":"108","parent":"106","text":"IF persistente post-desimpactación","guid":"","children":[]},{"id":"109","parent":"106","text":"Dolor/distensión abdominal","guid":"","children":[]},{"id":"110","parent":"106","text":"Heces en ciego = tránsito lento","guid":"","children":[]}]},{"id":"111","parent":"105","text":"Colonoscopia indicaciones:","guid":"","children":[{"id":"112","parent":"111","text":"Síntomas alarma","guid":"","children":[]},{"id":"113","parent":"111","text":"Sangrado rectal","guid":"","children":[]},{"id":"114","parent":"111","text":"Cambio reciente hábito intestinal","guid":"","children":[]},{"id":"115","parent":"111","text":">50 años sin screening previo","guid":"","children":[]}]},{"id":"116","parent":"105","text":"Manometría anorrectal →\\Nconfirma disinergia pélvica","guid":"","children":[]},{"id":"117","parent":"105","text":"Estudios tránsito colónico","guid":"","children":[{"id":"118","parent":"117","text":"**Sitzmarks** → >5\\Nmarcadores retenidos día 5","guid":"","children":[]},{"id":"119","parent":"117","text":"Dispersos → tránsito lento","guid":"","children":[]},{"id":"120","parent":"117","text":"Acumulados rectosigmoides\\N→ disfunción salida","guid":"","children":[]}]},{"id":"121","parent":"105","text":"Defecografía →\\Nanormalidades\\Nanatómicas","guid":"","children":[]}]}]},{"id":"122","parent":"0","text":"Tratamiento no farmacológico","guid":"","children":[{"id":"123","parent":"122","text":"**Entrenamiento\\Nintestinal** → primera\\Nlínea","guid":"","children":[{"id":"124","parent":"123","text":"Ir al baño cuando surja urgencia","guid":"","children":[]},{"id":"125","parent":"123","text":"Postura correcta → pies\\Nen taburete bajo","guid":"","children":[]},{"id":"126","parent":"123","text":"No sentarse >10 min","guid":"","children":[]},{"id":"127","parent":"123","text":"**Respiración diafragmática** →\\Ninspiración profunda, espiración fuerte","guid":"","children":[]},{"id":"128","parent":"123","text":"Aprovechar reflejo\\Ngastrocólico (post-prandial)","guid":"","children":[]}]},{"id":"129","parent":"122","text":"Dieta","guid":"","children":[{"id":"130","parent":"129","text":"Fibra **10-30 g/día**\\N(aumentar gradualmente)","guid":"","children":[]},{"id":"131","parent":"129","text":"**Fibra soluble** > insoluble","guid":"","children":[]},{"id":"132","parent":"129","text":"Líquidos **1.5-2 L/día**","guid":"","children":[]}]},{"id":"133","parent":"122","text":"Actividad física","guid":"","children":[{"id":"134","parent":"133","text":"Caminata 30 min diaria","guid":"","children":[]},{"id":"135","parent":"133","text":"↑ HAPCs posprandiales","guid":"","children":[]}]},{"id":"136","parent":"122","text":"Masaje abdominal → cierta evidencia","guid":"","children":[]},{"id":"137","parent":"122","text":"Privacidad/dignidad → intervención\\Nterapéutica clave en institucionalizados","guid":"","children":[]},{"id":"138","parent":"122","text":"**Biofeedback** → tratamiento MÁS\\NEFECTIVO para disfunción piso pélvico","guid":"","children":[{"id":"139","parent":"138","text":"Superior a laxantes en DTS","guid":"","children":[]},{"id":"140","parent":"138","text":"Efecto duradero","guid":"","children":[]},{"id":"141","parent":"138","text":"Efectivo en adultos mayores\\Nsin deterioro cognitivo","guid":"","children":[]}]}]},{"id":"142","parent":"0","text":"Tratamiento farmacológico","guid":"","children":[{"id":"143","parent":"142","text":"Enfoque escalonado","guid":"","children":[]},{"id":"144","parent":"142","text":"Formadores de volumen","guid":"","children":[{"id":"145","parent":"144","text":"Psyllium, metilcelulosa","guid":"","children":[]},{"id":"146","parent":"144","text":"Requieren hidratación adecuada","guid":"","children":[]},{"id":"147","parent":"144","text":"**NO en disfunción piso\\Npélvico** → puede empeorar","guid":"","children":[]}]},{"id":"148","parent":"142","text":"Laxantes osmóticos","guid":"","children":[{"id":"149","parent":"148","text":"**PEG (polietilenglicol)** → casos\\Nalto riesgo, desimpactación","guid":"","children":[]},{"id":"150","parent":"148","text":"Lactulosa/sorbitol","guid":"","children":[]},{"id":"151","parent":"148","text":"Leche magnesia → **precaución en\\NERC (hipermagnesemia)**","guid":"","children":[]}]},{"id":"152","parent":"142","text":"Laxantes estimulantes","guid":"","children":[{"id":"153","parent":"152","text":"**Senna** 1-3 tabletas al acostarse","guid":"","children":[]},{"id":"154","parent":"152","text":"Bisacodilo","guid":"","children":[]},{"id":"155","parent":"152","text":"Melanosis coli → hallazgo benigno,\\NNO causa daño intestinal","guid":"","children":[]}]},{"id":"156","parent":"142","text":"Supositorios/enemas","guid":"","children":[{"id":"157","parent":"156","text":"**Subutilizados** en\\Nretraso evacuación rectal","guid":"","children":[]},{"id":"158","parent":"156","text":"Glicerina → mejora\\Nvaciamiento rectal","guid":"","children":[]},{"id":"159","parent":"156","text":"Bisacodilo supositorio →\\Nsíntomas persistentes","guid":"","children":[]},{"id":"160","parent":"156","text":"**EVITAR enemas fosfato en\\Nadulto mayor** → alteraciones\\Nelectrolíticas fatales","guid":"","children":[]},{"id":"161","parent":"156","text":"Enemas agua grifo →\\Nseguros para uso regular","guid":"","children":[]}]},{"id":"162","parent":"142","text":"Agentes nuevos","guid":"","children":[{"id":"163","parent":"162","text":"**Lubiprostona** 24 µg BID","guid":"","children":[{"id":"164","parent":"163","text":"Activa canales ClC-2 →\\Nsecreción fluidos","guid":"","children":[]},{"id":"165","parent":"163","text":"Náuseas (menos en ancianos,\\Nmejora con comida)","guid":"","children":[]},{"id":"166","parent":"163","text":"Sin alteraciones electrolíticas","guid":"","children":[]}]},{"id":"167","parent":"162","text":"**Linaclotida** 72-145 µg/día\\Nconstipación, 290 µg/día SII-C","guid":"","children":[{"id":"168","parent":"167","text":"Agonista GC-C → ↑ GMPc\\N→ secreción Cl/HCO3","guid":"","children":[]},{"id":"169","parent":"167","text":"Diarrea dosis-dependiente","guid":"","children":[]},{"id":"170","parent":"167","text":"Datos limitados en ancianos","guid":"","children":[]}]},{"id":"171","parent":"162","text":"**Prucaloprida** → agonista 5-HT4","guid":"","children":[{"id":"172","parent":"171","text":"Dosis estándar 2 mg/día","guid":"","children":[]},{"id":"173","parent":"171","text":"**En >65 años →\\Nconsiderar 1 mg/día**","guid":"","children":[]},{"id":"174","parent":"171","text":"Sin efectos CV adversos","guid":"","children":[]}]}]},{"id":"175","parent":"142","text":"Constipación inducida opioides (CIO)","guid":"","children":[{"id":"176","parent":"175","text":"Responde mal a\\Nlaxantes convencionales","guid":"","children":[]},{"id":"177","parent":"175","text":"**PAMORA**\\N(antagonistas µ\\Nperiféricos):","guid":"","children":[{"id":"178","parent":"177","text":"Metilnaltrexona SC","guid":"","children":[]},{"id":"179","parent":"177","text":"Naloxegol oral","guid":"","children":[]}]},{"id":"180","parent":"175","text":"Considerar cambio a opioides\\Nlipofílicos (fentanilo, buprenorfina)","guid":"","children":[]}]}]},{"id":"181","parent":"0","text":"Impactación fecal","guid":"","children":[{"id":"182","parent":"181","text":"Presentación","guid":"","children":[{"id":"183","parent":"182","text":"Deterioro clínico inespecífico","guid":"","children":[]},{"id":"184","parent":"182","text":"Anorexia, vómitos, dolor abdominal","guid":"","children":[]},{"id":"185","parent":"182","text":"Fiebre, delirium, distensión","guid":"","children":[]}]},{"id":"186","parent":"181","text":"Manejo","guid":"","children":[{"id":"187","parent":"186","text":"**Obstrucción** → enemas\\Nretención diarios (aceite maní)\\NANTES de laxantes orales","guid":"","children":[]},{"id":"188","parent":"186","text":"Desimpactación rectal → manual si\\Nnecesario + enema fosfato","guid":"","children":[]},{"id":"189","parent":"186","text":"Desimpactación colónica →\\Nenemas diarios + PEG (~2L/día\\No 2-3 sobres Movicol)","guid":"","children":[]},{"id":"190","parent":"186","text":"Régimen mantenimiento para\\Nprevenir recurrencia","guid":"","children":[]}]}]},{"id":"191","parent":"0","text":"Intervenciones avanzadas","guid":"","children":[{"id":"192","parent":"191","text":"Cirugía → constipación\\Ntránsito lento refractaria","guid":"","children":[{"id":"193","parent":"192","text":"Requiere demostrar tránsito\\Nlento + excluir disinergia","guid":"","children":[]},{"id":"194","parent":"192","text":"Colectomía puede desenmascarar\\Ndismotilidad intestino delgado","guid":"","children":[]}]},{"id":"195","parent":"191","text":"Toxina botulínica → disinergia\\Nrefractaria a biofeedback","guid":"","children":[]},{"id":"196","parent":"191","text":"Neuromodulación sacra → evidencia limitada,\\NNO recomendada actualmente","guid":"","children":[]},{"id":"197","parent":"191","text":"Cápsula vibratoria → resultados\\Nalentadores, requiere más investigación","guid":"","children":[]}]},{"id":"198","parent":"0","text":"Perlas Clínicas ⭐","guid":"","children":[{"id":"199","parent":"198","text":"[Constipación NO es consecuencia\\Ninevitable del envejecimiento →\\Nmúltiples factores modificables]","guid":"","children":[]},{"id":"200","parent":"198","text":"[Tacto rectal SIEMPRE → \"empuje\" debe\\Nrelajar esfínter, no contraer]","guid":"","children":[]},{"id":"201","parent":"198","text":"[\"Diarrea\" en adulto mayor → descartar\\NIF por rebalse (impactación)]","guid":"","children":[]},{"id":"202","parent":"198","text":"[Recto vacío NO descarta impactación →\\Npuede ser colónica superior]","guid":"","children":[]},{"id":"203","parent":"198","text":"[Pujo y heces duras > frecuencia reducida\\Ncomo síntomas predominantes]","guid":"","children":[]},{"id":"204","parent":"198","text":"[Optimizar hidratación + fibra + actividad\\NANTES de escalar laxantes]","guid":"","children":[]},{"id":"205","parent":"198","text":"[Supositorios subutilizados → efectivos\\Nen retraso evacuación rectal]","guid":"","children":[]},{"id":"206","parent":"198","text":"[EVITAR enemas fosfato en ancianos → riesgo\\Nalteraciones electrolíticas graves]","guid":"","children":[]},{"id":"207","parent":"198","text":"[PEG + laxantes Mg con\\Nprecaución en ERC]","guid":"","children":[]},{"id":"208","parent":"198","text":"[Biofeedback → tratamiento más efectivo\\Npara disfunción piso pélvico]","guid":"","children":[]},{"id":"209","parent":"198","text":"[Prucaloprida en >65a →\\Niniciar 1 mg/día (no 2 mg)]","guid":"","children":[]},{"id":"210","parent":"198","text":"[Constipación opioides → PAMORAs\\N> laxantes convencionales]","guid":"","children":[]},{"id":"211","parent":"198","text":"[Antes de cirugía → confirmar tránsito\\Nlento Y excluir disinergia]","guid":"","children":[]},{"id":"212","parent":"198","text":"[Preguntar activamente → constipación e\\NIF son \"problemas ocultos\"]","guid":"","children":[]}]},{"id":"213","parent":"0","text":"Referencias","guid":"","children":[{"id":"214","parent":"213","text":"1. Gallogos-Orozco JF, et al. Chronic\\Nconstipation in the elderly. Am J\\NGastroenterol. 2012;107(1):18-25.","guid":"","children":[]},{"id":"215","parent":"213","text":"2. Bharucha AE, et al. American Gastroenterological\\NAssociation technical review on constipation.\\NGastroenterology. 2013;144:218-38.","guid":"","children":[]},{"id":"216","parent":"213","text":"3. Baffy N, et al. Intractable\\NConstipation in 