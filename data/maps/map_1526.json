intrahospitalaria → 43% en primeros\\N3 días (143/1000 días-paciente)","guid":"","children":[]}]},{"id":"19","parent":"0","text":"Síntomas predominantes\\Nen adulto mayor","guid":"","children":[{"id":"20","parent":"19","text":"**Pujo** → 2/3 de adultos\\Nmayores constipados","guid":"","children":[]},{"id":"21","parent":"19","text":"**Heces duras** → 39%","guid":"","children":[]},{"id":"22","parent":"19","text":"**Retraso evacuación rectal**\\N→ 21% en comunidad","guid":"","children":[]},{"id":"23","parent":"19","text":"Deposiciones infrecuentes (<2/semana) →\\Nsolo 1-7% (igual que jóvenes)","guid":"","children":[]}]},{"id":"24","parent":"0","text":"Clasificación","guid":"","children":[{"id":"25","parent":"24","text":"Formas primarias","guid":"","children":[{"id":"26","parent":"25","text":"**Tránsito normal (CTN)**","guid":"","children":[{"id":"27","parent":"26","text":"SII-C → dolor abdominal que\\Nmejora con evacuación","guid":"","children":[]},{"id":"28","parent":"26","text":"CIC → sin dolor predominante","guid":"","children":[]},{"id":"29","parent":"26","text":"~22% en clínicas geriátricas","guid":"","children":[]}]},{"id":"30","parent":"25","text":"**Tránsito lento (CTL)**","guid":"","children":[{"id":"31","parent":"30","text":"Tiempo tránsito hasta 9 días","guid":"","children":[]},{"id":"32","parent":"30","text":"↓ HAPCs (contracciones\\Npropagantes alta amplitud)","guid":"","children":[]},{"id":"33","parent":"30","text":"↓ reflejo gastrocólico","guid":"","children":[]},{"id":"34","parent":"30","text":"**↓ células intersticiales de Cajal**","guid":"","children":[]},{"id":"35","parent":"30","text":"Pérdida neuronal plexo mientérico","guid":"","children":[]},{"id":"36","parent":"30","text":"↑ depósitos colágeno colon izquierdo","guid":"","children":[]},{"id":"37","parent":"30","text":"↑ unión endorfinas plasmáticas a\\Nreceptores intestinales","guid":"","children":[]}]},{"id":"38","parent":"25","text":"**Disfunción tracto de salida (DTS)**","guid":"","children":[