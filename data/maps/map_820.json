parent":"0","text":"PRESBISTASIS","guid":"","children":[{"id":"196","parent":"195","text":"Definición","guid":"","children":[{"id":"197","parent":"196","text":"Disfunción vestibular relacionada con edad","guid":"","children":[]},{"id":"198","parent":"196","text":">50% adultos mayores tienen algún grado","guid":"","children":[]}]},{"id":"199","parent":"195","text":"Fisiopatología","guid":"","children":[{"id":"200","parent":"199","text":"Degeneración células ciliadas vestibulares","guid":"","children":[]},{"id":"201","parent":"199","text":"Pérdida neuronas ganglio Scarpa","guid":"","children":[]},{"id":"202","parent":"199","text":"Degeneración otolitos (utrículo > sáculo)","guid":"","children":[]},{"id":"203","parent":"199","text":"Reducción flujo vascular laberíntico","guid":"","children":[]},{"id":"204","parent":"199","text":"Origen embriológico, vascularización y neuroepitelio COMPARTIDOS con cóclea","guid":"","children":[]}]},{"id":"205","parent":"195","text":"Correlación cocleo-vestibular","guid":"","children":[{"id":"206","parent":"205","text":"Azevedo 2022: correlación negativa significativa","guid":"","children":[{"id":"207","parent":"206","text":"Umbral conducción ósea alta frecuencia vs respuesta calórica total (r=-0.320, p<0.05)","guid":"","children":[]}]},{"id":"208","parent":"205","text":"Debilidad vestibular bilateral: 22.5% en >60a vs 5% en 18-50a","guid":"","children":[]},{"id":"209","parent":"205","text":"HIPOACUSIA → estudio vestibular COMPLETO obligatorio","guid":"","children":[]}]},{"id":"210","parent":"195","text":"Manifestaciones clínicas","guid":"","children":[{"id":"211","parent":"210","text":"Inestabilidad postural crónica → NO vértigo rotatorio","guid":"","children":[]},{"id":"212","parent":"210","text":"Mareo inespecífico → más frecuente en AM","guid":"","children":[]},{"id":"213","parent":"210","text":"Oscilopsia → visión borrosa al caminar","guid":"","children":[]},{"id":"214","parent":"210","text":"Mayor riesgo caídas → fractura cadera, d