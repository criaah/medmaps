{"title":"03-Sindromes-Geriatricos-Domicilio","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Entidades clínicas/Geriatría/Cuidados-Domicilio/03-Sindromes-Geriatricos-Domicilio.smmx","root":{"id":"0","parent":"-1","text":"Síndromes Geriátricos y Problemas Frecuentes en Domicilio","guid":"9T9blgznRlmaRq6v9he-MA","children":[{"id":"1","parent":"0","text":"RITMO INTESTINAL","guid":"Msxt63dBQROYG79wpjPDlA","children":[{"id":"2","parent":"1","text":"NORMAL","guid":"CvNe0DdLQOyTPjCc5PXrDA","children":[{"id":"3","parent":"2","text":"3/semana ↔ 3/día","guid":"vXvkr-KbSratPUfNOMWmrQ","children":[]},{"id":"4","parent":"2","text":"Defecación INDOLORA + sin esfuerzo excesivo","guid":"9Me5psSsRG6xyp6rOLUYNw","children":[]},{"id":"5","parent":"2","text":"Vaciamiento completo","guid":"FsNmN_CpT6y1mw4-NHwRPw","children":[]}]},{"id":"6","parent":"1","text":"ESTREÑIMIENTO","guid":"wZullncPSoCtCtyhhSixow","children":[{"id":"7","parent":"6","text":"Definición: <3 deposiciones/sem + esfuerzo excesivo","guid":"DDC32GrXSwKTJcN4fjUjuw","children":[]},{"id":"8","parent":"6","text":"SÍNTOMA, NO enfermedad","guid":"VbXXV0r0TbCuTEE02n1Shg","children":[]},{"id":"9","parent":"6","text":"Epidemiología → ↑ con edad, mujer > hombre, encamados alto riesgo","guid":"hzZRoq6IRryPX35SZscPPA","children":[]},{"id":"10","parent":"6","text":"Causas no orgánicas","guid":"oDPScQsMQ1qFV8X0tPKuYA","children":[{"id":"11","parent":"10","text":"↓ FIBRA dieta","guid":"_eKpEVfhRs6O6SC1iq-NKw","children":[]},{"id":"12","parent":"10","text":"↓ HIDRATACIÓN (<1,5 L/d)","guid":"m4_WRo7BS9q3RDasmVS05g","children":[]},{"id":"13","parent":"10","text":"↓ Movilidad","guid":"f3JFkmtfQVKFTKOZrT8rCw","children":[]},{"id":"14","parent":"10","text":"Fármacos (opioides, anticolinérgicos, Fe, Ca)","guid":"Gj0ZUz50QzSqx_nhXpVjTg","children":[]}]},{"id":"15","parent":"6","text":"Manejo NO farmacológico","guid":"YLdLngVsR9CzHFi_CBWFMA","children":[{"id":"16","parent":"15","text":"FIBRA: fruta + verdura + legumbres + integrales","guid":"J5J7EvuBQnGOaIjZi8MLPw","children":[]},{"id":"17","parent":"15","text":"Hidratación 1,5-2 L/d","guid":"9QWnk1RiSaKa9G16pnMfkw","children":[]},{"id":"18","parent":"15","text":"Ejercicio adaptado","guid":"B315uBCkQYyaf3DJ5QqHUQ","children":[]},{"id":"19","parent":"15","text":"Horario regular → 10 min post-desayuno","guid":"erEt_POIREi1dwi7aWmFzg","children":[]},{"id":"20","parent":"15","text":"Posición cuclillas o pies elevados","guid":"vnQeG0K7SmqibSTzBfJqDg","children":[]},{"id":"21","parent":"15","text":"Masaje abdominal","guid":"YyviaCHOT5yoxidQeBA4Gw","children":[]},{"id":"22","parent":"15","text":"Evitar cuña (inhibe defecación)","guid":"9o7m5cxUQPqhRFmKBWH4OQ","children":[]}]},{"id":"23","parent":"6","text":"Alimentos que ESTRIÑEN (evitar)","guid":"00uAW1Y7TNuyYGEf8ReccQ","children":[{"id":"24","parent":"23","text":"Chocolate, arroz, zanahoria","guid":"qm2cZUVxTNe7AD_m9pvjnw","children":[]},{"id":"25","parent":"23","text":"Plátano, membrillo, compota manzana","guid":"dTa1tJv2QC2A4gMJFj5Khw","children":[]},{"id":"26","parent":"23","text":"Té (taninos)","guid":"eWZuYCL2SiK2dt2bCqBOoQ","children":[]}]},{"id":"27","parent":"6","text":"Laxantes → solo con prescripción (ABUSO peligroso)","guid":"ZkJ5aPaXQ4amHeOpuaZEMA","children":[]},{"id":"28","parent":"6","text":"Enemas → decúbito lateral izquierdo + retener 5-10 min","guid":"uchK_sBsQsOAfptCFk_ifA","children":[]}]},{"id":"29","parent":"1","text":"DIARREA","guid":"25vpsbtiQ06r-dEXfOE91g","children":[{"id":"30","parent":"29","text":">3 deposiciones/d o cambio consistencia","guid":"l8Jq74eeRh-3vFzyrGLn1w","children":[]},{"id":"31","parent":"29","text":"Descartar PSEUDODIARREA (→ fecaloma)","guid":"RW2x6xXzSCeYieioKgSK7w","children":[]},{"id":"32","parent":"29","text":"Manejo","guid":"HA0d9ecJQNWhLj9mOwkFJA","children":[{"id":"33","parent":"32","text":"LIMONADA ALCALINA: 1L agua + 2 limones + sal + bicarbonato + 2 cdas azúcar","guid":"8lvNVYMQRY6vmYWC5C8C_A","children":[]},{"id":"34","parent":"32","text":"Astringentes: arroz, zanahoria, pescado hervido, plátano, manzana asada","guid":"wWbSiW8lRVqBT1z86l091w","children":[]},{"id":"35","parent":"32","text":"Evitar residuos (vegetales, fruta fresca, leche)","guid":"QUe2SuAuTa-y1UWRBXkwYw","children":[]},{"id":"36","parent":"32","text":"Líquidos NO muy calientes ni fríos","guid":"OTu-zWjjQuWpeg3sRe_YDg","children":[]},{"id":"37","parent":"32","text":"NO antidiarreicos sin prescripción","guid":"TlQs3GY4THSZBnl76MYkPQ","children":[]},{"id":"38","parent":"32","text":"Protección perianal: vaselina / óxido zinc","guid":"l779gP7GRgO_lxOH_fYLIA","children":[]}]},{"id":"39","parent":"29","text":"Deshidratación → sed ausente, sequedad, ↓orina, cansancio","guid":"5qGkC08hQouEnuWZl8HCgw","children":[]}]},{"id":"40","parent":"1","text":"FECALOMA (impactación fecal)","guid":"l4nmsD0TQhSiG3-vX3eW2Q","children":[{"id":"41","parent":"40","text":"Complicación + FRECUENTE estreñimiento","guid":"F9-47Y1YQ7adUZqNBR87jQ","children":[]},{"id":"42","parent":"40","text":"Dolor rectal + cólico + distensión","guid":"iJNYZIaDS2-mRQ95ryIwNQ","children":[]},{"id":"43","parent":"40","text":"Deseo insatisfecho defecar","guid":"fE10YsIgSFa3J-z5WYzkmg","children":[]},{"id":"44","parent":"40","text":"PSEUDODIARREA por rebosamiento","guid":"QPogUn3iS2-mDSGayQoVQQ","children":[]},{"id":"45","parent":"40","text":"Manejo → consulta médica urgente","guid":"MuQU9vTERJu_BPmLBobeHA","children":[]}]},{"id":"46","parent":"1","text":"INCONTINENCIA FECAL","guid":"gr92X5AURBSoIc3HFeDeeg","children":[{"id":"47","parent":"46","text":"Reeducación intestinal con horario regular","guid":"55mbZItYQ-GsPsnYKkMKcA","children":[]},{"id":"48","parent":"46","text":"Absorbentes desechables","guid":"xA-jIGv7QU2RM9KRF7ESCw","children":[]},{"id":"49","parent":"46","text":"Higiene perianal + hidratantes","guid":"EiOklx3kRkW2I3xnkpgvVQ","children":[]}]}]},{"id":"50","parent":"0","text":"INCONTINENCIA DE ORINA","guid":"meAX51ZMRCCJ3vXSiekbtg","children":[{"id":"51","parent":"50","text":"Pérdida involuntaria de orina","guid":"5UZj3f7tTa6P3CY1Cz3y7Q","children":[]},{"id":"52","parent":"50","text":"Impacto → ↓ calidad vida + repercusión psicológica","guid":"xiVVl0M7QpWlMYiPVSZNpg","children":[]},{"id":"53","parent":"50","text":"TIPOS","guid":"og6RBZjnRV2mIq-89D-jSA","children":[{"id":"54","parent":"53","text":"URGENCIA (vejiga hiperactiva) → urgencia súbita","guid":"S4MUeG38QgyPPW7RU5hYNQ","children":[]},{"id":"55","parent":"53","text":"ESFUERZO → tos/esfuerzo/risa (↑ P abdominal)","guid":"hBqBBpX9T8CejqMkXvzRxg","children":[]},{"id":"56","parent":"53","text":"MIXTA → urgencia + esfuerzo","guid":"0ZOL1pQKTRmi2mQDCDVLnw","children":[]},{"id":"57","parent":"53","text":"REBOSAMIENTO → retención crónica + globo vesical","guid":"ge3BYYlkR7iGkE_ARIPCxw","children":[]},{"id":"58","parent":"53","text":"FUNCIONAL → barreras movilidad/cognición","guid":"lk-5oSqwT_q3srZwROs-fg","children":[]}]},{"id":"59","parent":"50","text":"DIAPPERS (causas reversibles — nemotecnia)","guid":"9oIoQNCMQnai788pUJFaqQ","children":[{"id":"60","parent":"59","text":"D - Delirium","guid":"rs0cK6WfTUOzSOP8T9mySA","children":[]},{"id":"61","parent":"59","text":"I - Infección urinaria","guid":"BjDPz3m0RzWgYYTzqtnrvA","children":[]},{"id":"62","parent":"59","text":"A - Atrofia uretral/vaginal","guid":"T7HdvtKZT7a-YgvWGLpwVA","children":[]},{"id":"63","parent":"59","text":"P - Psicofármacos","guid":"Uny16qMaT9ShqhiaeGMYIg","children":[]},{"id":"64","parent":"59","text":"P - Psicológico (depresión)","guid":"1IpppocfSXCFz1KRvGSm_g","children":[]},{"id":"65","parent":"59","text":"E - Endocrino (DM, hipercalcemia)","guid":"NumdS4nrSpyArLnLzIHSaw","children":[]},{"id":"66","parent":"59","text":"R - Restricción movilidad","guid":"rFOS5pPiRM6yODd1gb0PFg","children":[]},{"id":"67","parent":"59","text":"S - Stool (fecaloma)","guid":"2kgxSyq_T0qMfN4O-nxv2A","children":[]}]},{"id":"68","parent":"50","text":"TRATAMIENTO CURATIVO","guid":"kdKHEyBISGOuD33L-3lL_A","children":[{"id":"69","p