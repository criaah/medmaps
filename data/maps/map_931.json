eeRjyKEw0horDxtg","children":[]}]},{"id":"280","parent":"243","text":"SCPD (síntomas conductuales-psicológicos)","guid":"jtj3gV_tQjeo1HvnFhZIbg","children":[{"id":"281","parent":"280","text":"Agitación + agresividad","guid":"upsSs7x4QbSV3enZ2oABWQ","children":[]},{"id":"282","parent":"280","text":"Alucinaciones (visuales > auditivas)","guid":"1-Ou59yfTDOm6SRzUkG-ug","children":[]},{"id":"283","parent":"280","text":"Ideas delirantes (robo, infidelidad)","guid":"qeiT7TU1S7umBbejPp2Vcw","children":[]},{"id":"284","parent":"280","text":"Alteraciones sueño","guid":"-vCQa4H4RNWJ4UsivZgx3Q","children":[]},{"id":"285","parent":"280","text":"VAGABUNDEO","guid":"fTRm4ZeqRsO6dwgT-lG9Iw","children":[]},{"id":"286","parent":"280","text":"Depresión + apatía + ansiedad","guid":"XkxYa5D6RGWamIOQhiYlCQ","children":[]},{"id":"287","parent":"280","text":"Desinhibición","guid":"XRrMdr7uQ8qzCeaddogOWg","children":[]}]},{"id":"288","parent":"243","text":"MANEJO SCPD","guid":"jCaHtNl5QUSoGa94zmLb3g","children":[{"id":"289","parent":"288","text":"1ª LÍNEA: NO FARMACOLÓGICO siempre","guid":"qp1VE_6USiOT5vWBDlY-sA","children":[{"id":"290","parent":"289","text":"Validación emocional (Naomi Feil)","guid":"gYY4y_jAQDKwbSmTdsbOAA","children":[]},{"id":"291","parent":"289","text":"Musicoterapia + reminiscencia + aromaterapia","guid":"9bFEn8UzTcyHQ-6IsdSo7Q","children":[]},{"id":"292","parent":"289","text":"Snoezelen (multisensorial)","guid":"9AsPb610T-SHw4Ses6S_uA","children":[]},{"id":"293","parent":"289","text":"Actividad significativa","guid":"fvFsOs7iSyW92J27I7xcLw","children":[]},{"id":"294","parent":"289","text":"Contacto físico afectivo","guid":"fe_M_kc5QYWP-hqJmTXFVg","children":[]},{"id":"295","parent":"289","text":"Luz natural + rutinas","guid":"bzpCUvjXQhOGzhJ3KcSP6w","children":[]}]},{"id":"296","parent":"288","text":"2ª LÍNEA: farmacológico","guid":"O2K2gIyyRI6HnG0R_NxKrQ","children":[{"id":"297","parent":"296","text":"Solo si fracasa NO farmacológico","guid":"gDjrDbEwTS22tazv-wBWUg","children":[]},{"id":"298","parent":"296","text":"EVITAR antipsicóticos si cuerpos Lewy","guid":"HWoBPH0UTpmJxaMl-kw1zw","children":[]},{"id":"299","parent":"296","text":"Start low, go slow","guid":"YFvI2HHCSHy5DVEP9hS6cg","children":[]},{"id":"300","parent":"296","text":"Revalorar cada 3 meses","guid":"tlHujFZiTXy12fYn4BGtdQ","children":[]}]}]},{"id":"301","parent":"243","text":"AMBIENTE TERAPÉUTICO","guid":"9DS0JFWcStqpIFA6tPqIhQ","children":[{"id":"302","parent":"301","text":"Rutinas estables + iluminación + pictogramas","guid":"1S2IsGz6TrqOVh9M8llwiQ","children":[]},{"id":"303","parent":"301","text":"Fotos familiares + objetos significativos","guid":"ddgSW1rERgOEt2yP6yWwOQ","children":[]},{"id":"304","parent":"301","text":"Colores contrastados","guid":"Vng4ciJhRnGM0iv1Bo81Wg","children":[]},{"id":"305","parent":"301","text":"Eliminar espejos si angustia","guid":"ltvvYvGaR_aJIgHupa2G3Q","children":[]},{"id":"306","parent":"301","text":"Reloj visible + calendario","guid":"Ea2A5GH4SDeJex5I7fNAHg","children":[]}]},{"id":"307","parent":"243","text":"COMUNICACIÓN EN DEMENCIA AVANZADA","guid":"OrT9S8YTT4yetpy3W-staw","children":[{"id":"308","parent":"307","text":"Mensajes CORTOS + simples","guid":"iagFk-J1QKCbfKSULSUkvw","children":[]},{"id":"309","parent":"307","text":"Hablar despacio + tono cálido","guid":"Vf5XDWc0RnWJH2XUtcLfhA","children":[]},{"id":"310","parent":"307","text":"Una instrucción a la vez","guid":"nGlet-hiRseSec0fzbqKUA","children":[]},{"id":"311","parent":"307","text":"Gestos, caricias, sonrisa","guid":"JOu0xibMRsGOXPrw--nX8Q","children":[]},{"id":"312","parent":"307","text":"NO corregir + NO confrontar","guid":"tYn2lzRGQVCpr6sYNBPwWg","children":[]},{"id":"313","parent":"307","text":"Memoria EMOCIONAL permanece","guid":"Vzvu4o7iRoOlpK_KLzUWgQ","children":[]},{"id":"314","parent":"307","text":"Validación > orientación a realidad","guid":"N_V0VLxJTTqDHarXcj8ISQ","children":[]}]},{"id":"315","parent":"243","text":"MANEJO SITUACIONES DIFÍCILES","guid":"_70qbJBaS6ylJ2GLRxs4Gw","children":[{"id":"316","parent":"315","text":"Agitación → identificar desencadenante (dolor, ruido, fármaco)","guid":"gaurt6cBTWyF-cRV9W0Vrg","children":[]},{"id":"317","parent":"315","text":"Alucinaciones → actitud tranquila, no confrontar","guid":"JrPrz3yQRh6vHLdkg1jwEw","children":[]},{"id":"318","parent":"315","text":"Vagambundeo → espacio seguro + tarjeta ID + tecnología localización","guid":"NKdFaPQUQJadS5-kZQYf4A","children":[]}]},{"id":"319","parent":"243","text":"CUIDADOR","guid":"miN-nkfFSRGBt9wLZW8pkQ","children":[{"id":"320","parent":"319","text":"SOBRECARGA (Zarit) → evaluar","guid":"OtpYq3aGRWCQvlSEZmU5BA","children":[]},{"id":"321","parent":"319","text":"Burnout → ↑ riesgo depresión, enfermedad","guid":"QWIsEF9XRje_o704DLk7PQ","children":[]},{"id":"322","parent":"319","text":"Grupos ayuda mutua + respiro familiar + centro día","guid":"aUw2Tb5jRHy3IQObblYL_w","children":[]}]}]},{"id":"323","parent":"0","text":"Perlas Clínicas","guid":"id2TcAtTQOuDuwvQoCB3BQ","children":[{"id":"324","parent":"323","text":"PSEUDODIARREA + fecaloma → tacto rectal SIEMPRE en AM con \"diarrea nueva\" (antidiarreico empeora)","guid":"CVup3j35QOCH6k76u7rCWQ","children":[]},{"id":"325","parent":"323","text":"LIMONADA ALCALINA = SRO casera: 1L agua + 2 limones + sal + bicarbonato + 2 cdas azúcar","guid":"efqJE994RI-9YlLBvaNY8A","children":[]},{"id":"326","parent":"323","text":"DIAPPERS → nemotecnia oro para incontinencia reversible (ITU + fecaloma más frecuentes)","guid":"pzIlb40FRqKufzHVbF9-hw","children":[]},{"id":"327","parent":"323","text":"UPP sacra = fallo del sistema → cambios posturales cada 2h no negociable","guid":"vm078Y8CTAqdIllRsTlPzg","children":[]},{"id":"328","parent":"323","text":"NO MASAJEAR prominencias óseas eritematosas (aumenta daño microvascular)","guid":"ouGx0fmwRy6HAYhlSnG_5A","children":[]},{"id":"329","parent":"323","text":"TUG >14 seg = predictor caída en 6 meses (sensibilidad 87%)","guid":"F9-wWDTgSMSXsnumZYDxgA","children":[]},{"id":"330","parent":"323","text":"SUJECIONES físicas NO previenen caídas → aumentan UPP, delirium, muerte → Modelo Libre Sujeciones estándar","guid":"pNf466dbSBK9zB6JumbAjA","children":[]},{"id":"331","parent":"323","text":"CUERPOS LEWY → EVITAR haloperidol (SNM por hipersensibilidad) → preferir quetiapina baja dosis","guid":"0UUm1pVMT3acTvtArxU0lA","children":[]},{"id":"332","parent":"323","text":"SCPD → primer antipsicótico = NO FARMACOLÓGICO → si se usa, revaluar cada 3 meses","guid":"nIwSICbMQvmbGiQbMOEW0A","children":[]},{"id":"333","parent":"323","text":"MEMORIA EMOCIONAL persiste en demencia avanzada → caricias + tono cálido >> contenido verbal","guid":"krhn8nMFTS-5Srjx_goZqw","children":[]},{"id":"334","parent":"323","text":"Referencias","guid":"atPaQxTdTJGGBwCE437E5g","children":[{"id":"335","parent":"334","text":"1. SEGG. Curso cuidadores PM dependencia. Temas 12-17. Madrid: Ballesol; 2023. ISBN 978-84-09-47741-8.","guid":"2VIZZVGmREGbRAmBkHceWQ","children":[]},{"id":"336","parent":"334","text":"2. EPUAP/NPIAP/PPPIA. Prevention and Treatment of Pressure Ulcers/Injuries: Clinical Practice Guideline. 2019.","guid":"ikGlIj8vTmCjff1tpMvgwg","children":[]},{"id":"337","parent":"334","text":"3. Panel AGS/BGS. Summary of the Updated AGS/BGS CPG for Prevention of Falls in Older Persons. J Am Geriatr Soc. 2011;59(1):148-57.","guid":"slMI7k_2TjmQTNoRr8HiAw","children":[]},{"id":"338","parent":"334","text":"4. Fundación Cuidados Dignos. Norma Libera-Care: atención centrada en la persona sin sujeciones.","guid":"TLlEgdHkQMa1zLHP9qvI3g","children":[]},{"id":"339","parent":"334","text":"5. Livingston G, et al. Dementia prevention, intervention, and care: 2020 report of the Lancet Commission. Lancet. 2020;396(10248):413-46.","guid":"egRNiQsvRbKZ7gIG2qpkTw","children":[]},{"id":"340","parent":"334","text":"6. Abrams P, et al. 6th International Consultation on Incontinence. Neurourol Urodyn. 2018;37(7):2271-2.","guid":"5nU4rdFySI-uiIB6gES_EA","children":[]}]}]}]},"node_count":340,"relations":[],"cross_references":[],"specialty":"Geriatría","folder":"Entidades clínicas/Geriatría/Cuidados-Domicilio","filename":"03-Sindromes-Geriatricos-Domicilio","id":"map_931","resolved_references":[],"title_raw":"03-Sindromes-Geriatricos-Domicilio"}