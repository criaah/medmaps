{"title":"MUE_EPOC_Asma_Grave","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/MUE - Medicina de Urgencia/MUE_EPOC_Asma_Grave.smmx","root":{"id":"0","parent":"-1","text":"EPOC EXACERBADO Y ASMA GRAVE EN URGENCIA","guid":"W9IeIZ2PRFCKeGkYow95ew","children":[{"id":"1","parent":"0","text":"EXACERBACION DE EPOC","guid":"s6M2g7OgRxO-6gQm84qzYg","children":[{"id":"2","parent":"1","text":"Definicion GOLD 2024","guid":"7VbKzncxQI-5nH2HnvsQcQ","children":[{"id":"3","parent":"2","text":"Empeoramiento agudo de sintomas respiratorios","guid":"3PLFhAFHSseb-rJdcKOKdw","children":[]},{"id":"4","parent":"2","text":"Requiere cambio en tratamiento habitual","guid":"wc9WtPAFS6ufsXiRuYuyfw","children":[]},{"id":"5","parent":"2","text":"Clasificacion de gravedad","guid":"Kr5153rEQLqf7OFfQaH9KQ","children":[{"id":"6","parent":"5","text":"LEVE → aumento de terapia inhalatoria","guid":"uP8lZo6ZR_6N54nCqvv_0g","children":[]},{"id":"7","parent":"5","text":"MODERADA → requiere antibioticos y/o corticoides","guid":"898XQXScTGCSw8HjiMebVQ","children":[]},{"id":"8","parent":"5","text":"SEVERA → requiere hospitalizacion o UCI","guid":"lXciJvzkSmWkAHc3oWAbtA","children":[]}]}]},{"id":"9","parent":"1","text":"Epidemiologia en adulto mayor","guid":"qpRQ06pWR_usHF7syRwnrg","children":[{"id":"10","parent":"9","text":"EPOC → 4ta causa de muerte mundial","guid":"cxvDBcyLRxipd2roTeOo7Q","children":[]},{"id":"11","parent":"9","text":"Prevalencia ↑ con edad (>10% en >65 anos)","guid":"OLF0Pg8URZurIdp-jUa6Hw","children":[]},{"id":"12","parent":"9","text":"Exacerbaciones → causa frecuente de consulta en urgencia AM","guid":"ngGs_qZzQjimpdZVfO250Q","children":[]},{"id":"13","parent":"9","text":"Mortalidad intrahospitalaria 2.5-30% segun gravedad","guid":"q_IfDH2uQdeJlwOXWefE-Q","children":[]},{"id":"14","parent":"9","text":"Cada exacerbacion → deterioro funcional progresivo","guid":"92gT_qX5TQSapH9cg_0dEg","children":[]}]},{"id":"15","parent":"1","text":"Desencadenantes","guid":"hfmDnCR0TO6S2aFln4jq1A","children":[{"id":"16","parent":"15","text":"INFECCION → 50-70% de exacerbaciones","guid":"XjZwXqbHTWOPbbBVd-tSyQ","children":[{"id":"17","parent":"16","text":"Viral → rinovirus, influenza, VRS","guid":"Pb40JeJQRp-uJuYgwIlzqg","children":[]},{"id":"18","parent":"16","text":"Bacteriana → H. influenzae, S. pneumoniae, M. catarrhalis","guid":"OQ_dWPsSQ1SRBO_m8Ri9yA","children":[]},{"id":"19","parent":"16","text":"PERLA → coinfeccion viral-bacteriana frecuente en AM","guid":"1FZIkrC9R3uMeMKvJKdeoQ","children":[]}]},{"id":"20","parent":"15","text":"Contaminacion ambiental","guid":"HadkPCBdSH-B5vJVt_PdDw","children":[]},{"id":"21","parent":"15","text":"Incumplimiento tratamiento","guid":"9wOperSsT5qI0ltarfmcww","children":[]},{"id":"22","parent":"15","text":"Insuficiencia cardiaca descompensada (overlap frecuente)","guid":"1JMO-x4xT16p-dfRSlZA1g","children":[]},{"id":"23","parent":"15","text":"TEP → considerar siempre en exacerbacion sin causa clara","guid":"t89xEuXPTnqdfr1PEB2atw","children":[]},{"id":"24","parent":"15","text":"Farmacos → betabloqueadores no selectivos, sedantes","guid":"-_0q8MYyQ0W3Gl1ceIqu6Q","children":[]}]},{"id":"25","parent":"1","text":"Presentacion clinica","guid":"pqGe3bZzQCWyoVhsX45NWQ","children":[{"id":"26","parent":"25","text":"Aumento de disnea","guid":"gdx2Jh-eRBKu7Md0tBxq_g","children":[]},{"id":"27","parent":"25","text":"Aumento de volumen y purulencia del esputo","guid":"5BzzmrToQ3WneAesD7awqw","children":[]},{"id":"28","parent":"25","text":"Criterios de Anthonisen","guid":"COB_WQF6RO6amHzEfb6axg","children":[{"id":"29","parent":"28","text":"Tipo 1 → 3 sintomas cardinales (disnea + esputo purulento + volumen ↑)","guid":"2Asmvlu6QY-dF-qZyKdbGg","children":[]},{"id":"30","parent":"28","text":"Tipo 2 → 2 de 3 sintomas","guid":"Dy0L2UECQv66jSN73-4_vQ","children":[]},{"id":"31","parent":"28","text":"Tipo 3 → 1 sintoma + hallazgo asociado","guid":"lIZ5DwBqTb2MP8DLGXKE3g","children":[]}]},{"id":"32","parent":"25","text":"EN ADULTO MAYOR","guid":"WIBvdBx6SzqwaXMkOyvWOw","children":[{"id":"33","parent":"32","text":"Presentacion atipica frecuente","guid":"-5YPDWihS_aJnk9eJo_dLA","children":[]},{"id":"34","parent":"32","text":"Confusion/delirium como manifestacion principal","guid":"fe5ykfIHQoaMbGXQSzn4Jw","children":[]},{"id":"35","parent":"32","text":"Menor percepcion de disnea","guid":"KxudZDH4QTKSNk3t4Xgy7g","children":[]},{"id":"36","parent":"32","text":"IC descompensada simultanea","guid":"ks8A1yhKSzCugGKlK98SYg","children":[]}]}]},{"id":"37","parent":"1","text":"Evaluacion en urgencia","guid":"gmIy4Sg8S-aOhSOq0GHQPQ","children":[{"id":"38","parent":"37","text":"SIGNOS DE GRAVEDAD","guid":"-uoYG_fxTzKb4zXocnc3Vg","children":[{"id":"39","parent":"38","text":"FR >30, FC >120, SpO2 <88%","guid":"mdDll3EgSSeJPrS4cPOTcw","children":[]},{"id":"40","parent":"38","text":"Uso de musculatura accesoria","guid":"o8GAcdDLQzKElNUukRZs_A","children":[]},{"id":"41","parent":"38","text":"Cianosis, diaforesis","guid":"4Vmr8cKGR8qRQ4UjT0X0sw","children":[]},{"id":"42","parent":"38","text":"Alteracion de conciencia","guid":"UXsO3gE0TXC45cuhxDei0A","children":[]},{"id":"43","parent":"38","text":"Habla entrecortada (no completa frases)","guid":"f5PxoIpXRDSjMOqhNjjBTg","children":[]}]},{"id":"44","parent":"37","text":"LABORATORIO","guid":"se6_gIX2RlWNOK-ER808hQ","children":[{"id":"45","parent":"44","text":"Gasometria arterial → CLAVE","guid":"7Ol6yH28SbyfNuGYB096Wg","children":[{"id":"46","parent":"45","text":"pH, pCO2, pO2, HCO3, lactato","guid":"97VCeckcRWu8NUiiDkfIWw","children":[]},{"id":"47","parent":"45","text":"Acidosis respiratoria aguda vs cronica reagudizada","guid":"hmgf54tbTc289cFnb4blwg","children":[]},{"id":"48","parent":"45","text":"pCO2 >50 con pH <7.35 → considerar VMNI","guid":"ZT179F2JR2m_dToAcQ07eA","children":[]}]},{"id":"49","parent":"44","text":"Hemograma, PCR, procalcitonina","guid":"k9GsHFV9R_ueIlclUawtSw","children":[]},{"id":"50","parent":"44","text":"BNP/NT-proBNP (descartar IC concomitante)","guid":"AMC7KQtgT9mGeqt6Q9-qHg","children":[]},{"id":"51","parent":"44","text":"Funcion renal, electrolitos","guid":"GI5h3bM_Q2Wf2jQJox94Ag","children":[]}]},{"id":"52","parent":"37","text":"IMAGENOLOGIA","guid":"iiYomh7yTCq6AFFaBMW_hQ","children":[{"id":"53","parent":"52","text":"Rx torax → infiltrados, neumotorax, derrame, IC","guid":"pDxz0tbwRd-5Q1Nr7sBWtQ","children":[]},{"id":"54","parent":"52","text":"TAC torax si sospecha TEP","guid":"-HjSNoJpQS-ZqWpJqVo4lQ","children":[]}]},{"id":"55","parent":"37","text":"ECG → arritmias, sobrecarga derecha, isquemia","guid":"IE6kWhgGQlOw0490UDv7Rw","children":[]}]},{"id":"56","parent":"1","text":"Manejo farmacologico","guid":"AVEywgdlT56L-KPOBWoJUw","children":[{"id":"57","parent":"56","text":"BRONCODILATADORES → primera linea","guid":"faVNd-A_TOGM7DnBoK7xHA","children":[{"id":"58","parent":"57","text":"SABA → salbutamol 2.5-5 mg NBZ cada 20 min x 3","guid":"2K2DA6m6QFOh7EUHCTA2nQ","children":[]},{"id":"59","parent":"57","text":"Ipratropio 500 mcg NBZ junto con SABA","guid":"wi3VS-ZpSgGRqrpHEpjZOw","children":[]},{"id":"60","parent":"57","text":"Luego cada 4-6h segun respuesta","guid":"NZugvLBpRpeM2Fyt8DKDVQ","children":[]},{"id":"61","parent":"57","text":"EN ADULTO MAYOR → monitorizar FC (taquicardia)","guid":"1nQPhbE1Ruqkv3B8O4eU6w","children":[]}]},{"id":"62","parent":"56","text":"CORTICOIDES SISTEMICOS","guid":"-TerWnyAR8OOrtaJ9wqsNQ","children":[{"id":"63","parent":"62","text":"Prednisona 40 mg VO x 5 dias","guid":"woB7Oq4kSj2Nrb1-MHXkLA","children":[]},{"id":"64","parent":"62","text":"O metilprednisolona 40 mg IV si no tolera VO","guid":"JThdN3EHR0O0MgWUbh7Bzw","children":[]},{"id":"65","parent":"62","text":"GOLD 2024 → ciclo corto 5 dias (no mas de 14)","guid":"I_Fy9ytXTB2injpFuttlvQ","children":[]},{"id":"66","parent":"62","text":"NNT TheNNT → Corticoides en EPOC exacerbado","guid":"WAh36QC-S1iHf6ka5iRueA","children":[{"id":"67","parent":"66","text":"NNT 9 para evitar fallo de tratamiento a 30 dias","guid":"JPf6rhMjQYan7xkJ-QZJpg","children":[]},{"id":"68","parent":"66","text":"Reduccion estadia hospitalaria ~1.2 dias","guid":"XE0ZItC4SpW09Kzh270_jQ","children":[]},{"id":"69","parent":"66","text":"NNH 6 para efectos adversos (hiperglicemia incluida)","guid":"zjJz4YNQRVezlK0pSbGHKg","children":[]},{"id":"70","parent":"66","text":"Cochrane Walters 2014 → 16 RCTs, 1787 pacientes","guid":"UIOk3AraTdmacNN127Fqig","children":[]},{"id":"71","parent":"66","text":"PERLA → beneficio claro en fallo de tratamiento, sin efecto en mortalidad a 30 dias","guid":"kdoXLva3TuWyohhLt07nlg","children":[]}]},{"id":"72","parent":"62","text":"EN ADULTO MAYOR → hiperglicemia frecuente, monitorizar","guid":"6VZyb5w6SxGXMRkHLPpqqw","children":[]}]},{"id":"73","parent":"56","text":"ANTIBIOTICOS","guid":"37QHH4xLQQ2YFa-G4SmPhg","children":[{"id":"74","parent":"73","text":"Indicacion → esputo purulento + ≥1 cardinal mas","guid":"ja04jK35S4Oq9mCsxo2dSg","children":[]},{"id":"75","parent":"73","text":"O exacerbacion severa (hospitalizacion/UCI)","guid":"VxhLURXCQJyL1sWdMpyXIg","children":[]},{"id":"76","parent":"73","text":"Amoxicilina-clavulanico 875/125 mg c/12h x 5-7 dias","guid":"V1UgQSJbTOqNEByGOKvxBQ","children":[]},{"id":"77","parent":"73","text":"Alternativa: azitromicina 500 mg x 3 dias","guid":"76bgAfecTY-XCu8ComJVeQ","children":[]},{"id":"78","parent":"73","text":"Levofloxacino 500-750 mg/dia si riesgo Pseudomonas","guid":"nLduVLxaQrS8n8BhcqVEZg","children":[]},{"id":"79","parent":"73","text":"NNT TheNNT → Antibioticos en EPOC exacerbado","guid":"BhFvBKqXRd2Wv7cpfmGkKQ","children":[{"id":"80","parent":"79","text":"NNT 8 para reducir mortalidad a corto plazo","guid":"w1rRs6bBQcGO6FyYQgNlwA","children":[]},{"id":"81","parent":"79","text":"NNT 3 para reducir fallo de tratamiento","guid":"l70ixL-ERh-IlpHVqyP15A","children":[]},{"id":"82","parent":"79","text":"NNH 20 para diarrea","guid":"FEwecBaGRAS2Wk84T9Fy1w","children":[]},{"id":"83","parent":"79","text":"Cochrane Ram 2006 → 11 RCTs, 817 pacientes","guid":"PhAgFaTRSgy4dd7_26r4oQ","children":[]},{"id":"84","parent":"79","text":"PERLA → mayor beneficio en pacientes mas graves (hospitalizados/UCI)","guid":"ekRc0s3sRfep2ofqTi0fgg","children":[]}]},{"id":"85","parent":"73","text":"EN ADULTO MAYOR → ajustar por funcion renal","guid":"Qa5kMiaLQUaGv8SkYXUEbA","children":[]}]},{"id":"86","parent":"56","text":"OXIGENOTERAPIA","guid":"oYlKOJsuRd6_W_GbmfVeoQ","children":[{"id":"87","parent":"86","text":"Meta SpO2 88-92% (NO >92% en EPOC)","guid":"s6r8jM3QRRC-uqTsmpPV6A","children":[]},{"id":"88","parent":"86","text":"Riesgo de hipercapnia con O2 excesivo","guid":"3kb6aRgCRDaBKJGoin6ucQ","children":[]},{"id":"89","parent":"86","text":"Venturi al 24-28% inicial","guid":"jVKOE_XlQGqgSTKa5CMy8w","children":[]},{"id":"90","parent":"86","text":"Control gasometrico a los 30-60 min","guid":"PuyzpMf8T6e8igXsI76mJQ","children":[]}]}]},{"id":"91","parent":"1","text":"Soporte ventilatorio","guid":"mGNxzw5qQLSW1JmQX0lQEw","children":[{"id":"92","parent":"91","text":"VMNI (VNI) → INDICACION CLAVE","guid":"KmRhF9s-S9S_FDCm1PZPHw","children":[{"id":"93","parent":"92","text":"pH <7.35 con pCO2 >45 mmHg","guid":"xKKnnlzDSGGzuT_1dhOJ9w","children":[]},{"id":"94","parent":"92","text":"Disnea severa con signos de fatiga","guid":"DTxFkqNkQB6c8AbOs_oBcw","children":[]},{"id":"95","parent":"92","text":"Modalidad → BiPAP (IPAP 10-20, EPAP 4-8)","guid":"_hXVq_LnTzCJGSW_jQxhSg","children":[]},{"id":"96","parent":"92","text":"Meta → mejorar pH y reducir pCO2","guid":"SsgQfSQ9Q3-TTmBTpA6UAg","children":[]},{"id":"97","parent":"92","text":"Contraindicaciones → PCR, incapacidad proteger via aerea, agitacion extrema","guid":"E9SiXwyvRdCXb5YKztWEDA","children":[]},{"id":"98","parent":"92","text":"PERLA → VMNI reduce mortalidad NNT ~10, reduce intubacion","guid":"oDCC0wgLTvqM2ZTokW7qZg","children":[]},{"id":"99","parent":"92","text":"EN ADULTO MAYOR → excelente opcion, tolerar interfaz adecuada","guid":"w8IsWm6eTJO5P5Lbw38Jwg","children":[]}]},{"id":"100","parent":"91","text":"VENTILACION MECANICA INVASIVA","guid":"jGfOZKl4T7iU59ey0aTmHA","children":[{"id":"101","parent":"100","text":"Si fracaso VMNI (no mejoria en 1-2h)","guid":"TQ-mS6zjSAKmYv9RLcN6Nw","children":[]},{"id":"102","parent":"100","text":"pH <7.20 persistente","guid":"t4Z0v0AHRFupc6ZuDUYJEA","children":[]},{"id":"103","parent":"100","text":"Compromiso de conciencia severo","guid":"kKGzPvTzRW-mpaDaTxKXEg","children":[]},{"id":"104","parent":"100","text":"Estrategia → volumen tidal bajo, FR baja, TI:TE largo","guid":"JaPeuUdPSbGuyGPist530g","children":[]}]}]},{"id":"105","parent":"1","text":"Criterios de hospitalizacion","guid":"qxqb_AhORMie24tK989SNQ","children":[{"id":"106","parent":"105","text":"Exacerbacion severa","guid":"XTZiWYSPRmGsGaMGcdRb9g","children":[]},{"id":"107","parent":"105","text":"Fallo de tratamiento ambulatorio","guid":"14fj2yaJSiS9D9vNXUcLYw","children":[]},{"id":"108","parent":"105","text":"Comorbilidades descompensadas","guid":"8Y6N7a2_STOnUWBV9m8Cyg","children":[]},{"id":"109","parent":"105","text":"Hipoxemia/hipercapnia significativa","guid":"P6ApcEfqRSyMn_u28m_nOw","children":[]},{"id":"110","parent":"105","text":"Soporte social insuficiente","guid":"7-egIhnnTs-adnfzHwnmxw","children":[]}]},{"id":"111","parent":"1","text":"Criterios de alta","guid":"VyCfnaRzQcmU3dC5cEJGaQ","children":[{"id":"112","parent":"111","text":"SpO2 >88% con O2 habitual o ambiente","guid":"g-RK1V1FRKiAENEMa_Mfkg","children":[]},{"id":"113","parent":"111","text":"SABA cada 4h o mas","guid":"pzkHfzBnSz6jeol0nqyyDg","children":[]},{"id":"114","parent":"111","text":"Deambula por habitacion","guid":"A4ZsAW-2Rua4ONXyucsvlA","children":[]},{"id":"115","parent":"111","text":"Tolera alimentacion","guid":"Zojxt1LKQ9q1kW516N6Jyw","children":[]},{"id":"116","parent":"111","text":"Estable >12-24h","guid":"cniCtlhkT5Kqy_QwK1_cFQ","children":[]},{"id":"117","parent":"111","text":"Plan de accion escrito","guid":"9BeigykrTeiBg5GoicBSvg","children":[]}]}]},{"