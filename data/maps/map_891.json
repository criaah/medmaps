{"title":"Varicocele","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Entidades clínicas/General/Varicocele iPad.smmx","root":{"id":"0","parent":"-1","text":"Varicocele","guid":"wJU5eRAsSQChCs0qL-vPGA","children":[{"id":"1","parent":"0","text":"Definición","guid":"","children":[{"id":"2","parent":"1","text":"Dilatación venas gonadales (plexo pampiniforme) en escroto","guid":"","children":[]},{"id":"3","parent":"1","text":"Aspecto clásico → 'SACO DE GUSANOS' (bag of worms)","guid":"","children":[]},{"id":"4","parent":"1","text":"CAUSA MÁS COMÚN de infertilidad masculina corregible","guid":"","children":[]}]},{"id":"5","parent":"0","text":"Clasificación\\Netiológica","guid":"SNCP1ND80d8FZbC5jhul3Q","children":[{"id":"6","parent":"5","text":"Primario","guid":"","children":[{"id":"7","parent":"6","text":"Reflujo venoso hacia plexo pampiniforme","guid":"","children":[]},{"id":"8","parent":"6","text":"IZQUIERDO 90% → vena gonadal izq drena en ángulo recto en vena renal izq","guid":"","children":[]},{"id":"9","parent":"6","text":"Mayor presión/resistencia hemodinámica","guid":"","children":[]}]},{"id":"10","parent":"5","text":"Secundario","guid":"","children":[{"id":"11","parent":"10","text":"Compresión externa de venas espermáticas","guid":"","children":[]},{"id":"12","parent":"10","text":"Lateralidad DERECHA o bilateral súbito → BANDERA ROJA","guid":"","children":[]},{"id":"13","parent":"10","text":"Causas: Ca células renales, fibrosis retroperitoneal, hipertensión portal","guid":"","children":[]}]}]},{"id":"14","parent":"0","text":"Epidemiología","guid":"","children":[{"id":"15","parent":"14","text":"Prevalencia población general masculina → 15-20%","guid":"","children":[]},{"id":"16","parent":"14","text":"Más común en adolescentes y adultos jóvenes","guid":"","children":[]},{"id":"17","parent":"14","text":"Prevalencia aumenta con edad (~42% en adultos mayores)","guid":"","children":[]},{"id":"18","parent":"14","text":"Infertilidad primaria → hasta 40%","guid":"","children":[]},{"id":"19","parent":"14","text":"INFERTILIDAD SECUNDARIA → HASTA 80%","guid":"","children":[]},{"id":"20","parent":"14","text":"3% hombres tienen varicoceles grandes con mayor riesgo infertilidad","guid":"","children":[]}]},{"id":"21","parent":"0","text":"Fisiopatología","guid":"","children":[{"id":"22","parent":"21","text":"Anatomía\\Nvascular","guid":"8y3PntGR59Gyx1HRZuna2w","children":[{"id":"23","parent":"22","text":"Lado izquierdo → vena espermática más larga","guid":"","children":[]},{"id":"24","parent":"22","text":"Drenaje ángulo recto en vena renal izq","guid":"","children":[]},{"id":"25","parent":"22","text":"Efecto 'CASCANUECES' → compresión entre aorta y AMS","guid":"","children":[]},{"id":"26","parent":"22","text":"Lado derecho → drenaje oblicuo directo en VCI (mejor flujo)","guid":"","children":[]}]},{"id":"27","parent":"21","text":"Mecanismos de daño\\N(TRÍADA)","guid":"BrM6NgjjUMaGSQep-t8nQQ","children":[{"id":"28","parent":"27","text":"1. ESTRÉS TÉRMICO\\N(hipertermia)","guid":"RER6c-y5dQHk0oH4ZAlTlw","children":[{"id":"29","parent":"28","text":"Temperatura escrotal óptima 33-34°C","guid":"","children":[]},{"id":"30","parent":"28","text":"Alteración espermatogénesis por calor","guid":"","children":[]}]},{"id":"31","parent":"27","text":"2. Hipoperfusión/Hipoxia","guid":"","children":[{"id":"32","parent":"31","text":"Estasis sanguínea → cambios isquémicos","guid":"","children":[]},{"id":"33","parent":"31","text":"Acumulación metabolitos tóxicos","guid":"","children":[]}]},{"id":"34","parent":"27","text":"3. ESTRÉS OXIDATIVO\\N(ROS)","guid":"GCLk9NKEl2kRGrSXNCnz9Q","children":[{"id":"35","parent":"34","text":"↓ producción ATP espermático","guid":"","children":[]},{"id":"36","parent":"34","text":"↓ movilidad espermática","guid":"","children":[]},{"id":"37","parent":"34","text":"↑ FRAGMENTACIÓN ADN espermático","guid":"","children":[]},{"id":"38","parent":"34","text":"Varicocelectomía ↓ OS y ↑ antioxidantes seminales","guid":"","children":[]}]}]},{"id":"39","parent":"21","text":"Daño testicular PROGRESIVO desde adolescencia","guid":"","children":[]},{"id":"40","parent":"21","text":"Afecta célula de Leydig → atrofia, vacuolización, ↓ número","guid":"","children":[]}]},{"id":"41","parent":"0","text":"Evaluación\\Nclínica","guid":"8dxDtlAMwataZVC0vtDf_w","children":[{"id":"42","parent":"41","text":"Historia\\Nclínica","guid":"v-a-bTm-n_uMnWUq9AmGzg","children":[{"id":"43","parent":"42","text":"Masa escrotal indolora","guid":"","children":[]},{"id":"44","parent":"42","text":"Dolor escrotal (pesadez, peor con bipedestación)","guid":"","children":[]},{"id":"45","parent":"42","text":"Infertilidad como motivo de consulta","guid":"","children":[]},{"id":"46","parent":"42","text":"BANDERAS ROJAS\\N(varicocele secundario)","guid":"pS21AwE21YN4aeFL4LuhCQ","children":[{"id":"47","parent":"46","text":"Inicio tardío","guid":"","children":[]},{"id":"48","parent":"46","text":"Lado DERECHO aislado → descartar masa renal","guid":"","children":[]},{"id":"49","parent":"46","text":"Hematuria macroscópica o dolor flanco","guid":"","children":[]},{"id":"50","parent":"46","text":"Historia OH / Hepatitis B-C (hipertensión portal)","guid":"","children":[]}]}]},{"id":"51","parent":"41","text":"Examen\\Nfísico","guid":"9vlEaeOW8ErHLfifKV7cHg","children":[{"id":"52","parent":"51","text":"Posición: decúbito supino Y BIPEDESTACIÓN (obligatorio)","guid":"","children":[]},{"id":"53","parent":"51","text":"Maniobra de VALSALVA → dilata varicocele (fundamental para Grado I)","guid":"","children":[]},{"id":"54","parent":"51","text":"Evaluar tamaño y consistencia testicular (buscar atrofia ipsilateral)","guid":"","children":[]}]},{"id":"55","parent":"41","text":"Clasificación de\\NDUBIN Y AMELAR","guid":"_3d5EBSprWSuax_ZjJHW2Q","children":[{"id":"56","parent":"55","text":"Grado 0 (subclínico) → NO palpable ni visible, SOLO ecografía","guid":"","children":[]},{"id":"57","parent":"55","text":"Grado I → palpable SOLO con Valsalva","guid":"","children":[]},{"id":"58","parent":"55","text":"Grado II → palpable en reposo, NO visible","guid":"","children":[]},{"id":"59","parent":"55","text":"Grado III → VISIBLE y palpable en reposo ('saco de gusanos')","guid":"","children":[]}]}]},{"id":"60","parent":"0","text":"Estudios\\Ncomplementarios","guid":"f5CBANO1tG4TqDz5WYvq3g","children":[{"id":"61","parent":"60","text":"Ecografía Doppler\\Nescrotal","guid":"7H3vs2ba5Z4bFz1i3xZtMA","children":[{"id":"62","parent":"61","text":"Indicación → examen físico no concluyente (escroto tenso, obesidad)","guid":"","children":[]},{"id":"63","parent":"61","text":"Evaluación recurrencia post-qx","guid":"","children":[]},{"id":"64","parent":"61","text":"Hallazgos: diámetro venoso >2-3mm, reflujo con Valsalva","guid":"","children":[]},{"id":"65","parent":"61","text":"NO buscar varicoceles subclínicos sin indicación","guid":"","children":[]}]},{"id":"66","parent":"60","text":"Imágenes abdominales\\N(TC/RM)","guid":"_IcWp9lQofB3UgHPSVu-xw","children":[{"id":"67","parent":"66","text":"SOLO si sospecha varicocele secundario","guid":"","children":[]},{"id":"68","parent":"66","text":"Varicocele derecho aislado → TC abdominal OBLIGATORIO","guid":"","children":[]},{"id":"69","parent":"66","text":"Descartar Ca células renales, fibrosis retroperitoneal","guid":"","children":[]}]},{"id":"70","parent":"60","text":"Espermiograma","guid":"","children":[{"id":"71","parent":"70","text":"2 muestras recomendadas","guid":"","children":[]},{"id":"72","parent":"70","text":"Hallazgos típicos: OAT (oligo-asteno-teratozoospermia)","guid":"","children":[]},{"id":"73","parent":"70","text":"Control post-qx → 3 MESES (ciclo espermatogénesis ~72 días)","guid":"","children":[]}]},{"id":"74","parent":"60","text":"Perfil hormonal","guid":"","children":[{"id":"75","parent":"74","text":"FSH, LH, testosterona sérica","guid":"","children":[]},{"id":"76","parent":"74","text":"Efecto sobre T sérica → CONTROVERSIAL","guid":"","children":[]},{"id":"77","parent":"74","text":"Lima 2020: mejora espermiograma sin cambios en T sérica ni ITT","guid":"","children":[]}]}]},{"id":"78","parent":"0","text":"Manejo","guid":"","children":[{"id":"79","parent":"78","text":"Indicaciones tratamiento\\N(AUA/ASRM + EAU)","guid":"eQpRaAHgqcOwkEyUsZj6gg","children":[{"id":"80","parent":"79","text":"Varicocele PALPABLE (Grado I-III)","guid":"","children":[]},{"id":"81","parent":"79","text":"Pareja con INFERTILIDAD conocida","guid":"","children":[]},{"id":"82","parent":"79","text":"Mujer con reserva ovárica normal","guid":"","children":[]},{"id":"83","parent":"79","text":"Parámetros semen ANORMALES","guid":"","children":[]},{"id":"84","parent":"79","text":"Otras: ↑ fragmentación ADN, fallo TRA, dolor escrotal persistente","guid":"","children":[]}]},{"id":"85","parent":"78","text":"Contraindicaciones","guid":"","children":[{"id":"86","parent":"85","text":"Varicocele SUBCLÍNICO → NO OPERAR (recomendación fuerte)","guid":"","children":[]},{"id":"87","parent":"85","text":"Espermiograma normal → NO tratar","guid":"","children":[]},{"id":"88","parent":"85","text":"Azoospermia (salvo casos específicos con biopsia)","guid":"","children":[]}]},{"id":"89","parent":"78","text":"Opciones\\Nterapéuticas","guid":"AiQmJ_nLaQfHwlfeEZ36uw","children":[{"id":"90","parent":"89","text":"1. MICROCIRUGÍA\\N→ GOLD STANDARD","guid":"TBeLVoDChrSVfr6xOlCcCw","children":[{"id":"91","parent":"90","text":"Subinguinal o inguinal","guid":"","children":[]},{"id":"92","parent":"90","text":"Preserva arterias y linfáticos → ↓ hidrocele","guid":"","children":[]},{"id":"93","parent":"90","text":"↓ recurrencia vs técnica abierta","guid":"","children":[]},{"id":"94","parent":"90","text":"Mejora concentración +9-12 × 10⁶/mL (p<0.00001)","guid":"","children":[]},{"id":"95","parent":"90","text":"Mejora movilidad +10% (p<0.0001)","guid":"","children":[]}]},{"id":"96","parent":"89","text":"2. Cirugía abierta\\Nconvencional","guid":"4ZbvBPw6rFT5eefVEAZs9g","children":[{"id":"97","parent":"96","text":"Mayor riesgo complicaciones","guid":"","children":[]},{"id":"98","parent":"96","text":"Hidrocele = complicación más frecuente","guid":"","children":[]}]},{"id":"99","parent":"89","text":"3. Laparoscopia","guid":"","children":[{"id":"100","parent":"99","text":"Mayor invasividad abdominal","guid":"","children":[]}]},{"id":"101","parent":"89","text":"4. Embolización\\Nvenosa percutánea","guid":"hEC--k5ztigRkO_zQszSJQ","children":[{"id":"102","parent":"101","text":"Alternativa menos invasiva","guid":"","children":[]},{"id":"103","parent":"101","text":"Éxito 90-97%","guid":"","children":[]},{"id":"104","parent":"101","text":"Recurrencia 2-24%","guid":"","children":[]},{"id":"105","parent":"101","text":"Recuperación más rápida","guid":"","children":[]}]}]}]},{"id":"106","parent":"0","text":"Resultados\\Ny pronóstico","guid":"L0Mc8LLoi_iw6Z6nxSaxnQ","children":[{"id":"107","parent":"106","text":"Post-reparación","guid":"","children":[{"id":"108","parent":"107","text":"Embarazo espontáneo → ~40% parejas","guid":"","children":[]},{"id":"109","parent":"107","text":"Mejoría semen sin embarazo → ~30%","guid":"","children":[]},{"id":"110","parent":"107","text":"Sin cambios en semen → ~30%","guid":"","children":[]}]},{"id":"111","parent":"106","text":"Evidencia actualizada\\N(Cochrane/meta-análisis)","guid":"wAT2V__3egjqhl_C8RCn5w","children":[{"id":"112","parent":"111","text":"13 RCTs: varicocelectomía mejora tasa embarazo (OR 1.55, IC 95% 1.06-2.26)","guid":"","children":[]},{"id":"113","parent":"111","text":"Palpable + semen anormal → mayor beneficio (OR 1.94, IC 95% 1.23-3.05)","guid":"","children":[]},{"id":"114","parent":"111","text":"Birowo 2023 (31 estudios): embarazo (OR 1.82, IC 1.37-2.41), nacido vivo (OR 2.80, IC 1.67-4.72)","guid":"","children":[]},{"id":"115","parent":"111","text":"Grados II-III responden mejor, pero TODOS los grados mejoran","guid":"","children":[]}]},{"id":"116","parent":"106","text":"Adolescentes","guid":"","children":[{"id":