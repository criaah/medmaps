4_JSLHR-H-13-0226","guid":"","children":[]},{"id":"131","parent":"128","text":"3. Danneels M, et al. Central auditory processing and listening effort in normal-hearing children. Int J Audiol. 2021;60(10):739-746. https://doi.org/10.1080/14992027.2021.1877365","guid":"","children":[]},{"id":"132","parent":"128","text":"4. Mattsson TS, et al. Normative data for diagnosing APD in Norwegian children. Int J Audiol. 2017;57(1):10-20. https://doi.org/10.1080/14992027.2017.1366670","guid":"","children":[]}]}]},"node_count":132,"relations":[],"cross_references":[],"specialty":"General","folder":"Entidades clínicas/General","filename":"TPAC iPad","id":"map_874","resolved_references":[],"title_raw":"TPAC iPad"}