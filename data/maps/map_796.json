{"title":"KFD (Enfermedad de Kikuchi-Fujimoto)-2024-1","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Entidades clínicas/General/KFD (Enfermedad de Kikuchi-Fujimoto)-2024-1.smmx","root":{"id":"0","parent":"-1","text":"KFD (Enfermedad\\Nde Kikuchi-Fujimoto)","guid":"cKi5g1THuZIiz7tZPIV03g","children":[{"id":"1","parent":"0","text":"General","guid":"","children":[{"id":"2","parent":"1","text":"- General: Rara, idiopática, linfadenopatía benigna","guid":"","children":[]},{"id":"3","parent":"1","text":"- Demografía: Afecta ambos géneros, 20-40 años, todas las etnias","guid":"","children":[]},{"id":"4","parent":"1","text":"- Clínica: Inicio agudo/subagudo con fiebre, dolores, sudoración nocturna, pérdida de peso","guid":"","children":[{"id":"5","parent":"4","text":"- Autolimitada, resolución en 3-4 meses","guid":"","children":[]}]},{"id":"6","parent":"1","text":"- Etiología: Incierta, estudios virales inconsistentes","guid":"","children":[]},{"id":"7","parent":"1","text":"- Patobiología: Vías moleculares no bien entendidas","guid":"","children":[]},{"id":"8","parent":"1","text":"- Asociaciones: Trastornos autoinmunes, especialmente LES","guid":"","children":[]},{"id":"9","parent":"1","text":"- Diagnóstico:","guid":"","children":[{"id":"10","parent":"9","text":"- Basado en histopatología","guid":"","children":[]},{"id":"11","parent":"9","text":"- Biopsia excisional en casos dudosos","guid":"","children":[]},{"id":"12","parent":"9","text":"- Secuenciación de alta capacidad puede identificar biomarcadores","guid":"","children":[]}]},{"id":"13","parent":"1","text":"- Criterios diagnósticos:","guid":"","children":[{"id":"14","parent":"13","text":"- Propuestos para niños, basados en temperatura, tamaño ganglionar, B2 microglobulina","guid":"","children":[]}]},{"id":"15","parent":"1","text":"- Tratamiento:","guid":"","children":[{"id":"16","parent":"15","text":"- Manejo sintomático; glucocorticoides para casos severos","guid":"","children":[]},{"id":"17","parent":"15","text":"- No hay guías establecidas","guid":"","children":[]},{"id":"18","parent":"15","text":"- Corticosteroides, AINES, hidroxicloroquina, inmunomoduladores","guid":"","children":[]}]}]},{"id":"19","parent":"0","text":"- Epidemiología ","guid":"","children":[{"id":"20","parent":"19","text":"- Origen: Descrita en 1972, Japón por Kikuchi y Fujimoto","guid":"","children":[]},{"id":"21","parent":"19","text":"- Casos:","guid":"","children":[{"id":"22","parent":"21","text":"- Focal reticulum cell hyperplasia, nuclear debris, phagocytosis","guid":"","children":[]},{"id":"23","parent":"21","text":"- Subacute necrotizing cervical lymphadenitis","guid":"","children":[]}]},{"id":"24","parent":"19","text":"- Diseminación: Reportada mundialmente, todas las razas y grupos étnicos","guid":"","children":[]},{"id":"25","parent":"19","text":"- Alta prevalencia en japoneses","guid":"","children":[]},{"id":"26","parent":"19","text":"- Estudios:","guid":"","children":[{"id":"27","parent":"26","text":"- EE.UU.: 75% pacientes blancos de 88 casos","guid":"","children":[]},{"id":"28","parent":"26","text":"- Arabia Saudita: 0.5% de 920 ganglios linfáticos con histopatología KFD","guid":"","children":[]},{"id":"29","parent":"26","text":"- Taiwán: 5.7% adenitis asociada a KFD","guid":"","children":[]},{"id":"30","parent":"26","text":"- Corea: 35% de 147 pacientes con linfadenitis cervical","guid":"","children":[]}]},{"id":"31","parent":"19","text":"- Prevalencia: Subestudiada, falta de criterios diagnósticos validados","guid":"","children":[]},{"id":"32","parent":"19","text":"- Demografía:","guid":"","children":[{"id":"33","parent":"32","text":"- Edad de presentación: 6-80 años, promedio 30 años","guid":"","children":[]},{"id":"34","parent":"32","text":"- Preponderancia inicial en mujeres, pero afecta ambos géneros","guid":"","children":[]},{"id":"35","parent":"32","text":"- Ratio M:F variado: 1:4, 1:1.6, 1:1.3","guid":"","children":[]},{"id":"36","parent":"32","text":"- En niños coreanos < 18 años, afecta igualmente a ambos géneros","guid":"","children":[]},{"id":"37","parent":"32","text":"- En niños < 12 años, mayor propensión en hombres","guid":"","children":[]}]}]},{"id":"38","parent":"0","text":"- Etiología","guid":"","children":[{"id":"39","parent":"38","text":"- Respuesta inmune: Mediada por células T y histiocitos","guid":"","children":[]},{"id":"40","parent":"38","text":"- Desencadenantes:","guid":"","children":[{"id":"41","parent":"40","text":"- Infecciosos: ↑ IFN-α sugiere etiología viral","guid":"","children":[{"id":"42","parent":"41","text":"- Agentes: EBV, HHV 6/8, HIV, Parvovirus B19, Paramyxovirus, Parainfluenza, Y. enterocolitica, Toxoplasma, S. pneumoniae","guid":"","children":[]}]},{"id":"43","parent":"40","text":"- No infecciosos: Respuesta a minociclina, ciprofloxacino, ofloxacino","guid":"","children":[]}]},{"id":"44","parent":"38","text":"- Observaciones:","guid":"","children":[{"id":"45","parent":"44","text":"- EBV más observado, pero evidencia directa limitada","guid":"","children":[]},{"id":"46","parent":"44","text":"- Minivirus parecido a circovirus en pacientes coreanos","guid":"","children":[]},{"id":"47","parent":"44","text":"- Reacción hiperinmune postviral como posible disparador","guid":"","children":[]}]},{"id":"48","parent":"38","text":"- Tras vacunación: Casos tras vacunas influenza, encefalitis japonesa, HPV, COVID-19","guid":"","children":[]},{"id":"49","parent":"38","text":"- Mecanismo autoinmune: Similaridades clínico-patológicas con SLE y otros trastornos autoinmunes","guid":"","children":[]},{"id":"50","parent":"38","text":"- Asociaciones:","guid":"","children":[{"id":"51","parent":"50","text":"- ↑ Riesgo de evolución a síndrome autoinmune, especialmente en mujeres","guid":"","children":[]},{"id":"52","parent":"50","text":"- Enfermedades asociadas: Tiroiditis de Hashimoto, síndrome de\\NSjögren, síndrome antifosfolípido, vasculitis leucocitoclástica","guid":"","children":[]}]},{"id":"53","parent":"38","text":"- Casos anecdóticos: Post trasplante de células madre hematopoyéticas y cirugía bariátrica","guid":"","children":[]}]},{"id":"54","parent":"0","text":"- Patogénesis KFD","guid":"","children":[{"id":"55","parent":"54","text":"- Transmisión genética:\\NNo definida claramente","guid":"","children":[{"id":"56","parent":"55","text":"- Casos en gemelos y hermanos HLA-idénticos sin patrón hereditario claro","guid":"","children":[]},{"id":"57","parent":"55","text":"- Algunos casos familiares sugieren predisposición genética","guid":"","children":[]}]},{"id":"58","parent":"54","text":"- Relación HLA:","guid":"","children":[{"id":"59","parent":"58","text":"- Posible relación con alelos HLA clase 2 DPA1*01 y DPB1*0202","guid":"","children":[]},{"id":"60","parent":"58","text":"- Más frecuentes en Asia, posible vínculo con mayor prevalencia de KFD en esta región","guid":"","children":[]}]},{"id":"61","parent":"54","text":"- Mecanismo celular:","guid":"","children":[{"id":"62","parent":"61","text":"- Regulación al alza de genes asociados al ciclo celular y apoptosis (ej. caspasa)","guid":"","children":[]},{"id":"63","parent":"61","text":"- Regulación a la baja de genes inhibidores de la apoptosis (ej. BCL2)","guid":"","children":[]}]},{"id":"64","parent":"54","text":"- Muerte celular por apoptosis:","guid":"","children":[{"id":"65","parent":"64","text":"- Inducida por sistema Fas-Fas ligando, mediada por células CD8+","guid":"","children":[]},{"id":"66","parent":"64","text":"- Histiocitos potencian apoptosis, fagocitan restos apoptóticos","guid":"","children":[]}]},{"id":"67","parent":"54","text":"- Involucración de\\Ncitocinas y quimiocinas:","guid":"","children":[{"id":"68","parent":"67","text":"- IFN-γ, IL-18, MIG, IFN-γ-induced protein 10 implicados en apoptosis en KFD","guid":"","children":[]},{"id":"69","parent":"67","text":"- Niveles séricos de IFN-γ y IL-6 elevados durante la fase aguda, normalizan en convalecencia","guid":"","children":[]}]},{"id":"70","parent":"54","text":"- Hipótesis:","guid":"","children":[{"id":"71","parent":"70","text":"- KFD como enfermedad de dos pasos: predisposición HLA + disparador secundario (infección?)","guid":"","children":[]},{"id":"72","parent":"70","text":"- Necesita más investigación para aclarar patogénesis molecular","guid":"","children":[]}]}]},{"id":"73","parent":"0","text":"- Características\\NClínicas KFD","guid":"","children":[{"id":"74","parent":"73","text":"- Manifestación: Aguda o subaguda","guid":"","children":[]},{"id":"75","parent":"73","text":"- Síntomas principales:","guid":"","children":[{"id":"76","parent":"75","text":"- Fiebre: Baja, intermitente, 1 semana (hasta 1 mes)","guid":"","children":[]},{"id":"77","parent":"75","text":"- Linfadenopatía cervical posterior: Dolorosa","guid":"","children":[]},{"id":"78","parent":"75","text":"- Consistencia ganglionar: Firme a rubbery, 0.5-4 cm (hasta 7 cm)","guid":"","children":[]}]},{"id":"79","parent":"73","text":"- Prevalencia síntomas:","guid":"","children":[{"id":"80","parent":"79","text":"- Linfadenopatía: 100%","guid":"","children":[]},{"id":"81","parent":"79","text":"- Fiebre: 35%","guid":"","children":[]},{"id":"82","parent":"79","text":"- Rash eritematoso: 10%","guid":"","children":[]},{"id":"83","parent":"79","text":"- Artritis: 7%","guid":"","children":[]},{"id":"84","parent":"79","text":"- Fatiga: 7%","guid":"","children":[]},{"id":"85","parent":"79","text":"- Hepatoesplenomegalia: 3%","guid":"","children":[]}]},{"id":"86","parent":"73","text":"- Compromiso ganglionar:","guid":"","children":[{"id":"87","parent":"86","text":"- Común: Cervical unilateral","guid":"","children":[]},{"id":"88","parent":"86","text":"- Raro: Bilateral, generalizado (axilar, epitroclear, mediastínico)","guid":"","children":[]}]},{"id":"89","parent":"73","text":"- Manifestaciones cutáneas:","guid":"","children":[{"id":"90","parent":"89","text":"- 30%-40% pacientes","guid":"","children":[]},{"id":"91","parent":"89","text":"- Eritema facial, rash malar tipo SLE","guid":"","children":[]},{"id":"92","parent":"89","text":"- Lesiones: Maculas, pápulas, placas","guid":"","children":[]}]},{"id":"93","parent":"73","text":"- Manifestaciones sistémicas:","guid":"","children":[{"id":"94","parent":"93","text":"- Pérdida de peso, leucocitosis/leucopenia","guid":"","children":[]},{"id":"95","parent":"93","text":"- Asociación con síndromes inflamatorios","guid":"","children":[]}]},{"id":"96","parent":"73","text":"- Complicaciones neurológicas:","guid":"","children":[{"id":"97","parent":"96","text":"- Meningitis aséptica, meningoencefalitis, síntomas cerebelosos","guid":"","children":[]}]}]},{"id":"98","parent":"0","text":"- Diagnóstico KFD","guid":"","children":[{"id":"99","parent":"98","text":"- Reto diagnóstico: Diferenciar de linfoma maligno y SLE","guid":"","children":[]},{"id":"100","parent":"98","text":"- Frecuente confusión: Con linfoma no-Hodgkin o Hodgkin","guid":"","children":[]},{"id":"101","parent":"98","text":"- Diferenciales comunes: Tumor parótida, linfadenitis lúpica, enfermedad de\\NKawasaki, enfermedad por arañazo de gato, síndrome de Sweet, sarcoidosis","guid":"","children":[]},{"id":"102","parent":"98","text":"- Biopsia:","guid":"","children":[{"id":"103","parent":"102","text":"- Histopatología\\Nes clave","guid":"","children":[{"id":"104","parent":"103","text":"- Biopsia excisional recomendada previamente","guid":"","children":[]},{"id":"105","parent":"103","text":"- Aspiración con aguja fina (AAF): Útil, 56% de precisión","guid":"","children":[]},{"id":"106","parent":"103","text":"- Biopsia con aguja gruesa guiada por ultrasonido: Precisión del 95.6%","guid":"","children":[]}]},{"id":"107","parent":"102","text":"- Características histológicas:","guid":"","children":[{"id":"108","parent":"107","text":"- Fases: Proliferativa, necrotizante, xantomatosa","guid":"","children":[]},{"id":"109","parent":"107","text":"- Diferenciación de SLE, linfadenitis viral/tuberculosa, linfomas","guid":"","children":[]}]},{"id":"110","parent":"102","text":"- Inmunohistoquímica:","guid":"","children":[{"id":"111","parent":"110","text":"- CD8+, CD68+, CD3+ en lesiones","guid":"","children":[]},{"id":"112","parent":"110","text":"- Útil para diferenciar KFD de otras patologías","guid":"","children":[]}]}]},{"id":"113","parent":"98","text":"- Pruebas de\\Nlaboratorio:","guid":"","children":[{"id":"114","parent":"113","text":"- Linfocitos atípicos, leucopenia","guid":"","children":[]},{"id":"115","parent":"113","text":"- VSG, PCR, pruebas hepáticas: No específicas","guid":"","children":[]}]},{"id":"116","parent":"98","text":"- Estudios serológicos:","guid":"","children":[{"id":"117","parent":"116","text":"- EBV, HHV, VIH, toxoplasmosis, etc.","guid":"","children":[]},{"id":"118","parent":"116","text":"- ANA para descartar SLE","guid":"","children":[]}]},{"id":"119","parent":"98","text":"- Estudios de imagen:","guid":"","children":[{"id":"120","parent":"119","text":"- Ultrasonografía, TAC, IRM: Patrones sugestivos, no definitivos","guid":"","children":[]},{"id":"121","parent":"119","text":"- PET para evaluar severidad","guid":"","children":[]}]}]},{"id":"122","parent":"0","text":"- Complicaciones\\NSistémicas KFD","guid":"","children":[{"id":"123","parent":"122","text":"- General: Benigna y autolimitada, pero puede tener complicaciones serias","guid":"","children":[]},{"id":"124","parent":"122","text":"- Cardíacas: Taponamiento cardíaco","guid":"","children":[]},{"id":"125","parent":"122","text":"- Pulmonares: Derrames pleurales, infiltrados y nódulos\\N(enfermedad pulmonar intersticial)","guid":"","children":[]},{"id":"126","parent":"122","text":"- Articulares: Poliartritis simétrica","guid":"","children":[]},{"id":"127","parent":"122","text":"- Endocrinas: Tiroiditis, agrandamiento parotídeo","guid":"","children":[]},{"id":"128","parent":"122","text":"- Hepáticas: Hepatitis autoinmune","guid":"","children":[]},{"id":"129","parent":"122","text":"- Renales: Insuficiencia renal aguda","guid":"","children":[]},{"id":"130","parent":"122","text":"- Oculares: Conjuntivitis papilar bilateral, panuveitis, vasculitis ocular, infiltrados maculares subretinales","guid":"","children":[]},{"id":"131","parent":"122","text":"- Musculoesqueléticas: Polimiositis, paresia de extremidades por neuritis del plexo braquial","guid":"","children":[]},{"id":"132","parent":"122","text":"- Neurológicas: Neuropatía periférica, síndrome antifosfolipídico con fallo multiorgánico","guid":"","children":[]},{"id":"133","parent":"122","text":"- Hematológicas: Hemofagocitosis","guid":"","children":[]},{"id":"134","parent":"122","text":"- Asociaciones raras: Enfermedad de Still, neumonía organizativa\\Ncriptogénica, síndrome hemofagocítico, linfoma de células B","guid":"","children":[]}]},{"id":"135","parent":"0","text":"- KFD y LES (Lupus\\NEritematoso Sistémico)","guid":"","children":[{"id":"136","parent":"135","text":"- Comparten: predisposición de género y edad, características histológicas","guid":"","children":[]},{"id":"137","parent":"135","text":"- Relación temporal:","guid":"","children":[{"id":"138","parent":"137","text":"- LES puede preceder a KFD","guid":"","children":[]},{"id":"139","parent":"137","text":"- Puede estar asociado o desarrollarse después de KFD","guid":"","children":[]}]},{"id":"140","parent":"135","text":"- Estudio: 55 pacientes con KFD y\\Ntrastorno del tejido conectivo","guid":"","children":[{"id":"141","parent":"140","text":"- 40% con inicio simultáneo de KFD y LES","guid":"","children":[]},{"id":"142","parent":"140","text":"- 35% LES precede a KFD","guid":"","children":[]},{"id":"143","parent":"140","text":"- 25% KFD después de LES","guid":"","children":[]}]},{"id":"144","parent":"135","text":"- Complicaciones: KFD puede\\Ncomplicar LES preexistente","guid":"","children":[{"id":"145","parent":"144","text":"- Tratamiento intensivo: ej., metilprednisolona en alta dosis + HCQS","guid":"","children":[]}]},{"id":"146","parent":"135","text":"- Características comunes:","guid":"","children":[{"id":"147","parent":"146","text":"- Lesiones desaparecen sin tratamiento específico","guid":"","children":[]},{"id":"148","parent":"146","text":"- Recurrencia sugiere mecanismo inmunitario","guid":"","children":[]},{"id":"149","parent":"146","text":"- KFD podría ser aspecto común de LES","guid":"","children":[]}]},{"id":"150","parent":"135","text":"- Estudios:","guid":"","children":[{"id":"151","parent":"150","text":"- Estudio ultraestructural indica condición autoinmune SLE-like","guid":"","children":[]},{"id":"152","parent":"150","text":"- Focal necrosis e infiltración inmunoblástica\\Nen LES indistinguible de KFD","guid":"","children":[]}]},{"id":"153","parent":"135","text":"- Marcadores histológicos:","guid":"","children":[{"id":"154","parent":"153","text":"- Lesiones cutáneas KFD similares a LES","guid":"","children":[]},{"id":"155","parent":"153","text":"- Biopsia indica dermatitis de interfaz, posible marcador de evolución a LES","guid":"","children":[]},{"id":"156","parent":"153","text":"- Inmunohistoquímica:","guid":"","children":[{"id":"157","parent":"156","text":"- CD30+ más numeroso en KFD que en LES, útil para diferenciación","guid":"","children":[]}]}]},{"id":"158","parent":"135","text":"- Seguimiento: Necesario a largo plazo para evaluar evolución de KFD a LES","guid":"","children":[]}]},{"id":"159","parent":"0","text":"- KFD en Mujeres\\NEmbarazadas y Niños","guid":"","children":[{"id":"160","parent":"159","text":"- Embarazo","guid":"","children":[{"id":"161","parent":"160","text":"- Afecta comúnmente a mujeres <40 años","guid":"","children":[]},{"id":"162","parent":"160","text":"- Datos sobre impacto en gestación y resultado del embarazo son escasos","guid":"","children":[]},{"id":"163","parent":"160","text":"- Tratamiento con antibióticos y esteroides: Sin efectos adversos en madre o feto","guid":"","children":[]},{"id":"164","parent":"160","text":"- Caso reportado de aborto espontáneo en paciente con KFD y LES en evolución","guid":"","children":[]}]},{"id":"165","parent":"159","text":"- Niños","guid":"","children":[{"id":"166","parent":"165","text":"- Características clínicas similares a adultos","guid":"","children":[]},{"id":"167","parent":"165","text":"- Más frecuente en niños <18 años: Fiebre, rash, linfadenopatía cervical bilateral","guid":"","children":[]},{"id":"168","parent":"165","text":"- Menos común: Linfadenopatía generalizada","guid":"","children":[]},{"id":"169","parent":"165","text":"- Presentación atípica en niños <6 años","guid":"","children":[]},{"id":"170","parent":"165","text":"- Recurrencia en ~3% de pacientes pediátricos, más común en varones","guid":"","children":[]}]}]},{"id":"171","parent":"0","text":"- Tratamiento KFD","guid":"","children":[{"id":"172","parent":"171","text":"- General: Sin tratamiento específico, resolución espontánea en 1-4 meses","guid":"","children":[]},{"id":"173","parent":"171","text":"- Biopsia excisional: Beneficio terapéutico al remover foco inflamatorio","guid":"","children":[]},{"id":"174","parent":"171","text":"- Farmacoterapia: Reducir morbilidad\\Ny prevenir complicaciones","guid":"","children":[{"id":"175","parent":"174","text":"- Manejo leve:","guid":"","children":[{"id":"176","parent":"175","text":"- AINES: Alivian fiebre y dolor ganglionar","guid":"","children":[]}]},{"id":"177","parent":"174","text":"- Manejo severo o prolongado:","guid":"","children":[{"id":"178","parent":"177","text":"- Corticosteroides sistémicos (prednisolona 1-2 mg/kg)","guid":"","children":[]},{"id":"179","parent":"177","text":"- Inmunomoduladores, IVIg en enfermedad extranodal severa o síndrome hemofagocítico","guid":"","children":[]}]},{"id":"180","parent":"174","text":"- Casos resistentes\\No recurrentes:","guid":"","children":[{"id":"181","parent":"180","text":"- Hidroxicloroquina sola o con corticosteroides","guid":"","children":[]},{"id":"182","parent":"180","text":"- Respuesta rápida con cloroquina o anakinra (inhibidor de IL-1)","guid":"","children":[]},{"id":"183","parent":"180","text":"- Eficacia anecdótica de ciprofloxacino, minociclina, ofloxacina: Requiere más estudio","guid":"","children":[]}]}]}]},{"id":"184","parent":"0","text":"- Pronóstico KFD","guid":"","children":[{"id":"185","parent":"184","text":"- General: Bueno, autolimitado en la mayoría","guid":"","children":[]},{"id":"186","parent":"184","text":"- Resolución: Espontánea en 1-6 meses","guid":"","children":[]},{"id":"187","parent":"184","text":"- Recurrencia: 3%-4% de casos","guid":"","children":[]}]},{"id":"188","parent":"0","text":"- Seguimiento\\Nlargo plazo:","guid":"","children":[{"id":"189","parent":"188","text":"- 92% vivos y bien tras 32 meses","guid":"","children":[]},{"id":"190","parent":"188","text":"- Posibilidad de desarrollar LES","guid":"","children":[]},{"id":"191","parent":"188","text":"- Casos de recurrencia continua durante años","guid":"","children":[]},{"id":"192","parent":"188","text":"- Casos coreanos:","guid":"","children":[{"id":"193","parent":"192","text":"- 11.3% recurrencia, 2.7% desarrollan enfermedades autoinmunes","guid":"","children":[]},{"id":"194","parent":"192","text":"- Recurrencias tardías en 13%, tempranas en 8%","guid":"","children":[]},{"id":"195","parent":"192","text":"- 3% desarrollan LES","guid":"","children":[]}]},{"id":"196","parent":"188","text":"- Síntomas en recurrencias: Fiebre, fatiga, compromiso extranodal","guid":"","children":[]},{"id":"197","parent":"188","text":"- Factores de\\Nriesgo recurrencia:","guid":"","children":[{"id":"198","parent":"197","text":"- ANA positivo asociado a mayor riesgo","guid":"","children":[]},{"id":"199","parent":"197","text":"- EBV positivo y ANA negativo con enfermedad severa inicial, relapses frecuentes","guid":"","children":[]}]},{"id":"200","parent":"188","text":"- Mortalidad: 2.1%, asociada a síndrome hemofagocítico o enfermedad del tejido conectivo","guid":"","children":[]},{"id":"201","parent":"188","text":"- Importancia: Seguimiento a largo plazo esencial","guid":"","children":[]}]},{"id":"202","parent":"0","text":"f","guid":"","children":[]}]},"node_count":202,"relations":[],"cross_references":[],"specialty":"General","folder":"Entidades clínicas/General","filename":"KFD (Enfermedad de Kikuchi-Fujimoto)-2024-1","id":"map_796","resolved_references":[]}