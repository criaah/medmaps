"children":[{"id":"229","parent":"228","text":"Tumores parotideos → sospechar si paralisis progresiva/incompleta","guid":"","children":[]},{"id":"230","parent":"228","text":"Colesteatoma → paralisis + otorrea cronica","guid":"","children":[]},{"id":"231","parent":"228","text":"Post-cirugia otologica","guid":"","children":[]},{"id":"232","parent":"228","text":"ACV → DIFERENCIAR\\Ncentral vs periferico","guid":"nNIIAhTjsUCD-qU8qXy3EA","children":[{"id":"233","parent":"232","text":"Periferico → compromiso frente (TODA la hemicara)","guid":"","children":[]},{"id":"234","parent":"232","text":"Central → respeta frente (inervacion bilateral del facial superior)","guid":"","children":[]},{"id":"235","parent":"232","text":"PERLA: si respeta frente → neuroimagen urgente","guid":"","children":[]}]}]},{"id":"236","parent":"187","text":"Impacto\\Nfuncional\\Ngeriatrico","guid":"ZU0u8oY8v_s6bo2pk33n2w","children":[{"id":"237","parent":"236","text":"Ojo seco → ulcera corneal (PROTECCION OBLIGATORIA)","guid":"","children":[]},{"id":"238","parent":"236","text":"Incompetencia oral → disfagia, babeo","guid":"","children":[]},{"id":"239","parent":"236","text":"Alteracion de la comunicacion → aislamiento social","guid":"","children":[]},{"id":"240","parent":"236","text":"Impacto emocional → depresion, ansiedad","guid":"","children":[]}]},{"id":"241","parent":"187","text":"Decisiones\\Nterapeuticas\\Nen AM fragil","guid":"uMX9ekkdpzBfw4Sq8p_H7A","children":[{"id":"242","parent":"241","text":"Corticoides → riesgo/beneficio en diabetico/fragil","guid":"","children":[]},{"id":"243","parent":"241","text":"Antivirales → ajuste renal (ClCr en AM)","guid":"","children":[]},{"id":"244","parent":"241","text":"Rehabilitacion facial → adaptada a capacidad funcional","guid":"","children":[]},{"id":"245","parent":"241","text":"Proporcionalidad terapeutica en deterioro severo","guid":"","children":[]}]}]},{"id":"246","parent":"0","text":"Perlas\\NClinicas","guid":"6rAGCUZ9nDLLGYEeZ0u1Pw","children":[{"id":"247","parent":"246","text":"Presbiacusia NO es normal del envejecimiento → es TRATABLE","guid":"","children":[]},{"id":"248","parent":"246","text":"ACHIEVE trial: audifonos reducen deterioro cognitivo 48% en poblacion de riesgo","guid":"","children":[]},{"id":"249","parent":"246","text":"Cerumen impactado puede simular deterioro cognitivo → SIEMPRE revisar oidos en VGI","guid":"","children":[]},{"id":"250","parent":"246","text":"Otorrea + diabetes + granulacion en CAE = otitis externa MALIGNA hasta demostrar lo contrario","guid":"","children":[]},{"id":"251","parent":"246","text":"Vesiculas en CAE + paralisis facial = Ramsay Hunt → aciclovir IV URGENTE","guid":"","children":[]},{"id":"252","parent":"246","text":"14% de Ramsay Hunt presenta vesiculas DESPUES de la paralisis → no esperar vesiculas para tratar","guid":"","children":[]},{"id":"253","parent":"246","text":"VPPB es la causa MAS frecuente de vertigo en AM → maniobra de Epley cura >80%","guid":"","children":[]},{"id":"254","parent":"246","text":"Audifonos mejoran no solo audicion sino tambien ESTABILIDAD POSTURAL","guid":"","children":[]},{"id":"255","parent":"246","text":"EVITAR sedantes vestibulares cronicos (dimenhidrinato) → empeoran equilibrio basal","guid":"","children":[]},{"id":"256","parent":"246","text":"En paralisis facial: si respeta frente → ACV hasta demostrar lo contrario → neuroimagen urgente","guid":"","children":[]},{"id":"257","parent":"246","text":"Bell en AM: edad es el predictor MAS critico de mal pronostico → seguimiento estrecho","guid":"","children":[]},{"id":"258","parent":"246","text":"Corticoides en Bell + diabetes: monitorizar glicemia, NO contraindicacion absoluta","guid":"","children":[]},{"id":"259","parent":"246","text":"Implante coclear seguro en >80 anos → no excluir por edad","guid":"","children":[]}]},{"id":"260","parent":"0","text":"VER\\NTAMBIEN","guid":"3iTI15WefWnIcjkjpLR7UQ","children":[{"id":"261","parent":"260","text":"→ Semiologia ORL Geriatrica (Modulo 1)","guid":"","children":[]},{"id":"262","parent":"260","text":"→ Nariz y Olfato en el Envejecimiento (Modulo 3)","guid":"","children":[]},{"id":"263","parent":"260","text":"→ Caidas y Prevencion (Sindromes Geriatricos)","guid":"","children":[]},{"id":"264","parent":"260","text":"→ Delirium (Sindromes Geriatricos)","guid":"","children":[]},{"id":"265","parent":"260","text":"→ Fragilidad y Proporcionalidad Terapeutica (VGI)","guid":"","children":[]},{"id":"266","parent":"260","text":"→ Deterioro Cognitivo (Sindromes Geriatricos)","guid":"","children":[]}]},{"id":"267","parent":"0","text":"Referencias","guid":"","children":[{"id":"268","parent":"267","text":"1. Lin FR et al. Hearing intervention versus health education control to reduce cognitive decline (ACHIEVE). Lancet. 2023;402(10404):786-797.","guid":"","children":[]},{"id":"269","parent":"267","text":"2. Schuknecht HF, Gacek MR. Cochlear pathology in presbycusis. Ann Otol Rhinol Laryngol. 1993;102(1 Pt 2):1-16.","guid":"","children":[]},{"id":"270","parent":"267","text":"3. Livingston G et al. Dementia prevention, intervention, and care: 2020 report of the Lancet Commission. Lancet. 2020;396(10248):413-446.","guid":"","children":[]},{"id":"271","parent":"267","text":"4. Rumalla K et al. The effect of hearing aids on postural stability. Laryngoscope. 2015;125(3):720-723.","guid":"","children":[]},{"id":"272","parent":"267","text":"5. Bareiss SK, Nieman CL, Emmett SD. Hearing and Vestibular Loss in the Elderly. En: Brocklehurst's Textbook of Geriatric Medicine. 9th ed. 2023; Cap 12.","guid":"","children":[]},{"id":"273","parent":"267","text":"6. Kafle D, Thakur A. Prognostic factors of Bell's palsy: a retrospective study. Kathmandu Univ Med J. 2021;19(4):481-485.","guid":"","children":[]},{"id":"274","parent":"267","text":"7. Escalante DA et al. Factors predicting facial nerve recovery in Bell's palsy. Am J Otolaryngol. 2021;42(6):103157.","guid":"","children":[]},{"id":"275","parent":"267","text":"8. Neckel APC et al. Risk factors for Bell's palsy: systematic review and meta-analysis. BMC Neurol. 2025;25(1):42.","guid":"","children":[]},{"id":"276","parent":"267","text":"9. Kakeeto C et al. Ramsay Hunt syndrome in an 87-year-old: case report. BMC Geriatr. 2025;25(1):89.","guid":"","children":[]},{"id":"277","parent":"267","text":"10. Chang JL et al. Corticosteroid use in otolaryngology during COVID-19. Otolaryngol Head Neck Surg. 2021;165(3):375-384.","guid":"","children":[]},{"id":"278","parent":"267","text":"11. Matamala G. Clase Oido Externo - Otorrinolaringologia. Universidad Mayor. 2015.","guid":"","children":[]},{"id":"279","parent":"267","text":"12. Matamala G. Clase Examen de ORL y Diagnostico. Universidad Mayor. 2014.","guid":"","children":[]}]}]},"node_count":279,"relations":[],"cross_references":[],"specialty":"General","folder":"Entidades clínicas/Geriatría","filename":"Mod2 Oido AM Ipad (1)","id":"map_991","resolved_references":[]}