{"title":"Algoritmo_Paro_Cardiaco_ACLS_AHA2025_iPad","guid":"","filepath":"/Users/criaah/Vault/📚 Resources/Mapas-Mentales/Entidades clínicas/UCI-Medicina Crítica/Algoritmo_Paro_Cardiaco_ACLS_AHA2025_iPad.smmx","root":{"id":"0","parent":"-1","text":"Algoritmo Paro Cardíaco\\N(ACLS AHA 2025)","guid":"J2vi3SeFNQJITIk7F7Md-A","children":[{"id":"1","parent":"0","text":"Diagnóstico de\\NParo Cardíaco","guid":"bDAmGlSrSEMO0IUgFUhYQw","children":[{"id":"2","parent":"1","text":"Paciente INCONSCIENTE + SIN PULSO","guid":"","children":[]},{"id":"3","parent":"1","text":"Escena segura → estímulo táctil y verbal","guid":"","children":[]},{"id":"4","parent":"1","text":"Activar sistema de emergencias (código azul/rojo)","guid":"","children":[]},{"id":"5","parent":"1","text":"Verificar pulso carotídeo →\\N<10 segundos (AHA 2025)","guid":"IWIyGgnyhAQh7Xm-dJZnkg","children":[{"id":"6","parent":"5","text":"Centro del cuello → 2 cm lateral","guid":"","children":[]},{"id":"7","parent":"5","text":"Si no percibes pulso en 2-5 seg → iniciar RCP","guid":"","children":[]}]},{"id":"8","parent":"1","text":"Diagnóstico diferencial\\Ndel colapso","guid":"btPYZBOwA290zGgUeAK7bQ","children":[{"id":"9","parent":"8","text":"Sin pulso + sin respiración/agónica → PARO CARDÍACO","guid":"","children":[]},{"id":"10","parent":"8","text":"Con pulso + sin respiración eficaz →\\NPARO RESPIRATORIO","guid":"TkxEFyI_f9kM76yJVMRwAg","children":[{"id":"11","parent":"10","text":"FR <10-12, pobre amplexión → ventilaciones de rescate","guid":"","children":[]},{"id":"12","parent":"10","text":"Si no se trata → evoluciona a paro cardíaco","guid":"","children":[]}]},{"id":"13","parent":"8","text":"Con pulso + respiración adecuada →\\NDETERIORO NEUROLÓGICO","guid":"PKM7y3q-ix1i_DYtZA8eqA","children":[{"id":"14","parent":"13","text":"Hipoglucemia severa","guid":"","children":[]},{"id":"15","parent":"13","text":"EVC isquémico/hemorrágico","guid":"","children":[]},{"id":"16","parent":"13","text":"Trauma craneal (hematoma epidural/subdural)","guid":"","children":[]}]}]}]},{"id":"17","parent":"0","text":"Causas de\\NParo Cardíaco","guid":"IkPAHytIv2h7wjyhMoRS-g","children":[{"id":"18","parent":"17","text":"REVERSIBLES →\\N5Hs y 5Ts","guid":"aAePanXbQT1qFekiWhEo2A","children":[{"id":"19","parent":"18","text":"Hipovolemia","guid":"","children":[]},{"id":"20","parent":"18","text":"Hipoxia","guid":"","children":[]},{"id":"21","parent":"18","text":"Hidrogenión (acidosis)","guid":"","children":[]},{"id":"22","parent":"18","text":"Hipo/Hiperpotasemia","guid":"","children":[]},{"id":"23","parent":"18","text":"Hipotermia","guid":"","children":[]},{"id":"24","parent":"18","text":"Neumotórax a Tensión","guid":"","children":[]},{"id":"25","parent":"18","text":"Tamponamiento cardíaco","guid":"","children":[]},{"id":"26","parent":"18","text":"Trombosis pulmonar","guid":"","children":[]},{"id":"27","parent":"18","text":"Trombosis coronaria","guid":"","children":[]},{"id":"28","parent":"18","text":"Tóxicos","guid":"","children":[]}]},{"id":"29","parent":"17","text":"NO REVERSIBLES\\N(congénitas/hereditarias)","guid":"H-9j7kXFiNAYHErJDB-KCQ","children":[{"id":"30","parent":"29","text":"Síndrome de Brugada","guid":"","children":[]},{"id":"31","parent":"29","text":"Fibrilación ventricular idiopática","guid":"","children":[]},{"id":"32","parent":"29","text":"Muerte súbita congénita","guid":"","children":[]},{"id":"33","parent":"29","text":"Miocardiopatía hipertrófica hereditaria","guid":"","children":[]}]}]},{"id":"34","parent":"0","text":"Ritmos de\\NParo Cardíaco","guid":"GnDREybsz-ohZ-JMO9MDLQ","children":[{"id":"35","parent":"34","text":"DESFIBRILABLES","guid":"","children":[{"id":"36","parent":"35","text":"Fibrilación ventricular (FV)","guid":"","children":[{"id":"37","parent":"36","text":"Ritmo caótico, sin P-QRS-T visibles","guid":"","children":[]},{"id":"38","parent":"36","text":"Frecuencia indeterminada","guid":"","children":[]},{"id":"39","parent":"36","text":"NO genera pulso → no checar pulso","guid":"","children":[]}]},{"id":"40","parent":"35","text":"Taquicardia ventricular sin pulso (TVSP)","guid":"","children":[{"id":"41","parent":"40","text":"Monomórfica → QRS ancho, RR regular, FC >100","guid":"","children":[]},{"id":"42","parent":"40","text":"Polimórfica → QRS ancho, RR IRREGULAR","guid":"","children":[]},{"id":"43","parent":"40","text":"PUEDE generar pulso → SÍ checar pulso","guid":"","children":[]}]}]},{"id":"44","parent":"34","text":"NO DESFIBRILABLES","guid":"","children":[{"id":"45","parent":"44","text":"Asistolia → línea isoeléctrica","guid":"","children":[{"id":"46","parent":"45","text":"Verificar contacto adecuado de electrodos","guid":"","children":[]},{"id":"47","parent":"45","text":"Línea punteada = mal contacto vs línea continua = asistolia real","guid":"","children":[]}]},{"id":"48","parent":"44","text":"Actividad eléctrica sin pulso (AESP)","guid":"","children":[{"id":"49","parent":"48","text":"Ritmo organizado + sin pulso","guid":"","children":[]}]},{"id":"50","parent":"44","text":"Pseudo-AESP (con POCUS)","guid":"","children":[{"id":"51","parent":"50","text":"Actividad eléctrica + contracción cardíaca visible + sin pulso palpable","guid":"","children":[]}]}]}]},{"id":"52","parent":"0","text":"RCP de Alta\\NCalidad","guid":"MN9T7kNVXAowaWrAH7MsUw","children":[{"id":"53","parent":"52","text":"Compresiones\\Ntorácicas","guid":"R3VSrSSllEp6FhOUBBiOeA","children":[{"id":"54","parent":"53","text":"Ubicación → centro del pecho, talón de la mano","guid":"","children":[]},{"id":"55","parent":"53","text":"Profundidad → AL MENOS 5 cm (cambio desde 2020)","guid":"","children":[{"id":"56","parent":"55","text":"Antes 5-6 cm → se quedaban cortas","guid":"","children":[]}]},{"id":"57","parent":"53","text":"Frecuencia → 100-120/min","guid":"","children":[]},{"id":"58","parent":"53","text":"RECOIL completo → permitir descompresión total","guid":"","children":[{"id":"59","parent":"58","text":"Compresión = sístole, Recoil = diástole","guid":"","children":[]}]},{"id":"60","parent":"53","text":"Brazos rectos, posición correcta del reanimador","guid":"","children":[]},{"id":"61","parent":"53","text":"Cambio de compresor si fatiga","guid":"","children":[]}]},{"id":"62","parent":"52","text":"Ventilaciones de rescate\\N(sin DVA)","guid":"VwVfeiU10tQXtefAJVGjkQ","children":[{"id":"63","parent":"62","text":"30 compresiones : 2 ventilaciones","guid":"","children":[]},{"id":"64","parent":"62","text":"Duración 1 segundo cada ventilación","guid":"","children":[]},{"id":"65","parent":"62","text":"Volumen 500-600 mL","guid":"","children":[]},{"id":"66","parent":"62","text":"Técnica C-E para sellado de mascarilla","guid":"","children":[]},{"id":"67","parent":"62","text":"Bolsa autoinsuflable + O2 al 100%","guid":"","children":[]},{"id":"68","parent":"62","text":"Permitir retroceso de caja torácica","guid":"","children":[]}]},{"id":"69","parent":"52","text":"Ventilaciones\\Ncon DVA","guid":"H2QfZ10SScFoJ60hQaffhg","children":[{"id":"70","parent":"69","text":"Compresiones CONTINUAS (no pausar)","guid":"","children":[]},{"id":"71","parent":"69","text":"1 ventilación cada 6 segundos (10/min)","guid":"","children":[]},{"id":"72","parent":"69","text":"ASINCRÓNICAS respecto a compresiones","guid":"","children":[]},{"id":"73","parent":"69","text":"Evitar HIPERVENTILAR → obstruye retorno venoso → reduce RCE","guid":"","children":[]}]},{"id":"74","parent":"52","text":"Capnografía\\N(ETCO2)","guid":"CFsJKmPp6cJ0LDKBcGKYlA","children":[{"id":"75","parent":"74","text":"Meta >10 mmHg (mínimo calidad RCP)","guid":"","children":[]},{"id":"76","parent":"74","text":">15 mmHg = MUY BUEN indicador","guid":"","children":[]},{"id":"77","parent":"74","text":"Guías anestesiología → >20 mmHg","guid":"","children":[]},{"id":"78","parent":"74","text":"A MAYOR ETCO2 → mejor perfusión capilar pulmonar","guid":"","children":[]}]},{"id":"79","parent":"52","text":"Línea arterial (si disponible)","guid":"WcUq_15CG6NKc8FsebSO7Q","children":[{"id":"80","parent":"79","text":"Presión diastólica >20 mmHg durante compresiones","guid":"","children":[]}]}]},{"id":"81","parent":"0","text":"Algoritmo Ritmos\\NDESFIBRILABLES","guid":"JAekc2KQDDYF1Bj2Pnh1hg","children":[{"id":"82","parent":"81","text":"1er Ciclo → Quick Look + 1ra Descarga","guid":"","children":[{"id":"83","parent":"82","text":"Identificar ritmo con palas (quick look) o DEA","guid":"","children":[]},{"id":"84","parent":"82","text":"Posición palas → infraclavicular derecha + apex\\N(abajo-izquierda tetilla izq)","guid":"apFXTSq043NaD1xhQZa2xw","children":[{"id":"85","parent":"84","text":"NO esternón directo → mayor impedancia ósea","guid":"","children":[]},{"id":"86","parent":"84","text":"Vector diagonal entre ambas palas","guid":"","children":[]}]},{"id":"87","parent":"82","text":"Seleccionar\\Nenergía MÁXIMA","guid":"T-q2R3HFRCJm6FpYF2AI9A","children":[{"id":"88","parent":"87","text":"Monofásico → 360 J","guid":"","children":[]},{"id":"89","parent":"87","text":"Bifásico → 200 J (algunos hasta 360 J)","guid":"","children":[]}]},{"id":"90","parent":"82","text":"Cargar MIENTRAS se dan compresiones","guid":"","children":[]},{"id":"91","parent":"82","text":"Pasta conductora, presión ~10 kg","guid":"","children":[]},{"id":"92","parent":"82","text":"Seguridad → fuera tú, fuera yo, fuera todos, fuera vía aérea","guid":"","children":[]},{"id":"93","parent":"82","text":"Retirar fuente de oxígeno (si circuito abierto)","guid":"","children":[]},{"id":"94","parent":"82","text":"DESCARGA → reiniciar RCP inmediato × 2 min","guid":"","children":[]}]},{"id":"95","parent":"81","text":"2do Ciclo → 2da Descarga + Adrenalina","guid":"","children":[{"id":"96","parent":"95","text":"Evaluar ritmo a los 2 min","guid":"","children":[]},{"id":"97","parent":"95","text":"Si persiste ritmo desfibrilable → 2da descarga","guid":"","children":[]},{"id":"98","parent":"95","text":"ADRENALINA 1 mg\\NIV/IO post-2da descarga","guid":"CXzcICc7-0J6S3izOlwwDg","children":[{"id":"99","parent":"98","text":"Cada 3-5 minutos","guid":"","children":[]},{"id":"100","parent":"98","text":"Vía IV: llave 3 vías + push 20 mL SF 0.9%","guid":"","children":[]},{"id":"101","parent":"98","text":"Alternativa: diluir 1 mg en 9 mL SF (total 10 mL)","guid":"","children":[]}]}]},{"id":"102","parent":"81","text":"3er Ciclo → 3ra Descarga + Antiarrítmico","guid":"","children":[{"id":"103","parent":"102","text":"Evaluar ritmo → si persiste desfibrilable → 3ra descarga","guid":"","children":[]},{"id":"104","parent":"102","text":"ANTIARRÍTMICO\\Npost-3ra descarga","guid":"FmrYbGD-bewbeJdtNc730w","children":[{"id":"105","parent":"104","text":"Amiodarona 300 mg IV (1ra dosis) → UNA u OTRA","guid":"","children":[]},{"id":"106","parent":"104","text":"Lidocaína 1-1.5 mg/kg IV (1ra dosis) → UNA u OTRA","guid":"","children":[]},{"id":"107","parent":"104","text":"NUNCA ambas juntas","guid":"","children":[]},{"id":"108","parent":"104","text":"Preferir amiodarona si toxicidad por anestésicos locales","guid":"","children":[]}]},{"id":"109","parent":"102","text":"Continuar adrenalina cada 3-5 min","guid":"","children":[]}]},{"id":"110","parent":"81","text":"4to Ciclo y posteriores","guid":"","children":[{"id":"111","parent":"110","text":"Si 4ta descarga necesaria","guid":"","children":[{"id":"112","parent":"111","text":"Amiodarona 150 mg (50% de dosis inicial)","guid":"","children":[]},{"id":"113","parent":"111","text":"Lidocaína 0.5-0.75 mg/kg (50% de dosis inicial)","guid":"","children":[]}]},{"id":"114","parent":"110","text":"Desfibrilación doble secuencial → FV refractaria post 3 descargas","guid":"","children":[]},{"id":"115","parent":"110","text":"Continuar ciclos 2 min RCP → evaluar ritmo → descarga si procede","guid":"","children":[]}]}]},{"id":"116","parent":"0","text":"Algoritmo Ritmos NO\\NDESFIBRILABLES","guid":"PhC3rgOgRI53dtdZRmvA2A","children":[{"id":"117","parent":"116","text":"Asistolia o AESP identificada","guid":"","children":[]},{"id":"118","parent":"116","text":"Reiniciar RCP inmediata × 2 min","guid":"","children":[]},{"id":"119","parent":"116","text":"ADRENALINA INMEDIATA →\\Ntan pronto como acceso IV/IO","guid":"Z4ouUGujCdo2zllsQU9ZTw","children":[{"id":"120","parent":"119","text":"1 mg cada 3-5 minutos","guid":"","children":[]},{"id":"121","parent":"119","text":"Pacientes con AESP/pseudo-AESP → MÁS beneficio de adrenalina","guid":"","children":[]}]},{"id":"122","parent":"116","text":"DVA lo antes posible → HIPOXIA causa frecuente","guid":"","children":[]},{"id":"123","parent":"116","text":"Cada 2 min → evaluar ritmo","guid":"","children":[{"id":"124","parent":"123","text":"Si cambia a desfibrilable → desfibrilar y seguir algoritmo","guid":"","children":[]}]},{"id":"125","parent":"116","text":"Buscar y tratar Hs y Ts","guid":"","children":[{"id":"126","parent":"125","text":"POCUS → tamponamiento, contractilidad, volemia","guid":"","children":[]}]},{"id":"127","parent":"116","text":"Estos pacientes tienen PEOR pronóstico vs desfibrilables","guid":"","children":[]}]},{"id":"128","parent":"0","text":"Acceso Vascular\\Ny Monitorización","guid":"EECS2zy-0AJ6GQScN5GWJw","children":[{"id":"129","parent":"128","text":"Acceso IV → 1ra opción","guid":"","children":[{"id":"130","parent":"129","text":"Preferir: antecubital (16-18 G), antebrazo","guid":"","children":[]},{"id":"131","parent":"129","text":"EVITAR dorsales de mano → riesgo necrosis por vasopresores","guid":"","children":[]},{"id":"132","parent":"129","text":"Acceso venoso central → NO en paro cardíaco","guid":"","children":[]}]},{"id":"133","parent":"128","text":"Acceso IO → 2da opción","guid":"","children":[]},{"id":"134","parent":"128","text":"Monitorización\\NECG continua","guid":"SeUlfQFCGtk7A-g8bezJ8A","children":[{"id":"135","parent":"134","text":"Triángulo de Einthoven\\N→ 3 cables","guid":"Y9InD0DYATMsZT92bU8DLw","children":[{"id":"136","parent":"135","text":"Brazo derecho (RA)","guid":"","children":[]},{"id":"137","parent":"135","text":"Brazo izquierdo (LA)","guid":"","children":[]},{"id":"138","parent":"135","text":"Pierna izquierda (LL)","guid":"","children":[]}]},{"id":"139","parent":"134","text":"Colocar en tórax superior/posterior → no estorbar RCP","guid":"","children":[]},{"id":"140","parent":"134","text":"Derivación D2 → ideal (vector anatómico normal)","guid":"","children":[]},{"id":"141","parent":"134","text":"Cambiar de palas a derivación una vez colocados cables","guid":"","children":[]}]}]},{"id":"142","parent":"0","text":"Dispositivo Avanzado\\NVía Aérea (DVA)","guid":"aBP8dSawuConqzM9UqVTwg","children":[{"id":"143","parent":"142","text":"Mascarilla laríngea → supraglótico, seguro, rápido","guid":"UWWbnQG6j58UPAqJIVBR5Q","children":[{"id":"144","parent":"143","text":"Seleccionar tamaño según peso","guid":"","children":[]},{"id":"145","parent":"143","text":"Inflar neumotaponamiento según fabricante","guid":"","children":[]}]},{"id":"146","parent":"142","text":"Tubo orotraqueal → requiere operador entrenado","guid":"","children":[{"id":"147","parent":"146","text":"Laringoscopía directa o VIDEOLARINGOSCOPÍA (ideal)","guid":"","children":[]}]},{"id":"148","parent":"142","text":"Colocar SIN detener compresiones","guid":"","children":[]},{"id":"149","parent":"142","text":"Post DVA → compresiones continuas + ventilación cada 6 seg","guid":"","children":[]},{"id":"150","parent":"142","text":"Ventilador mecánico programable si disponible","guid":"","children":[]}]},{"id":"151","parent":"0","text":"Equipo de Reanimación\\N→ Roles","guid":"c3_TwXskZOI4sFrZCeqsLQ","children":[{"id":"152","parent":"151","text":"LÍDER → a los pies, visión global, indicaciones","guid":"","children":[]},{"id":"153","parent":"151","text":"REGISTRO → al lado del líder, tiempo y acciones","guid":"","children":[]},{"id":"154","parent":"151","text":"VÍA AÉREA → cabecera del paciente","guid":"","children":[]},{"id":"155","parent":"151","text":"FÁRMACOS → lado derecho del paciente","guid":"","children":[]},{"id":"156","parent":"151","text":"COMPRESIONES → lado derecho, intercambiable","guid":"","children":[]},{"id":"157","parent":"151","text":"MONITOR/DESFIBRILADOR → lado izquierdo del paciente","guid":"","children":[]},{"id":"158","parent":"151","text":"Rotación de compresores cuando hay fatiga","guid":"","children":[]}]},{"id":"159","parent":"0","text":"Retorno a Circulación\\NEspontánea (RCE/ROSC)","guid":"XCLSzlQo8kY_uaQAGjOKfA","children":[{"id":"160","parent":"159","text":"Ritmo organizado + PULSO presente","guid":"","children":[]},{"id":"161","parent":"159","text":"Iniciar cuidados post-paro\\N(AHA 2025)","guid":"V8k21Dcwe1lgn0tUP1NlJA","children":[{"id":"162","parent":"161","text":"Control PA, oxigenación, ventilación, glucosa","guid":"","children":[]},{"id":"163","parent":"161","text":"Control de temperatura dirigido","guid":"","children":[]},{"id":"164","parent":"161","text":"Coronariografía si indicada","guid":"","children":[]},{"id":"165","parent":"161","text":"Neuropronóstico multimodal","guid":"","children":[]},{"id":"166","parent":"161","text":"Manejo de convulsiones","guid":"","children":[]}]}]},{"id":"167","parent":"0","text":"Limitación del Esfuerzo\\NTerapéutico (LET)","guid":"ItOFNBdtpMEAor5zbLiqsQ","children":[{"id":"168","parent":"167","text":"No existe tiempo fijo descrito en guías","guid":"","children":[]},{"id":"169","parent":"167","text":"INDIVIDUALIZAR cada caso","guid":"","children":[]},{"id":"170","parent":"167","text":"Considerar si >15-20 min RCP + ritmo no desfibrilable persistente","guid":"","children":[]},{"id":"171","parent":"167","text":"A pesar de manejo de Hs y Ts","guid":"","children":[]},{"id":"172","parent":"167","text":"Líder del equipo → decisión ética","guid":"","children":[]},{"id":"173","parent":"167","text":"AHA 2025 → ética en RCP incluye dignidad, autonomía, beneficencia","guid":"","children":[]},{"id":"174","parent":"167","text":"Prehospital → se recomienda reanimar en escena y determinar ahí","guid":"","children":[]},{"id":"175","parent":"167","text":"En AM → considerar fragilidad, estado funcional previo, directrices anticipadas","guid":"","children":[]}]},{"id":"176","parent":"0","text":"Escenarios\\NEspeciales de\\NRCP","guid":"GK-_mjumprBapXSifIHmqQ","children":[{"id":"177","parent":"176","text":"Embarazada","guid":"","children":[]},{"id":"178","parent":"176","text":"Quirófano/perioperatorio → agregar vasopresina 40 U","guid":"","children":[]},{"id":"179","parent":"176","text":"UCI","guid":"","children":[]},{"id":"180","parent":"176","text":"Ahogamiento","guid":"","children":[]},{"id":"181","parent":"176","text":"Intoxicaciones","guid":"","children":[]},{"id":"182","parent":"176","text":"Hiperpotasemia","guid":"","children":[]},{"id":"183","parent":"176","text":"TEP masivo","guid":"","children":[]},{"id":"184","parent":"176","text":"Tamponamiento cardíaco","guid":"","children":[]}]},{"id":"185","parent":"0","text":"Perlas Clínicas","guid":"","children":[{"id":"186","parent":"185","text":"Verificar pulso <10 seg → si no lo sientes en 5 seg, inicia RCP","guid":"","children":[]},{"id":"187","parent":"185","text":"Compresiones AL MENOS 5 cm → no te quedes corto","guid":"","children":[]},{"id":"188","parent":"185","text":"ETCO2 >15 mmHg = buen indicador de calidad RCP","guid":"","children":[]},{"id":"189","parent":"185","text":"Amiodarona O lidocaína → NUNCA ambas → igual de (poco) efectivas","guid":"","children":[]},{"id":"190","parent":"185","text":"Adrenalina post-2da descarga en desfibrilables, INMEDIATA en no desfibrilables","guid":"","children":[]},{"id":"191","parent":"185","text":"No suspender compresiones para colocar DVA → operador entrenado","guid":"","children":[]},{"id":"192","parent":"185","text":"Palas infraclavicular derecha + apex → NO sobre esternón directo","guid":"","children":[]},{"id":"193","parent":"185","text":"AESP/pseudo-AESP → más beneficio de adrenalina vs asistolia","guid":"","children":[]},{"id":"194","parent":"185","text":"POCUS transparo → diferencia AESP vs pseudo-AESP → guía tratamiento","guid":"","children":[]},{"id":"195","parent":"185","text":"EN GERIÁTRICO → evaluar fragilidad pre-paro, directrices anticipadas, LET precoz si CFS ≥7","guid":"","children":[]},{"id":"196","parent":"185","text":"Evitar hiperventilar → reduce retorno venoso → reduce probabilidad RCE","guid":"","children":[]}]},{"id":"197","parent":"0","text":"Referencias","guid":"","children":[{"id":"198","parent":"197","text":"1. Kleinman ME et al. Part 7: Adult BLS. AHA Guidelines 2025. Circulation. 2025;152(16 suppl 2):S448-S478.","guid":"","children":[]},{"id":"199","parent":"197","text":"2. Panchal AR et al. Part 2: Evidence Evaluation. AHA Guidelines 2025. Circulation. 2025;152(16 suppl 2):S313-S322.","guid":"","children":[]},{"id":"200","parent":"197","text":"3. Hirsch KG et al. Part 11: Post-Cardiac Arrest Care. AHA Guidelines 2025. Circulation. 2025;152(16 suppl 2):S673-S718.","guid":"","children":[]},{"id":"201","parent":"197","text":"4. Elmer J et al. Part 3: Ethics. AHA Guidelines 2025. Circulation. 2025;152(16 suppl 2):S323-S352.","guid":"","children":[]},{"id":"202","parent":"197","text":"5. Cao D et al. Part 10: Special Circumstances. AHA Guidelines 2025. Circulation. 2025;152(16 suppl 2):S578-S672.","guid":"","children":[]},{"id":"203","parent":"197","text":"6. Shepard LN et al. Physiology-Guided CPR. Crit Care Clin. 2025.","guid":"","children":[]},{"id":"204","parent":"197","text":"7. Video: Dr. Eder Zamarrón. Algoritmo Paro Cardíaco ACLS. YouTube: Entrenamiento en Áreas Críticas. 2025.","guid":"","children":[]}]}]},"node_count":204,"relations":[],"cross_references":[],"specialty":"UCI/Medicina Crítica","folder":"Entidades clínicas/UCI-Medicina Crítica","filename":"Algoritmo_Paro_Cardiaco_ACLS_AHA2025_iPad","id":"map_2297","resolved_references":[]}