","parent":"18","text":"Fenotipo más severo","guid":"","children":[]}]},{"id":"20","parent":"10","text":"Receptor de\\Nandrógenos","guid":"x6tssDPcAh6z_q1A9nvHSg","children":[{"id":"21","parent":"20","text":"Repeticiones CAG más largas","guid":"","children":[]},{"id":"22","parent":"20","text":"Mayor longitud CAG → MAYOR severidad fenotípica","guid":"","children":[]}]},{"id":"23","parent":"10","text":"Fisiopatología\\Ntesticular","guid":"PmMjqM2tsKLpBhuY1GnM9w","children":[{"id":"24","parent":"23","text":"Fibrosis progresiva de túbulos seminíferos","guid":"","children":[]},{"id":"25","parent":"23","text":"Destrucción de células de Leydig","guid":"","children":[]},{"id":"26","parent":"23","text":"Espermatogénesis PRECEDE y es MÁS SEVERA que déficit de T","guid":"","children":[]}]}]},{"id":"27","parent":"0","text":"Clínica\\Npor Etapa","guid":"YoG7Mo4ENZVN-Bmf-xpgig","children":[{"id":"28","parent":"27","text":"Neonatos/\\NPrepuberales","guid":"piQ3DnTswVyKT3JINIfNWQ","children":[{"id":"29","parent":"28","text":"Micropene (<1.9 cm neonatal)","guid":"","children":[]},{"id":"30","parent":"28","text":"Clinodactilia","guid":"","children":[]},{"id":"31","parent":"28","text":"Hipospadias","guid":"","children":[]},{"id":"32","parent":"28","text":"Criptorquidia","guid":"","children":[]},{"id":"33","parent":"28","text":"Retraso del lenguaje","guid":"","children":[]},{"id":"34","parent":"28","text":"Discapacidades de aprendizaje","guid":"","children":[]},{"id":"35","parent":"28","text":"Hipertelorismo","guid":"","children":[]}]},{"id":"36","parent":"27","text":"Pubertad","guid":"","children":[{"id":"37","parent":"36","text":"Falla inicio/completitud desarrollo puberal","guid":"","children":[]},{"id":"38","parent":"36","text":"Testículos no crecen","guid":"","children":[]},{"id":"39","parent":"36","text":"Virilización incompleta","guid":"","children":[]},{"id":"40","parent":"36","text":"Ginecomastia","guid":"","children":[]},{"id":"41","parent":"36","text":"TALLA ALTA → piernas\\