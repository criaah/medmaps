0yw","children":[]},{"id":"269","parent":"267","text":"Especificidad moderada","guid":"v_w8bvL0QLyd-P8r2JzWWA","children":[]},{"id":"270","parent":"267","text":"Belmin 1995: VPP bajo en poblacion general AM","guid":"l6uds_fpTcWLDu9lZx4GvQ","children":[]},{"id":"271","parent":"267","text":"NO es gold standard → es screening clinico","guid":"x4srz4HETZyYyC-wdC9uTQ","children":[]}]}]},{"id":"272","parent":"249","text":"Confirmacion → medicion INTRAARTERIAL (gold standard)","guid":"uLh65bOnTn2EYIAQ1bO6Ww","children":[{"id":"273","parent":"272","text":"Diferencia PAS no invasiva vs intraarterial >10 mmHg → pseudoHTA significativa","guid":"EJ9ZapwaQ2Wu7mUr0ZjSNw","children":[]},{"id":"274","parent":"272","text":"Indicacion de medicion invasiva","guid":"VZhURFlZRk-26IAIRSpv9g","children":[{"id":"275","parent":"274","text":"Sospecha clinica alta + Osler (+)","guid":"HE5qh_DpQHGKHnhwy_JlGA","children":[]},{"id":"276","parent":"274","text":"Cifras muy elevadas SIN dano organo blanco","guid":"FkAfR0qRQleKdvNywBJXYA","children":[]},{"id":"277","parent":"274","text":"Falta de respuesta a multiples antihipertensivos","guid":"fTO9jyOBQK6cNVjO6wzCSg","children":[]},{"id":"278","parent":"274","text":"Hipotension sintomatica con PA \"normal\" en manguito","guid":"oZAFu2BjTaecvv7AmCLgnw","children":[]}]},{"id":"279","parent":"272","text":"En practica → rara vez disponible fuera de UCI","guid":"JX0VQTm0RHyc_iJPPkFmpw","children":[]}]},{"id":"280","parent":"249","text":"Claves clinicas para sospechar pseudoHTA","guid":"X6chv5D7S3Kkxy1e4Rso_g","children":[{"id":"281","parent":"280","text":"PA muy elevada PERSISTENTE sin dano organo blanco","guid":"2JXQVaoqSwO1CIK0EolsdA","children":[]},{"id":"282","parent":"280","text":"Multiples farmacos sin respuesta terapeutica","guid":"RRV-3yMcQV-hChOfv1odQA","children":[]},{"id":"283","parent":"280","text":"Hipotension ortostatica sintomatica con PA manguito \"alta\"","guid":"C4qowcxwSaWvIbok9g_QUw","children":[]},{"id":"284","parent":"280","text":"Mareos, sincope o caidas con PA aparentemente elevada","guid":"5xnHAm4MQrSNto2P9ltVrg","children":[]},{"id":"285","parent":"280","text":"Calcificaciones arteriales extensas en Rx (arterias en rieles de tren)","guid":"XMdRR7gSTGGJeGKjlY319w","children":[]}]},{"id":"286","parent":"249","text":"RIESGO → SOBRETRATAMIENTO IATROGENICO","guid":"PnW36fPZQF6noKQmJxj-og","children":[{"id":"287","parent":"286","text":"Tratar cifra falsa → hipotension REAL","guid":"GUCQWw_CSKWiC0U6SuSjDQ","children":[]},{"id":"288","parent":"286","text":"Hipoperfusion cerebral → confusion, caidas, ACV watershed","guid":"MJzcP1mOS0awyCBLtaUnWA","children":[]},{"id":"289","parent":"286","text":"Hipoperfusion renal → IRA prerrenal","guid":"LgGMybkCQ2K1i4xVE5abUQ","children":[]},{"id":"290","parent":"286","text":"Hipoperfusion coronaria → SCA","guid":"NFb40HjOR0ysOXSMomnsAw","children":[]},{"id":"291","parent":"286","text":"AM fragil → cascada funcional irreversible","guid":"Lwyb-PpnT02iwrjGhPjyAQ","children":[]}]},{"id":"292","parent":"249","text":"Manejo si se sospecha pseudoHTA","guid":"ipA7IH8eRTWhe5o7B-8ESw","children":[{"id":"293","parent":"292","text":"NO iniciar antihipertensivos agresivos","guid":"s8GOjlqaRqasbwK4ZBXFqw","children":[]},{"id":"294","parent":"292","text":"Evaluar dano organo blanco real (ECG, fondo ojo, funcion renal)","guid":"ksQ6oSNsQBeYqdSG4WC1Fg","children":[]},{"id":"295","parent":"292","text":"Si NO hay dano → observacion + control ambulatorio","guid":"RC8W3VfZQfa4apBsTETRyg","children":[]},{"id":"296","parent":"292","text":"Considerar MAPA 24h → puede subestimar menos que manguito","guid":"uT1cp3pYTc2IqqhtV2NtDQ","children":[]},{"id":"297","parent":"292","text":"Derivar a cardiologia/nefrologia si duda diagnostica","guid":"G4H3SgZAS-GPPa3PtuSFCQ","children":[]},{"id":"298","parent":"292","text":"Revisar farmacos actuales → DEPRESCRIBIR si sobretratamiento","guid":"7K2NKCK-TAGVl_HfWCNyZg","children":[]}]},{"id":"299","parent":"249","text":"Relacion con HTA de bata blanca en AM","guid":"0CGdvC7JQ9-SUkcVY5aP-A","children":[{"id":"300","parent":"299","text":"Ambas producen cifras elevadas sin dano real","guid":"77lQjzcjSDKrtAlLuaNVBg","children":[]},{"id":"301","parent":"299","text":"Bata blanca → componente adrenergico transitorio","guid":"cw9HNtWoTyiv1ItFg5G0mg","children":[]},{"id":"302","parent":"299","text":"PseudoHTA → componente estructural permanente (rigidez arterial)","guid":"BP5GTeeDSqKmyJj3R7KJjg","children":[]},{"id":"303","parent":"299","text":"Pueden COEXISTIR en el mismo paciente","guid":"P3P8IpwSSBu7XLh0m9xSiw","children":[]},{"id":"304","parent":"299","text":"MAPA 24h ayuda a diferenciar","guid":"FyNtyqd4RjWWCHUXqadyCQ","children":[]}]}]},{"id":"305","parent":"240","text":"Ajuste farmacologico","guid":"ZSD6-m-vTLqtu5VdBfrpaw","children":[{"id":"306","parent":"305","text":"Funcion renal → ajustar dosis segun ClCr","guid":"vB-AdRDmTKSYCGSyBAcetQ","children":[]},{"id":"307","parent":"305","text":"Polifarmacia → revisar interacciones (AINE ↑ PA)","guid":"dlKUAem3QPKwSY1qFOqgkg","children":[]},{"id":"308","parent":"305","text":"EVITAR betabloqueadores en bradicardia previa","guid":"yzGCCGz0RsG9HBwEdDDHhQ","children":[]},{"id":"309","parent":"305","text":"EVITAR nifedipino e hidralazina → AUMENTAN mortalidad en AM","guid":"haQ_Wkd_TIeeLV4q2nwBVQ","children":[]},{"id":"310","parent":"305","text":"Preferir nicardipino si disponible (hemodinamicamente estable)","guid":"uVfV4hLRRQWhUFWF7w3I9g","children":[]},{"id":"311","parent":"305","text":"Start low, go slow → pero no go nowhere","guid":"XEMmu1KsSESoH2ktjpAU2g","children":[]}]},{"id":"312","parent":"240","text":"Fragilidad como predictor","guid":"xonqNgfyToW-CyF_GZj_0g","children":[{"id":"313","parent":"312","text":"CFS >=5 → mayor riesgo de hipotension iatrogenica","guid":"q9NPXS1vRA2vxSCEGpR4TQ","children":[]},{"id":"314","parent":"312","text":"Riesgo de caidas post-hipotension","guid":"kETwnuksQz2XeJKMSNNScQ","children":[]},{"id":"315","parent":"312","text":"Considerar metas menos agresivas en fragiles","guid":"q6LOB8b2TrKys5jnDFL5nw","children":[]},{"id":"316","parent":"312","text":"Proporcionalidad terapeutica","guid":"M8CKWRmcSHepIwAn3ahj5A","children":[]}]},{"id":"317","parent":"240","text":"Comorbilidades frecuentes","guid":"sDzyjUmwR9u0fx9t8TF-xQ","children":[{"id":"318","parent":"317","text":"ERC → ajustar metas PA y farmacos","guid":"RlfH58VJTniz_M4Q51d8_A","children":[]},{"id":"319","parent":"317","text":"IC → NTG preferida, evitar labetalol en IC avanzada","guid":"enZxmjgQQyqTu2hGAwuHnw","children":[]},{"id":"320","parent":"317","text":"DM → riesgo de hipoperfusion renal con descenso brusco","guid":"MJ5keuxtSBuUR_F33IcurA","children":[]},{"id":"321","parent":"317","text":"Demencia → evaluacion neurologica basal compleja","guid":"GpKfkJ1hRaqDF60YfPRYlQ","children":[]}]}]},{"id":"322","parent":"0","text":"Fuentes USS (eMUE)","guid":"74FMvEXDRvKS_b8DAbWq0Q","children":[{"id":"323","parent":"322","text":"Video 41: Emergencia hipertensiva en urgencia [NB]","guid":"4VU1AyJlTaiwNxPcIdMdtA","children":[{"id":"324","parent":"323","text":"Enfoque sistematico ABCD","guid":"nWSWA2nJSJmeoxEdjVKu7Q","children":[]},{"id":"325","parent":"323","text":"Diferenciacion urgencia vs emergencia","guid":"35424TXNRHa-qm2lfZC2SA","children":[]},{"id":"326","parent":"323","text":"Metas por patologia especifica","guid":"bVZSx3XkQCiKF3bKzj89Zw","children":[]}]},{"id":"327","parent":"322","text":"Video 42: Hipertension en urgencia [NB+DL]","guid":"PYoxdDCNQxuZU0MApch1jA","children":[{"id":"328","parent":"327","text":"Farmacologia de antihipertensivos EV","guid":"aypNS3QLQU-ua9inbPhoUQ","children":[]},{"id":"329","parent":"327","text":"Caso clinico: hidralazina → IRA iatrogenica","guid":"vSzrXO8-TyqzPuB6Z7n6uw","children":[]},{"id":"330","parent":"327","text":"Importancia de tratar causa antes que cifra","guid":"_dz2CNfmQfqLBJhk2XqwCA","children":[]}]},{"id":"331","parent":"322","text":"Video 43: HTA arterial asintomatica en urgencia [DL]","guid":"Q4VK-xd4QdmTKrlo8XxY1Q","children":[{"id":"332","parent":"331","text":"Manejo conservador de HTA asintomatica","guid":"MFPDdFC0TZmjcIJauawAMw","children":[]},{"id":"333","parent":"331","text":"Error frecuente → tratar numero en vez de paciente","guid":"eCoFLg4DRlGX-xL126LbYA","children":[]},{"id":"334","parent":"331","text":"Derivacion ambulatoria vs tratamiento agudo","guid":"LGbPPGglT_OFFaRJPSisag","children":[]}]}]},{"id":"335","parent":"0","text":"LR DIAGNOSTICOS","guid":"1CRf6WJ6TBuOCdk5Pti0nQ","children":[{"id":"336","parent":"335","text":"HALLAZGOS CLINICOS (cabecera)","guid":"BgsZ4ZbeQXueS0PBCfXDOA","children":[{"id":"337","parent":"336","text":"Cefalea aislada en HTA -> LR+ ~1.2 -> LR- ~0.9 -> PMID:12131541","guid":"f_g0zAeURtaVC6yFxCYYjg","children":[]},{"id":"338","parent":"336","text":"Papiledema (fondo de ojo) -> [hallazgo DEFINITORIO de emergencia HTA, LR no calculado formalmente] -> (guias ESC/ESH 2023)","guid":"Ox0lI2AZRnuim9WqWlNDRA","children":[]},{"id":"339","parent":"336","text":"Retinopatia grado III-IV (hemorragias, exudados) -> [LR no consolidado formalmente]","guid":"I4kWDRXNQAqmSA_OJezKbA","children":[]},{"id":"340","parent":"336","text":"Alteracion estado mental + PA severa -> [definitorio encefalopatia HTA]","guid":"SG5YKcU6TTaCK9nX9fRJow","children":[]},{"id":"341","parent":"336","text":"Dolor toracico + PA severa -> alerta SCA / diseccion","guid":"CgaBDUY7RR2ToBU0_XwD0g","children":[]},{"id":"342","parent":"336","text":"Disnea aguda + PA severa -> alerta EPA hipertensivo","guid":"tC5V7SnGTcGoKZex6ivFNQ","children":[]},{"id":"343","parent":"336","text":"Deficit neurologico focal -> alerta ACV","guid":"tYZcFvo7StqiZe2IAJj1vw","children":[]}]},{"id":"344","parent":"335","text":"HALLAZGOS LABORATORIO","guid":"9R7qy7vFS2anuvVAKNwHlg","children":[{"id":"345","parent":"344","text":"Creatinina elevada aguda (injuria renal) -> [definitorio dano organo blanco]","guid":"2oVFhk_FSYCqmzaz4qOqdQ","children":[]},{"id":"346","parent":"344","text":"Troponina elevada (injuria miocardica) -> [definitorio dano organo blanco]","guid":"glmqjHFyRLqdKxeYyFl2Gg","children":[]},{"id":"347","parent":"344","text":"LDH elevada + esquistocitos (MAT) -> [definitorio]","guid":"Zw3FnqEXSaq_HxHXPvG5qw","children":[]},{"id":"348","parent":"344","text":"Proteinuria aguda -> dano renal agudo","guid":"OduAIVe-RmiOmDOUK6DpQw","children":[]}]},{"id":"349","parent":"335","text":"HALLAZGOS IMAGEN","guid":"oQJQVx3CRLa0gmfmgEiVyw","children":[{"id":"350","parent":"349","text":"TC cerebro con ACV o HSA -> [definitorio emergencia neurologica]","guid":"wEvkel0dRxa20KxnBsHxVg","children":[]},{"id":"351","parent":"349","text":"AngioTC toracico con diseccion aortica -> [definitorio]","guid":"m1_-h2POTie0XvPrJhkXWA","children":[]},{"id":"352","parent":"349","text":"CXR con edema pulmonar agudo -> [definitorio EPA hipertensivo]","guid":"6TVCMHG_QIuS7D3uzP9W6A","children":[]},{"id":"353","parent":"349","text":"Eco cardiaco con disfuncion VI aguda -> apoyo","guid":"uA8MIykORTqYnGIui9y-_A","children":[]}]},{"id":"354","parent":"335","text":"DEFINICION OPERATIVA","guid":"iashe1t9RaCgbwmABuqzvQ","children":[{"id":"355","parent":"354","text":"Emergencia HTA = PA >180/120 + dano agudo organo blanco","guid":"PCvO4DZzSdyjdpDRzdgXvQ","children":[]},{"id":"356","parent":"354","text":"Urgencia HTA = PA >180/120 SIN dano agudo organo blanco","guid":"frllxKAbTQ-VBBzcCC3rtw","children":[]},{"id":"357","parent":"354","text":"El dx es CLINICO + evidencia de dano, no basado en LR clasicos","guid":"iS48780IRXaj_pHhMQUyQg","children":[]}]},{"id":"358","parent":"335","text":"INTERPRETACION","guid":"LW6jFf5FRce07KSDSz2EdA","children":[{"id":"359","parent":"358","text":"La mayoria de hallazgos son DEFINITORIOS (categoricos) no probabilisticos","guid":"7C2AwiCxRQunjjjcr-PlaQ","children":[]},{"id":"360","parent":"358","text":"Guias ESC/ESH 2023 y ACC/AHA 2017 definen emergencia por criterios clinicos + laboratorio/imagen","guid":"Jq0d6lbPTVG4BQhjyYoCGg","children":[]}]}]},{"id":"361","parent":"0","text":"Perlas Clinicas","guid":"h8Hg2RzGSTq3u7C7HIjagw","children":[{"id":"362","parent":"361","text":"PRIMERO diferenciar urgencia vs emergencia → buscar dano organo blanco","guid":"W2QJfuq6QoyHdAY0N0MMKw","children":[]},{"id":"363","parent":"361","text":"En urgencia HTA → CALMA, farmacos orales, NO EV","guid":"-iM-QSTHSaKxoi6mYb-dJA","children":[]},{"id":"364","parent":"361","text":"TRATAR LA CAUSA antes que el numero (dolor, ansiedad, retencion urinaria, globo vesical)","guid":"bR3EfaiISEGUW7dAodXq5w","children":[]},{"id":"365","parent":"361","text":"ACV isquemico → PERMISIVO con PA (solo tratar si >220/120 sin reperfusion)","guid":"sKmjlLu3SI2S4o--kxPhLg","children":[]},{"id":"366","parent":"361","text":"DISECCION AORTICA → unica emergencia con reduccion AGRESIVA e INMEDIATA","guid":"WJHRWx2ZQiyO75F41AR2Qw","children":[]},{"id":"367","parent":"361","text":"NUNCA nifedipino sublingual ni hidralazina EV en AM → aumentan mortalidad","guid":"-ZEv62C7S7uc8KJKCr-zvA","children":[]},{"id":"368","parent":"361","text":"Captopril sublingual → puede ser deleterio, evitar","guid":"q9eg_auQQUCRNyg4nHFvmg","children":[]},{"id":"369","parent":"361","text":"Nitroprusiato → evitar (toxicidad cianuro, aumenta PIC)","guid":"ZWX8l1yWT5qS3YaJLlKF5A","children":[]},{"id":"370","parent":"361","text":"En AM → 55% presentacion asintomatica o inespecifica → buscar activamente dano organo","guid":"WbpeCxqRQri9dZKsMOPTaw","children":[]},{"id":"371","parent":"361","text":"PseudoHTA (Osler +) → sospechar en AM con cifras altas sin correlato clinico ni respuesta a tratamiento → gold standard es medicion intraarterial","guid":"XR5SBYQmQn6tBRP41ycq_A","children":[]},{"id":"372","parent":"361","text":"RIESGO sobretratamiento en pseudoHTA → hipotension real → caidas, ACV watershed, IRA prerrenal","guid":"f31xOK31SjKPM_xC32Gmug","children":[]},{"id":"373","parent":"361","text":"ECG + funcion renal + sedimento urinario → exámenes indispensables en toda crisis HTA","guid":"y05yMe6LST-vLn1OcXUq7w","children":[]},{"id":"374","parent":"361","text":"Labetalol → primera linea en Chile por disponibilidad","guid":"IvgY1NX0RVu0Kws95OR2vg","children":[]},{"id":"375","parent":"361","text":"Nicardipino → superior a labetalol para alcanzar meta PA en 30 min (91.7% vs 82.5%, Peacock 2011)","guid":"pYszI0TYRAaLQHTG1NRDww","children":[]},{"id":"376","parent":"361","text":"NNT anti-HTA cronico = 125 a 5 anios (prevencion 1 evento fatal, poblacion general)","guid":"OUBStfq8R0m08JAORlVCHQ","children":[]},{"id":"377","parent":"361","text":"NNT = 24 en alto riesgo CV (SPRINT, subgrupo mayor beneficio)","guid":"muRAQ_OjTiOFBcFf_834xQ","children":[]},{"id":"378","parent":"361","text":"Referencias","guid":"xDCG5GJSS5-API6vklaUKg","children":[{"id":"379","parent":"378","text":"1. Mancia G et al. 2023 ESH Guidelines for the management of arterial hypertension. J Hypertens. 2023;41(12):1874-2071.","guid":"UDrWons-Qoa_6usyOrAFYw","children":[]},{"id":"380","parent":"378","text":"2. Whelton PK et al. 2017 ACC/AHA Guideline for Prevention, Detection, Evaluation, and Management of High Blood Pressure in Adults. Hypertension. 2018;71(6):e13-e115.","guid":"cbVbkz4ER7erDIgNqouIpg","children":[]},{"id":"381","parent":"378","text":"3. Peacock WF et al. IV nicardipine for the acute treatment of hypertension. Am J Emerg Med. 2011;29(8):905-912.","guid":"IMKJHtOSSTmvSzTUcp353g","children":[]},{"id":"382","parent":"378","text":"4. SPRINT Research Group. A Randomized Trial of Intensive vs Standard Blood-Pressure Control. N Engl J Med. 2015;373(22):2103-2116.","guid":"JbPe9lb1QHqzgRhBMwoSwA","children":[]},{"id":"383","parent":"378","text":"5. Anderson CS et al. Rapid blood-pressure lowering in patients with acute intracerebral hemorrhage (INTERACT2). N Engl J Med. 2013;368(25):2355-2365.","guid":"vmTyIgDlQFyLRyWSxxem0Q","children":[]},{"id":"384","parent":"378","text":"6. van den Born BH et al. ESC Council on hypertension position document on the management of hypertensive emergencies. Eur Heart J Cardiovasc Pharmacother. 2019;5(1):37-46.","guid":"dYw8cx3fQIas4tPca4odig","children":[]},{"id":"385","parent":"378","text":"7. Qureshi AI et al. Intensive Blood-Pressure Lowering in Patients with Acute Cerebral Hemorrhage (ATACH-2). N Engl J Med. 2016;375(11):1033-1043.","guid":"Iz9nbJTXQbS_yXMfNmsBLg","children":[]},{"id":"386","parent":"378","text":"8. Rosen Cap. 75: Hypertension. Rosen's Emergency Medicine 10a Ed.","guid":"JqK_93IoRTGuTgSLtZZ1-w","children":[]},{"id":"387","parent":"378","text":"9. Wilson KG et al. Management of Inpatient Elevated Blood Pressures: A Systematic Review. Ann Intern Med. 2024;177(3):359-370.","guid":"-w_VzkDvSy-DoRlF4OXNhw","children":[]},{"id":"388","parent":"378","text":"10. Peixoto AJ. Acute Severe Hypertension. N Engl J Med. 2019;381(19):1843-1852.","guid":"7-SPaXOrRs2Rv32MZus7Gg","children":[]},{"id":"389","parent":"378","text":"11. Belmin J et al. Osler's maneuver and pseudohypertension in elderly patients. J Hypertens. 1995;13(12 Pt 2):1866-1868.","guid":"Hi96Y8RDTKmIXwB8OZaDYw","children":[]},{"id":"390","parent":"378","text":"12. Messerli FH et al. Pseudohypertension: a poseur for hypertension. Heart. 2006;92(8):1009-1013.","guid":"E5dlPAz-SPOVKezi11MTVA","children":[]}]}]}]},"node_count":390,"relations":[],"cross_references":[],"specialty":"General","folder":"MUE - Medicina de Urgencia","filename":"MUE_Crisis_HTA","id":"map_2499","resolved_references":[]}