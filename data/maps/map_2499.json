ina","guid":"3_qAG0nnSS2ACWu6tYqz9A","children":[]}]}]},{"id":"102","parent":"0","text":"Tratamiento","guid":"AB9IERncSoiEjDvk7UhRpQ","children":[{"id":"103","parent":"102","text":"URGENCIA HIPERTENSIVA (sin dano organo blanco)","guid":"HEulbJqTQBu93UqiPKOnQw","children":[{"id":"104","parent":"103","text":"NO requiere hospitalizacion","guid":"vBCqD3LmRwStlzh5iQSr6Q","children":[]},{"id":"105","parent":"103","text":"NO requiere farmacos EV","guid":"oclH0YNjRgeA3R6_aCVGqA","children":[]},{"id":"106","parent":"103","text":"Farmacos orales de accion corta","guid":"9OQDCesRTCClCWfRdntMgw","children":[]},{"id":"107","parent":"103","text":"Meta → reduccion gradual en 24-48 horas","guid":"RPwi1fYnSCqW7ckIi_NiyQ","children":[]},{"id":"108","parent":"103","text":"Control ambulatorio","guid":"I-l6khI7QQ2XIdR3VIuqKw","children":[]},{"id":"109","parent":"103","text":"TRATAR CAUSA SUBYACENTE PRIMERO","guid":"cUUfGq0sRemf1Yfc5ht5zg","children":[{"id":"110","parent":"109","text":"Dolor → analgesia","guid":"PjOika88Tn-Zy893jjDVPQ","children":[]},{"id":"111","parent":"109","text":"Ansiedad → manejo no farmacologico","guid":"BmXeLIdZRiKUSrGLyNRJwg","children":[]},{"id":"112","parent":"109","text":"Retencion urinaria → sonda Foley","guid":"-Qwvne0ESqSkOPKak-53Dw","children":[]},{"id":"113","parent":"109","text":"Reajustar terapia oral de base","guid":"eWG8WvkWRYqBchOd9yxZkg","children":[]}]},{"id":"114","parent":"103","text":"NNT tratamiento HTA cronico (prevencion CV)","guid":"JeiaCt3XReGTuxKmMDURHQ","children":[{"id":"115","parent":"114","text":"NNT = 125 para prevenir 1 evento fatal a 5 anios (poblacion general)","guid":"6_-N6oOeSJyhOiTwbZmhag","children":[]},{"id":"116","parent":"114","text":"NNT = 24 en alto riesgo CV (SPRINT, subgrupo mayor beneficio, 5 anios)","guid":"JF3-WLzAR1ODBxwnvgEwmQ","children":[]},{"id":"117","parent":"114","text":"NNH = 27 para 1 evento adverso serio (subgrupo mayor dano)","guid":"KOo4GhvnRAePfkme-7hdow","children":[]},{"id":"118","parent":"114","text":"SPRINT: control intensivo PAS <120 vs <140","guid":"npFLTHHPT9qOeM9z_XOHww","children":[]}]}]},{"id":"119","parent":"102","text":"EMERGENCIA HIPERTENSIVA (con dano organo blanco)","guid":"F_MCbsc7SEWtBc-07GADTg","children":[{"id":"120","parent":"119","text":"Hospitalizacion UCI/UTI","guid":"6vDqNBLpSYS8O_uTzy0m_A","children":[]},{"id":"121","parent":"119","text":"Monitorizacion continua (linea arterial ideal)","guid":"1qmJscA7QJuD9dpaw2Zfgg","children":[]},{"id":"122","parent":"119","text":"Farmacos EV, vida media corta, TITULABLES","guid":"fWGsdBGMTraFNecHnb_xLQ","children":[]},{"id":"123","parent":"119","text":"Meta general","guid":"g8O3i1cgQJ2yaNaWPKzoUA","children":[{"id":"124","parent":"123","text":"Reducir PAM 10-15% en PRIMERA HORA","guid":"PCBX5pieSg-u9RvDeAjmnQ","children":[]},{"id":"125","parent":"123","text":"15% adicional en siguientes 2-4 horas","guid":"tUQI9Bn5S6-X2CkcKxORKg","children":[]},{"id":"126","parent":"123","text":"NUNCA reduccion >25% en primeras horas","guid":"DAbvNck2TNCqLIVfYVV6aw","children":[]},{"id":"127","parent":"123","text":"RIESGO → hipoperfusion cerebral, renal, coronaria","guid":"Y4B6F3IkT8mPivVPWaol0Q","children":[]}]}]},{"id":"128","parent":"102","text":"FARMACOS ENDOVENOSOS","guid":"7z6gn8pIT0uZXtDRBgugTw","children":[{"id":"129","parent":"128","text":"LABETALOL → alfa y betabloqueador","guid":"dJbj6aO5TMOwp8F6opXXZg","children":[{"id":"130","parent":"129","text":"Dosis → bolo 20 mg EV en 2 min, repetir cada 10 min","guid":"ZM3Kt8DqQxGRyiHZ37qdKQ","children":[]},{"id":"131","parent":"129","text":"Infusion → 0.5-2 mg/min","guid":"7ji31FpfSBaoH9HuMXFhNg","children":[]},{"id":"132","parent":"129","text":"Indicaciones → DISECCION AORTICA (reduce PA + FC)","guid":"MgXjffYURoSOh_LmTbEyvg","children":[]},{"id":"133","parent":"129","text":"Indicaciones → ACV, encefalopatia hipertensiva","guid":"GG9vXs0vSXKwu9hQubedRA","children":[]},{"id":"134","parent":"129","text":"Contraindicaciones → bloqueo AV 2-3 grado","guid":"otrXkzrsRD2jVpRkJb136w","children":[]},{"id":"135","parent":"129","text":"Contraindicaciones → IC avanzada, asma severa","guid":"FPsSolgtQ_CmEpQ4zw-k1A","children":[]},{"id":"136","parent":"129","text":"Contraindicaciones → bradicardia severa","guid":"JenGAAdkT6WF3bSuh4IOVQ","children":[]},{"id":"137","parent":"129","text":"Precaucion en AM → efecto betabloqueador","guid":"5Mn5H7KfQJKPir7ActTY0A","children":[]}]},{"id":"138","parent":"128","text":"NITROGLICERINA (NTG)","guid":"pc-eHFW_QGGY3U5fMxh1vA","children":[{"id":"139","parent":"138","text":"Dosis → 5-200 mcg/min EV infusion","guid":"09y496oBSw6x-J3q7bzRiA","children":[]},{"id":"140","parent":"138","text":"Indicaciones → SCA, EPA, sobrecarga de volumen","guid":"TbTcWHowRY6WqILnxGOcDg","children":[]},{"id":"141","parent":"138","text":"Efectos adversos → cefalea, taquifilaxia","guid":"j8s6Nq5QSASghUcCGrTM-A","children":[]},{"id":"142","parent":"138","text":"Precaucion → NO usar con inhibidores PDE5","guid":"DWcV-gcoSG2SnJ962lmESw","children":[]},{"id":"143","parent":"138","text":"LIMITACION → venodilatador predominante, poco efecto en RVS","guid":"cIW0K_j5TD2y7Nc-dTYfMQ","children":[]}]},{"id":"144","parent":"128","text":"NICARDIPINO (no disponible rutina en Chile)","guid":"JC5c3EoBSgSwOluI7K0t9A","children":[{"id":"145","parent":"144","text":"Dosis → 5-15 mg/h EV infusion","guid":"OCfrnRONTxuMhbizEmTbxQ","children":[]},{"id":"146","parent":"144","text":"BCC dihidropiridinico EV → primera linea segun AHA","guid":"M-DRWQQoRXeM3iEam2QG9g","children":[]},{"id":"147","parent":"144","text":"Alcanza meta PA en 30 min → superior a labetalol","guid":"FQnmKrUuRRamV7apxzH_Dg","children":[]},{"id":"148","parent":"144","text":"NNT nicardipino vs labetalol (meta PA 30min)","guid":"Ewzisr-1RzmiYBwijZkJHA","children":[{"id":"149","parent":"148","text":"Peacock 2011: 226 pacientes","guid":"DVknRIUOSaGO1S_eyn5yvQ","children":[]},{"id":"150","parent":"148","text":"Nicardipino alcanzo meta → 91.7% vs labetalol 82.5%","guid":"HMxasD4vQuOR9T5gL-Zu3