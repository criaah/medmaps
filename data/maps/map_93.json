22RMnQw2h3foKVvV-hg","children":[]},{"id":"206","parent":"202","text":"Troponinas seriadas post evento","guid":"i5INdKs3RWWahF7B7CUVgA","children":[]},{"id":"207","parent":"202","text":"Cardiologo si sospecha Kounis tipo II/III","guid":"KDj0FMr6TR-zLgrJj1eJ0Q","children":[]}]},{"id":"208","parent":"196","text":"Paciente anticoagulado","guid":"pHgdq4jCSFip6QRVByAdIw","children":[{"id":"209","parent":"208","text":"Adrenalina IM puede causar hematoma","guid":"Kof__HP9TwiXIEXHGno2iw","children":[]},{"id":"210","parent":"208","text":"NO es contraindicacion","guid":"R46-iOy6S_S4sXJE9X8ebA","children":[]},{"id":"211","parent":"208","text":"Preferir cara anterolateral del muslo","guid":"mL2V-spfSCyYpm7cm3hHOw","children":[]}]},{"id":"212","parent":"196","text":"Anafilaxia perioperatoria","guid":"2G2gL4DZS7OsQHAr4rfe3Q","children":[{"id":"213","parent":"212","text":"Relajantes neuromusculares → causa #1","guid":"uoNrhrR5SZOpnGHBybREFA","children":[]},{"id":"214","parent":"212","text":"Antibioticos profilacticos","guid":"MPJGTMpSSAWA_zRxmkHb0Q","children":[]},{"id":"215","parent":"212","text":"Latex","guid":"8U7THqXSSeKZ_ZG7O33yKg","children":[]},{"id":"216","parent":"212","text":"Clorhexidina","guid":"5YB0gBXXTTChnFk_s1_IBA","children":[]},{"id":"217","parent":"212","text":"Manejo → suspender agente, adrenalina IV, volumen","guid":"Efuq4GvkR6qj0R8wgJBYyw","children":[]}]},{"id":"218","parent":"196","text":"Anafilaxia por medios de contraste","guid":"2t2gBtvQSFSnqYFHcCiCXQ","children":[{"id":"219","parent":"218","text":"Premedicacion NO previene verdadera anafilaxia IgE","guid":"2cFkJa1aT4u-Vgu3etLgZw","children":[]},{"id":"220","parent":"218","text":"Solo reduce reacciones anafilactoides","guid":"KIOL_JwTQmiR2hfQ5UvZGQ","children":[]},{"id":"221","parent":"218","text":"Corticoides 12-13h y 1h antes","guid":"im6PahqAQsKhvb2OK0skQw","children":[]},{"id":"222","parent":"218","text":"Antihistaminico 1h antes","guid":"mOiByqr6RDeuRxWQT5p0uQ","children":[]},{"id":"223","parent":"218","text":"Usar contraste de baja osmolaridad","guid":"zM02Wgk4R3inQuYjgubzMQ","children":[]}]}]},{"id":"224","parent":"0","text":"AL ALTA Y SEGUIMIENTO","guid":"ruFmEJmjQXaFhM-KvxFbaA","children":[{"id":"225","parent":"224","text":"Prescripcion de autoinyector de adrenalina","guid":"9jebB8qGSiKLFoSOn4p1ug","children":[{"id":"226","parent":"225","text":"SIEMPRE si anafilaxia confirmada","guid":"ys7LhsMJShaFJC-9q8Sitg","children":[]},{"id":"227","parent":"225","text":"2 dispositivos (en caso de fallo o bifasica)","guid":"sttz8iTNTPmKA3U-95XRhg","children":[]},{"id":"228","parent":"225","text":"Educacion al paciente Y cuidador","guid":"0Ia84RvJQueXY-mmO7It0Q","children":[]},{"id":"229","parent":"225","text":"En adulto mayor → involucrar familia/cuidador","guid":"CwIkkEzzTziW5HgVBKNMYA","children":[]}]},{"id":"230","parent":"224","text":"Plan de accion escrito","guid":"tLuSts0WTb6XVuphCIItpg","children":[{"id":"231","parent":"230","text":"Reconocimiento de sintomas","guid":"12eWbUFRQlWu9o3g-VaLkw","children":[]},{"id":"232","parent":"230","text":"Cuando y como usar autoinyector","guid":"-s3vPWvxSb6Mn1FNeRhPSg","children":[]},{"id":"233","parent":"230","text":"Llamar a emergencias","guid":"7f6K4Sv4Sw-Betppzrmq3A","children":[]}]},{"id":"234","parent":"224","text":"Derivacion a alergologia","guid":"YjCcqPwsSPa80uF7EZdIkg","children":[{"id":"235","parent":"234","text":"Identificar desencadenante","guid":"jRv9hJs3Q9ygrrMKb6tYHQ","children":[]},{"id":"236","parent":"234","text":"Pruebas cutaneas/IgE especifica","guid":"chqyqAudSCWzZE0bkex4GQ","children":[]},{"id":"237","parent":"234","text":"Desensibilizacion si indicada","guid":"XsRko9caRw2bWv9UXNoXTw","children":[]}]},{"id":"238","parent":"224","text":"Identificacion medica (pulsera/collar)","guid":"2yW9vZK4SiWyRxxigrBF9Q","children":[]},{"id":"239","parent":"224","text":"Evitacion del alergeno","guid":"nOHAO1LsTwaqcqSOahermQ","children":[]},{"id":"240","parent":"224","text":"Revision de medicamentos","guid":"XBdwG9-KSi6UMSF2DPHTXg","children":[{"id":"241","parent":"240","text":"Suspender betabloqueador si posible","guid":"TZQIES1TRG29SsMiGyW0xQ","children":[]},{"id":"242","parent":"240","text":"Alternativa: cardioselectivo a dosis minima","guid":"btcVe_E4QMWIKtycsi0dew","children":[]},{"id":"243","parent":"240","text":"Revisar IECA","guid":"yf9U1BJjQ8ua3nxouvUXkw","children":[]}]}]},{"id":"244","parent":"0","text":"ALGORITMO RESUMEN","guid":"WmOao3E-TBON49c9maHtcg","children":[{"id":"245","parent":"244","text":"RECONOCER → criterios clinicos (no esperar labs)","guid":"qssfaCjIT_eMQWj3zqoxng","children":[]},{"id":"246","parent":"244","text":"ADRENALINA IM → inmediata, repetir cada 5-15 min","guid":"1VjQQf_AQmqjSsAkNT7Y-Q","children":[]},{"id":"247","parent":"244","text":"POSICION → segun sintoma predominante","guid":"w6wbKh3dQuCbRdIUp9mJew","children":[]},{"id":"248","parent":"244","text":"VOLUMEN → SF 0.9% agresivo","guid":"cz9QYpFiQj-JBY3CqNL9OQ","children":[]},{"id":"249","parent":"244","text":"O2 → alto flujo","guid":"uLeO6pdvRu28Z-mYvcELJA","children":[]},{"id":"250","parent":"244","text":"MONITOR → ECG, SpO2, PA continua","guid":"I991n4DaRRy7ok_Fhcgk8Q","children":[]},{"id":"251","parent":"244","text":"EVALUAR → respuesta en 5 min","guid":"H2Pjues1Sqqo4VsibY6ATA","children":[{"id":"252","parent":"251","text":"Si responde → observar 12-24 h","guid":"rYKV0avZS6SSH4DhINb3uQ","children":[]},{"id":"253","parent":"251","text":"No responde → repetir adrenalina, considerar infusion IV","guid":"1GeVPJ7vQtW9XZ4J9-Go5A","children":[]},{"id":"254","parent":"251","text":"Refractaria → glucagon, vasopresina, azul de metileno","guid":"uEpMy1H-QBCLPOF5tWc3wA","children":[]}]},{"id":"255","parent":"244","text":"ALTA → autoinyector + plan escrito + alergologia","guid":"bjooLWLNSFmPmtCoWQYHaQ","children":[]}]},{"id":"256","parent":"0","text":"LR DIAGNOSTICOS","guid":"itB0jH8DToqcUPruUdn6sw","children":[{"id":"257","parent":"256","text":"CRITERIOS CLINICOS (NIAID/FAAN 2006)","guid":"iFc6dbCRQp2woj7SQk4K2Q","children":[{"id":"258","parent":"257","text":"Criterio 1 -> sintomas agudos (min-horas) de piel/mucosas + compromiso resp/hipotension","guid":"HX3gKFh0SS2p-ewb4nBf7g","children":[]},{"id":"259","parent":"257","text":"Criterio 2 -> dos o mas: piel, resp, CV, GI, tras exposicion a probable alergeno","guid":"jHW3mNnqTjGYXWhdOmK-Yg","children":[]},{"id":"260","parent":"257","text":"Criterio 3 -> hipotension tras exposicion a alergeno CONOCIDO del paciente","guid":"8JAnxGN8ST2PLhLr5B7pkA","children":[]},{"id":"261","parent":"257","text":"Sensibilidad criterios NIAID -> 96.7 porciento -> PMID:22051696","guid":"rwkE8xzSTpKIZG7w8k1tQg","children":[]},{"id":"262","parent":"257","text":"Especificidad criterios NIAID -> 82.4 porciento -> PMID:22051696","guid":"0G4oeIgVSnGo21myCbxPlw","children":[]}]},{"id":"263","parent":"256","text":"HALLAZGOS CLINICOS (cabecera)","guid":"p_kmYVUbS2i5G2HpAtphFA","children":[{"id":"264","parent":"263","text":"Sintomas cutaneos + compromiso respiratorio agudo -> [definitorio dentro NIAID criterio 1]","guid":"dtPq5rPWQCmkh_jHoPpcUw","children":[]},{"id":"265","parent":"263","text":"Hipotension post-exposicion alergeno conocido -> [definitorio NIAID criterio 3]","guid":"8wHfAb7xR2m3zqiA2JEgFA","children":[]},{"id":"266","parent":"263","text":"Angioedema agudo + estridor -> compromiso via aerea","guid":"hqGhhHx7S9-KVYoc01ysZA","children":[]},{"id":"267","parent":"263","text":"Broncoespasmo nuevo post-exposicion -> criterio respiratorio NIAID","guid":"GCw8dmjnSTOx3A4oB3SHRg","children":[]}]},{"id":"268","parent":"256","text":"HALLAZGOS LABORATORIO","guid":"FisfTjZvTeWwoir5xV91tg","children":[{"id":"269","parent":"268","text":"Triptasa serica >11.4 ng/mL (0-3h post-evento) -> alto LR+ especifico, Sens 30-50 -> PMID:24084075","guid":"aV7BI8IgSzKwBPiUYmOnVQ","children":[]},{"id":"270","parent":"268","text":"Criterio WAO 2020 -> Triptasa post > (basal x 1.2) + 2 ng/mL -> PMID:22041891","guid":"Vh1yCKeRT3qNVqjMdKL_Cw","children":[]},{"id":"271","parent":"268","text":"Triptasa NORMAL no descarta anafilaxia","guid":"B8AZRgLiQqipCHU2aDORUQ","children":[]}]},{"id":"272","parent":"256","text":"INTERPRETACION","guid":"nPE_2mCvQYKGji9agsBTiA","children":[{"id":"273","parent":"272","text":"Diagnostico es CLINICO por criterios compuestos NIAID/FAAN","guid":"lz6sVPp5SUapbrXzPah4OA","children":[]},{"id":"274","parent":"272","text":"Triptasa confirma pero NO descarta","guid":"TkFHQjpgSLSbyOsQvyEa9Q","children":[]},{"id":"275","parent":"272","text":"LRs de hallazgos individuales no consolidados formalmente (diagnostico por criterio)","guid":"UfizP2gqRtuuKjMMeeU9tA","children":[]}]},{"id":"276","parent":"256","text":"GERIATRIA","guid":"uq6-Jl3zTTCGvYRBfcwmFw","children":[{"id":"277","parent":"276","text":"En AM la hipotension puede ser la unica manifestacion (sin urticaria)","guid":"9PkXWJB6SDygv3Zgg0j8Ig","children":[]},{"id":"278","parent":"276","text":"IECA/betabloqueadores pueden enmascarar o potenciar","guid":"fod4KBetSfmgC-lzy02cMg","children":[]},{"id":"279","parent":"276","text":"Adrenalina IM 0.3-0.5 mg sigue siendo primera linea, SIN contraindicacion absoluta por edad","guid":"-hp2ib4QQG-2nmQnMXwQeQ","children":[]}]}]},{"id":"280","parent":"0","text":"Perlas Clinicas","guid":"FT13rQg8RZWPR9AOxkROzA","children":[{"id":"281","parent":"280","text":"Adrenalina IM 0.3-0.5 mg en muslo lateral\\Nes PRIMERA LINEA y SIN contraindicacion\\Nabsoluta por edad ni cardiopatia.","guid":"INO3aSk2SBiL6nFXRhPOGQ","children":[]},{"id":"282","parent":"280","text":"Reaccion bifasica ocurre en 5-20% (NICE 2020,\\NPourmand 2018) → observacion minima 4-6 h\\Ny hasta 24 h en casos graves.","guid":"G0J9bYxWTT-pXlXRyNcd2g","children":[]},{"id":"283","parent":"280","text":"Anafilaxia en AM tiene mayor mortalidad:\\N comorbilidades, betabloqueadores y polifarmacia\\Ndificultan respuesta a adrenalina (Ventura 2022).","guid":"-8_o0GcHQTqbef0bVtQDMw","children":[]},{"id":"284","parent":"280","text":"Glucagon 1-5 mg IV lento si paciente toma\\Nbetabloqueador y no responde a adrenalina.","guid":"0uzlLcTRQjGgEkOjBH5Bzw","children":[]},{"id":"285","parent":"280","text":"Antihistaminicos y corticoides son ADYUVANTES,\\NNUNCA reemplazan a adrenalina ni previenen\\Nreaccion bifasica.","guid":"iFwumh_cQpGTOighpvUZvg","children":[]},{"id":"286","parent":"280","text":"Tres criterios WAO 2020 para diagnostico:\\N(1) sintomas mucocutaneos + respiratorios/CV;\\N(2) ≥2 sistemas afectados tras alergeno probable;\\N(3) hipotension tras alergeno conocido.","guid":"Btr_UtQ5RoeOhGXh5VRvOw","children":[]},{"id":"287","parent":"280","text":"Adrenalina IM se puede repetir cada 5-15 min;\\Ndosis maxima total ~3 mg.","guid":"6872QzzeSRC4wwaMkebryg","children":[]},{"id":"288","parent":"280","text":"Decubito supino con piernas elevadas - NO\\Nsentar al paciente (riesgo de paro al cambiar postura).","guid":"eT7s7LmgRQqOJXDgNWezIw","children":[]},{"id":"289","parent":"280","text":"Trigger comun en AM: AINE, contrastes IV,\\Nantibioticos β-lactamicos, picaduras himenoptero.","guid":"G7I7mxjqS2eiPn02gdtw-g","children":[]},{"id":"290","parent":"280","text":"Triptasa serica >11.4 μg/L apoya diagnostico\\Nretrospectivo (tomar a 1-2 h del evento).","guid":"5Wzsph2sRy6mZS9lYK9nRA","children":[]},{"id":"291","parent":"280","text":"Inicio mas rapido de sintomas = mayor gravedad.","guid":"uFtqtbC8T6aecDMAEJRXwA","children":[]},{"id":"292","parent":"280","text":"Auto-inyector adrenalina al alta + plan escrito\\N+ derivacion a alergologia (NICE 2020).","guid":"ZmcwEKywTeaiXk-DIsRh_w","children":[]},{"id":"293","parent":"280","text":"REFERENCIAS","guid":"zXEPSAbDQBW1K2nS2TebMw","children":[{"id":"294","parent":"293","text":"Ventura 2022 → anafilaxia en adulto mayor (PMID:36165408, DOI:10.1097/ACI.0000000000000855)","guid":"Bxxa4ilETC-Nsyj6PCuuYQ","children":[]},{"id":"295","parent":"293","text":"Pourmand 2018 → revision bifasica (PMID:29759531, DOI:10.1016/j.ajem.2018.05.009)","guid":"YR3cAcqPRj69NCMAbarwEw","children":[]},{"id":"296","parent":"293","text":"Rohacek 2014 → incidencia/mortalidad bifasica (PMID:24725226, DOI:10.1111/all.12404)","guid":"VVMpVhMXQj-hkGlKmJ2vJw","children":[]},{"id":"297","parent":"293","text":"Santos 2024 → guias EAACI alergia alimentaria (PMID:39473345, DOI:10.1111/all.16345)","guid":"ru3by4MdQBSyTJwM98FDoQ","children":[]},{"id":"298","parent":"293","text":"Lee 2024 → anafilaxia por remimazolam (PMID:38929588, DOI:10.3390/medicina60060971)","guid":"X_D7zFw5SRCc9Zb6ehvo4A","children":[]},{"id":"299","parent":"293","text":"WAO 2020 → criterios diagnosticos actualizados","guid":"eferaL1iRbuN6hvl6mk1Uw","children":[]},{"id":"300","parent":"293","text":"NICE 2020 → guia manejo anafilaxia","guid":"yuAmv9r-RGGd4rATkPUi5A","children":[]},{"id":"301","parent":"293","text":"Cardona 2020 → WAO position paper","guid":"RhjpoERIQiK32jv8AyZJcw","children":[]}]}]}]},"node_count":301,"relations":[],"cross_references":[],"specialty":"Geriatría","folder":"Entidades clínicas/Geriatría","filename":"Bases Moleculares del Envejecimiento Dr. Rosson-2024","id":"map_93","resolved_references":[]}